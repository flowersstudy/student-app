page {
  background: #f5f7fb;
}

.review-page {
  min-height: 100vh;
  padding: 24rpx 24rpx 0;
  box-sizing: border-box;
}

.hero-card {
  background: linear-gradient(180deg, #eef4ff 0%, #ffffff 100%);
}

.hero-kicker {
  display: inline-flex;
  min-height: 42rpx;
  padding: 0 16rpx;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  background: #dbeafe;
  color: #1d4ed8;
  font-size: 22rpx;
  font-weight: 700;
}

.hero-title {
  display: block;
  margin-top: 18rpx;
  font-size: 40rpx;
  font-weight: 700;
  line-height: 1.4;
  color: #0f172a;
}

.hero-subtitle {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #64748b;
  line-height: 1.7;
}

.section-head {
  margin-bottom: 18rpx;
}

.section-desc {
  display: block;
  margin-top: 8rpx;
  font-size: 23rpx;
  line-height: 1.7;
  color: #94a3b8;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.tag-chip {
  min-height: 64rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  background: #f8fafc;
  border: 1rpx solid rgba(148, 163, 184, 0.18);
  display: flex;
  align-items: center;
  justify-content: center;
}

.tag-chip-active {
  background: #eaf2ff;
  border-color: rgba(37, 99, 235, 0.18);
}

.tag-chip-text {
  font-size: 24rpx;
  color: #64748b;
  font-weight: 600;
}

.tag-chip-text-active {
  color: #1d4ed8;
}

.field-block {
  margin-top: 18rpx;
}

.field-block-last {
  margin-top: 26rpx;
}

.field-label {
  display: block;
  margin-bottom: 14rpx;
  font-size: 26rpx;
  line-height: 1.5;
  color: #0f172a;
  font-weight: 700;
}

.field-label-check {
  margin-top: 28rpx;
}

.check-row {
  display: flex;
  align-items: center;
  gap: 18rpx;
  min-height: 72rpx;
  padding: 8rpx 0;
  margin-top: 8rpx;
}

.check-box {
  width: 40rpx;
  height: 40rpx;
  border-radius: 12rpx;
  border: 2rpx solid #cbd5e1;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.check-box-active {
  border-color: #2563eb;
  background: #2563eb;
}

.check-mark {
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 700;
}

.check-text {
  flex: 1;
  font-size: 25rpx;
  color: #334155;
  line-height: 1.75;
}

.bottom-space {
  height: 144rpx;
}

.pay-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 20;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  padding: 20rpx 24rpx calc(20rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.96);
  border-top: 1rpx solid rgba(148, 163, 184, 0.16);
  box-shadow: 0 -12rpx 32rpx rgba(15, 23, 42, 0.06);
}

.pay-link {
  flex-shrink: 0;
  min-width: 120rpx;
}

.pay-link-text {
  font-size: 26rpx;
  color: #64748b;
  font-weight: 600;
}

.pay-btn {
  min-width: 300rpx;
  height: 84rpx;
  line-height: 84rpx;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #2563eb 0%, #3b82f6 100%);
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 700;
  border: none;
}

.pay-btn::after {
  border: none;
}
