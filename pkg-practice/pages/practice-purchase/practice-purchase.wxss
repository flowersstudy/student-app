page {
  background: linear-gradient(180deg, #f7f9fc 0%, #f3f6fb 100%);
}

.practice-purchase-page {
  min-height: 100vh;
  padding: 24rpx 24rpx 0;
  box-sizing: border-box;
}

.hero-card {
  background: linear-gradient(180deg, #eff6ff 0%, #ffffff 100%);
  border: 1rpx solid rgba(37, 99, 235, 0.12);
}

.hero-kicker {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 44rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: #dbeafe;
}

.hero-kicker-text {
  font-size: 22rpx;
  font-weight: 700;
  color: #1d4ed8;
}

.hero-title {
  display: block;
  margin-top: 18rpx;
  font-size: 40rpx;
  line-height: 1.3;
  font-weight: 700;
  color: #0f172a;
}

.hero-subtitle {
  display: block;
  margin-top: 12rpx;
  font-size: 26rpx;
  line-height: 1.7;
  color: #475569;
}

.hero-price-row {
  display: flex;
  align-items: center;
  margin-top: 22rpx;
}

.hero-price {
  font-size: 44rpx;
  font-weight: 700;
  line-height: 1.35;
  color: #0f172a;
}

.hero-extra {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #64748b;
  line-height: 1.7;
}

.pricing-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 16rpx;
  margin-top: 24rpx;
}

.pricing-item {
  padding: 20rpx 18rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.92);
  border: 1rpx solid rgba(148, 163, 184, 0.14);
}

.pricing-label {
  display: block;
  font-size: 22rpx;
  color: #64748b;
}

.pricing-value {
  display: block;
  margin-top: 8rpx;
  font-size: 30rpx;
  font-weight: 700;
  color: #0f172a;
}

.hero-tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 24rpx;
}

.hero-tag {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(37, 99, 235, 0.08);
  color: #1d4ed8;
  font-size: 22rpx;
  font-weight: 600;
}

.bullet-row {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  margin-top: 20rpx;
}

.bullet-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  margin-top: 12rpx;
  flex-shrink: 0;
}

.primary-dot {
  background: #2563eb;
}

.success-dot {
  background: #16a34a;
}

.bullet-text {
  flex: 1;
  font-size: 26rpx;
  line-height: 1.7;
  color: #334155;
}

.week-card {
  padding: 22rpx 24rpx;
  border-radius: 22rpx;
  background: #f8fbff;
  border: 1rpx solid rgba(148, 163, 184, 0.16);
  margin-top: 18rpx;
}

.week-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.week-label {
  font-size: 24rpx;
  font-weight: 700;
  color: #2563eb;
}

.week-focus {
  font-size: 28rpx;
  font-weight: 700;
  color: #0f172a;
}

.week-desc {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #475569;
}

.warm-card {
  background: linear-gradient(180deg, #fffaf0 0%, #ffffff 100%);
}

.warm-copy {
  display: block;
  margin-top: 6rpx;
  font-size: 26rpx;
  line-height: 1.7;
  color: #475569;
}

.ghost-btn {
  margin-top: 24rpx;
  height: 84rpx;
  border-radius: 999rpx;
  border: 2rpx solid rgba(37, 99, 235, 0.16);
  display: flex;
  align-items: center;
  justify-content: center;
  background: #ffffff;
}

.ghost-btn-text {
  font-size: 28rpx;
  font-weight: 700;
  color: #2563eb;
}

.bottom-space {
  height: 144rpx;
}

.pay-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 20;
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 20rpx 24rpx calc(20rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.96);
  border-top: 1rpx solid rgba(148, 163, 184, 0.16);
  box-shadow: 0 -12rpx 32rpx rgba(15, 23, 42, 0.06);
}

.pay-info {
  flex: 1;
  min-width: 0;
}

.pay-label {
  display: block;
  font-size: 22rpx;
  color: #64748b;
}

.pay-price {
  display: block;
  margin-top: 8rpx;
  font-size: 34rpx;
  font-weight: 700;
  color: #2563eb;
}

.pay-btn {
  min-width: 280rpx;
  height: 84rpx;
  line-height: 84rpx;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #2563eb 0%, #3b82f6 100%);
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 700;
  padding: 0 36rpx;
  border: none;
  box-shadow: 0 12rpx 28rpx rgba(37, 99, 235, 0.24);
}

.pay-btn::after {
  border: none;
}
