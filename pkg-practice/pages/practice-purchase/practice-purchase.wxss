page {
  background: linear-gradient(180deg, #f7f9fc 0%, #f3f6fb 100%);
}

.consult-page {
  min-height: 100vh;
  padding: 24rpx 24rpx 0;
  box-sizing: border-box;
}

.consult-hero-card {
  background: linear-gradient(180deg, #eff6ff 0%, #ffffff 100%);
  border: 1rpx solid rgba(37, 99, 235, 0.12);
}

.consult-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 44rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: #dbeafe;
}

.consult-badge-text {
  font-size: 22rpx;
  line-height: 1.2;
  font-weight: 700;
  color: #1d4ed8;
}

.consult-title {
  display: block;
  margin-top: 18rpx;
  font-size: 40rpx;
  line-height: 1.35;
  font-weight: 700;
  color: #0f172a;
}

.consult-subtitle {
  display: block;
  margin-top: 16rpx;
  font-size: 26rpx;
  line-height: 1.75;
  color: #475569;
}

.consult-help-card,
.consult-qr-card {
  margin-top: 20rpx;
}

.consult-help-item {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  margin-top: 20rpx;
}

.consult-help-dot {
  width: 14rpx;
  height: 14rpx;
  margin-top: 12rpx;
  border-radius: 50%;
  background: #2563eb;
  flex-shrink: 0;
}

.consult-help-text {
  flex: 1;
  font-size: 26rpx;
  line-height: 1.75;
  color: #334155;
}

.consult-qr-desc {
  display: block;
  margin-top: 8rpx;
  font-size: 26rpx;
  line-height: 1.75;
  color: #475569;
}

.consult-qr-image {
  width: 360rpx;
  height: 360rpx;
  margin: 28rpx auto 0;
  display: block;
  border-radius: 28rpx;
  background: #ffffff;
  border: 1rpx solid rgba(148, 163, 184, 0.2);
  box-shadow: 0 12rpx 28rpx rgba(15, 23, 42, 0.08);
}

.consult-qr-tip {
  display: block;
  margin-top: 18rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: #64748b;
  text-align: center;
}

.bottom-space {
  height: 160rpx;
}

.consult-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 20;
  display: flex;
  gap: 20rpx;
  padding: 20rpx 24rpx calc(20rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.96);
  border-top: 1rpx solid rgba(148, 163, 184, 0.16);
  box-shadow: 0 -12rpx 32rpx rgba(15, 23, 42, 0.06);
}

.consult-btn {
  flex: 1;
  height: 84rpx;
  line-height: 84rpx;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 700;
  padding: 0 24rpx;
  border: none;
}

.consult-btn::after {
  border: none;
}

.consult-btn-secondary {
  background: #ffffff;
  color: #2563eb;
  border: 2rpx solid rgba(37, 99, 235, 0.18);
}

.consult-btn-primary {
  background: linear-gradient(90deg, #2563eb 0%, #3b82f6 100%);
  color: #ffffff;
  box-shadow: 0 12rpx 28rpx rgba(37, 99, 235, 0.24);
}
