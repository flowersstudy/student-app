.diagnose-path-page {
  min-height: 100vh;
  padding: 24rpx 24rpx 120rpx;
  background: #f5f5f5;
  box-sizing: border-box;
}

.path-hero-card,
.path-footer-card {
  padding: 30rpx;
  border-radius: 28rpx;
  background: #ffffff;
  border: 1rpx solid rgba(148, 163, 184, 0.16);
  box-shadow: 0 16rpx 40rpx rgba(15, 23, 42, 0.06);
}

.path-hero-card {
  background: #ffffff;
}

.path-hero-badge {
  display: inline-flex;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: #f2f2f2;
  color: #666666;
  font-size: 22rpx;
  font-weight: 700;
  line-height: 1.4;
}

.path-hero-title {
  display: block;
  margin-top: 20rpx;
  font-size: 38rpx;
  font-weight: 800;
  color: #0f172a;
  line-height: 1.3;
}

.path-hero-desc {
  display: block;
  margin-top: 14rpx;
  font-size: 26rpx;
  color: #475569;
  line-height: 1.7;
}

.path-hero-meta {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-top: 22rpx;
}

.path-hero-meta-text,
.path-hero-meta-dot {
  font-size: 23rpx;
  color: #94a3b8;
}

.path-timeline {
  margin-top: 26rpx;
}

.path-step {
  display: flex;
  align-items: stretch;
}

.path-step-left {
  width: 46rpx;
  margin-right: 18rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  flex-shrink: 0;
}

.path-step-dot {
  width: 42rpx;
  height: 42rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 18rpx;
  background: #d9d9d9;
  border: 4rpx solid #ffffff;
  box-shadow: 0 8rpx 18rpx rgba(15, 23, 42, 0.08);
}

.path-step-dot-done {
  background: #9e9e9e;
}

.path-step-dot-current {
  background: #6f6f6f;
}

.path-step-dot-pending {
  background: #d9d9d9;
}

.path-step-dot-text {
  font-size: 20rpx;
  font-weight: 800;
  color: #ffffff;
}

.path-step-line {
  width: 2rpx;
  flex: 1;
  min-height: 34rpx;
  margin-top: 6rpx;
  background: #dbe3ee;
}

.path-step-card {
  flex: 1;
  min-width: 0;
  margin-bottom: 22rpx;
  padding: 26rpx;
  border-radius: 26rpx;
  background: #ffffff;
  border: 1rpx solid rgba(148, 163, 184, 0.16);
  box-shadow: 0 12rpx 30rpx rgba(15, 23, 42, 0.05);
}

.path-step-card:active {
  transform: scale(0.99);
}

.path-step-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.path-step-main {
  flex: 1;
  min-width: 0;
}

.path-step-title {
  display: block;
  font-size: 30rpx;
  font-weight: 800;
  color: #0f172a;
  line-height: 1.35;
}

.path-step-note {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #64748b;
  line-height: 1.65;
}

.path-step-status {
  flex-shrink: 0;
  padding: 7rpx 16rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 700;
  line-height: 1.4;
  background: #f2f2f2;
  color: #666666;
}

.path-step-status-done {
  background: #f2f2f2;
  color: #666666;
}

.path-step-status-current {
  background: #ebebeb;
  color: #4f4f4f;
}

.path-step-status-pending {
  background: #f2f2f2;
  color: #666666;
}

.path-step-footer {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 10rpx;
  margin-top: 20rpx;
}

.path-step-action {
  font-size: 23rpx;
  font-weight: 700;
  color: #444444;
}

.path-step-arrow {
  width: 10rpx;
  height: 10rpx;
  border-top: 2rpx solid #c7c7cc;
  border-right: 2rpx solid #c7c7cc;
  transform: rotate(45deg);
}

.path-footer-card {
  margin-top: 8rpx;
}

.path-footer-title {
  display: block;
  font-size: 30rpx;
  font-weight: 800;
  color: #0f172a;
}

.path-footer-desc {
  display: block;
  margin-top: 12rpx;
  font-size: 25rpx;
  color: #475569;
  line-height: 1.72;
}

.safe-bottom {
  height: 24rpx;
}
