.card-path-page {
  min-height: 100vh;
  padding: 24rpx 24rpx 120rpx;
  background:
    radial-gradient(circle at top left, rgba(37, 99, 235, 0.08), transparent 28%),
    linear-gradient(180deg, #f7f9fc 0%, #f3f5f8 100%);
  box-sizing: border-box;
}

.path-report-action {
  flex-shrink: 0;
  min-height: 64rpx;
  padding: 0 24rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  background: #eaf2ff;
  border: 1rpx solid rgba(37, 99, 235, 0.12);
}

.path-report-action-text {
  font-size: 24rpx;
  font-weight: 700;
  color: #2563eb;
  line-height: 1.4;
}

.learning-summary-card {
  margin-bottom: 20rpx;
  padding: 28rpx 30rpx;
  border-radius: 30rpx;
  background: #ffffff;
  border: 1rpx solid rgba(37, 99, 235, 0.1);
  box-shadow: 0 16rpx 40rpx rgba(15, 23, 42, 0.06);
}

.learning-summary-main {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.learning-summary-total {
  width: 100%;
  min-height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  box-sizing: border-box;
}

.learning-summary-total-main {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.learning-summary-content {
  flex: 1;
  min-width: 0;
}

.learning-summary-label {
  display: inline;
  font-size: 24rpx;
  font-weight: 700;
  color: #64748b;
  line-height: 1.5;
}

.learning-summary-value {
  display: inline;
  font-size: 40rpx;
  font-weight: 900;
  color: #2563eb;
  line-height: 1.2;
}

.learning-summary-message {
  display: block;
  font-size: 28rpx;
  font-weight: 800;
  color: #0f172a;
  line-height: 1.55;
}

.path-stage-card {
  background: #ffffff;
  border: 1rpx solid rgba(148, 163, 184, 0.16);
  box-shadow: 0 16rpx 40rpx rgba(15, 23, 42, 0.06);
  padding: 30rpx;
  border-radius: 30rpx;
}

.path-stage-list {
  padding-top: 2rpx;
}

.path-stage-item {
  display: flex;
  align-items: stretch;
  gap: 16rpx;
}

.path-stage-item-pending {
  opacity: 0.48;
}

.path-stage-item-pending .path-stage-child-marker {
  background: #cbd5e1;
}

.path-stage-item-pending .path-stage-toggle {
  border-color: #cbd5e1;
}

.path-stage-line-wrap {
  width: 42rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  flex-shrink: 0;
}

.path-stage-index {
  width: 42rpx;
  height: 42rpx;
  margin-top: 14rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 4rpx solid #cbd5e1;
  background: #ffffff;
  box-sizing: border-box;
}

.path-stage-index-done {
  background: #2563eb;
  border-color: #2563eb;
}

.path-stage-index-current {
  border-color: #2563eb;
  box-shadow: 0 0 0 6rpx rgba(37, 99, 235, 0.12);
}

.path-stage-index-text {
  font-size: 20rpx;
  font-weight: 900;
  color: #94a3b8;
  line-height: 1;
}

.path-stage-index-done .path-stage-index-text,
.path-stage-index-current .path-stage-index-text {
  color: #2563eb;
}

.path-stage-index-done .path-stage-index-text {
  color: #ffffff;
}

.path-stage-line {
  flex: 1;
  width: 2rpx;
  margin-top: 10rpx;
  background: rgba(148, 163, 184, 0.28);
}

.path-stage-main {
  flex: 1;
  min-width: 0;
  padding: 12rpx 0 24rpx;
}

.path-stage-title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.path-stage-title-main {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.path-stage-item-title {
  flex: 1;
  min-width: 0;
  font-size: 32rpx;
  font-weight: 800;
  color: #0f172a;
  line-height: 1.45;
}

.path-stage-toggle {
  width: 18rpx;
  height: 18rpx;
  margin-right: 6rpx;
  border-right: 4rpx solid #94a3b8;
  border-bottom: 4rpx solid #94a3b8;
  transform: rotate(45deg);
  transition: transform 0.2s ease;
  box-sizing: border-box;
  flex-shrink: 0;
}

.path-stage-toggle-open {
  margin-top: 10rpx;
  transform: rotate(225deg);
}

.path-stage-children {
  margin-top: 14rpx;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.path-stage-child {
  min-height: 68rpx;
  padding: 0 20rpx;
  display: flex;
  align-items: center;
  gap: 14rpx;
  border-radius: 18rpx;
  background: #f8fafc;
  border: 1rpx solid rgba(226, 232, 240, 0.9);
}

.path-stage-child-marker {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: #2563eb;
  flex-shrink: 0;
}

.path-stage-child-text {
  flex: 1;
  min-width: 0;
  color: #334155;
  font-size: 26rpx;
  font-weight: 700;
  line-height: 1.5;
}

.safe-bottom {
  height: 24rpx;
}
