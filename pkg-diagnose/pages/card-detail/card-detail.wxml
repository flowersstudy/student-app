<view class="card-path-page">
  <view class="learning-summary-card">
    <view class="learning-summary-main">
      <view class="learning-summary-total">
        <view class="learning-summary-total-main">
          <text class="learning-summary-label">总学习时长</text>
          <text class="learning-summary-value">{{learningSummary.totalText}}</text>
        </view>
        <view class="path-report-action" bindtap="onViewReport">
          <text class="path-report-action-text">查看卡点报告</text>
        </view>
      </view>
      <view class="learning-summary-content">
        <text class="learning-summary-message">{{learningSummary.encouragement}}</text>
      </view>
    </view>
  </view>

  <view class="path-stage-card">
    <view class="path-stage-list">
      <view wx:for="{{pathStages}}" wx:key="key" class="path-stage-item path-stage-item-{{item.status}}">
        <view class="path-stage-line-wrap">
          <view class="path-stage-index path-stage-index-{{item.status}}">
            <text class="path-stage-index-text">{{item.index}}</text>
          </view>
          <view wx:if="{{!item.isLast}}" class="path-stage-line"></view>
        </view>

        <view class="path-stage-main">
          <view class="path-stage-title-row" bindtap="toggleStageExpand" data-key="{{item.key}}">
            <view class="path-stage-title-main">
              <text class="path-stage-item-title">{{item.title}}</text>
            </view>
            <view class="path-stage-toggle {{item.expanded ? 'path-stage-toggle-open' : ''}}"></view>
          </view>

          <view wx:if="{{item.expanded}}" class="path-stage-children">
            <view
              wx:for="{{item.reviewItems}}"
              wx:key="*this"
              wx:for-item="child"
              class="path-stage-child"
            >
              <view class="path-stage-child-marker"></view>
              <text class="path-stage-child-text">{{child}}</text>
            </view>
          </view>
        </view>
      </view>
    </view>
  </view>

  <view class="safe-bottom"></view>
</view>

<diagnose-coupon-fab auto-popup="{{true}}"></diagnose-coupon-fab>
