.diagnose-detail-page {
  min-height: 100vh;
  padding: 24rpx 24rpx calc(40rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  background: linear-gradient(180deg, #f8fafc 0%, #f3f6fb 100%);
}

.card {
  background: #ffffff;
  border-radius: 28rpx;
  padding: 28rpx 24rpx;
  box-sizing: border-box;
  box-shadow: 0 10rpx 28rpx rgba(15, 23, 42, 0.05);
  margin-bottom: 18rpx;
}

.dd-hero {
  background: linear-gradient(180deg, #eff6ff 0%, #ffffff 100%);
  border: 1rpx solid rgba(59, 130, 246, 0.12);
}

.dd-badge {
  display: inline-flex;
  align-items: center;
  height: 42rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  background: #dbeafe;
  color: #1d4ed8;
  font-size: 20rpx;
  font-weight: 700;
}

.dd-title {
  display: block;
  margin-top: 18rpx;
  color: #0f172a;
  font-size: 42rpx;
  line-height: 1.3;
  font-weight: 700;
}

.dd-desc {
  display: block;
  margin-top: 14rpx;
  color: #64748b;
  font-size: 24rpx;
  line-height: 1.7;
}

.dd-metrics {
  display: flex;
  gap: 14rpx;
  margin-top: 24rpx;
}

.dd-metric {
  flex: 1;
  min-height: 140rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.88);
  border: 1rpx solid rgba(148, 163, 184, 0.14);
  padding: 20rpx 16rpx;
}

.dd-metric-value {
  display: block;
  color: #0f172a;
  font-size: 36rpx;
  line-height: 1.1;
  font-weight: 700;
}

.dd-metric-label {
  display: block;
  margin-top: 12rpx;
  color: #64748b;
  font-size: 22rpx;
}

.dd-tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 22rpx;
}

.dd-tag {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.9);
  color: #475569;
  border: 1rpx solid rgba(148, 163, 184, 0.16);
  font-size: 22rpx;
  font-weight: 500;
}

.dd-score {
  padding-bottom: 24rpx;
}

.dd-student-row {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.dd-avatar {
  width: 86rpx;
  height: 86rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #2563eb, #60a5fa);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.dd-avatar-text {
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 700;
}

.dd-student-info {
  flex: 1;
}

.dd-student-name {
  display: block;
  color: #0f172a;
  font-size: 30rpx;
  font-weight: 700;
}

.dd-student-meta {
  display: block;
  margin-top: 4rpx;
  color: #64748b;
  font-size: 22rpx;
}

.dd-score-panel {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 8rpx;
  border-radius: 24rpx;
  background: linear-gradient(180deg, #f8fafc, #f1f5f9);
  padding: 22rpx 18rpx;
}

.dd-score-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.dd-score-value {
  font-size: 42rpx;
  font-weight: 700;
  line-height: 1.1;
}

.dd-score-warn {
  color: #f97316;
}

.dd-score-target {
  color: #2563eb;
}

.dd-score-gap {
  font-size: 36rpx;
  font-weight: 700;
  color: #16a34a;
  line-height: 1.1;
}

.dd-score-label {
  margin-top: 8rpx;
  color: #94a3b8;
  font-size: 20rpx;
}

.dd-score-arrow {
  color: #94a3b8;
  font-size: 28rpx;
  font-weight: 700;
}

.dd-summary-grid {
  display: flex;
  gap: 14rpx;
}

.dd-summary-card {
  flex: 1;
  margin-bottom: 18rpx;
  min-height: 180rpx;
}

.dd-section-kicker {
  display: inline-flex;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: #eff6ff;
  color: #2563eb;
  font-size: 20rpx;
  font-weight: 700;
}

.dd-summary-desc {
  display: block;
  margin-top: 18rpx;
  color: #475569;
  font-size: 24rpx;
  line-height: 1.7;
}

.dd-section-title {
  display: block;
  color: #0f172a;
  font-size: 30rpx;
  line-height: 1.4;
  font-weight: 700;
}

.dd-section-subtitle {
  display: block;
  margin-top: 12rpx;
  color: #64748b;
  font-size: 22rpx;
  line-height: 1.72;
}

.dd-point-card {
  margin-top: 18rpx;
  padding: 22rpx 20rpx;
  border-radius: 24rpx;
}

.dd-point-card-red {
  background: #fff7f7;
  border-left: 8rpx solid #ef4444;
}

.dd-point-card-yellow {
  background: #fffdf4;
  border-left: 8rpx solid #eab308;
}

.dd-point-card-blue {
  background: #f4fbff;
  border-left: 8rpx solid #38bdf8;
}

.dd-point-head {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 10rpx;
}

.dd-point-tier {
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 700;
}

.dd-point-tier-red {
  background: #fee2e2;
  color: #b91c1c;
}

.dd-point-tier-yellow {
  background: #fef3c7;
  color: #a16207;
}

.dd-point-tier-blue {
  background: #dbeafe;
  color: #1d4ed8;
}

.dd-point-name {
  color: #0f172a;
  font-size: 27rpx;
  font-weight: 700;
}

.dd-point-desc {
  display: block;
  margin-top: 10rpx;
  color: #475569;
  font-size: 22rpx;
  line-height: 1.75;
}

.dd-basis-row {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
  padding: 20rpx 0;
  border-bottom: 1rpx solid rgba(226, 232, 240, 0.88);
}

.dd-basis-row:last-child {
  border-bottom: none;
}

.dd-basis-label {
  width: 150rpx;
  color: #64748b;
  font-size: 23rpx;
  flex-shrink: 0;
}

.dd-basis-value {
  flex: 1;
  color: #0f172a;
  font-size: 23rpx;
  line-height: 1.7;
  text-align: right;
}

.dd-fact-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
  margin-top: 18rpx;
}

.dd-fact-card {
  border-radius: 24rpx;
  padding: 22rpx 18rpx;
  background: linear-gradient(180deg, #f8fbff 0%, #f8fafc 100%);
  border: 1rpx solid rgba(148, 163, 184, 0.16);
}

.dd-fact-value {
  display: block;
  color: #2563eb;
  font-size: 42rpx;
  line-height: 1.1;
  font-weight: 800;
}

.dd-fact-label {
  display: block;
  margin-top: 10rpx;
  color: #0f172a;
  font-size: 24rpx;
  font-weight: 700;
}

.dd-fact-desc {
  display: block;
  margin-top: 10rpx;
  color: #64748b;
  font-size: 20rpx;
  line-height: 1.7;
}

.dd-phase-card {
  margin-top: 18rpx;
  border-radius: 24rpx;
  background: #f8fafc;
  border: 1rpx solid rgba(148, 163, 184, 0.12);
  padding: 22rpx 20rpx;
}

.dd-phase-head {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-wrap: wrap;
}

.dd-phase-tag {
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: #0f172a;
  color: #ffffff;
  font-size: 19rpx;
  font-weight: 700;
}

.dd-phase-title {
  color: #0f172a;
  font-size: 27rpx;
  font-weight: 700;
}

.dd-phase-desc {
  display: block;
  margin-top: 10rpx;
  color: #64748b;
  font-size: 22rpx;
  line-height: 1.75;
}

.dd-fit-row {
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
  margin-top: 18rpx;
}

.dd-fit-dot {
  width: 12rpx;
  height: 12rpx;
  margin-top: 12rpx;
  border-radius: 50%;
  background: #2563eb;
  flex-shrink: 0;
}

.dd-fit-text {
  flex: 1;
  color: #475569;
  font-size: 23rpx;
  line-height: 1.75;
}

.dd-footer {
  background: linear-gradient(135deg, #172033, #24334b);
}

.dd-footer-title {
  display: block;
  color: #ffffff;
  font-size: 34rpx;
  font-weight: 700;
}

.dd-footer-desc {
  display: block;
  margin-top: 12rpx;
  color: rgba(255, 255, 255, 0.72);
  font-size: 22rpx;
  line-height: 1.72;
}

.dd-footer-note-list {
  margin-top: 18rpx;
  padding: 18rpx 20rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.08);
}

.dd-footer-note {
  display: block;
  color: rgba(255, 255, 255, 0.82);
  font-size: 22rpx;
  line-height: 1.65;
}

.dd-footer-note + .dd-footer-note {
  margin-top: 10rpx;
}

.dd-footer-btn {
  margin-top: 24rpx;
  height: 82rpx;
  border-radius: 999rpx;
  background: #f8fafc;
  display: flex;
  align-items: center;
  justify-content: center;
}

.dd-footer-btn-text {
  color: #0f172a;
  font-size: 26rpx;
  font-weight: 800;
}
