/* app.wxss - 全局样式 */
page {
  background-color: #f3f5f8;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', sans-serif;
  font-size: 28rpx;
  color: #1f2937;
  box-sizing: border-box;
}

view, text, input, textarea, button, image, scroll-view {
  box-sizing: border-box;
}

/* 通用卡片 */
.card {
  background: #ffffff;
  border-radius: 28rpx;
  padding: 30rpx;
  margin: 18rpx 24rpx;
  border: 1rpx solid rgba(148, 163, 184, 0.18);
  box-shadow: 0 16rpx 40rpx rgba(15, 23, 42, 0.06);
}

/* 主按钮 */
.btn-primary {
  background: #2563eb;
  color: #ffffff;
  border-radius: 999rpx;
  padding: 22rpx 48rpx;
  font-size: 30rpx;
  font-weight: 700;
  text-align: center;
  border: none;
  line-height: 1.5;
  box-shadow: 0 12rpx 28rpx rgba(37, 99, 235, 0.22);
}

.btn-primary::after {
  border: none;
}

/* 标签基础 */
.tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 44rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 600;
  line-height: 1.4;
  border: 1rpx solid transparent;
}

.tag-status-active,
.tag-blue {
  background: #eaf2ff;
  color: #2563eb;
  border-color: rgba(37, 99, 235, 0.14);
}

.tag-status-danger,
.tag-red {
  background: #fff1f2;
  color: #e11d48;
  border-color: rgba(225, 29, 72, 0.12);
}

.tag-status-success,
.tag-green {
  background: #eefbf3;
  color: #15803d;
  border-color: rgba(21, 128, 61, 0.12);
}

.tag-status-muted,
.tag-gray {
  background: #f3f4f6;
  color: #6b7280;
  border-color: rgba(107, 114, 128, 0.12);
}

.tag-status-warning,
.tag-orange {
  background: #fff7ed;
  color: #c2410c;
  border-color: rgba(194, 65, 12, 0.12);
}

/* 分割线 */
.divider {
  height: 1rpx;
  background: #e5e7eb;
  margin: 16rpx 0;
}

/* 底部安全区 */
.safe-bottom {
  height: 120rpx;
}

/* 时间线容器 */
.timeline {
  padding: 0 24rpx;
}

.timeline-item {
  display: flex;
  flex-direction: row;
  position: relative;
  padding-bottom: 32rpx;
}

.timeline-left {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 48rpx;
  margin-right: 20rpx;
}

.timeline-dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  background: #2563eb;
  flex-shrink: 0;
  margin-top: 8rpx;
}

.timeline-dot-gray {
  background: #cbd5e1;
}

.timeline-line {
  width: 2rpx;
  flex: 1;
  background: #dbe3ee;
  margin-top: 4rpx;
}

.timeline-content {
  flex: 1;
}

/* 文件卡片 */
.file-card {
  background: #ffffff;
  border-radius: 18rpx;
  padding: 20rpx 24rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  border: 1rpx solid rgba(148, 163, 184, 0.16);
  margin-bottom: 16rpx;
}

.file-icon {
  width: 72rpx;
  height: 72rpx;
  background: #ef4444;
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.file-icon-text {
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 700;
}

.file-info {
  flex: 1;
}

.file-name {
  font-size: 28rpx;
  color: #1f2937;
  font-weight: 600;
}

.file-size {
  font-size: 22rpx;
  color: #94a3b8;
  margin-top: 4rpx;
}

/* 输入框 */
.input-area {
  background: #f8fafc;
  border-radius: 18rpx;
  padding: 20rpx;
  font-size: 28rpx;
  color: #1f2937;
  width: 100%;
  min-height: 120rpx;
  border: 1rpx solid rgba(148, 163, 184, 0.18);
}

/* 页面标题 */
.section-title {
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.35;
  color: #111827;
  margin-bottom: 18rpx;
}

/* 行布局 */
.row {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.row-between {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
}

/* 二级待办任务列表 */
.task-progress-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  margin-bottom: 16rpx;
}

.task-progress-text {
  font-size: 24rpx;
  color: #94a3b8;
}

.task-item {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #eef2f7;
}

.task-item:last-child {
  border-bottom: none;
}

.task-check {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  border: 2rpx solid #cbd5e1;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-right: 20rpx;
  margin-top: 4rpx;
}

.task-check-done {
  background: #16a34a;
  border-color: #16a34a;
}

.task-check-icon {
  font-size: 22rpx;
  color: #ffffff;
  font-weight: 700;
}

.task-body {
  flex: 1;
}

.task-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1f2937;
  display: block;
  margin-bottom: 6rpx;
}

.task-title-done {
  color: #94a3b8;
  text-decoration: line-through;
}

.task-desc {
  font-size: 24rpx;
  color: #9aa5b1;
  line-height: 1.5;
  display: block;
}

.task-tag {
  font-size: 20rpx;
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
  flex-shrink: 0;
  margin-left: 12rpx;
  margin-top: 4rpx;
}

.task-tag-todo {
  background: #fff7ed;
  color: #c2410c;
}

.task-tag-done {
  background: #eefbf3;
  color: #15803d;
}

/* 文件未上传状态 */
.file-card-disabled {
  opacity: 0.5;
}

.file-icon-gray {
  background: #cbd5e1 !important;
}

.file-name-gray {
  color: #94a3b8;
}

/* 文字省略 */
.text-ellipsis {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
