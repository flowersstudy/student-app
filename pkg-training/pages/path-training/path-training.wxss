@import "/pages/path-common.wxss";

.training-group-card {
  margin-top: 20rpx;
  padding: 30rpx;
  border-radius: 30rpx;
  background: #ffffff;
  border: 1rpx solid rgba(148, 163, 184, 0.16);
  box-shadow: 0 16rpx 40rpx rgba(15, 23, 42, 0.06);
}

.training-group-card:first-child {
  margin-top: 0;
}

.training-group-head {
  display: flex;
  align-items: center;
  padding-bottom: 18rpx;
  border-bottom: 1rpx solid rgba(148, 163, 184, 0.12);
}

.training-group-title {
  font-size: 30rpx;
  font-weight: 800;
  color: #0f172a;
  line-height: 1.4;
}

.training-group-card .path-list {
  margin-top: 8rpx;
}

.training-group-card .path-main {
  padding-bottom: 20rpx;
}
