.bottom-nav {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 999;
  background: rgba(255, 255, 255, 0.98);
  border-top: 1px solid rgba(15, 23, 42, 0.08);
  box-shadow: 0 -6px 20px rgba(15, 23, 42, 0.05);
}

.bottom-nav__content {
  height: 56px;
  padding: 0 28px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-sizing: border-box;
}

.bottom-nav__item {
  width: 56px;
  height: 56px;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 2px;
}

.bottom-nav__icon {
  width: 32px;
  height: 32px;
  display: block;
}

.bottom-nav__text {
  font-size: 20rpx;
  line-height: 24rpx;
  color: #999999;
  font-weight: 500;
}

.bottom-nav__item.is-active .bottom-nav__text {
  color: #1A6EFF;
  font-weight: 600;
}

.bottom-nav__safe {
  height: env(safe-area-inset-bottom);
}
