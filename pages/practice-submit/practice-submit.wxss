page {
  background: #f5f7fb;
}

.practice-submit-page {
  min-height: 100vh;
  padding: 24rpx 24rpx 0;
  box-sizing: border-box;
}

.hero-card {
  background: linear-gradient(180deg, #eef4ff 0%, #ffffff 100%);
}

.hero-kicker {
  display: inline-flex;
  min-height: 42rpx;
  padding: 0 16rpx;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  background: #dbeafe;
  color: #1d4ed8;
  font-size: 22rpx;
  font-weight: 700;
}

.hero-title {
  display: block;
  margin-top: 18rpx;
  font-size: 40rpx;
  line-height: 1.4;
  font-weight: 700;
  color: #0f172a;
}

.hero-subtitle {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #64748b;
  line-height: 1.7;
}

.hero-chip-row {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 20rpx;
}

.hero-chip {
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(37, 99, 235, 0.08);
  color: #1d4ed8;
  font-size: 22rpx;
  font-weight: 600;
}

.ai-tip {
  margin-top: 20rpx;
  padding: 18rpx 20rpx;
  border-radius: 20rpx;
  background: #eff6ff;
}

.ai-tip-text {
  font-size: 24rpx;
  line-height: 1.7;
  color: #1d4ed8;
}

.section-head {
  margin-bottom: 18rpx;
}

.section-desc {
  display: block;
  margin-top: 8rpx;
  font-size: 23rpx;
  line-height: 1.7;
  color: #94a3b8;
}

.upload-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
}

.upload-box {
  padding: 30rpx 22rpx;
  border-radius: 24rpx;
  background: #f8fbff;
  border: 1rpx dashed rgba(37, 99, 235, 0.24);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-direction: column;
}

.upload-icon {
  width: 56rpx;
  height: 56rpx;
}

.upload-title {
  margin-top: 16rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: #0f172a;
}

.upload-desc {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #64748b;
}

.file-list {
  margin-top: 24rpx;
}

.file-list-head {
  margin-bottom: 12rpx;
}

.file-list-title {
  display: block;
  font-size: 24rpx;
  color: #64748b;
}

.file-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 18rpx 0;
  border-bottom: 1rpx solid rgba(226, 232, 240, 0.9);
}

.file-thumb {
  width: 80rpx;
  height: 80rpx;
  border-radius: 18rpx;
  overflow: hidden;
  background: #e2e8f0;
  flex-shrink: 0;
}

.file-thumb-image {
  width: 100%;
  height: 100%;
}

.file-thumb-doc {
  display: flex;
  align-items: center;
  justify-content: center;
  background: #eff6ff;
}

.file-thumb-text {
  font-size: 22rpx;
  color: #1d4ed8;
  font-weight: 700;
}

.file-row-main {
  flex: 1;
  min-width: 0;
}

.file-row-name {
  display: block;
  font-size: 26rpx;
  color: #0f172a;
  font-weight: 600;
}

.file-row-meta {
  display: block;
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #64748b;
}

.file-row-remove {
  font-size: 24rpx;
  color: #ef4444;
  flex-shrink: 0;
}

.ai-card {
  background: linear-gradient(180deg, #f8fbff 0%, #ffffff 100%);
}

.ai-card-head {
  align-items: flex-start;
}

.ai-card-sub {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #94a3b8;
}

.score-pill {
  min-width: 96rpx;
  height: 48rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: #dbeafe;
  color: #1d4ed8;
  font-size: 24rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

.ai-summary {
  display: block;
  margin-top: 18rpx;
  font-size: 26rpx;
  line-height: 1.75;
  color: #334155;
}

.ai-grid {
  margin-top: 22rpx;
}

.ai-block {
  padding: 22rpx 22rpx 24rpx;
  border-radius: 22rpx;
  background: #ffffff;
  border: 1rpx solid rgba(148, 163, 184, 0.12);
}

.ai-block-risk {
  margin-top: 16rpx;
}

.ai-block-suggest {
  margin-top: 16rpx;
}

.ai-block-title {
  display: block;
  font-size: 26rpx;
  font-weight: 700;
  color: #0f172a;
}

.teacher-card {
  background: linear-gradient(180deg, #ffffff 0%, #fbfdff 100%);
}

.teacher-card-head {
  align-items: flex-start;
}

.teacher-card-sub {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #94a3b8;
}

.teacher-badge {
  min-width: 128rpx;
  height: 48rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  background: #fff7ed;
  color: #c2410c;
  font-size: 22rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

.teacher-desc {
  display: block;
  margin-top: 18rpx;
  font-size: 25rpx;
  line-height: 1.75;
  color: #334155;
}

.teacher-wait-card {
  margin-top: 20rpx;
  padding: 20rpx 22rpx;
  border-radius: 20rpx;
  background: #f8fafc;
}

.teacher-wait-label {
  display: block;
  font-size: 22rpx;
  color: #94a3b8;
}

.teacher-wait-value {
  display: block;
  margin-top: 8rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: #0f172a;
}

.helper-card {
  background: #ffffff;
}

.bullet-row {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  margin-top: 16rpx;
}

.bullet-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  margin-top: 12rpx;
  background: #2563eb;
  flex-shrink: 0;
}

.bullet-dot-green {
  background: #16a34a;
}

.bullet-dot-orange {
  background: #ea580c;
}

.bullet-text {
  flex: 1;
  font-size: 25rpx;
  line-height: 1.75;
  color: #334155;
}

.bottom-space {
  height: 144rpx;
}

.pay-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 20;
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 20rpx 24rpx calc(20rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.96);
  border-top: 1rpx solid rgba(148, 163, 184, 0.16);
  box-shadow: 0 -12rpx 32rpx rgba(15, 23, 42, 0.06);
}

.pay-info {
  flex: 1;
}

.pay-label {
  display: block;
  font-size: 22rpx;
  color: #64748b;
}

.pay-price {
  display: block;
  margin-top: 8rpx;
  font-size: 30rpx;
  font-weight: 700;
  color: #0f172a;
}

.pay-btn {
  min-width: 220rpx;
  height: 84rpx;
  line-height: 84rpx;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #2563eb 0%, #3b82f6 100%);
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 700;
  border: none;
}

.pay-btn::after {
  border: none;
}
