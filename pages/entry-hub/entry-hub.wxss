page {
  background: #f7f9fc;
}

.entry-page {
  position: relative;
  min-height: 100vh;
  overflow: hidden;
  background:
    radial-gradient(circle at top left, rgba(37, 99, 235, 0.08), transparent 30%),
    linear-gradient(180deg, #f8fafe 0%, #f3f6fb 100%);
}

.entry-overlay {
  position: absolute;
  inset: 0;
  background: rgba(15, 23, 42, 0.12);
  pointer-events: none;
}

.entry-bg {
  position: absolute;
  border-radius: 50%;
  filter: blur(8rpx);
  pointer-events: none;
}

.entry-bg-left {
  width: 340rpx;
  height: 340rpx;
  left: -90rpx;
  top: 90rpx;
  background: rgba(37, 99, 235, 0.08);
}

.entry-bg-right {
  width: 300rpx;
  height: 300rpx;
  right: -70rpx;
  top: 180rpx;
  background: rgba(96, 165, 250, 0.1);
}

.entry-stage {
  position: relative;
  z-index: 2;
  min-height: 100vh;
  padding: calc(68rpx + env(safe-area-inset-top)) 34rpx calc(68rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
}

.entry-shell {
  width: 100%;
  max-width: 600rpx;
  min-height: auto;
  padding: 40rpx 24rpx 26rpx;
  box-sizing: border-box;
  border-radius: 36rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.72);
  background: rgba(255, 255, 255, 0.98);
  box-shadow:
    0 28rpx 84rpx rgba(15, 23, 42, 0.16),
    0 8rpx 24rpx rgba(15, 23, 42, 0.06);
  display: flex;
  flex-direction: column;
}

.entry-top {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
  padding: 2rpx 8rpx 18rpx;
}

.entry-top-eyebrow {
  display: block;
  font-size: 18rpx;
  line-height: 1;
  color: #64748b;
  font-weight: 700;
  letter-spacing: 6rpx;
}

.entry-top-title {
  display: block;
  margin-top: 12rpx;
  font-size: 40rpx;
  line-height: 1.2;
  color: #0f172a;
  font-weight: 700;
}

.entry-top-desc {
  display: block;
  width: 100%;
  max-width: 440rpx;
  margin-top: 12rpx;
  font-size: 20rpx;
  line-height: 1.7;
  color: #64748b;
}

.entry-cards {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  padding: 6rpx 0 0;
}

.entry-card {
  position: relative;
  width: 100%;
  min-height: 138rpx;
  padding: 18rpx 18rpx;
  box-sizing: border-box;
  border-radius: 22rpx;
  border: 1rpx solid rgba(148, 163, 184, 0.16);
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(248, 250, 252, 0.95));
  box-shadow: 0 8rpx 20rpx rgba(15, 23, 42, 0.04);
  display: flex;
  flex-direction: row;
  align-items: center;
}

.entry-card::before {
  content: '';
  position: absolute;
  left: 0;
  top: 14rpx;
  bottom: 14rpx;
  width: 5rpx;
  border-radius: 0 999rpx 999rpx 0;
}

.entry-card-diagnose::before {
  background: linear-gradient(180deg, #2563eb, #60a5fa);
}

.entry-card-trial::before {
  background: linear-gradient(180deg, #64748b, #94a3b8);
}

.entry-card-kpoint::before {
  background: linear-gradient(180deg, #1a6eff, #7db8ff);
}

.entry-card-main {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 16rpx;
  padding-left: 8rpx;
}

.entry-card-copy {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.entry-card-icon {
  width: 62rpx;
  height: 62rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.entry-card-icon-diagnose {
  background: #eff6ff;
}

.entry-card-icon-trial {
  background: #eef2f7;
}

.entry-card-icon-kpoint {
  background: #edf4ff;
}

.entry-card-icon-image {
  width: 32rpx;
  height: 32rpx;
}

.entry-card-kicker {
  display: inline-block;
  align-self: flex-start;
  min-height: 28rpx;
  padding: 0 10rpx;
  border-radius: 999rpx;
  background: #f8fbff;
  border: 1rpx solid rgba(37, 99, 235, 0.12);
  color: #2563eb;
  font-size: 16rpx;
  line-height: 28rpx;
  font-weight: 600;
}

.entry-card-title {
  display: block;
  margin-top: 8rpx;
  font-size: 26rpx;
  line-height: 1.3;
  color: #0f172a;
  font-weight: 700;
}

.entry-card-desc {
  display: block;
  margin-top: 4rpx;
  font-size: 19rpx;
  line-height: 1.56;
  color: #64748b;
}

.entry-card-meta {
  display: block;
  margin-top: 6rpx;
  font-size: 16rpx;
  line-height: 1.5;
  color: #94a3b8;
}

.entry-card-arrow-wrap {
  width: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-left: 8rpx;
}

.entry-arrow {
  font-size: 20rpx;
  color: #94a3b8;
  line-height: 1;
}

.entry-bottom {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-end;
  gap: 10rpx;
  padding-top: 20rpx;
}

.entry-bottom-tip {
  font-size: 18rpx;
  color: #94a3b8;
  line-height: 1.6;
}

.entry-skip {
  min-width: 140rpx;
  height: 50rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  border: 1rpx solid rgba(148, 163, 184, 0.16);
  background: rgba(255, 255, 255, 0.82);
  display: flex;
  align-items: center;
  justify-content: center;
}

.entry-skip-text {
  font-size: 18rpx;
  color: #64748b;
}
