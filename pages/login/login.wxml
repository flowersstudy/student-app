<view class="login-page">
  <view class="login-shell">
    <view class="brand-area">
      <view class="brand-mark">步知</view>
      <text class="brand-name">{{productName}}</text>
      <text class="brand-slogan">{{slogan}}</text>
    </view>

    <view class="login-card">
      <view class="tab-row">
        <view
          class="tab-pill {{activeTab === 'login' ? 'tab-pill-active' : ''}}"
          bindtap="switchTab"
          data-tab="login"
        >
          <text class="tab-text {{activeTab === 'login' ? 'tab-text-active' : ''}}">登录</text>
        </view>
        <view
          class="tab-pill {{activeTab === 'register' ? 'tab-pill-active' : ''}}"
          bindtap="switchTab"
          data-tab="register"
        >
          <text class="tab-text {{activeTab === 'register' ? 'tab-text-active' : ''}}">注册</text>
        </view>
      </view>

      <view class="form">
        <view class="field-group">
          <text class="field-label">手机号</text>
          <view class="input-wrap">
            <text class="input-prefix">+86</text>
            <input
              class="form-input"
              type="number"
              maxlength="11"
              placeholder="请输入手机号"
              placeholder-class="form-placeholder"
              value="{{phone}}"
              bindinput="onPhoneInput"
            />
          </view>
        </view>

        <view class="field-group">
          <text class="field-label">密码</text>
          <view class="input-wrap">
            <input
              class="form-input"
              password="{{!showPassword}}"
              placeholder="请输入密码（6位以上）"
              placeholder-class="form-placeholder"
              value="{{password}}"
              bindinput="onPasswordInput"
            />
            <text class="input-eye" bindtap="togglePassword">{{showPassword ? '隐藏' : '显示'}}</text>
          </view>
        </view>

        <view wx:if="{{activeTab === 'register'}}" class="field-group">
          <text class="field-label">确认密码</text>
          <view class="input-wrap">
            <input
              class="form-input"
              password="{{!showPassword}}"
              placeholder="再次输入密码"
              placeholder-class="form-placeholder"
              value="{{confirmPassword}}"
              bindinput="onConfirmPasswordInput"
            />
          </view>
        </view>
      </view>

      <button
        class="btn-submit {{loading ? 'btn-submit-loading' : ''}}"
        bindtap="submit"
        disabled="{{loading}}"
      >
        <text>{{loading ? '请稍候…' : activeTab === 'login' ? '登录' : '注册'}}</text>
      </button>

      <text class="login-tip">登录或注册即代表同意《用户协议》和《隐私政策》</text>
    </view>
  </view>
</view>
