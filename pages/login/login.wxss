page {
  background: linear-gradient(180deg, #eff4fb 0%, #ffffff 48%, #ffffff 100%);
}

.login-page {
  position: relative;
  min-height: 100vh;
  padding: 28rpx 44rpx 56rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.bg-glow {
  position: absolute;
  border-radius: 50%;
  pointer-events: none;
  filter: blur(14rpx);
}

.bg-glow-top {
  width: 420rpx;
  height: 420rpx;
  top: -140rpx;
  right: -120rpx;
  background: rgba(64, 146, 255, 0.16);
}

.bg-glow-bottom {
  width: 360rpx;
  height: 360rpx;
  left: -140rpx;
  bottom: -120rpx;
  background: rgba(130, 198, 255, 0.12);
}

.login-main {
  position: relative;
  z-index: 2;
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 40rpx;
  padding-bottom: 140rpx;
}

.brand-shell {
  width: 240rpx;
  height: 240rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.brand-logo {
  width: 240rpx;
  height: 240rpx;
}

.brand-title {
  margin-top: 14rpx;
  font-size: 44rpx;
  line-height: 1.4;
  font-weight: 700;
  color: #263142;
  text-align: center;
}

.form-area {
  width: 100%;
  margin-top: 36rpx;
}

.fields-wrap {
  margin-top: 12rpx;
}

.form-field {
  height: 96rpx;
  background: rgba(255, 255, 255, 0.68);
  border-radius: 48rpx;
  padding: 0 30rpx;
  display: flex;
  align-items: center;
  border: 1rpx solid rgba(226, 232, 240, 0.9);
  box-shadow: 0 8rpx 24rpx rgba(148, 163, 184, 0.08);
}

.form-field + .form-field {
  margin-top: 22rpx;
}

.field-icon {
  width: 36rpx;
  height: 36rpx;
  margin-right: 18rpx;
  position: relative;
  flex-shrink: 0;
}

.field-input {
  flex: 1;
  height: 100%;
  font-size: 28rpx;
  color: #475569;
}

.field-placeholder {
  color: #b6c0ce;
}

.field-side-link {
  margin-left: 18rpx;
  font-size: 26rpx;
  color: #6b7a90;
}

.user-head {
  position: absolute;
  top: 0;
  left: 9rpx;
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  border: 3rpx solid #a8b3c3;
}

.user-body {
  position: absolute;
  left: 4rpx;
  bottom: 2rpx;
  width: 28rpx;
  height: 14rpx;
  border-radius: 14rpx 14rpx 10rpx 10rpx;
  border: 3rpx solid #a8b3c3;
  border-top: none;
}

.lock-shackle {
  position: absolute;
  left: 9rpx;
  top: 0;
  width: 16rpx;
  height: 16rpx;
  border-radius: 12rpx 12rpx 0 0;
  border: 3rpx solid #a8b3c3;
  border-bottom: none;
}

.lock-body {
  position: absolute;
  left: 5rpx;
  bottom: 2rpx;
  width: 24rpx;
  height: 18rpx;
  border-radius: 8rpx;
  border: 3rpx solid #a8b3c3;
}

.login-btn {
  margin-top: 42rpx;
  height: 98rpx;
  line-height: 98rpx;
  border: none;
  border-radius: 49rpx;
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 700;
  background: linear-gradient(90deg, #4b83f7 0%, #36a0ff 100%);
  box-shadow: 0 20rpx 36rpx rgba(74, 131, 247, 0.28);
}

.login-btn::after {
  border: none;
}

.login-btn-hover {
  opacity: 0.92;
}

.register-link {
  display: block;
  margin-top: 34rpx;
  text-align: center;
  font-size: 30rpx;
  color: #6b7280;
}

.agreement-bar {
  position: relative;
  z-index: 2;
  padding-bottom: 12rpx;
}

.agreement-row {
  display: flex;
  align-items: center;
  justify-content: center;
}

.agreement-check-wrap {
  width: 34rpx;
  height: 34rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-right: 10rpx;
}

.agreement-checkbox {
  width: 22rpx;
  height: 22rpx;
  border-radius: 50%;
  border: 2rpx solid #c9d2de;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #ffffff;
}

.agreement-checkbox-active {
  border-color: #3f8cff;
}

.agreement-checkbox-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: #3f8cff;
}

.agreement-copy {
  font-size: 22rpx;
  line-height: 1.7;
  color: #b0b8c5;
}

.agreement-text {
  color: #b0b8c5;
}

.agreement-link {
  color: #4d86f8;
  font-weight: 600;
}
