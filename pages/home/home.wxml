<view class="path-page">
  <view class="path-bar-list">
    <block wx:for="{{pathNodes}}" wx:key="id">
      <view id="path-node-{{item.pointId}}" class="path-item path-item-tone-{{item.tone}} {{item.expanded ? 'path-item-expanded' : ''}}" style="{{item.themeStyle}}">
        <view class="path-item-accent" style="background: {{item.themeColor}};"></view>
        <view class="path-bar path-bar-{{item.status}}" bindtap="handleNodeTap" data-id="{{item.id}}">
          <view class="path-bar-main">
            <text class="path-bar-title">{{item.title}}</text>
            <text wx:if="{{item.currentTaskText}}" class="path-bar-progress">{{item.currentTaskText}}</text>
          </view>
          <view class="path-bar-side">
            <view class="path-bar-tag path-bar-tag-{{item.status}}">
              <text class="path-bar-tag-text path-bar-tag-text-{{item.status}}">{{item.note}}</text>
            </view>
            <text class="path-bar-arrow {{item.expanded ? 'path-bar-arrow-open' : ''}}">v</text>
          </view>
        </view>

        <view wx:if="{{item.expanded}}" class="path-expand" style="{{item.themeExpandStyle}}">
          <view class="path-expand-body" style="{{item.bodyStyle}}">
            <view class="path-ip-float" style="{{item.ipStyle}}">
              <image class="path-ip-image" src="/assets/buka/buka-koi-mascot-v2.svg" mode="widthFix"></image>
            </view>

            <view class="duo-map" style="height: {{item.mapHeight}};">
              <block wx:for="{{item.steps}}" wx:key="id" wx:for-item="step">
                <view class="duo-step" style="{{step.positionStyle}}">
                  <view class="duo-node-wrap duo-node-wrap-{{step.status}}" style="{{pathLayout.nodeWrapStyle}}" catchtap="handleStepTap" data-url="{{step.url}}">
                    <view class="duo-node duo-node-{{step.status}} {{step.iconPath ? 'duo-node-has-icon' : ''}}" style="{{pathLayout.nodeStyle}}">
                      <image wx:if="{{step.iconPath}}" class="duo-node-icon" src="{{step.iconPath}}" mode="aspectFit"></image>
                      <text wx:else class="duo-node-text" style="{{pathLayout.nodeTextStyle}}">{{step.shortLabel}}</text>
                    </view>
                  </view>
                </view>
              </block>
            </view>
          </view>
        </view>
      </view>
    </block>
  </view>
</view>
