<view class="path-page">
  <view class="exam-info-bar">
    <view class="exam-info-item">
      <text class="exam-info-label">{{examInfo.subjectLabel}}</text>
      <text class="exam-info-value">{{examInfo.subjectValue}}</text>
    </view>
    <view class="exam-info-item">
      <text class="exam-info-label">{{examInfo.targetLabel}}</text>
      <text class="exam-info-value exam-info-value-blue">{{examInfo.targetValue}}</text>
    </view>
    <view class="exam-info-item">
      <text class="exam-info-label">{{examInfo.deadlineLabel}}</text>
      <text class="exam-info-value">{{examInfo.deadlineValue}}</text>
    </view>
  </view>

  <view class="path-card">
    <view class="path-header">
      <view class="path-top-row">
        <view class="path-current-task">
          <text class="path-current-task-text">{{currentTaskText}}</text>
        </view>
        <view class="path-top-tag" bindtap="handlePlanTap">
          <text class="path-top-tag-text">{{topTagText}}</text>
        </view>
      </view>
      <view class="path-progress">
        <view class="path-progress-meta">
          <text class="path-progress-label">当前卡点进度</text>
          <text class="path-progress-value">{{currentCardProgress}}%</text>
        </view>
        <view class="path-progress-track">
          <view class="path-progress-fill" style="width: {{currentCardProgress}}%;"></view>
        </view>
      </view>
    </view>

    <view class="path-track-surface">
      <view class="path-track">
        <view class="branch-area branch-area-{{branchState}}">
          <view class="branch-node" bindtap="handleBranchTap">
            <view class="branch-shadow"></view>
            <view class="branch-glow"></view>
            <view class="branch-spirit">
              <view class="branch-spirit-belly"></view>
              <view class="branch-spirit-gloss"></view>
              <view class="branch-eye branch-eye-left"></view>
              <view class="branch-eye branch-eye-right"></view>
            </view>
          </view>
          <view class="branch-bubble">
            <text class="branch-bubble-title">{{branchNode.title}}</text>
            <text class="branch-bubble-subtitle">{{branchNode.subtitle}}</text>
            <text class="branch-bubble-slogan">{{branchNode.slogan}}</text>
            <view class="branch-bubble-tail"></view>
          </view>
        </view>

        <block wx:for="{{pathNodes}}" wx:key="id">
          <view class="path-node-wrap path-node-wrap-{{item.id}}">
            <view wx:if="{{item.showCurve}}" class="path-curve path-curve-{{item.id}}"></view>
            <view wx:if="{{item.showHighlight}}" class="path-node-highlight"></view>

            <view class="path-node-group">
              <view class="path-node path-node-{{item.status}}" bindtap="handleNodeTap" data-id="{{item.id}}">
                <view class="path-node-icon path-node-icon-{{item.status}}">
                  <text class="path-node-icon-text">{{item.icon}}</text>
                </view>
                <view class="path-node-text">
                  <text class="path-node-title">{{item.title}}</text>
                  <text class="path-node-note">{{item.note}}</text>
                </view>
                <text wx:if="{{item.hasDetail}}" class="path-node-expand">{{item.expandText}}</text>
              </view>

              <view wx:if="{{item.detailVisible}}" class="path-node-detail path-node-detail-{{item.id}} path-node-detail-{{item.detailStateClass}}">
                <view class="path-node-detail-card path-node-detail-card-{{item.id}}">
                  <view class="path-node-detail-connector"></view>
                  <block wx:for="{{item.detailSections}}" wx:key="index">
                    <block wx:for="{{item.items}}" wx:key="text" wx:for-item="detail">
                      <view class="path-node-subpath-item">
                        <view class="path-node-subpath-rail">
                          <view class="path-node-subpath-dot"></view>
                          <view wx:if="{{detail.showLine}}" class="path-node-subpath-line"></view>
                        </view>
                        <view class="path-node-subpath-card">
                          <text class="path-node-subpath-text">{{detail.text}}</text>
                        </view>
                      </view>
                    </block>
                  </block>
                  <text class="path-node-detail-inline-action" bindtap="handleNodeTap" data-id="{{item.id}}">收起</text>
                </view>
              </view>
            </view>
          </view>
        </block>

      </view>
    </view>
  </view>

  <view class="bottom-shell-section">
    <view class="bottom-shell-row">
      <view class="path-shell path-shell-whelk" bindtap="handleWhelkTap">
        <view class="path-shell-top path-shell-top-whelk"></view>
        <view class="path-shell-body path-shell-body-whelk">
          <text class="path-shell-icon path-shell-icon-whelk">螺</text>
        </view>
        <text class="path-shell-label">行测刷题</text>
      </view>

      <view class="path-shell" bindtap="handleShellTap">
        <view class="path-shell-top"></view>
        <view class="path-shell-body">
          <text class="path-shell-icon">贝</text>
        </view>
        <text class="path-shell-label">刷题</text>
      </view>
    </view>
  </view>
</view>
