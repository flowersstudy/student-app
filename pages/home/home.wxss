page {
  background: linear-gradient(180deg, #f5f8fc 0%, #f2f5fa 100%);
}

.path-page {
  min-height: 100vh;
  padding: 24rpx 20rpx 0;
  box-sizing: border-box;
}

.coupon-mask {
  position: fixed;
  inset: 0;
  z-index: 99;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx 44rpx;
  background: rgba(15, 23, 42, 0.52);
  box-sizing: border-box;
}

.coupon-dialog {
  position: relative;
  width: 100%;
  max-width: 610rpx;
  padding: 28rpx 24rpx 24rpx;
  background:
    radial-gradient(circle at top right, rgba(255, 214, 170, 0.72) 0%, rgba(255, 214, 170, 0) 34%),
    radial-gradient(circle at top left, rgba(254, 240, 138, 0.26) 0%, rgba(254, 240, 138, 0) 28%),
    linear-gradient(180deg, #fff7ed 0%, #ffffff 100%);
  border: 2rpx solid rgba(251, 146, 60, 0.22);
  border-radius: 32rpx;
  box-shadow: 0 22rpx 56rpx rgba(15, 23, 42, 0.24);
  box-sizing: border-box;
  overflow: hidden;
}

.coupon-glow {
  position: absolute;
  width: 220rpx;
  height: 220rpx;
  border-radius: 50%;
  background: rgba(251, 146, 60, 0.12);
  filter: blur(16rpx);
}

.coupon-glow-left {
  top: -80rpx;
  left: -80rpx;
}

.coupon-glow-right {
  right: -90rpx;
  bottom: 200rpx;
}

.coupon-close {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  width: 52rpx;
  height: 52rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.8);
  color: #94a3b8;
  font-size: 36rpx;
  line-height: 1;
}

.coupon-topline {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
  position: relative;
  z-index: 1;
}

.coupon-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 46rpx;
  padding: 0 18rpx;
  background: linear-gradient(90deg, #ea580c 0%, #fb923c 100%);
  border-radius: 999rpx;
  color: #ffffff;
  font-size: 20rpx;
  font-weight: 700;
  box-shadow: 0 10rpx 22rpx rgba(249, 115, 22, 0.18);
}

.coupon-title {
  display: block;
  position: relative;
  z-index: 1;
  margin-top: 16rpx;
  padding-right: 52rpx;
  font-size: 34rpx;
  line-height: 1.32;
  color: #111827;
  font-weight: 700;
}

.coupon-subtitle {
  display: block;
  position: relative;
  z-index: 1;
  margin-top: 10rpx;
  font-size: 22rpx;
  line-height: 1.58;
  color: #6b7280;
}

.coupon-countdown {
  flex-shrink: 0;
  padding: 10rpx 14rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: rgba(255, 255, 255, 0.9);
  border: 2rpx solid #fed7aa;
  border-radius: 999rpx;
}

.coupon-countdown-label {
  font-size: 20rpx;
  color: #9a3412;
  font-weight: 600;
}

.coupon-countdown-value {
  font-size: 24rpx;
  color: #ea580c;
  font-weight: 700;
  letter-spacing: 2rpx;
}

.coupon-ticket {
  position: relative;
  margin-top: 18rpx;
  padding: 24rpx 22rpx;
  display: flex;
  align-items: stretch;
  background: linear-gradient(135deg, #fff2e2 0%, #fffbeb 100%);
  border: 2rpx solid #fdba74;
  border-radius: 26rpx;
  box-shadow: inset 0 0 0 2rpx rgba(255, 255, 255, 0.42);
}

.coupon-ticket-hole {
  position: absolute;
  top: 50%;
  width: 26rpx;
  height: 26rpx;
  background: rgba(15, 23, 42, 0.52);
  border-radius: 50%;
  transform: translateY(-50%);
}

.coupon-ticket-hole-left {
  left: -13rpx;
}

.coupon-ticket-hole-right {
  right: -13rpx;
}

.coupon-ticket-left {
  flex: 1;
  min-width: 0;
}

.coupon-ticket-kicker {
  display: block;
  font-size: 20rpx;
  color: #9a3412;
  font-weight: 700;
}

.coupon-ticket-save {
  display: block;
  margin-top: 6rpx;
  font-size: 34rpx;
  line-height: 1.15;
  color: #c2410c;
  font-weight: 800;
}

.coupon-ticket-hero {
  display: block;
  margin-top: 8rpx;
  font-size: 20rpx;
  line-height: 1.55;
  color: #7c2d12;
}

.coupon-ticket-divider {
  width: 2rpx;
  margin: 0 16rpx;
  background: repeating-linear-gradient(
    to bottom,
    rgba(194, 65, 12, 0.22) 0,
    rgba(194, 65, 12, 0.22) 10rpx,
    transparent 10rpx,
    transparent 18rpx
  );
}

.coupon-ticket-right {
  width: 156rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.coupon-price-row {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 8rpx;
  margin-top: 10rpx;
}

.coupon-price-label {
  font-size: 21rpx;
  color: #9a3412;
  font-weight: 600;
}

.coupon-price-value {
  font-size: 50rpx;
  line-height: 1;
  color: #ea580c;
  font-weight: 700;
}

.coupon-original-price {
  font-size: 20rpx;
  color: #94a3b8;
  text-decoration: line-through;
}

.coupon-tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 16rpx;
}

.coupon-tag {
  padding: 8rpx 14rpx;
  background: #fff7ed;
  border: 1rpx solid #fed7aa;
  border-radius: 999rpx;
  font-size: 20rpx;
  color: #9a3412;
  font-weight: 600;
}

.coupon-benefit-list {
  margin-top: 16rpx;
  padding: 18rpx 18rpx 6rpx;
  background: rgba(255, 255, 255, 0.78);
  border: 2rpx solid #ffedd5;
  border-radius: 20rpx;
}

.coupon-benefit-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 10rpx;
}

.coupon-benefit-dot {
  width: 12rpx;
  height: 12rpx;
  margin-top: 9rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
  border-radius: 50%;
  background: linear-gradient(180deg, #f97316 0%, #fb923c 100%);
  box-shadow: 0 0 0 5rpx rgba(251, 146, 60, 0.12);
}

.coupon-benefit-text {
  flex: 1;
  font-size: 22rpx;
  line-height: 1.55;
  color: #374151;
}

.coupon-summary {
  display: block;
  margin-top: 14rpx;
  font-size: 21rpx;
  line-height: 1.6;
  color: #6b7280;
}

.coupon-action {
  height: 78rpx;
  margin-top: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(90deg, #ea580c 0%, #fb923c 100%);
  border-radius: 999rpx;
  box-shadow: 0 12rpx 24rpx rgba(249, 115, 22, 0.24);
}

.coupon-action-text {
  font-size: 26rpx;
  color: #ffffff;
  font-weight: 700;
}

.coupon-hint {
  display: block;
  margin-top: 12rpx;
  font-size: 18rpx;
  line-height: 1.55;
  color: #9ca3af;
  text-align: center;
}

.home-notice-btn {
  position: relative;
  width: 76rpx;
  height: 76rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.92);
  border: 2rpx solid #e3ebf5;
  border-radius: 24rpx;
  box-shadow: 0 10rpx 22rpx rgba(29, 45, 74, 0.08);
}

.home-notice-btn-inline {
  width: 56rpx;
  height: 56rpx;
  margin-right: 10rpx;
  border-radius: 18rpx;
  flex-shrink: 0;
  background: rgba(247, 250, 255, 0.92);
  border-color: #e8eef7;
  box-shadow: 0 6rpx 14rpx rgba(29, 45, 74, 0.05);
}

.home-notice-icon {
  width: 42rpx;
  height: 42rpx;
}

.home-notice-btn-inline .home-notice-icon {
  width: 30rpx;
  height: 30rpx;
}

.home-notice-badge {
  position: absolute;
  top: -4rpx;
  right: -4rpx;
  min-width: 34rpx;
  height: 34rpx;
  padding: 0 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #ff5b6d;
  border: 4rpx solid #f5f8fc;
  border-radius: 999rpx;
  box-sizing: border-box;
}

.home-notice-badge-inline {
  top: -4rpx;
  right: -4rpx;
  min-width: 30rpx;
  height: 30rpx;
  padding: 0 6rpx;
}

.home-notice-badge-text {
  font-size: 18rpx;
  line-height: 1;
  color: #ffffff;
  font-weight: 700;
}

.exam-info-bar {
  display: flex;
  overflow: hidden;
  margin: 0 -6rpx;
  background: #ffffff;
  border: 2rpx solid #e5ebf2;
  border-radius: 24rpx;
  box-shadow: 0 12rpx 28rpx rgba(29, 45, 74, 0.06);
}

.exam-info-item {
  flex: 1;
  padding: 16rpx 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
}

.exam-info-item + .exam-info-item {
  border-left: 1rpx solid #edf1f5;
}

.exam-info-icon {
  width: 30rpx;
  height: 30rpx;
  flex-shrink: 0;
}

.exam-info-value {
  display: block;
  font-size: 28rpx;
  line-height: 1.2;
  color: #1d2433;
  font-weight: 700;
  white-space: nowrap;
}

.exam-info-value-blue {
  color: #3d7cff;
}

.path-card {
  margin-top: 20rpx;
  overflow: hidden;
  background: #ffffff;
  border: 2rpx solid #e6ebf2;
  border-radius: 32rpx;
  box-shadow: 0 18rpx 40rpx rgba(29, 45, 74, 0.08);
}

.path-header {
  padding: 24rpx 22rpx 18rpx;
  background: linear-gradient(180deg, #fbfdff 0%, #f5f8fc 100%);
  border-bottom: 1rpx solid #edf1f5;
}

.path-top-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.path-top-actions {
  display: flex;
  align-items: center;
  flex-shrink: 0;
}

.path-current-task {
  flex: 1;
  min-width: 0;
  padding-right: 16rpx;
}

.path-current-task-text {
  display: block;
  margin-top: 8rpx;
  font-size: 23rpx;
  line-height: 1.5;
  color: #6f7d93;
}

.path-top-tag {
  min-height: 58rpx;
  padding: 0 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #edf4ff;
  border: 1rpx solid #d7e5ff;
  border-radius: 999rpx;
}

.path-top-tag-text {
  font-size: 24rpx;
  color: #3d7cff;
  font-weight: 700;
}

.path-progress {
  margin-top: 18rpx;
}

.path-progress-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.path-progress-label {
  font-size: 22rpx;
  color: #8b97aa;
}

.path-progress-value {
  font-size: 22rpx;
  color: #3d7cff;
  font-weight: 700;
}

.path-progress-track {
  margin-top: 10rpx;
  height: 12rpx;
  border-radius: 999rpx;
  background: #eaf0f7;
  overflow: hidden;
}

.path-progress-fill {
  height: 100%;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #84b4ff 0%, #3d7cff 100%);
  box-shadow: 0 0 12rpx rgba(61, 124, 255, 0.18);
}

.path-track-surface {
  background: linear-gradient(180deg, #ffffff 0%, #fbfcfe 100%);
}

.path-track {
  position: relative;
  min-height: 1160rpx;
  padding: 34rpx 0 72rpx;
  background:
    radial-gradient(circle at 90% 22%, rgba(61, 124, 255, 0.05) 0, rgba(61, 124, 255, 0.05) 64rpx, transparent 66rpx),
    radial-gradient(circle at 12% 76%, rgba(95, 141, 86, 0.04) 0, rgba(95, 141, 86, 0.04) 54rpx, transparent 56rpx),
    #ffffff;
}

.branch-area {
  position: absolute;
  left: 18rpx;
  top: 308rpx;
  width: 228rpx;
  height: 194rpx;
  z-index: 1;
  transition: top 0.24s ease, left 0.24s ease, right 0.24s ease;
}

.branch-area-expanded {
  left: 18rpx;
  top: 300rpx;
  width: 224rpx;
  height: 190rpx;
}

.branch-guide {
  position: absolute;
  left: 64rpx;
  top: 72rpx;
  width: 26rpx;
  height: 60rpx;
  border-left: 2rpx solid rgba(210, 221, 234, 0.95);
  border-bottom: 2rpx solid rgba(210, 221, 234, 0.95);
  border-bottom-left-radius: 24rpx;
  opacity: 0.9;
}

.branch-node {
  position: absolute;
  left: 0;
  top: 68rpx;
  width: 98rpx;
  height: 112rpx;
  z-index: 10;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: transform 0.24s ease;
}

.branch-area,
.branch-guide,
.branch-node,
.branch-shadow,
.branch-glow,
.branch-koi-shell,
.branch-koi,
.branch-koi-shine,
.branch-koi-orb,
.branch-bubble-tail,
.branch-bubble-title,
.branch-bubble-slogan {
  pointer-events: none;
}

.branch-koi-shell {
  position: relative;
  width: 110rpx;
  height: 110rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: transform 0.28s ease;
}

.branch-koi-shell-left {
  transform: scaleX(1);
}

.branch-koi-shell-right {
  transform: scaleX(-1);
}

.branch-area-expanded .branch-node {
  transform: scale(0.96);
}

.branch-shadow {
  display: none;
}

.branch-glow {
  display: none;
}

.branch-koi-shine {
  display: none;
}

.branch-koi {
  position: relative;
  width: 110rpx;
  height: 110rpx;
  transform: rotate(-3deg);
  z-index: 2;
  transform-origin: 46% 54%;
  animation: branch-koi-sway 4.8s ease-in-out infinite;
  opacity: 0.98;
}

.branch-koi-orb {
  display: none;
}

.branch-koi-orb-top {
  top: 26rpx;
  right: 6rpx;
  width: 14rpx;
  height: 14rpx;
  animation: branch-orb-rise-1 3.4s ease-in-out infinite;
}

.branch-koi-orb-side {
  top: 50rpx;
  right: -4rpx;
  width: 9rpx;
  height: 9rpx;
  animation: branch-orb-rise-2 3s ease-in-out infinite;
}

.branch-bubble {
  position: absolute;
  left: 82rpx;
  top: 10rpx;
  width: 158rpx;
  min-height: 0;
  padding: 12rpx 14rpx 12rpx;
  box-sizing: border-box;
  background: rgba(252, 254, 255, 0.9);
  border: 1rpx solid rgba(221, 230, 240, 0.95);
  border-radius: 16rpx;
  box-shadow: 0 4rpx 10rpx rgba(29, 45, 74, 0.03);
  z-index: 6;
  transition: top 0.24s ease, left 0.24s ease, width 0.24s ease;
  pointer-events: auto;
}

.branch-area-expanded .branch-bubble {
  left: 78rpx;
  top: 8rpx;
  width: 154rpx;
}

.branch-bubble-tail {
  display: none;
}

.branch-bubble-title {
  display: block;
  font-size: 18rpx;
  color: #5f7088;
  font-weight: 800;
  text-align: left;
}

.branch-bubble-subtitle {
  display: block;
  margin-top: 4rpx;
  font-size: 18rpx;
  color: #6b7b93;
  text-align: left;
}

.branch-bubble-slogan {
  display: block;
  margin-top: 6rpx;
  font-size: 16rpx;
  line-height: 1.45;
  color: rgba(98, 113, 134, 0.92);
  font-weight: 500;
  text-align: left;
  display: -webkit-box;
  overflow: hidden;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.branch-bubble-action {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 78rpx;
  height: 34rpx;
  margin-top: 10rpx;
  padding: 0 12rpx;
  border-radius: 999rpx;
  background: rgba(61, 124, 255, 0.08);
  box-shadow: none;
  pointer-events: auto;
}

.branch-bubble-action-text {
  font-size: 16rpx;
  color: #3d7cff;
  font-weight: 700;
  line-height: 1;
}

.branch-bubble-mood-urgent {
  background: rgba(255, 249, 245, 0.9);
  border-color: rgba(251, 146, 60, 0.18);
}

.branch-bubble-mood-remind {
  background: rgba(255, 252, 245, 0.9);
  border-color: rgba(234, 179, 8, 0.18);
}

.branch-bubble-mood-warm {
  background: rgba(247, 253, 248, 0.9);
  border-color: rgba(74, 169, 108, 0.16);
}

.branch-bubble-mood-calm {
  background: rgba(245, 250, 255, 0.9);
  border-color: rgba(96, 165, 250, 0.16);
}

.branch-bubble-mood-urgent .branch-bubble-title {
  color: #c2410c;
}

.branch-bubble-mood-remind .branch-bubble-title {
  color: #a16207;
}

.branch-bubble-mood-warm .branch-bubble-title {
  color: #2f855a;
}

.branch-bubble-mood-calm .branch-bubble-title {
  color: #2b6cb0;
}

.branch-bubble-mood-urgent .branch-bubble-action {
  background: rgba(249, 115, 22, 0.12);
}

.branch-bubble-mood-remind .branch-bubble-action {
  background: rgba(234, 179, 8, 0.12);
}

.branch-bubble-mood-warm .branch-bubble-action {
  background: rgba(57, 168, 102, 0.12);
}

.branch-bubble-mood-urgent .branch-bubble-action-text {
  color: #ea580c;
}

.branch-bubble-mood-remind .branch-bubble-action-text {
  color: #ca8a04;
}

.branch-bubble-mood-warm .branch-bubble-action-text {
  color: #2f855a;
}

.branch-bubble-mood-calm .branch-bubble-action-text {
  color: #2b6cb0;
}

@keyframes branch-koi-float {
  0%, 100% {
    transform: translateY(0) translateX(0);
  }
  50% {
    transform: translateY(-6rpx) translateX(2rpx);
  }
}

@keyframes branch-shadow-breathe {
  0%, 100% {
    transform: scaleX(1) scaleY(1);
    opacity: 0.9;
  }
  50% {
    transform: scaleX(0.9) scaleY(0.8);
    opacity: 0.62;
  }
}

@keyframes branch-glow-pulse {
  0%, 100% {
    opacity: 0.7;
    transform: scale(0.98);
  }
  50% {
    opacity: 1;
    transform: scale(1.05);
  }
}

@keyframes branch-koi-sway {
  0%, 100% {
    transform: rotate(-3deg);
  }
  25% {
    transform: rotate(-5deg);
  }
  50% {
    transform: rotate(-2deg);
  }
  75% {
    transform: rotate(-4deg);
  }
}

@keyframes branch-koi-shimmer {
  0%, 100% {
    opacity: 0.2;
    transform: translateX(-10rpx) rotate(-20deg);
  }
  50% {
    opacity: 0.72;
    transform: translateX(14rpx) rotate(-20deg);
  }
}

@keyframes branch-orb-rise-1 {
  0%, 100% {
    transform: translateY(0) translateX(0) scale(1);
    opacity: 0.55;
  }
  50% {
    transform: translateY(-12rpx) translateX(4rpx) scale(1.12);
    opacity: 0.92;
  }
}

@keyframes branch-orb-rise-2 {
  0%, 100% {
    transform: translateY(0) translateX(0) scale(1);
    opacity: 0.45;
  }
  50% {
    transform: translateY(-10rpx) translateX(3rpx) scale(1.08);
    opacity: 0.82;
  }
}

.path-node-wrap {
  position: relative;
  display: flex;
  width: 100%;
}

.path-node-wrap-diagnose {
  z-index: 3;
  padding-top: 24rpx;
  justify-content: flex-start;
  padding-left: 136rpx;
}

.path-node-wrap-final-card {
  padding-top: 118rpx;
  justify-content: flex-end;
  padding-right: 82rpx;
}

.path-node-wrap-yellow-card {
  padding-top: 120rpx;
  justify-content: flex-start;
  padding-left: 116rpx;
}

.path-node-wrap-blue-card {
  padding-top: 122rpx;
  justify-content: flex-end;
  padding-right: 90rpx;
}

.path-node-group {
  position: relative;
  z-index: 2;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
}

.path-node-wrap-final-card .path-node-group,
.path-node-wrap-blue-card .path-node-group {
  align-items: flex-end;
}

.path-curve {
  position: absolute;
  box-sizing: border-box;
  pointer-events: none;
  z-index: 1;
}

.path-curve-final-card {
  display: none;
}

.path-curve-yellow-card {
  display: none;
  left: 236rpx;
  width: 260rpx;
  height: 138rpx;
  border-right-width: 4rpx;
  border-right-style: solid;
