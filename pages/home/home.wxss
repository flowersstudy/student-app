}

.path-node-subpath-dot-locked {
  border-color: #cfd6df;
  box-shadow: none;
}

.path-node-subpath-line {
  position: absolute;
  top: 30rpx;
  left: 13rpx;
  bottom: -28rpx;
  width: 4rpx;
  border-radius: 999rpx;
  background: #dbe3ef;
}

.path-node-subpath-line-completed {
  background: linear-gradient(180deg, #cfead2 0%, #dbe3ef 100%);
}

.path-node-subpath-line-active {
