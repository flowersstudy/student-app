page {
  background: linear-gradient(180deg, #f5f8fc 0%, #f2f5fa 100%);
}

.path-page {
  min-height: 100vh;
  padding: 24rpx 20rpx 0;
  box-sizing: border-box;
}

.coupon-mask {
  position: fixed;
  inset: 0;
  z-index: 99;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx;
  background: rgba(15, 23, 42, 0.52);
  box-sizing: border-box;
}

.coupon-dialog {
  position: relative;
  width: 100%;
  max-width: 670rpx;
  padding: 40rpx 34rpx 34rpx;
  background:
    radial-gradient(circle at top right, rgba(255, 227, 195, 0.72) 0%, rgba(255, 227, 195, 0) 34%),
    linear-gradient(180deg, #fffaf4 0%, #ffffff 100%);
  border-radius: 32rpx;
  box-shadow: 0 22rpx 56rpx rgba(15, 23, 42, 0.22);
  box-sizing: border-box;
}

.coupon-close {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  width: 52rpx;
  height: 52rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.8);
  color: #94a3b8;
  font-size: 36rpx;
  line-height: 1;
}

.coupon-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 50rpx;
  padding: 0 18rpx;
  background: linear-gradient(90deg, #ffedd5 0%, #fde68a 100%);
  border-radius: 999rpx;
  color: #b45309;
  font-size: 22rpx;
  font-weight: 700;
}

.coupon-title {
  display: block;
  margin-top: 22rpx;
  padding-right: 52rpx;
  font-size: 40rpx;
  line-height: 1.35;
  color: #1f2937;
  font-weight: 700;
}

.coupon-subtitle {
  display: block;
  margin-top: 14rpx;
  font-size: 25rpx;
  line-height: 1.7;
  color: #64748b;
}

.coupon-countdown {
  margin-top: 24rpx;
  padding: 18rpx 22rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: rgba(255, 255, 255, 0.82);
  border: 2rpx solid #fde7cf;
  border-radius: 24rpx;
}

.coupon-countdown-label {
  font-size: 24rpx;
  color: #92400e;
  font-weight: 600;
}

.coupon-countdown-value {
  font-size: 34rpx;
  color: #ea580c;
  font-weight: 700;
  letter-spacing: 2rpx;
}

.coupon-price-card {
  margin-top: 22rpx;
  padding: 28rpx 26rpx;
  background: linear-gradient(135deg, #fff7ed 0%, #fffbeb 100%);
  border: 2rpx solid #fed7aa;
  border-radius: 28rpx;
}

.coupon-price-row {
  display: flex;
  align-items: baseline;
  gap: 16rpx;
}

.coupon-price-label {
  font-size: 24rpx;
  color: #9a3412;
  font-weight: 600;
}

.coupon-price-value {
  font-size: 56rpx;
  line-height: 1;
  color: #ea580c;
  font-weight: 700;
}

.coupon-original-price {
  font-size: 24rpx;
  color: #94a3b8;
  text-decoration: line-through;
}

.coupon-save-text {
  display: block;
  margin-top: 14rpx;
  font-size: 24rpx;
  color: #c2410c;
  font-weight: 700;
}

.coupon-tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 22rpx;
}

.coupon-tag {
  padding: 10rpx 18rpx;
  background: #f8fafc;
  border: 1rpx solid #e2e8f0;
  border-radius: 999rpx;
  font-size: 22rpx;
  color: #475569;
  font-weight: 600;
}

.coupon-summary {
  display: block;
  margin-top: 18rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #64748b;
}

.coupon-action {
  height: 88rpx;
  margin-top: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(90deg, #f97316 0%, #fb923c 100%);
  border-radius: 999rpx;
  box-shadow: 0 12rpx 28rpx rgba(249, 115, 22, 0.24);
}

.coupon-action-text {
  font-size: 28rpx;
  color: #ffffff;
  font-weight: 700;
}

.coupon-hint {
  display: block;
  margin-top: 18rpx;
  font-size: 20rpx;
  line-height: 1.6;
  color: #94a3b8;
  text-align: center;
}

.home-notice-btn {
  position: relative;
  width: 76rpx;
  height: 76rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.92);
  border: 2rpx solid #e3ebf5;
  border-radius: 24rpx;
  box-shadow: 0 10rpx 22rpx rgba(29, 45, 74, 0.08);
}

.home-notice-btn-inline {
  width: 56rpx;
  height: 56rpx;
  margin-right: 10rpx;
  border-radius: 18rpx;
  flex-shrink: 0;
  background: rgba(247, 250, 255, 0.92);
  border-color: #e8eef7;
  box-shadow: 0 6rpx 14rpx rgba(29, 45, 74, 0.05);
}

.home-notice-icon {
  width: 42rpx;
  height: 42rpx;
}

.home-notice-btn-inline .home-notice-icon {
  width: 30rpx;
  height: 30rpx;
}

.home-notice-badge {
  position: absolute;
  top: -4rpx;
  right: -4rpx;
  min-width: 34rpx;
  height: 34rpx;
  padding: 0 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #ff5b6d;
  border: 4rpx solid #f5f8fc;
  border-radius: 999rpx;
  box-sizing: border-box;
}

.home-notice-badge-inline {
  top: -4rpx;
  right: -4rpx;
  min-width: 30rpx;
  height: 30rpx;
  padding: 0 6rpx;
}

.home-notice-badge-text {
  font-size: 18rpx;
  line-height: 1;
  color: #ffffff;
  font-weight: 700;
}

.exam-info-bar {
  display: flex;
  overflow: hidden;
  margin: 0 -6rpx;
  background: #ffffff;
  border: 2rpx solid #e5ebf2;
  border-radius: 24rpx;
  box-shadow: 0 12rpx 28rpx rgba(29, 45, 74, 0.06);
}

.exam-info-item {
  flex: 1;
  padding: 16rpx 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
}

.exam-info-item + .exam-info-item {
  border-left: 1rpx solid #edf1f5;
}

.exam-info-icon {
  width: 30rpx;
  height: 30rpx;
  flex-shrink: 0;
}

.exam-info-value {
  display: block;
  font-size: 28rpx;
  line-height: 1.2;
  color: #1d2433;
  font-weight: 700;
  white-space: nowrap;
}

.exam-info-value-blue {
  color: #3d7cff;
}

.path-card {
  margin-top: 20rpx;
  overflow: hidden;
  background: #ffffff;
  border: 2rpx solid #e6ebf2;
  border-radius: 32rpx;
  box-shadow: 0 18rpx 40rpx rgba(29, 45, 74, 0.08);
}

.path-header {
  padding: 24rpx 22rpx 18rpx;
  background: linear-gradient(180deg, #fbfdff 0%, #f5f8fc 100%);
  border-bottom: 1rpx solid #edf1f5;
}

.path-top-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.path-top-actions {
  display: flex;
  align-items: center;
  flex-shrink: 0;
}

.path-current-task {
  flex: 1;
  min-width: 0;
  padding-right: 16rpx;
}

.path-current-task-text {
  display: block;
  margin-top: 8rpx;
  font-size: 23rpx;
  line-height: 1.5;
  color: #6f7d93;
}

.path-top-tag {
  min-height: 58rpx;
  padding: 0 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #edf4ff;
  border: 1rpx solid #d7e5ff;
  border-radius: 999rpx;
}

.path-top-tag-text {
  font-size: 24rpx;
  color: #3d7cff;
  font-weight: 700;
}

.path-progress {
  margin-top: 18rpx;
}

.path-progress-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.path-progress-label {
  font-size: 22rpx;
  color: #8b97aa;
}

.path-progress-value {
  font-size: 22rpx;
  color: #3d7cff;
  font-weight: 700;
}

.path-progress-track {
  margin-top: 10rpx;
  height: 12rpx;
  border-radius: 999rpx;
  background: #eaf0f7;
  overflow: hidden;
}

.path-progress-fill {
  height: 100%;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #84b4ff 0%, #3d7cff 100%);
  box-shadow: 0 0 12rpx rgba(61, 124, 255, 0.18);
}

.path-track-surface {
  background: linear-gradient(180deg, #ffffff 0%, #fbfcfe 100%);
}

.path-track {
  position: relative;
  min-height: 1160rpx;
  padding: 34rpx 0 72rpx;
  background:
    radial-gradient(circle at 90% 22%, rgba(61, 124, 255, 0.05) 0, rgba(61, 124, 255, 0.05) 64rpx, transparent 66rpx),
    radial-gradient(circle at 12% 76%, rgba(95, 141, 86, 0.04) 0, rgba(95, 141, 86, 0.04) 54rpx, transparent 56rpx),
    #ffffff;
}

.branch-area {
  position: absolute;
  left: 8rpx;
  top: 296rpx;
  width: 176rpx;
  height: 214rpx;
  z-index: 6;
  transition: top 0.24s ease, left 0.24s ease, right 0.24s ease;
}

.branch-area-expanded {
  left: 8rpx;
  top: 278rpx;
  width: 172rpx;
  height: 208rpx;
}

.branch-node {
  position: absolute;
  left: 18rpx;
  top: 84rpx;
  width: 108rpx;
  height: 122rpx;
  z-index: 8;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: transform 0.24s ease;
}

.branch-area-expanded .branch-node {
  transform: translateY(-6rpx) scale(0.96);
}

.branch-shadow {
  position: absolute;
  left: 50%;
  bottom: 0;
  width: 74rpx;
  height: 18rpx;
  margin-left: -37rpx;
  border-radius: 50%;
  background: rgba(74, 113, 173, 0.14);
  filter: blur(4rpx);
}

.branch-glow {
  position: absolute;
  left: 50%;
  top: 16rpx;
  width: 114rpx;
  height: 114rpx;
  margin-left: -57rpx;
  border-radius: 50%;
  background: radial-gradient(circle at 50% 50%, rgba(113, 197, 255, 0.22) 0%, rgba(46, 125, 246, 0.1) 45%, rgba(46, 125, 246, 0) 76%);
  filter: blur(3rpx);
}

.branch-spirit {
  position: relative;
  width: 94rpx;
  height: 108rpx;
  border-radius: 52% 48% 48% 46% / 38% 38% 62% 62%;
  background: linear-gradient(180deg, rgba(165, 223, 255, 0.96) 0%, rgba(81, 165, 255, 0.94) 46%, rgba(46, 125, 246, 0.96) 100%);
  box-shadow:
    0 16rpx 28rpx rgba(46, 125, 246, 0.18),
    inset 0 0 0 2rpx rgba(255, 255, 255, 0.24);
  overflow: hidden;
  transform: translateY(4rpx) rotate(-3deg);
}

.branch-spirit-gloss {
  position: absolute;
  top: 12rpx;
  left: 14rpx;
  width: 36rpx;
  height: 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.3);
  transform: rotate(-20deg);
}

.branch-spirit-belly {
  position: absolute;
  left: 16rpx;
  right: 16rpx;
  bottom: 14rpx;
  height: 48rpx;
  border-radius: 50%;
  background: linear-gradient(180deg, rgba(230, 248, 255, 0.34) 0%, rgba(255, 255, 255, 0.16) 100%);
}

.branch-eye {
  position: absolute;
  top: 46rpx;
  width: 12rpx;
  height: 16rpx;
  border-radius: 999rpx;
  background: rgba(29, 36, 51, 0.78);
  box-sizing: border-box;
  box-shadow: inset 0 -2rpx 0 rgba(255, 255, 255, 0.14);
}

.branch-eye-left {
  left: 26rpx;
}

.branch-eye-right {
  right: 26rpx;
}

.branch-bubble {
  position: absolute;
  left: 92rpx;
  top: 10rpx;
  width: 168rpx;
  min-height: 0;
  padding: 14rpx 18rpx;
  box-sizing: border-box;
  background: linear-gradient(180deg, #ffffff 0%, #f7fbff 100%);
  border: 2rpx solid #cfe3f7;
  border-radius: 26rpx;
  box-shadow: 0 12rpx 24rpx rgba(29, 45, 74, 0.08);
  z-index: 9;
  transition: top 0.24s ease, left 0.24s ease, width 0.24s ease;
}

.branch-area-expanded .branch-bubble {
  left: 84rpx;
  top: 2rpx;
  width: 162rpx;
}

.branch-bubble-tail {
  position: absolute;
  left: -7rpx;
  bottom: 20rpx;
  width: 16rpx;
  height: 16rpx;
  background: #f7fbff;
  border-left: 2rpx solid #cfe3f7;
  border-bottom: 2rpx solid #cfe3f7;
  border-bottom-left-radius: 6rpx;
  transform: rotate(32deg);
  box-sizing: border-box;
}

.branch-bubble-title {
  display: block;
  font-size: 24rpx;
  color: #1d2433;
  font-weight: 800;
  text-align: left;
}

.branch-bubble-subtitle {
  display: block;
  margin-top: 4rpx;
  font-size: 18rpx;
  color: #6b7b93;
  text-align: left;
}

.branch-bubble-slogan {
  display: block;
  font-size: 20rpx;
  line-height: 1.4;
  color: #4e6f96;
  font-weight: 700;
  text-align: left;
}

.path-node-wrap {
  position: relative;
  display: flex;
  width: 100%;
}

.path-node-wrap-diagnose {
  padding-top: 24rpx;
  justify-content: flex-start;
  padding-left: 126rpx;
}

.path-node-wrap-final-card {
  padding-top: 132rpx;
  justify-content: flex-end;
  padding-right: 64rpx;
}

.path-node-wrap-yellow-card {
  padding-top: 136rpx;
  justify-content: flex-start;
  padding-left: 128rpx;
}

.path-node-wrap-blue-card {
  padding-top: 138rpx;
  justify-content: flex-end;
  padding-right: 102rpx;
}

.path-node-group {
  position: relative;
  z-index: 2;
  display: flex;
  flex-direction: column;
}

.path-curve {
  position: absolute;
  top: -18rpx;
  border-color: #dbe3ef;
  box-sizing: border-box;
  opacity: 0.95;
}

.path-curve-final-card {
  left: 232rpx;
  width: 214rpx;
  height: 136rpx;
  border-left-width: 4rpx;
  border-left-style: solid;
  border-bottom-width: 4rpx;
  border-bottom-style: solid;
  border-bottom-left-radius: 144rpx;
  border-color: #f3b0b9;
}

.path-curve-yellow-card {
  left: 154rpx;
  width: 256rpx;
  height: 146rpx;
  border-right-width: 4rpx;
  border-right-style: solid;
  border-bottom-width: 4rpx;
  border-bottom-style: solid;
  border-bottom-right-radius: 152rpx;
  border-color: #f2d26f;
}

.path-curve-blue-card {
  left: 210rpx;
  width: 220rpx;
  height: 152rpx;
  border-left-width: 4rpx;
  border-left-style: solid;
  border-bottom-width: 4rpx;
  border-bottom-style: solid;
  border-bottom-left-radius: 156rpx;
  border-color: #bfd7ff;
}

.path-node-highlight {
  display: none;
}

.path-node-wrap-final-card .path-node-highlight {
  display: none;
}

.path-node-wrap-yellow-card .path-node-highlight {
  display: none;
}

.path-node-wrap-blue-card .path-node-highlight {
  display: none;
}

.path-node {
  position: relative;
  z-index: 2;
  min-width: 224rpx;
  min-height: 96rpx;
  padding: 0 22rpx;
  display: flex;
  align-items: center;
  justify-content: flex-start;
  box-sizing: border-box;
  background: #ffffff;
  border-radius: 999rpx;
  border: 2rpx solid #e4eaf2;
  box-shadow: 0 12rpx 24rpx rgba(29, 45, 74, 0.06);
}

.path-node-expand {
  margin-left: 18rpx;
  font-size: 22rpx;
  color: #7f8ba0;
  flex-shrink: 0;
}

.path-node-done {
  border-color: #d8ead9;
  background: linear-gradient(180deg, #ffffff 0%, #fbfffb 100%);
}

.path-node-current {
  min-width: 276rpx;
  min-height: 108rpx;
  border: 3rpx solid #4d8dff;
  background: linear-gradient(180deg, #f6faff 0%, #ffffff 100%);
  box-shadow: 0 14rpx 28rpx rgba(77, 141, 255, 0.12);
}

.path-node-browse {
  border-color: #dbe7ff;
  background: linear-gradient(180deg, #f8fbff 0%, #ffffff 100%);
  box-shadow: 0 12rpx 24rpx rgba(61, 124, 255, 0.06);
}

.path-node-locked {
  border-color: #e6eaef;
  background: linear-gradient(180deg, #fafbfc 0%, #f4f6f8 100%);
}

.path-node-wrap-yellow-card .path-node {
  min-width: 238rpx;
}

.path-node-wrap-blue-card .path-node {
  min-width: 230rpx;
}

.path-node-wrap-final-card .path-node-done,
.path-node-wrap-final-card .path-node-current,
.path-node-wrap-final-card .path-node-browse,
.path-node-wrap-final-card .path-node-locked {
  border-color: #f2c6cc;
  background: #ffffff;
  box-shadow: 0 12rpx 24rpx rgba(29, 45, 74, 0.06);
}

.path-node-wrap-final-card .path-node-current {
  border-width: 3rpx;
  border-color: #ea4c60;
  background: #fff7f8;
  box-shadow: 0 12rpx 24rpx rgba(29, 45, 74, 0.08);
}

.path-node-wrap-final-card .path-node-icon-done,
.path-node-wrap-final-card .path-node-icon-current,
.path-node-wrap-final-card .path-node-icon-browse,
.path-node-wrap-final-card .path-node-icon-locked {
  background: #ea4c60;
}

.path-node-wrap-final-card .path-node-note {
  color: #c23b4c;
  background: #ffe9ed;
}

.path-node-wrap-final-card .path-node-expand {
  color: #d45a6a;
}

.path-node-wrap-yellow-card .path-node-done,
.path-node-wrap-yellow-card .path-node-current,
.path-node-wrap-yellow-card .path-node-browse,
.path-node-wrap-yellow-card .path-node-locked {
  border-color: #efd98a;
  background: #ffffff;
  box-shadow: 0 12rpx 24rpx rgba(29, 45, 74, 0.06);
}

.path-node-wrap-yellow-card .path-node-current {
  border-width: 3rpx;
  border-color: #e2aa14;
  background: #fff9e9;
  box-shadow: 0 12rpx 24rpx rgba(29, 45, 74, 0.08);
}

.path-node-wrap-yellow-card .path-node-icon-done,
.path-node-wrap-yellow-card .path-node-icon-current,
.path-node-wrap-yellow-card .path-node-icon-browse,
.path-node-wrap-yellow-card .path-node-icon-locked {
  background: #e2aa14;
}

.path-node-wrap-yellow-card .path-node-note {
  color: #aa7a00;
  background: #fff1c4;
}

.path-node-wrap-yellow-card .path-node-expand {
  color: #9a7000;
}

.path-node-wrap-blue-card .path-node-done,
.path-node-wrap-blue-card .path-node-current,
.path-node-wrap-blue-card .path-node-browse,
.path-node-wrap-blue-card .path-node-locked {
  border-color: #cfe0ff;
  background: #ffffff;
  box-shadow: 0 12rpx 24rpx rgba(29, 45, 74, 0.06);
}

.path-node-wrap-blue-card .path-node-current {
  border-width: 3rpx;
  border-color: #3d7cff;
  background: #f5f9ff;
  box-shadow: 0 12rpx 24rpx rgba(29, 45, 74, 0.08);
}

.path-node-wrap-blue-card .path-node-icon-done,
.path-node-wrap-blue-card .path-node-icon-current,
.path-node-wrap-blue-card .path-node-icon-browse,
.path-node-wrap-blue-card .path-node-icon-locked {
  background: #3d7cff;
}

.path-node-wrap-blue-card .path-node-note {
  color: #3567d8;
  background: #eaf2ff;
}

.path-node-wrap-blue-card .path-node-title,
.path-node-wrap-blue-card .path-node-note,
.path-node-wrap-blue-card .path-node-expand {
  color: #355a9d;
}

.path-node-icon {
  width: 48rpx;
  height: 48rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
}

.path-node-icon-done {
  background: #65b96c;
}

.path-node-icon-current {
  width: 56rpx;
  height: 56rpx;
  background: #4d8dff;
}

.path-node-icon-browse {
  background: #8fb6ff;
}

.path-node-icon-locked {
  background: #cfd6df;
}

.path-node-icon-text {
  font-size: 24rpx;
  color: #ffffff;
  font-weight: 800;
}

.path-node-text {
  margin-left: 12rpx;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
}

.path-node-title {
  font-size: 30rpx;
  line-height: 1.14;
  color: #1d2433;
  font-weight: 800;
}

.path-node-note {
  margin-top: 8rpx;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  line-height: 1.2;
}

.path-node-done .path-node-note {
  color: #4c8b52;
  background: #edf8ef;
}

.path-node-current .path-node-note {
  color: #3d7cff;
  background: #edf4ff;
}

.path-node-browse .path-node-note {
