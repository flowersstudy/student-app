page {
  background: #f5f7fb;
}

.path-page {
  min-height: 100vh;
  padding: 12rpx 22rpx calc(36rpx + 56px + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.path-bar-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.path-item {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.path-bar {
  min-height: 104rpx;
  padding: 0 26rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-sizing: border-box;
  background: #ffffff;
  border: 2rpx solid #e6ebf2;
  border-radius: 28rpx;
  box-shadow: 0 10rpx 24rpx rgba(29, 45, 74, 0.06);
}

.path-bar-done {
  border-color: #d9eadc;
  background: linear-gradient(180deg, #ffffff 0%, #fbfffc 100%);
}

.path-bar-current {
  border-color: #b8d3ff;
  background: linear-gradient(180deg, #f8fbff 0%, #ffffff 100%);
  box-shadow: 0 12rpx 28rpx rgba(61, 124, 255, 0.12);
}

.path-bar-locked {
  background: linear-gradient(180deg, #ffffff 0%, #f7f8fa 100%);
}

.path-bar-main {
  flex: 1;
  min-width: 0;
  padding-right: 20rpx;
}

.path-bar-title {
  display: block;
  font-size: 31rpx;
  line-height: 1.25;
  color: #1d2433;
  font-weight: 800;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.path-bar-locked .path-bar-title {
  color: #8a95a6;
}

.path-bar-side {
  display: flex;
  align-items: center;
  flex-shrink: 0;
  gap: 14rpx;
}

.path-bar-tag {
  height: 42rpx;
  padding: 0 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  background: #f1f5f9;
}

.path-bar-tag-done {
  background: #edf8ef;
}

.path-bar-tag-current {
  background: #edf4ff;
}

.path-bar-tag-locked {
  background: #eceff3;
}

.path-bar-tag-text {
  font-size: 21rpx;
  line-height: 1;
  color: #697589;
  font-weight: 700;
  white-space: nowrap;
}

.path-bar-tag-text-done {
  color: #4c8b52;
}

.path-bar-tag-text-current {
  color: #3d7cff;
}

.path-bar-tag-text-locked {
  color: #98a1ae;
}

.path-bar-arrow {
  width: 34rpx;
  height: 34rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #9aa5b5;
  font-size: 30rpx;
  line-height: 1;
  transition: transform 0.18s ease;
}

.path-bar-arrow-open {
  transform: rotate(180deg);
}

.path-expand {
  padding: 18rpx 18rpx 18rpx;
  background: linear-gradient(180deg, #ffffff 0%, #fbfcfe 100%);
  border: 2rpx solid #e6ebf2;
  border-radius: 28rpx;
  box-shadow: 0 12rpx 28rpx rgba(29, 45, 74, 0.05);
}

.path-expand-head {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 18rpx;
  margin-bottom: 8rpx;
}

.path-expand-title {
  flex: 1;
  min-width: 0;
  font-size: 26rpx;
  line-height: 1.35;
  color: #1d2433;
  font-weight: 800;
}

.path-expand-summary {
  flex-shrink: 0;
  font-size: 20rpx;
  color: #8a95a6;
  font-weight: 600;
}

.path-expand-body {
  position: relative;
}

.duo-map {
  position: relative;
  min-height: 200rpx;
}

.duo-step {
  position: absolute;
  transform: translateX(-50%);
}

.duo-node-wrap {
  position: relative;
  width: 88rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  z-index: 2;
}

.duo-node {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: linear-gradient(180deg, #ffffff 0%, #f2f5f9 100%);
  border: 5rpx solid #dfe6ee;
  box-shadow: 0 8rpx 18rpx rgba(29, 45, 74, 0.08);
  box-sizing: border-box;
}

.duo-node-done {
  background: linear-gradient(180deg, #7fdc46 0%, #58bf17 100%);
  border-color: #4baa15;
  box-shadow: 0 10rpx 20rpx rgba(88, 191, 23, 0.24);
}

.duo-node-current {
  background: linear-gradient(180deg, #7fdc46 0%, #58bf17 100%);
  border-color: #4baa15;
  box-shadow: 0 12rpx 22rpx rgba(88, 191, 23, 0.26);
}

.duo-node-locked {
  background: linear-gradient(180deg, #ffffff 0%, #eef2f6 100%);
  border-color: #dfe5ec;
}

.duo-node-text {
  line-height: 1;
  color: #ffffff;
  font-weight: 800;
}

.duo-node-locked .duo-node-text {
  color: #a7b0bd;
}

.path-ip-float {
  position: absolute;
  z-index: 1;
}

.path-ip-image {
  width: 100%;
  display: block;
}
