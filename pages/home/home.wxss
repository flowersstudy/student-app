}

.path-node-subpath-card {
  min-width: 300rpx;
  max-width: 340rpx;
  min-height: 60rpx;
  padding: 14rpx 24rpx;
  border-radius: 999rpx;
  background: linear-gradient(180deg, #ffffff 0%, #fbfcfe 100%);
  border: 1rpx solid #e3eaf3;
  box-shadow: 0 8rpx 16rpx rgba(29, 45, 74, 0.04);
  box-sizing: border-box;
}

.path-node-subpath-card-completed {
  background: linear-gradient(180deg, #ffffff 0%, #f7fcf8 100%);
  border-color: #d8ead9;
  box-shadow: 0 8rpx 18rpx rgba(97, 183, 106, 0.08);
}

.path-node-subpath-card-active {
