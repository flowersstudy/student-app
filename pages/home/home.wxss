.path-node-detail {
  position: relative;
  z-index: 2;
  margin-top: 14rpx;
}

.path-node-detail-final-card {
  margin-right: 34rpx;
}

.path-node-detail-yellow-card {
  margin-left: 28rpx;
}

.path-node-detail-blue-card {
  margin-right: 34rpx;
}

.path-node-detail-card {
  position: relative;
  min-width: 280rpx;
  padding: 8rpx 0 6rpx;
  background: transparent;
  border: none;
  box-shadow: none;
}

.path-node-detail-connector {
  position: absolute;
  top: -16rpx;
  left: 14rpx;
  width: 4rpx;
  height: 42rpx;
  border-radius: 999rpx;
  background: linear-gradient(180deg, #d9e4f2 0%, #d4e0f0 100%);
  transform-origin: top center;
}

.path-node-detail-final-card .path-node-detail-connector {
  background: #efb0ba;
}

.path-node-detail-yellow-card .path-node-detail-connector {
  background: #ecc34a;
}

.path-node-detail-blue-card .path-node-detail-connector {
  background: #b5d0ff;
}

.path-node-detail-open .path-node-detail-card {
  animation: detailGrowDown 0.24s ease forwards;
}

.path-node-detail-open .path-node-detail-connector {
  animation: detailTrackGrow 0.22s ease forwards;
}

.path-node-detail-close .path-node-detail-card {
  animation: detailShrinkUp 0.2s ease forwards;
}

.path-node-detail-close .path-node-detail-connector {
  animation: detailTrackShrink 0.18s ease forwards;
}

.path-node-subpath-section + .path-node-subpath-section {
