/* ===== 未购课视图样式 ===== */
.section-label {
  font-size: 30rpx;
  font-weight: 700;
  color: #1a1a1a;
  padding: 32rpx 32rpx 16rpx;
}

.course-grid-home {
  display: flex;
  flex-wrap: wrap;
  padding: 0 24rpx;
}

.diagnose-hero-home {
  margin: 24rpx 32rpx;
  background: linear-gradient(150deg, #1248cc, #1A6EFF 50%, #4a9eff);
  border-radius: 28rpx;
  padding: 40rpx 36rpx 36rpx;
  display: flex;
  flex-direction: column;
  box-shadow: 0 12rpx 40rpx rgba(26,110,255,0.35);
}

.diagnose-hero-badge {
  align-self: flex-start;
  background: rgba(255,255,255,0.25);
  color: #fff;
  font-size: 20rpx;
  font-weight: 700;
  padding: 6rpx 18rpx;
  border-radius: 20rpx;
  margin-bottom: 20rpx;
  letter-spacing: 2rpx;
}

.diagnose-hero-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #fff;
  display: block;
  margin-bottom: 12rpx;
  letter-spacing: 1rpx;
}

.diagnose-hero-sub {
  font-size: 26rpx;
  color: rgba(255,255,255,0.85);
  display: block;
  line-height: 1.6;
  margin-bottom: 28rpx;
}

.diagnose-province-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  background: rgba(255,255,255,0.15);
  border-radius: 16rpx;
  padding: 16rpx 24rpx;
  margin-bottom: 28rpx;
}

.diagnose-province-label {
  font-size: 24rpx;
  color: rgba(255,255,255,0.75);
  margin-right: 16rpx;
}

.diagnose-province-val {
  font-size: 28rpx;
  font-weight: 700;
  color: #fff;
  flex: 1;
}

.diagnose-province-arrow {
  font-size: 22rpx;
  color: rgba(255,255,255,0.75);
}

.diagnose-report-preview {
  background: rgba(255,255,255,0.12);
  border-radius: 16rpx;
  padding: 24rpx 28rpx;
  margin-bottom: 28rpx;
}

.diagnose-report-title {
  font-size: 22rpx;
  color: rgba(255,255,255,0.65);
  display: block;
  margin-bottom: 14rpx;
  letter-spacing: 1rpx;
}

.diagnose-report-item {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  margin-bottom: 10rpx;
}

.diagnose-report-dot {
  color: rgba(255,255,255,0.6);
  font-size: 28rpx;
  margin-right: 10rpx;
  line-height: 1.5;
}

.diagnose-report-text {
  font-size: 26rpx;
  color: rgba(255,255,255,0.9);
  line-height: 1.5;
  flex: 1;
}

.diagnose-stats-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-around;
  margin-bottom: 32rpx;
}

.diagnose-stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.diagnose-stat-num {
  font-size: 32rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 4rpx;
}

.diagnose-stat-desc {
  font-size: 20rpx;
  color: rgba(255,255,255,0.7);
}

.diagnose-stat-divider {
  width: 1rpx;
  height: 48rpx;
  background: rgba(255,255,255,0.25);
}

.btn-diagnose-hero {
  background: #fff;
  color: #1A6EFF;
  border-radius: 50rpx;
  padding: 26rpx 0;
  font-size: 32rpx;
  font-weight: 700;
  border: none;
  width: 100%;
  text-align: center;
}
.btn-diagnose-hero::after { border: none; }

.kadian-carousel {
  margin: 0 32rpx 24rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 36rpx 32rpx 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}

.kadian-carousel-label {
  font-size: 22rpx;
  color: #aaa;
  display: block;
  margin-bottom: 24rpx;
  letter-spacing: 1rpx;
}

.kadian-card-wrap {
  min-height: 120rpx;
  display: flex;
  align-items: center;
  margin-bottom: 28rpx;
}

.kadian-card {
  width: 100%;
  animation: kadian-fade 0.5s ease;
}

@keyframes kadian-fade {
  from { opacity: 0; transform: translateY(16rpx); }
  to   { opacity: 1; transform: translateY(0); }
}

.kadian-card-name {
  font-size: 40rpx;
  font-weight: 700;
  color: #1A6EFF;
  display: block;
  margin-bottom: 12rpx;
}

.kadian-card-symptom {
  font-size: 28rpx;
  color: #555;
  line-height: 1.6;
  display: block;
}

.kadian-dots {
  display: flex;
  flex-direction: row;
  gap: 10rpx;
}

.kadian-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: #e0e0e0;
  transition: all 0.3s;
}

.kadian-dot-active {
  width: 28rpx;
  border-radius: 5rpx;
  background: #1A6EFF;
}

.course-grid-home {
  display: flex;
  flex-wrap: wrap;
  padding: 0 24rpx;
}

.course-card-home {
  width: 44%;
  margin: 0 1.5% 16rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx 20rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.05);
}

.course-num-home {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: #f0f0f0;
  font-size: 22rpx;
  font-weight: 700;
  color: #999;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-right: 12rpx;
}

.course-card-name-home {
  font-size: 26rpx;
  font-weight: 600;
  color: #1a1a1a;
  flex: 1;
}

.course-card-arrow {
  font-size: 34rpx;
  color: #cccccc;
  flex-shrink: 0;
}

.profile-example-home {
  margin: 0 32rpx 20rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}

.example-header-home {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.example-avatar-home {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #1A6EFF;
  color: #fff;
  font-size: 28rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.example-base-home { flex: 1; }

.example-name-home {
  font-size: 28rpx;
  font-weight: 700;
  color: #1a1a1a;
}

.example-meta-home {
  font-size: 22rpx;
  color: #999;
  display: block;
  margin-top: 4rpx;
}

.example-score-home {
  font-size: 36rpx;
  font-weight: 700;
  color: #52c41a;
  flex-shrink: 0;
}

.example-comment-home {
  font-size: 24rpx;
  color: #555;
  line-height: 1.7;
}

/* ===== 复习提醒置顶 Banner ===== */
.review-banner {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  margin: 16rpx 24rpx 4rpx;
  border-radius: 20rpx;
  padding: 22rpx 20rpx 22rpx 24rpx;
  gap: 12rpx;
}

.review-banner-interrupted {
  background: linear-gradient(135deg, #fff7e6, #fff1cc);
  border: 1.5rpx solid #ffd591;
}

.review-banner-cycle_end {
  background: linear-gradient(135deg, #f0f7ff, #dbeeff);
  border: 1.5rpx solid #91caff;
}

.review-banner-all_complete {
  background: linear-gradient(135deg, #f6ffed, #d9f7be);
  border: 1.5rpx solid #b7eb8f;
}

.review-banner-left {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 14rpx;
  flex: 1;
  min-width: 0;
}

.review-banner-icon {
  font-size: 44rpx;
  flex-shrink: 0;
}

.review-banner-text-wrap {
  flex: 1;
  min-width: 0;
}

.review-banner-label {
  font-size: 26rpx;
  font-weight: 700;
  color: #1a1a1a;
  display: block;
  margin-bottom: 4rpx;
}

.review-banner-desc {
  font-size: 22rpx;
  color: #666;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.review-banner-actions {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 12rpx;
  flex-shrink: 0;
}

.review-banner-btn {
  background: #fa8c16;
  border-radius: 30rpx;
  padding: 10rpx 24rpx;
}

.review-banner-cycle_end .review-banner-btn {
  background: #1A6EFF;
}

.review-banner-all_complete .review-banner-btn {
  background: #52c41a;
}

.review-banner-btn-text {
  font-size: 24rpx;
  font-weight: 700;
  color: #fff;
}

.review-banner-close {
  width: 44rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.review-banner-close-icon {
  font-size: 36rpx;
  color: #bbb;
  font-weight: 300;
  line-height: 1;
}

/* ===== 已购课视图样式 ===== */
.pending-title {
  color: #ff4d4f;
  font-size: 32rpx;
  font-weight: 700;
}

.resolved-title {
  color: #52c41a;
  font-size: 32rpx;
  font-weight: 700;
}

.home-page {
  min-height: 100vh;
  background: #f5f6fa;
}

/* 简洁个人信息条（无复习提醒时显示）*/
.profile-simple-bar {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 24rpx 28rpx 20rpx;
  padding-top: calc(24rpx + env(safe-area-inset-top));
  background: #ffffff;
  gap: 18rpx;
}

.profile-simple-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #1A6EFF, #4a9eff);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.profile-simple-avatar-text {
  color: #fff;
  font-size: 30rpx;
  font-weight: 700;
}

.profile-simple-info {
  flex: 1;
  min-width: 0;
}

.profile-simple-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #1a1a1a;
  display: block;
  margin-bottom: 4rpx;
}

.profile-simple-meta {
  font-size: 22rpx;
  color: #999;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.diagnosis-grid {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
}

.diagnosis-item {
  width: 50%;
  padding: 16rpx 0;
  display: flex;
  flex-direction: column;
}

.diagnosis-label {
  font-size: 24rpx;
  color: #999999;
  margin-bottom: 8rpx;
}

.diagnosis-value {
  font-size: 36rpx;
  font-weight: 700;
  color: #333333;
}

.diagnosis-value.small {
  font-size: 24rpx;
}

.diagnosis-value.warn {
  color: #ff4d4f;
}

.diagnosis-value.primary {
  color: #1A6EFF;
}

.module-section {
  margin: 16rpx 24rpx;
}

.module-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  margin-bottom: 16rpx;
}

.module-tag {
  background: #1A6EFF;
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 600;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  margin-right: 16rpx;
}

.module-tag-orange {
  background: #fa8c16;
}

.module-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
}

.point-list {
  background: #ffffff;
  border-radius: 16rpx;
  overflow: hidden;
}

.point-card {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 24rpx;
  border-bottom: 1rpx solid #f5f6fa;
}

.point-card:last-child {
  border-bottom: none;
}

.point-left {
  flex: 1;
  margin-right: 24rpx;
}

.point-name {
  font-size: 28rpx;
  color: #333333;
  font-weight: 500;
  display: block;
  margin-bottom: 12rpx;
}

.progress-bar-wrap {
  height: 8rpx;
  background: #f0f0f0;
  border-radius: 4rpx;
  overflow: hidden;
}

.progress-bar-inner {
  height: 100%;
  background: linear-gradient(90deg, #1A6EFF, #4a9eff);
  border-radius: 4rpx;
}

.point-right {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 12rpx;
}

.point-arrow {
  font-size: 36rpx;
  color: #cccccc;
}

/* ===== 学生档案卡（已购课视图）===== */
.profile-card {
  margin-top: 8rpx;
}

.profile-card-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  margin-bottom: 24rpx;
}

.profile-card-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #1A6EFF, #4a9eff);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-right: 20rpx;
}

.profile-card-avatar-text {
  font-size: 32rpx;
  font-weight: 700;
  color: #fff;
}

.profile-card-identity {
  flex: 1;
}

.profile-card-name-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  margin-bottom: 8rpx;
}

.profile-card-name {
  font-size: 32rpx;
  font-weight: 700;
  color: #1a1a1a;
}

.profile-card-meta {
  font-size: 24rpx;
  color: #999;
}

.profile-card-diagnose-btn {
  display: flex;
  flex-direction: row;
  align-items: center;
  background: rgba(26,110,255,0.08);
  border-radius: 20rpx;
  padding: 10rpx 18rpx;
  flex-shrink: 0;
}

.profile-card-diagnose-text {
  font-size: 24rpx;
  color: #1A6EFF;
  font-weight: 600;
}

.profile-card-diagnose-arrow {
  font-size: 28rpx;
  color: #1A6EFF;
  margin-left: 4rpx;
}

.profile-card-divider {
  height: 1rpx;
  background: #f0f0f0;
  margin-bottom: 24rpx;
}

.profile-card-stats {
  display: flex;
  flex-direction: row;
  align-items: stretch;
  margin-bottom: 24rpx;
}

.profile-stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.profile-stat-divider {
  width: 1rpx;
  background: #f0f0f0;
  margin: 0 4rpx;
}

.profile-stat-val {
  font-size: 36rpx;
  font-weight: 700;
  color: #1a1a1a;
  margin-bottom: 8rpx;
  line-height: 1.2;
}

.profile-stat-val-sm {
  font-size: 24rpx;
  font-weight: 600;
  line-height: 1.4;
  text-align: center;
}

.profile-stat-val-warn {
  color: #ff4d4f;
}

.profile-stat-val-primary {
  color: #1A6EFF;
}

.profile-stat-label {
  font-size: 22rpx;
  color: #999;
}

.profile-card-footer {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
}

.profile-footer-item {
  font-size: 24rpx;
  color: #888;
}

/* ===== 学习日历（苹果风格）===== */
.cal-card {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.05);
}

.cal-nav {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 24rpx 8rpx;
}

.cal-nav-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1a1a1a;
}

.cal-nav-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.cal-nav-arrow {
  font-size: 44rpx;
  color: #aaa;
  line-height: 1;
}

.cal-view-toggle {
  background: #f0f5ff;
  border-radius: 20rpx;
  padding: 8rpx 24rpx;
}

.cal-view-toggle-text {
  font-size: 24rpx;
  color: #1A6EFF;
  font-weight: 600;
}

/* 星期标题行 */
.cal-weekday-row {
  display: flex;
  flex-direction: row;
  border-bottom: 1rpx solid #e8e8e8;
  padding-bottom: 10rpx;
}

.cal-weekday-label {
  flex: 1;
  text-align: center;
  font-size: 20rpx;
  color: #999;
}

/* 月视图主体 */
.cal-month-body {
  border-top: 1rpx solid #e8e8e8;
}

/* 每周一行 */
.cal-week-row {
  display: flex;
  flex-direction: row;
}

.cal-events-row {
  padding-bottom: 8rpx;
}

/* 每天一列 */
.cal-day-col {
  flex: 1;
  border-right: 1rpx solid #e8e8e8;
  padding: 8rpx 4rpx 10rpx;
  min-width: 0;
}

.cal-day-col:last-child {
  border-right: none;
}

/* 日期数字区 */
.cal-day-num-wrap {
  display: flex;
  justify-content: center;
  margin-bottom: 6rpx;
}

.cal-day-circle {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.cal-today-circle {
  background: #1A6EFF;
}

.cal-selected-circle {
  background: #dce8ff;
}

.cal-day-num {
  font-size: 24rpx;
  font-weight: 500;
  color: #1a1a1a;
  text-align: center;
}

.cal-day-num-today {
  color: #fff;
  font-weight: 700;
}

.cal-day-other {
  color: #c8c8c8;
}

/* 事件块 */
.cal-event-block {
  border-radius: 6rpx;
  padding: 4rpx 6rpx;
  margin: 2rpx 2rpx 0;
}

.cal-event-class { background: rgba(26,110,255,0.13); }
.cal-event-video { background: rgba(123,97,255,0.13); }
.cal-event-drill { background: rgba(250,140,22,0.13); }
.cal-event-exam  { background: rgba(255,77,79,0.13);  }
.cal-event-hw    { background: rgba(82,196,26,0.13);  }

/* 跨天事件条 */
.cal-week-container {
  border-bottom: 1rpx solid #e8e8e8;
}
.cal-week-container:last-child { border-bottom: none; }

.cal-span-layer {
  padding: 4rpx 0 2rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.cal-span-row-item {
  display: flex;
  flex-direction: row;
  height: 32rpx;
  align-items: center;
  margin-bottom: 2rpx;
}

.cal-span-bar {
  height: 28rpx;
  border-radius: 6rpx;
  display: flex;
  align-items: center;
  padding: 0 8rpx;
  overflow: hidden;
}

.cal-span-label {
  font-size: 18rpx;
  font-weight: 600;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.cal-event-hw .cal-span-label    { color: #389e0d; }
.cal-event-class .cal-span-label { color: #1A6EFF; }
.cal-event-video .cal-span-label { color: #7B61FF; }
.cal-event-drill .cal-span-label { color: #d46b08; }
.cal-event-exam  .cal-span-label { color: #cf1322; }

.cal-event-name {
  display: block;
  font-size: 18rpx;
  font-weight: 600;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}


.cal-event-class .cal-event-name { color: #1A6EFF; }
.cal-event-video .cal-event-name { color: #7B61FF; }
.cal-event-drill .cal-event-name { color: #d46b08; }
.cal-event-exam  .cal-event-name { color: #cf1322; }
.cal-event-hw    .cal-event-name { color: #389e0d; }

/* 今日日程 */
.today-card {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.05);
}

.today-empty {
  padding: 36rpx 0;
  text-align: center;
}

.today-empty-text {
  font-size: 26rpx;
  color: #ccc;
}

.today-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 20rpx 24rpx;
  border-bottom: 1rpx solid #f5f6fa;
  gap: 16rpx;
}

.today-item:last-child { border-bottom: none; }

.today-item-bar {
  width: 6rpx;
  height: 48rpx;
  border-radius: 3rpx;
  flex-shrink: 0;
}

.today-item-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.today-item-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #1a1a1a;
}

.today-item-meta {
  font-size: 22rpx;
  color: #aaa;
}

.today-item-arrow {
  flex-shrink: 0;
}

.today-arrow-text {
  font-size: 36rpx;
  color: #ccc;
}

.profile-footer-dot {
  font-size: 24rpx;
  color: #ccc;
  margin: 0 12rpx;
}

.profile-footer-countdown {
  font-size: 24rpx;
  color: #1A6EFF;
  font-weight: 600;
}

/* ===== 置顶课程提醒 Banner ===== */
.top-reminder {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  margin: 16rpx 24rpx 0;
  border-radius: 20rpx;
  padding: 24rpx 24rpx 24rpx 20rpx;
  gap: 12rpx;
}

.top-reminder-class {
  background: linear-gradient(135deg, #e8f0ff, #d0e2ff);
  border: 1.5rpx solid rgba(26,110,255,0.25);
}

.top-reminder-exam {
  background: linear-gradient(135deg, #fff1f0, #ffe4e4);
  border: 1.5rpx solid rgba(255,77,79,0.25);
}

.top-reminder-left {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 16rpx;
  flex: 1;
  min-width: 0;
}

.top-reminder-icon {
  font-size: 48rpx;
  flex-shrink: 0;
  line-height: 1;
}

.top-reminder-text-wrap {
  flex: 1;
  min-width: 0;
}

.top-reminder-label {
  font-size: 28rpx;
  font-weight: 700;
  color: #1a1a1a;
  display: block;
  margin-bottom: 4rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.top-reminder-desc {
  font-size: 22rpx;
  color: #666;
  display: block;
}

.top-reminder-class .top-reminder-desc { color: #1A6EFF; }
.top-reminder-exam  .top-reminder-desc { color: #ff4d4f; }

.top-reminder-btn {
  background: #1A6EFF;
  border-radius: 30rpx;
  padding: 12rpx 28rpx;
  flex-shrink: 0;
}

.top-reminder-exam .top-reminder-btn {
  background: #ff4d4f;
}

.top-reminder-btn-text {
  font-size: 24rpx;
  font-weight: 700;
  color: #fff;
}

.exam-cd-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 10rpx;
  margin-top: 4rpx;
}

.top-reminder-cd {
  font-size: 26rpx;
  font-weight: 700;
  color: #ff4d4f;
  font-family: 'Courier New', monospace;
  letter-spacing: 1rpx;
}

.top-reminder-cd-edit {
  font-size: 20rpx;
  color: #aaa;
  border: 1rpx solid #ddd;
  border-radius: 8rpx;
  padding: 2rpx 10rpx;
}

/* ===== 通用 Modal ===== */
.modal-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.45);
  z-index: 999;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-box {
  background: #fff;
  border-radius: 24rpx;
  padding: 44rpx 40rpx 32rpx;
  width: 580rpx;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1a1a1a;
  display: block;
  margin-bottom: 36rpx;
  text-align: center;
}

.modal-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.modal-row:last-of-type {
  border-bottom: none;
  margin-bottom: 8rpx;
}

.modal-label {
  font-size: 28rpx;
  color: #555;
}

.modal-picker-val {
  font-size: 28rpx;
  font-weight: 600;
  color: #1A6EFF;
}

.modal-input {
  font-size: 28rpx;
  font-weight: 600;
  color: #1A6EFF;
  text-align: right;
  width: 200rpx;
  border: none;
  background: transparent;
}

.modal-unit {
  font-size: 26rpx;
  color: #888;
  margin-left: 8rpx;
}

.modal-btns {
  display: flex;
  flex-direction: row;
  gap: 20rpx;
  margin-top: 36rpx;
}

.modal-btn {
  flex: 1;
  border-radius: 48rpx;
  padding: 22rpx 0;
  text-align: center;
  font-size: 28rpx;
  font-weight: 600;
}

.modal-btn-cancel {
  background: #f5f6fa;
  color: #888;
}

.modal-btn-confirm {
  background: #1A6EFF;
  color: #fff;
}

/* ===== 铃铛通知 ===== */
.bell-wrap {
  position: relative;
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-right: 12rpx;
}

.bell-icon {
  font-size: 40rpx;
  line-height: 1;
}

.bell-badge {
  position: absolute;
  top: 2rpx;
  right: 2rpx;
  min-width: 32rpx;
  height: 32rpx;
  background: #ff4d4f;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 6rpx;
}

.bell-badge-text {
  font-size: 18rpx;
  font-weight: 700;
  color: #fff;
  line-height: 1;
}
