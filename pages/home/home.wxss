  line-height: 1;
  font-weight: 700;
  white-space: nowrap;
}

.path-node-subpath-status-text-completed {
  color: #4c8b52;
}

.path-node-subpath-status-text-active {
  color: #3d7cff;
}

.path-node-subpath-status-text-locked {
  color: #98a1ae;
}

.path-node-detail-final-card .path-node-subpath-dot-active {
  border-color: #ea4c60;
  box-shadow: 0 0 0 8rpx rgba(234, 76, 96, 0.12);
}

.path-node-detail-final-card .path-node-subpath-line-active {
