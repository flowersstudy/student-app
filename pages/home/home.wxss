page {
  background: linear-gradient(180deg, #f5f8fc 0%, #f2f5fa 100%);
}

.path-page {
  min-height: 100vh;
  padding: 24rpx 20rpx 0;
  box-sizing: border-box;
}

.exam-info-bar {
  display: flex;
  overflow: hidden;
  background: #ffffff;
  border: 2rpx solid #e5ebf2;
  border-radius: 24rpx;
  box-shadow: 0 12rpx 28rpx rgba(29, 45, 74, 0.06);
}

.exam-info-item {
  flex: 1;
  padding: 18rpx 10rpx;
  text-align: center;
}

.exam-info-item + .exam-info-item {
  border-left: 1rpx solid #edf1f5;
}

.exam-info-label {
  display: block;
  font-size: 22rpx;
  color: #8995a7;
}

.exam-info-value {
  display: block;
  margin-top: 10rpx;
  font-size: 30rpx;
  line-height: 1.2;
  color: #1d2433;
  font-weight: 700;
}

.exam-info-value-blue {
  color: #3d7cff;
}

.path-card {
  margin-top: 20rpx;
  overflow: hidden;
  background: #ffffff;
  border: 2rpx solid #e6ebf2;
  border-radius: 32rpx;
  box-shadow: 0 18rpx 40rpx rgba(29, 45, 74, 0.08);
}

.path-header {
  padding: 24rpx 22rpx 18rpx;
  background: linear-gradient(180deg, #fbfdff 0%, #f5f8fc 100%);
  border-bottom: 1rpx solid #edf1f5;
}

.path-top-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.path-current-task {
  flex: 1;
  min-width: 0;
  padding-right: 16rpx;
}

.path-current-task-text {
  display: block;
  margin-top: 8rpx;
  font-size: 23rpx;
  line-height: 1.5;
  color: #6f7d93;
}

.path-top-tag {
  min-height: 58rpx;
  padding: 0 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #edf4ff;
  border: 1rpx solid #d7e5ff;
  border-radius: 999rpx;
}

.path-top-tag-text {
  font-size: 24rpx;
  color: #3d7cff;
  font-weight: 700;
}

.path-progress {
  margin-top: 18rpx;
}

.path-progress-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.path-progress-label {
  font-size: 22rpx;
  color: #8b97aa;
}

.path-progress-value {
  font-size: 22rpx;
  color: #3d7cff;
  font-weight: 700;
}

.path-progress-track {
  margin-top: 10rpx;
  height: 12rpx;
  border-radius: 999rpx;
  background: #eaf0f7;
  overflow: hidden;
}

.path-progress-fill {
  height: 100%;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #84b4ff 0%, #3d7cff 100%);
  box-shadow: 0 0 12rpx rgba(61, 124, 255, 0.18);
}

.path-track-surface {
  background: linear-gradient(180deg, #ffffff 0%, #fbfcfe 100%);
}

.path-track {
  position: relative;
  min-height: 1160rpx;
  padding: 34rpx 0 72rpx;
  background:
    radial-gradient(circle at 90% 22%, rgba(61, 124, 255, 0.05) 0, rgba(61, 124, 255, 0.05) 64rpx, transparent 66rpx),
    radial-gradient(circle at 12% 76%, rgba(95, 141, 86, 0.04) 0, rgba(95, 141, 86, 0.04) 54rpx, transparent 56rpx),
    #ffffff;
}

.branch-area {
  position: absolute;
  left: 24rpx;
  top: 456rpx;
  width: 210rpx;
  height: 244rpx;
  z-index: 3;
  transition: top 0.24s ease, left 0.24s ease, right 0.24s ease;
}

.branch-area-expanded {
  left: 24rpx;
  top: 416rpx;
  width: 204rpx;
  height: 236rpx;
}

.branch-node {
  position: absolute;
  left: 34rpx;
  top: 108rpx;
  width: 122rpx;
  height: 142rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: transform 0.24s ease;
}

.branch-area-expanded .branch-node {
  transform: translateY(-6rpx) scale(0.96);
}

.branch-shadow {
  position: absolute;
  left: 50%;
  bottom: 0;
  width: 86rpx;
  height: 20rpx;
  margin-left: -43rpx;
  border-radius: 50%;
  background: rgba(74, 113, 173, 0.14);
  filter: blur(4rpx);
}

.branch-glow {
  position: absolute;
  left: 50%;
  top: 18rpx;
  width: 128rpx;
  height: 128rpx;
  margin-left: -64rpx;
  border-radius: 50%;
  background: radial-gradient(circle at 50% 50%, rgba(113, 197, 255, 0.22) 0%, rgba(46, 125, 246, 0.1) 45%, rgba(46, 125, 246, 0) 76%);
  filter: blur(3rpx);
}

.branch-spirit {
  position: relative;
  width: 108rpx;
  height: 122rpx;
  border-radius: 52% 48% 48% 46% / 38% 38% 62% 62%;
  background: linear-gradient(180deg, rgba(165, 223, 255, 0.96) 0%, rgba(81, 165, 255, 0.94) 46%, rgba(46, 125, 246, 0.96) 100%);
  box-shadow:
    0 16rpx 28rpx rgba(46, 125, 246, 0.18),
    inset 0 0 0 2rpx rgba(255, 255, 255, 0.24);
  overflow: hidden;
  transform: translateY(4rpx) rotate(-3deg);
}

.branch-spirit-gloss {
  position: absolute;
  top: 14rpx;
  left: 16rpx;
  width: 42rpx;
  height: 22rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.3);
  transform: rotate(-20deg);
}

.branch-spirit-belly {
  position: absolute;
  left: 18rpx;
  right: 18rpx;
  bottom: 16rpx;
  height: 58rpx;
  border-radius: 50%;
  background: linear-gradient(180deg, rgba(230, 248, 255, 0.34) 0%, rgba(255, 255, 255, 0.16) 100%);
}

.branch-eye {
  position: absolute;
  top: 52rpx;
  width: 14rpx;
  height: 18rpx;
  border-radius: 999rpx;
  background: rgba(29, 36, 51, 0.78);
  box-sizing: border-box;
  box-shadow: inset 0 -2rpx 0 rgba(255, 255, 255, 0.14);
}

.branch-eye-left {
  left: 30rpx;
}

.branch-eye-right {
  right: 30rpx;
}

.branch-bubble {
  position: absolute;
  left: 0;
  top: -44rpx;
  width: 164rpx;
  min-height: 78rpx;
  padding: 12rpx 16rpx;
  box-sizing: border-box;
  background: linear-gradient(180deg, #ffffff 0%, #f4fbff 100%);
  border: 2rpx solid #d8eaf8;
  border-radius: 24rpx;
  box-shadow: 0 10rpx 22rpx rgba(29, 45, 74, 0.06);
  z-index: 4;
  transition: top 0.24s ease, width 0.24s ease;
}

.branch-area-expanded .branch-bubble {
  top: -58rpx;
  width: 156rpx;
}

.branch-bubble-tail {
  position: absolute;
  left: 64rpx;
  bottom: -10rpx;
  width: 14rpx;
  height: 14rpx;
  background: #f8fdff;
  border-right: 2rpx solid #d8eaf8;
  border-bottom: 2rpx solid #d8eaf8;
  transform: rotate(45deg);
  box-sizing: border-box;
}

.branch-bubble-title {
  display: block;
  font-size: 24rpx;
  color: #1d2433;
  font-weight: 800;
  text-align: left;
}

.branch-bubble-subtitle {
  display: block;
  margin-top: 4rpx;
  font-size: 18rpx;
  color: #6b7b93;
  text-align: left;
}

.branch-bubble-slogan {
  display: block;
  margin-top: 6rpx;
  font-size: 17rpx;
  line-height: 1.45;
  color: #7b8aa0;
  text-align: left;
}

.path-node-wrap {
  position: relative;
  display: flex;
  width: 100%;
}

.path-node-wrap-diagnose {
  padding-top: 24rpx;
  justify-content: flex-start;
  padding-left: 126rpx;
}

.path-node-wrap-final-card {
  padding-top: 132rpx;
  justify-content: flex-end;
  padding-right: 64rpx;
}

.path-node-wrap-yellow-card {
  padding-top: 136rpx;
  justify-content: flex-start;
  padding-left: 128rpx;
}

.path-node-wrap-blue-card {
  padding-top: 138rpx;
  justify-content: flex-end;
  padding-right: 102rpx;
}

.path-node-group {
  position: relative;
  z-index: 2;
  display: flex;
  flex-direction: column;
}

.path-curve {
  position: absolute;
  top: -18rpx;
  border-color: #dbe3ef;
  box-sizing: border-box;
  opacity: 0.95;
}

.path-curve-final-card {
  left: 232rpx;
  width: 214rpx;
  height: 136rpx;
  border-left-width: 4rpx;
  border-left-style: solid;
  border-bottom-width: 4rpx;
  border-bottom-style: solid;
  border-bottom-left-radius: 144rpx;
}

.path-curve-yellow-card {
  left: 154rpx;
  width: 256rpx;
  height: 146rpx;
  border-right-width: 4rpx;
  border-right-style: solid;
  border-bottom-width: 4rpx;
  border-bottom-style: solid;
  border-bottom-right-radius: 152rpx;
}

.path-curve-blue-card {
  left: 210rpx;
  width: 220rpx;
  height: 152rpx;
  border-left-width: 4rpx;
  border-left-style: solid;
  border-bottom-width: 4rpx;
  border-bottom-style: solid;
  border-bottom-left-radius: 156rpx;
}

.path-node-highlight {
  position: absolute;
  top: 112rpx;
  right: 46rpx;
  width: 356rpx;
  height: 150rpx;
  border-radius: 999rpx;
  background: radial-gradient(circle at 50% 50%, rgba(61, 124, 255, 0.11) 0%, rgba(61, 124, 255, 0.05) 62%, rgba(61, 124, 255, 0) 100%);
}

.path-node {
  position: relative;
  z-index: 2;
  min-width: 246rpx;
  min-height: 116rpx;
  padding: 0 28rpx;
  display: flex;
  align-items: center;
  justify-content: flex-start;
  box-sizing: border-box;
  background: #ffffff;
  border-radius: 999rpx;
  border: 2rpx solid #e4eaf2;
  box-shadow: 0 12rpx 24rpx rgba(29, 45, 74, 0.06);
}

.path-node-expand {
  margin-left: 18rpx;
  font-size: 22rpx;
  color: #7f8ba0;
  flex-shrink: 0;
}

.path-node-done {
  border-color: #d8ead9;
  background: linear-gradient(180deg, #ffffff 0%, #fbfffb 100%);
}

.path-node-current {
  min-width: 308rpx;
  min-height: 126rpx;
  border: 4rpx solid #4d8dff;
  background: linear-gradient(180deg, #f6faff 0%, #ffffff 100%);
  box-shadow: 0 18rpx 34rpx rgba(77, 141, 255, 0.14);
}

.path-node-locked {
  border-color: #e6eaef;
  background: linear-gradient(180deg, #fafbfc 0%, #f4f6f8 100%);
}

.path-node-wrap-yellow-card .path-node {
  min-width: 264rpx;
}

.path-node-wrap-blue-card .path-node {
  min-width: 248rpx;
}

.path-node-icon {
  width: 56rpx;
  height: 56rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
}

.path-node-icon-done {
  background: #65b96c;
}

.path-node-icon-current {
  width: 64rpx;
  height: 64rpx;
  background: #4d8dff;
}

.path-node-icon-locked {
  background: #cfd6df;
}

.path-node-icon-text {
  font-size: 28rpx;
  color: #ffffff;
  font-weight: 800;
}

.path-node-text {
  margin-left: 14rpx;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
}

.path-node-title {
  font-size: 36rpx;
  line-height: 1.16;
  color: #1d2433;
  font-weight: 800;
}

.path-node-note {
  margin-top: 10rpx;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  line-height: 1.2;
}

.path-node-done .path-node-note {
  color: #4c8b52;
  background: #edf8ef;
}

.path-node-current .path-node-note {
  color: #3d7cff;
  background: #edf4ff;
}

.path-node-locked .path-node-title {
  color: #8f99a8;
}

.path-node-locked .path-node-note {
  color: #98a1ae;
  background: #eceff3;
}

.path-node-detail {
  position: relative;
  z-index: 2;
  margin-top: 14rpx;
}

.path-node-detail-final-card {
  margin-right: 34rpx;
}

.path-node-detail-yellow-card {
  margin-left: 28rpx;
}

.path-node-detail-blue-card {
  margin-right: 34rpx;
}

.path-node-detail-card {
  position: relative;
  min-width: 280rpx;
  padding: 8rpx 0 6rpx;
  background: transparent;
  border: none;
  box-shadow: none;
}

.path-node-detail-connector {
  position: absolute;
  top: -16rpx;
  left: 14rpx;
  width: 4rpx;
  height: 42rpx;
  border-radius: 999rpx;
  background: linear-gradient(180deg, #d9e4f2 0%, #d4e0f0 100%);
  transform-origin: top center;
}

.path-node-detail-open .path-node-detail-card {
  animation: detailGrowDown 0.24s ease forwards;
}

.path-node-detail-open .path-node-detail-connector {
  animation: detailTrackGrow 0.22s ease forwards;
}

.path-node-detail-close .path-node-detail-card {
  animation: detailShrinkUp 0.2s ease forwards;
}

.path-node-detail-close .path-node-detail-connector {
  animation: detailTrackShrink 0.18s ease forwards;
}

.path-node-subpath-section + .path-node-subpath-section {
  margin-top: 18rpx;
}

.path-node-subpath-item {
  position: relative;
  display: flex;
  align-items: center;
  margin-top: 18rpx;
  opacity: 0;
}

.path-node-detail-open .path-node-subpath-item,
.path-node-detail-open .path-node-detail-inline-action {
  animation: detailItemFadeIn 0.18s ease forwards;
}

.path-node-detail-close .path-node-subpath-item,
.path-node-detail-close .path-node-detail-inline-action {
  animation: detailItemFadeOut 0.14s ease forwards;
}

.path-node-subpath-rail {
  position: relative;
  width: 42rpx;
  flex-shrink: 0;
}

.path-node-subpath-dot {
  position: absolute;
  top: 6rpx;
  left: 2rpx;
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  background: #ffffff;
  border: 5rpx solid #7ea7ff;
  box-sizing: border-box;
  box-shadow: 0 0 0 8rpx rgba(126, 167, 255, 0.08);
}

.path-node-subpath-line {
  position: absolute;
  top: 30rpx;
  left: 13rpx;
  bottom: -28rpx;
  width: 4rpx;
  border-radius: 999rpx;
  background: #dbe3ef;
}

.path-node-subpath-card {
  min-width: 210rpx;
  max-width: 280rpx;
  min-height: 60rpx;
  padding: 14rpx 24rpx;
  border-radius: 999rpx;
  background: linear-gradient(180deg, #ffffff 0%, #fbfcfe 100%);
  border: 1rpx solid #e3eaf3;
  box-shadow: 0 8rpx 16rpx rgba(29, 45, 74, 0.04);
  box-sizing: border-box;
}

.path-node-subpath-text {
  font-size: 24rpx;
  line-height: 1.4;
  color: #50607a;
}

.path-node-detail-inline-action {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  margin: 22rpx 0 0 40rpx;
  min-width: 84rpx;
  height: 42rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: #f4f7fb;
  color: #95a1b2;
  font-size: 20rpx;
  opacity: 0;
}

.bottom-shell-section {
  padding: 28rpx 0 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.bottom-shell-row {
  display: flex;
  align-items: flex-end;
  justify-content: center;
  gap: 56rpx;
}

.path-shell {
  position: relative;
  width: 156rpx;
  padding-top: 18rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.path-shell-whelk {
  width: 168rpx;
}

.path-shell-top {
  width: 84rpx;
  height: 34rpx;
  border-radius: 999rpx 999rpx 24rpx 24rpx;
  background: linear-gradient(180deg, #fff6d8 0%, #ffe7a6 100%);
  border: 2rpx solid #f3d38b;
  border-bottom: none;
  box-shadow: 0 4rpx 10rpx rgba(230, 184, 74, 0.12);
}

.path-shell-top-whelk {
  width: 78rpx;
  background: linear-gradient(180deg, #ffe9db 0%, #ffd0b3 100%);
  border-color: #efbb97;
  box-shadow: 0 4rpx 10rpx rgba(220, 132, 73, 0.12);
}

.path-shell-body {
  margin-top: -8rpx;
  width: 156rpx;
  height: 118rpx;
  border-radius: 56% 56% 46% 46% / 38% 38% 62% 62%;
  background: linear-gradient(180deg, #fffdf6 0%, #fff1ca 56%, #ffe3a4 100%);
  border: 2rpx solid #f1d18b;
  box-shadow: 0 16rpx 30rpx rgba(230, 184, 74, 0.16);
  display: flex;
  align-items: center;
  justify-content: center;
}

.path-shell-body-whelk {
  width: 168rpx;
  background: linear-gradient(180deg, #fff9f4 0%, #ffe6d2 56%, #ffc7a2 100%);
  border-color: #efbb97;
  box-shadow: 0 16rpx 30rpx rgba(220, 132, 73, 0.16);
}

.path-shell-icon {
  font-size: 34rpx;
  color: #c78922;
  font-weight: 700;
}

.path-shell-icon-whelk {
  color: #c86d33;
}

.path-shell-label {
  margin-top: 14rpx;
  font-size: 26rpx;
  color: #a86d12;
  font-weight: 700;
}

.path-shell-note {
  margin-top: 12rpx;
  font-size: 22rpx;
  color: #98a1ae;
}

@keyframes detailGrowDown {
  from {
    opacity: 0;
    transform: translateY(-10rpx) scaleY(0.94);
  }
  to {
    opacity: 1;
    transform: translateY(0) scaleY(1);
  }
}

@keyframes detailShrinkUp {
  from {
    opacity: 1;
    transform: translateY(0) scaleY(1);
  }
  to {
    opacity: 0;
    transform: translateY(-8rpx) scaleY(0.96);
  }
}

@keyframes detailTrackGrow {
  from {
    opacity: 0;
    transform: scaleY(0);
  }
  to {
    opacity: 1;
    transform: scaleY(1);
  }
}

@keyframes detailTrackShrink {
  from {
    opacity: 1;
    transform: scaleY(1);
  }
  to {
    opacity: 0;
    transform: scaleY(0);
  }
}

@keyframes detailItemFadeIn {
  from {
    opacity: 0;
    transform: translateY(-8rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes detailItemFadeOut {
  from {
    opacity: 1;
    transform: translateY(0);
  }
  to {
    opacity: 0;
    transform: translateY(-6rpx);
  }
}
