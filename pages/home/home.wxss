}

.path-node-detail-final-card .path-node-subpath-card-active {
  background: #fff7f8;
  border-color: #f5c3cb;
  box-shadow: 0 8rpx 16rpx rgba(29, 45, 74, 0.04);
}

.path-node-detail-final-card .path-node-subpath-text-active,
.path-node-detail-final-card .path-node-subpath-status-text-active {
  color: #c23b4c;
}

.path-node-detail-final-card .path-node-subpath-status-active {
  background: #ffe9ed;
}

.path-node-detail-yellow-card .path-node-subpath-dot-active {
  border-color: #e2aa14;
  box-shadow: 0 0 0 8rpx rgba(233, 184, 35, 0.12);
}

.path-node-detail-yellow-card .path-node-subpath-line-active {
  background: #f0dda0;
}

.path-node-detail-yellow-card .path-node-subpath-card-active {
  background: #fff9e9;
  border-color: #efd98a;
  box-shadow: 0 8rpx 16rpx rgba(29, 45, 74, 0.04);
}

.path-node-detail-yellow-card .path-node-subpath-text-active,
.path-node-detail-yellow-card .path-node-subpath-status-text-active {
  color: #9a7000;
}

.path-node-detail-yellow-card .path-node-subpath-status-active {
  background: #fff1c4;
}

.path-node-detail-blue-card .path-node-subpath-dot-active {
  border-color: #3d7cff;
  box-shadow: 0 0 0 8rpx rgba(61, 124, 255, 0.12);
}

.path-node-detail-blue-card .path-node-subpath-line-active {
  background: #d8e6ff;
}

.path-node-detail-blue-card .path-node-subpath-card-active {
  background: #f5f9ff;
  border-color: #cfe0ff;
  box-shadow: 0 8rpx 16rpx rgba(29, 45, 74, 0.04);
}

.path-node-detail-blue-card .path-node-subpath-text-active,
.path-node-detail-blue-card .path-node-subpath-status-text-active {
