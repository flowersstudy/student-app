page {
  background: #f5f7fb;
}

.path-page {
  min-height: 100vh;
  padding: 12rpx 14rpx calc(36rpx + 56px + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.path-bar-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.path-item {
  position: relative;
  display: flex;
  flex-direction: column;
  background: linear-gradient(180deg, var(--point-card-bg, #ffffff) 0%, #ffffff 88%);
  border: 2rpx solid var(--point-border, #e6ebf2);
  border-radius: 28rpx;
  box-shadow: 0 10rpx 24rpx var(--point-shadow, rgba(29, 45, 74, 0.06));
  overflow: hidden;
}

.path-item-tone-red,
.path-item-tone-blue,
.path-item-tone-yellow {
  border: 0;
  overflow: visible;
  background: transparent;
  box-shadow: none;
}

.path-item-expanded {
  box-shadow: 0 14rpx 32rpx var(--point-shadow-strong, rgba(29, 45, 74, 0.08));
}

.path-item-tone-red.path-item-expanded,
.path-item-tone-blue.path-item-expanded,
.path-item-tone-yellow.path-item-expanded {
  box-shadow: none;
}

.path-item-expanded .path-bar {
  border-bottom: 2rpx solid var(--point-divider, #eef2f6);
}

.path-item-tone-red .path-item-accent,
.path-item-tone-blue .path-item-accent,
.path-item-tone-yellow .path-item-accent {
  display: none;
}

.path-item-tone-red .path-bar,
.path-item-tone-red .path-bar-done,
.path-item-tone-red .path-bar-current,
.path-item-tone-red .path-bar-locked,
.path-item-tone-blue .path-bar,
.path-item-tone-blue .path-bar-done,
.path-item-tone-blue .path-bar-current,
.path-item-tone-blue .path-bar-locked,
.path-item-tone-yellow .path-bar,
.path-item-tone-yellow .path-bar-done,
.path-item-tone-yellow .path-bar-current,
.path-item-tone-yellow .path-bar-locked {
  background: var(--point-accent, #FE4A4C);
  position: relative;
  z-index: 2;
  border-radius: 28rpx;
  box-shadow: 0 12rpx 0 var(--point-deep, #CD3B3F), 0 24rpx 28rpx var(--point-shadow-strong, rgba(254, 74, 76, 0.18));
}

.path-item-tone-red.path-item-expanded .path-bar,
.path-item-tone-red.path-item-expanded .path-bar-done,
.path-item-tone-red.path-item-expanded .path-bar-current,
.path-item-tone-red.path-item-expanded .path-bar-locked,
.path-item-tone-blue.path-item-expanded .path-bar,
.path-item-tone-blue.path-item-expanded .path-bar-done,
.path-item-tone-blue.path-item-expanded .path-bar-current,
.path-item-tone-blue.path-item-expanded .path-bar-locked,
.path-item-tone-yellow.path-item-expanded .path-bar,
.path-item-tone-yellow.path-item-expanded .path-bar-done,
.path-item-tone-yellow.path-item-expanded .path-bar-current,
.path-item-tone-yellow.path-item-expanded .path-bar-locked {
  border-radius: 28rpx;
}

.path-item-tone-red .path-expand,
.path-item-tone-blue .path-expand,
.path-item-tone-yellow .path-expand {
  position: relative;
  z-index: 5;
  margin-top: 14rpx;
  border-radius: 28rpx;
  overflow: visible;
  border: 2rpx solid var(--point-border, #FFD5D4);
  box-shadow: 0 10rpx 24rpx var(--point-shadow, rgba(254, 74, 76, 0.14));
}

.path-item-tone-red.path-item-expanded .path-bar,
.path-item-tone-red.path-item-expanded .path-bar-done,
.path-item-tone-red.path-item-expanded .path-bar-current,
.path-item-tone-red.path-item-expanded .path-bar-locked,
.path-item-tone-blue.path-item-expanded .path-bar,
.path-item-tone-blue.path-item-expanded .path-bar-done,
.path-item-tone-blue.path-item-expanded .path-bar-current,
.path-item-tone-blue.path-item-expanded .path-bar-locked,
.path-item-tone-yellow.path-item-expanded .path-bar,
.path-item-tone-yellow.path-item-expanded .path-bar-done,
.path-item-tone-yellow.path-item-expanded .path-bar-current,
.path-item-tone-yellow.path-item-expanded .path-bar-locked {
  border-bottom: none;
}

.path-item-tone-red .path-bar-title,
.path-item-tone-red .path-bar-locked .path-bar-title,
.path-item-tone-red .path-bar-tag-text,
.path-item-tone-red .path-bar-tag-text-done,
.path-item-tone-red .path-bar-tag-text-current,
.path-item-tone-red .path-bar-tag-text-locked,
.path-item-tone-red .path-bar-arrow,
.path-item-tone-blue .path-bar-title,
.path-item-tone-blue .path-bar-locked .path-bar-title,
.path-item-tone-blue .path-bar-tag-text,
.path-item-tone-blue .path-bar-tag-text-done,
.path-item-tone-blue .path-bar-tag-text-current,
.path-item-tone-blue .path-bar-tag-text-locked,
.path-item-tone-blue .path-bar-arrow,
.path-item-tone-yellow .path-bar-title,
.path-item-tone-yellow .path-bar-locked .path-bar-title,
.path-item-tone-yellow .path-bar-tag-text,
.path-item-tone-yellow .path-bar-tag-text-done,
.path-item-tone-yellow .path-bar-tag-text-current,
.path-item-tone-yellow .path-bar-tag-text-locked,
.path-item-tone-yellow .path-bar-arrow {
  color: #FFFFFF;
  opacity: 1;
}

.path-item-tone-red .path-bar-progress,
.path-item-tone-blue .path-bar-progress,
.path-item-tone-yellow .path-bar-progress {
  color: rgba(255, 255, 255, 0.82);
}

.path-item-tone-red .path-bar-tag,
.path-item-tone-red .path-bar-tag-done,
.path-item-tone-red .path-bar-tag-current,
.path-item-tone-red .path-bar-tag-locked,
.path-item-tone-blue .path-bar-tag,
.path-item-tone-blue .path-bar-tag-done,
.path-item-tone-blue .path-bar-tag-current,
.path-item-tone-blue .path-bar-tag-locked,
.path-item-tone-yellow .path-bar-tag,
.path-item-tone-yellow .path-bar-tag-done,
.path-item-tone-yellow .path-bar-tag-current,
.path-item-tone-yellow .path-bar-tag-locked {
  background: rgba(255, 255, 255, 0.14);
  border: 2rpx solid rgba(255, 255, 255, 0.18);
}

.path-item-accent {
  width: 100%;
  height: 10rpx;
  background: var(--point-accent, #2563eb);
}

.path-bar {
  min-height: 124rpx;
  padding: 12rpx 20rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-sizing: border-box;
  background: transparent;
  border: none;
  border-radius: 0;
  box-shadow: none;
}

.path-bar-done {
  background: linear-gradient(180deg, var(--point-card-bg, #ffffff) 0%, #fbfffc 100%);
}

.path-bar-current {
  background: linear-gradient(180deg, var(--point-expand-bg, #f8fbff) 0%, #ffffff 100%);
}

.path-bar-locked {
  background: linear-gradient(180deg, var(--point-card-bg, #ffffff) 0%, #f7f8fa 100%);
}

.path-bar-main {
  flex: 1;
  min-width: 0;
  padding-right: 12rpx;
}

.path-bar-title {
  display: block;
  font-size: 32rpx;
  line-height: 1.3;
  color: var(--point-accent, #1d2433);
  font-weight: 700;
  overflow: hidden;
  white-space: normal;
  text-overflow: initial;
}

.path-bar-progress {
  display: block;
  margin-top: 6rpx;
  font-size: 24rpx;
  line-height: 1.45;
  color: #6f7b8f;
  font-weight: 600;
  overflow: hidden;
  white-space: normal;
  text-overflow: initial;
}

.path-bar-locked .path-bar-title {
  color: var(--point-accent, #8a95a6);
  opacity: 0.72;
}

.path-bar-side {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  align-self: stretch;
  width: 149rpx;
  gap: 22rpx;
}

.path-bar-divider {
  width: 2rpx;
  height: 89rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.22);
  flex-shrink: 0;
}

.path-bar-action-glyph {
  width: 77rpx;
  height: 77rpx;
  flex-shrink: 0;
  display: block;
  opacity: 1;
}

.path-bar-tag {
  height: 38rpx;
  padding: 0 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  background: #f1f5f9;
}

.path-bar-tag-done {
  background: #edf8ef;
}

.path-bar-tag-current {
  background: #edf4ff;
}

.path-bar-tag-locked {
  background: #eceff3;
}

.path-bar-tag-text {
  font-size: 20rpx;
  line-height: 1;
  color: #697589;
  font-weight: 600;
  white-space: nowrap;
}

.path-bar-tag-text-done {
  color: #4c8b52;
}

.path-bar-tag-text-current {
  color: #3d7cff;
}

.path-bar-tag-text-locked {
  color: #98a1ae;
}

.path-expand {
  padding: 18rpx 18rpx 24rpx;
  background: linear-gradient(180deg, var(--point-expand-bg, #ffffff) 0%, #fbfcfe 100%);
  border-top: none;
}

.path-expand-head {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 18rpx;
  margin-bottom: 8rpx;
}

.path-expand-title {
  flex: 1;
  min-width: 0;
  font-size: 24rpx;
  line-height: 1.45;
  color: #1d2433;
  font-weight: 700;
}

.path-expand-summary {
  flex-shrink: 0;
  font-size: 20rpx;
  color: #8a95a6;
  font-weight: 500;
}

.path-expand-body {
  position: relative;
}

.duo-map {
  position: relative;
  min-height: 200rpx;
  z-index: 3;
}

.duo-step {
  position: absolute;
  z-index: 2;
  transform: translateX(-50%);
}

.duo-step-tip-active {
  z-index: 999;
}

.duo-node-wrap {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  z-index: 2;
  padding: 18rpx 0;
}

.duo-node {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: linear-gradient(180deg, #ffffff 0%, #f2f5f9 100%);
  border: 5rpx solid #dfe6ee;
  box-shadow: 0 8rpx 18rpx rgba(29, 45, 74, 0.08);
  box-sizing: border-box;
  z-index: 2;
  transition: transform 0.18s ease, opacity 0.18s ease;
}

.duo-node-has-icon {
  background: transparent;
  border: 0;
  border-radius: 0;
  box-shadow: none;
  width: 78px !important;
  height: 78px !important;
  transform: none;
  transform-origin: center center;
}

.duo-node-done {
  opacity: 1;
  background: linear-gradient(180deg, #7fdc46 0%, #58bf17 100%);
  border-color: #4baa15;
  box-shadow: 0 10rpx 20rpx rgba(88, 191, 23, 0.24);
}

.duo-node-current {
  transform: scale(1.02);
  background: linear-gradient(180deg, #7fdc46 0%, #58bf17 100%);
  border-color: #4baa15;
  box-shadow: 0 12rpx 22rpx rgba(88, 191, 23, 0.26);
}

.duo-node-locked {
  opacity: 0.42;
  background: linear-gradient(180deg, #ffffff 0%, #eef2f6 100%);
  border-color: #dfe5ec;
}

.duo-node-has-icon.duo-node-done,
.duo-node-has-icon.duo-node-current,
.duo-node-has-icon.duo-node-locked {
  opacity: 1;
  background: transparent;
  border: 0;
  box-shadow: none;
  width: 78px !important;
  height: 78px !important;
  transform: none;
  transform-origin: center center;
}

.duo-node-text {
  line-height: 1;
  color: #ffffff;
  font-weight: 800;
}

.duo-node-locked .duo-node-text {
  color: #a7b0bd;
}

.duo-node-icon {
  width: 78px;
  height: 73px;
  display: block;
  position: relative;
  z-index: 2;
}

.duo-node-icon-done,
.duo-node-icon-locked {
  width: 78px;
  height: 73px;
}

.duo-node-icon-current {
  width: 78px;
  height: 73px;
}

.duo-current-ring-image {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 103px;
  height: 103px;
  transform: translate(-50%, -50%) scale(1);
  transform-origin: center center;
  z-index: 1;
  pointer-events: none;
  animation: duo-current-ring-pulse 1s ease-in-out infinite alternate;
}

@keyframes duo-current-ring-pulse {
  from {
    transform: translate(-50%, -50%) scale(1);
  }

  to {
    transform: translate(-50%, -50%) scale(1.1);
  }
}

.duo-node-text {
  position: relative;
  z-index: 2;
}

.path-ip-float {
  position: absolute;
  z-index: 4;
  display: block;
  pointer-events: auto;
}

.path-ip-float:active .path-ip-image-stack {
  transform: scale(0.98);
}

.path-ip-image {
  width: 100%;
  display: block;
}

.path-ip-image-stack {
  position: relative;
  width: 100%;
  transition: transform 0.16s ease;
  transform-origin: center bottom;
}

.path-ip-image-stack-bounce {
  animation: bukaBounceTwist 0.52s ease-out both;
}

.path-ip-speech {
  position: absolute;
  left: 42rpx;
  right: 42rpx;
  top: -8rpx;
  z-index: 3;
  padding: 14rpx 18rpx;
  border-radius: 18rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 20rpx rgba(15, 23, 42, 0.12);
  box-sizing: border-box;
  animation: bukaSpeechPop 0.22s ease-out both;
}

.path-ip-speech::after {
  content: '';
  position: absolute;
  left: 50%;
  bottom: -11rpx;
  width: 24rpx;
  height: 24rpx;
  background: #ffffff;
  transform: translateX(-50%) rotate(45deg);
}

.path-ip-speech-text {
  position: relative;
  z-index: 2;
  display: block;
  color: #1d2433;
  font-size: 24rpx;
  line-height: 1.45;
  font-weight: 700;
  text-align: center;
  white-space: normal;
}

@keyframes bukaSpeechPop {
  from {
    opacity: 0;
    transform: translateY(10rpx) scale(0.96);
  }

  to {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
}

@keyframes bukaBounceTwist {
  0% {
    transform: rotate(0deg) scale(1);
  }

  18% {
    transform: rotate(-10deg) scale(1.02);
  }

  38% {
    transform: rotate(12deg) scale(1.03);
  }

  58% {
    transform: rotate(-8deg) scale(1.02);
  }

  78% {
    transform: rotate(5deg) scale(1.01);
  }

  100% {
    transform: rotate(0deg) scale(1);
  }
}

.path-ip-image-blink {
  position: absolute;
  top: 0;
  left: 0;
  opacity: 0;
  animation: bukaBlink 4.8s ease-in-out infinite;
}

@keyframes bukaBlink {
  0%,
  44%,
  48%,
  100% {
    opacity: 0;
  }

  45%,
  47% {
    opacity: 1;
  }
}

.home-step-tip {
  position: fixed;
  z-index: 9999;
  padding: 28rpx 28rpx 24rpx;
  border-radius: 20rpx;
  background: #ffffff;
  border: 2rpx solid rgba(209, 216, 226, 0.9);
  box-shadow: 0 7rpx 0 rgba(210, 217, 226, 0.82), 0 16rpx 32rpx rgba(15, 23, 42, 0.10);
  box-sizing: border-box;
}

.home-step-tip-arrow {
  position: absolute;
  top: -15rpx;
  left: var(--tip-arrow-left, 50%);
  width: 28rpx;
  height: 28rpx;
  background: #ffffff;
  border-left: 2rpx solid rgba(209, 216, 226, 0.9);
  border-top: 2rpx solid rgba(209, 216, 226, 0.9);
  transform: translateX(-50%) rotate(45deg);
}

.home-step-tip-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
}

.home-step-tip-title {
  display: block;
  flex: 1;
  min-width: 0;
  align-items: center;
  color: #8a94a6;
  font-size: 28rpx;
  line-height: 1.35;
  font-weight: 700;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.home-step-tip-message {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #9aa3af;
  font-weight: 500;
}

.home-step-tip-action {
  width: 100%;
  min-height: 78rpx;
  margin-top: 26rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 16rpx;
  background: #e5e7eb;
  box-shadow: none;
}

.home-step-tip-action-primary {
  background: linear-gradient(180deg, #4d94ff 0%, #1a6eff 100%);
  box-shadow: 0 6rpx 0 #1658cc;
}

.home-step-tip-action-disabled {
  background: #e5e7eb;
}

.home-step-tip-action-text {
  font-size: 26rpx;
  line-height: 1;
  color: #8b95a1;
  font-weight: 700;
}

.home-step-tip-action-primary .home-step-tip-action-text {
  color: #ffffff;
}
