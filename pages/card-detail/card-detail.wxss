.card-path-page {
  min-height: 100vh;
  padding: 24rpx 24rpx 120rpx;
  background:
    radial-gradient(circle at top left, rgba(37, 99, 235, 0.08), transparent 28%),
    linear-gradient(180deg, #f7f9fc 0%, #f3f5f8 100%);
  box-sizing: border-box;
}

.path-hero,
.path-summary-card,
.path-stage-card {
  background: #ffffff;
  border: 1rpx solid rgba(148, 163, 184, 0.16);
  box-shadow: 0 16rpx 40rpx rgba(15, 23, 42, 0.06);
}

.path-hero,
.path-summary-card,
.path-stage-card {
  padding: 30rpx;
  border-radius: 30rpx;
}

.path-hero {
  background:
    radial-gradient(circle at top right, rgba(96, 165, 250, 0.18), transparent 34%),
    linear-gradient(135deg, #ffffff 0%, #f7fbff 100%);
}

.path-hero-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.path-badge,
.path-status-tag {
  min-height: 42rpx;
  padding: 0 16rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 800;
  line-height: 1.4;
}

.path-badge {
  background: #eaf2ff;
  color: #2563eb;
}

.path-status-tag-green {
  background: #eefbf3;
  color: #15803d;
}

.path-status-tag-orange {
  background: #fff1e8;
  color: #c2410c;
}

.path-title {
  display: block;
  margin-top: 22rpx;
  font-size: 40rpx;
  font-weight: 900;
  color: #0f172a;
  line-height: 1.25;
}

.path-subtitle {
  display: block;
  margin-top: 14rpx;
  font-size: 25rpx;
  color: #475569;
  line-height: 1.72;
}

.path-summary-card {
  margin-top: 20rpx;
}

.path-summary-label {
  display: block;
  font-size: 22rpx;
  color: #94a3b8;
  line-height: 1.5;
}

.path-summary-route {
  display: block;
  margin-top: 12rpx;
  font-size: 30rpx;
  font-weight: 800;
  color: #0f172a;
  line-height: 1.5;
}

.path-summary-current {
  margin-top: 20rpx;
  padding: 22rpx 20rpx;
  border-radius: 22rpx;
  background: linear-gradient(180deg, #f7fbff 0%, #eef5ff 100%);
  border: 1rpx solid rgba(37, 99, 235, 0.1);
}

.path-summary-current-label {
  display: block;
  font-size: 20rpx;
  color: #64748b;
  line-height: 1.5;
}

.path-summary-current-title {
  display: block;
  margin-top: 8rpx;
  font-size: 30rpx;
  font-weight: 800;
  color: #2563eb;
  line-height: 1.35;
}

.path-summary-current-desc {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #475569;
  line-height: 1.68;
}

.path-stage-card {
  margin-top: 20rpx;
}

.path-stage-head {
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid rgba(148, 163, 184, 0.12);
}

.path-stage-title {
  display: block;
  font-size: 32rpx;
  font-weight: 900;
  color: #0f172a;
  line-height: 1.3;
}

.path-stage-sub {
  display: block;
  margin-top: 8rpx;
  font-size: 23rpx;
  color: #64748b;
  line-height: 1.6;
}

.path-stage-list {
  padding-top: 14rpx;
}

.path-stage-item {
  display: flex;
  align-items: stretch;
  gap: 16rpx;
}

.path-stage-line-wrap {
  width: 42rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  flex-shrink: 0;
}

.path-stage-index {
  width: 42rpx;
  height: 42rpx;
  margin-top: 14rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 4rpx solid #cbd5e1;
  background: #ffffff;
  box-sizing: border-box;
}

.path-stage-index-done {
  background: #2563eb;
  border-color: #2563eb;
}

.path-stage-index-current {
  border-color: #2563eb;
  box-shadow: 0 0 0 6rpx rgba(37, 99, 235, 0.12);
}

.path-stage-index-text {
  font-size: 20rpx;
  font-weight: 900;
  color: #94a3b8;
  line-height: 1;
}

.path-stage-index-done .path-stage-index-text,
.path-stage-index-current .path-stage-index-text {
  color: #2563eb;
}

.path-stage-index-done .path-stage-index-text {
  color: #ffffff;
}

.path-stage-line {
  flex: 1;
  width: 2rpx;
  margin-top: 10rpx;
  background: rgba(148, 163, 184, 0.28);
}

.path-stage-main {
  flex: 1;
  min-width: 0;
  padding: 12rpx 0 24rpx;
}

.path-stage-title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.path-stage-item-title {
  flex: 1;
  min-width: 0;
  font-size: 28rpx;
  font-weight: 800;
  color: #0f172a;
  line-height: 1.45;
}

.path-stage-status {
  flex-shrink: 0;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 700;
  line-height: 1.4;
}

.path-stage-status-done {
  background: #eefbf3;
  color: #15803d;
}

.path-stage-status-current {
  background: #eaf2ff;
  color: #2563eb;
}

.path-stage-status-pending {
  background: #f1f5f9;
  color: #64748b;
}

.path-stage-desc {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #475569;
  line-height: 1.68;
}

.path-stage-placeholder {
  margin-top: 14rpx;
  padding: 16rpx 18rpx;
  border-radius: 18rpx;
  background: #f8fafc;
  border: 1rpx dashed rgba(148, 163, 184, 0.5);
}

.path-stage-placeholder-text {
  display: block;
  font-size: 22rpx;
  color: #94a3b8;
  line-height: 1.6;
}

.safe-bottom {
  height: 24rpx;
}
