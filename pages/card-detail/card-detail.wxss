.detail-page {
  min-height: 100vh;
  background: #f5f6fa;
  padding-bottom: 120rpx;
}

.detail-point-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #333333;
}

.cd-section-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #999999;
  letter-spacing: 1rpx;
}

/* ===== 学习时长入口卡 ===== */
.cd-link-card {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.cd-link-left {
  flex: 1;
}

.cd-big-value {
  font-size: 52rpx;
  font-weight: 700;
  color: #1A6EFF;
  line-height: 1.1;
}

.cd-link-hint {
  font-size: 22rpx;
  color: #1A6EFF;
  margin-top: 10rpx;
  display: block;
  opacity: 0.7;
}

.cd-entry-arrow {
  font-size: 48rpx;
  color: #1A6EFF;
  margin-left: 12rpx;
  flex-shrink: 0;
}

/* ===== 可展开统计卡（刷题/考试） ===== */
.cd-expand-header {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  justify-content: space-between;
}

.cd-header-left {
  flex: 1;
}

.cd-sub-value {
  font-size: 26rpx;
  color: #666666;
  margin-left: 4rpx;
}

.cd-sep {
  font-size: 26rpx;
  color: #cccccc;
  margin: 0 8rpx;
}

.cd-expand-arrow {
  font-size: 44rpx;
  color: #aaaaaa;
  margin-left: 12rpx;
  transform: rotate(0deg);
  transition: transform 0.2s;
  flex-shrink: 0;
}

.cd-arrow-up {
  transform: rotate(90deg);
}

/* 分数行不换行 */
.cd-score-line {
  display: flex;
  flex-direction: row;
  align-items: baseline;
  flex-wrap: nowrap;
  margin-top: 8rpx;
}

.cd-score-unit {
  font-size: 28rpx;
  color: #666666;
  margin-left: 6rpx;
}

/* ===== 考试展开：批改文件 ===== */
.exam-detail-wrap {
  margin-top: 4rpx;
}

.exam-detail-meta {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.exam-file-label {
  font-size: 22rpx;
  color: #aaaaaa;
  display: block;
  margin-bottom: 8rpx;
}

.exam-file-block {
  display: flex;
  flex-direction: row;
  align-items: center;
  background: #f8f9fb;
  border-radius: 12rpx;
  padding: 20rpx 20rpx;
  margin-bottom: 16rpx;
  border: 1rpx solid #eeeeee;
}

.exam-file-corrected {
  background: #f6ffed;
  border-color: #d9f7be;
}

.exam-file-info {
  flex: 1;
}

.exam-file-name {
  font-size: 26rpx;
  color: #333333;
  font-weight: 500;
  display: block;
}

.exam-file-hint {
  font-size: 22rpx;
  color: #1A6EFF;
  display: block;
  margin-top: 4rpx;
}

/* ===== 题目记录列表 ===== */
.cd-records {
  margin-top: 4rpx;
}

.cd-record-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.cd-record-row:last-child {
  border-bottom: none;
}

.cd-record-info {
  flex: 1;
  min-width: 0;
}

.cd-record-label {
  font-size: 28rpx;
  color: #333333;
  font-weight: 500;
}

.cd-record-date {
  font-size: 22rpx;
  color: #aaaaaa;
  margin-right: 12rpx;
}

.cd-record-score {
  background: #e8f0ff;
  border-radius: 8rpx;
  padding: 2rpx 12rpx;
  margin-right: 10rpx;
}

.cd-score-exam {
  background: #f6ffed;
}

.cd-score-text {
  font-size: 22rpx;
  color: #1A6EFF;
  font-weight: 600;
}

.cd-score-exam .cd-score-text {
  color: #52c41a;
}

.cd-record-pass {
  font-size: 22rpx;
  color: #aaaaaa;
  margin-right: 8rpx;
}

.cd-record-status {
  font-size: 22rpx;
}

.cd-status-done {
  color: #52c41a;
}

.cd-view-btn {
  background: #f5f6fa;
  color: #1A6EFF;
  font-size: 22rpx;
  padding: 10rpx 20rpx;
  border-radius: 20rpx;
  border: 1rpx solid #d0e0ff;
  line-height: 1.5;
  flex-shrink: 0;
  margin-left: 16rpx;
}

.cd-view-btn::after {
  border: none;
}

/* ===== 学习纪录（历史上的今天风格） ===== */
.history-item {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  padding: 20rpx 0;
}

.history-item-border {
  border-bottom: 1rpx solid #f5f5f5;
}

.history-content {
  flex: 1;
}

.history-title {
  font-size: 24rpx;
  color: #999999;
  margin-right: 16rpx;
}

.history-value {
  font-size: 36rpx;
  font-weight: 700;
  color: #333333;
}

.history-desc {
  font-size: 24rpx;
  color: #888888;
  line-height: 1.6;
  display: block;
}

/* ===== 请假记录 ===== */
.cd-leave-card {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.cd-leave-left {
  flex: 1;
}

.cd-leave-hint {
  font-size: 22rpx;
  color: #aaaaaa;
  display: block;
  margin-top: 6rpx;
}

.cd-leave-right {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin: 0 20rpx 0 12rpx;
}

.cd-leave-count-wrap {
  display: flex;
  flex-direction: row;
  align-items: baseline;
  margin-bottom: 8rpx;
}

.cd-leave-count {
  font-size: 44rpx;
  font-weight: 700;
  color: #333333;
}

.cd-leave-total {
  font-size: 24rpx;
  color: #aaaaaa;
  margin-left: 4rpx;
}

.cd-leave-dots {
  display: flex;
  flex-direction: row;
  gap: 8rpx;
}

.cd-leave-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
}

.cd-dot-used {
  background: #fa8c16;
}

.cd-dot-empty {
  background: #eeeeee;
  border: 1rpx solid #dddddd;
}

/* ===== 老师寄语（保留原样式） ===== */
.message-wrap {
  margin-bottom: 16rpx;
}

.teacher-message {
  font-size: 28rpx;
  color: #333333;
  line-height: 1.8;
  white-space: pre-wrap;
  display: block;
}

.message-collapsed {
  overflow: hidden;
  max-height: 96rpx;
}

.expand-btn {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  padding: 8rpx 0;
}

.expand-text {
  font-size: 26rpx;
  color: #1A6EFF;
}

.expand-icon {
  font-size: 20rpx;
  color: #1A6EFF;
  margin-left: 8rpx;
}

/* ===== 诊断报告入口 ===== */
.diagnose-entry {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  background: linear-gradient(135deg, #f0f5ff, #e8f0ff);
  border: 2rpx solid #c8d9ff;
}

.diagnose-entry-left {
  display: flex;
  flex-direction: row;
  align-items: center;
  flex: 1;
}

.diagnose-entry-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: #1A6EFF;
  color: #fff;
  font-size: 30rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.diagnose-entry-info {
  flex: 1;
}

.diagnose-entry-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1A6EFF;
  display: block;
  margin-bottom: 6rpx;
}

.diagnose-entry-sub {
  font-size: 22rpx;
  color: #5a8aff;
  display: block;
}

.diagnose-entry-arrow {
  font-size: 44rpx;
  color: #1A6EFF;
  margin-left: 12rpx;
}
