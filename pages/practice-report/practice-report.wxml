<view class="practice-report-page">
  <view class="card practice-report-hero">
    <view class="hero-badge">刷题课完整报告</view>
    <view class="hero-top row-between">
      <view>
        <text class="hero-name">{{student.name}}</text>
        <text class="hero-meta">{{student.course}}</text>
        <text class="hero-meta">{{student.period}}</text>
        <text class="hero-meta">报告时间：{{student.reportDate}}</text>
      </view>
      <view class="hero-type-pill">
        <text class="hero-type-pill-text">{{overview.status}}</text>
      </view>
    </view>

    <view class="hero-score-row">
      <view class="hero-score-card">
        <text class="hero-score-value hero-score-blue">{{overview.currentWeek}}</text>
        <text class="hero-score-label">当前周次</text>
      </view>
      <view class="hero-score-card">
        <text class="hero-score-value hero-score-warn">{{overview.taskCount}}</text>
        <text class="hero-score-label">任务进度</text>
      </view>
      <view class="hero-score-card">
        <text class="hero-score-value hero-score-green">{{overview.nextLiveDate}}</text>
        <text class="hero-score-label">下次直播</text>
      </view>
    </view>

    <text class="hero-summary">{{overview.summary}}</text>
    <text class="hero-basis">班主任：{{student.teacher}}</text>
  </view>

  <view class="card">
    <text class="section-title">本周进展</text>
    <view wx:for="{{highlights}}" wx:key="index" class="bullet-row">
      <view class="bullet-dot success-dot"></view>
      <text class="bullet-text">{{item}}</text>
    </view>
  </view>

  <view class="card">
    <text class="section-title">任务安排</text>
    <view wx:for="{{tasks}}" wx:key="title" class="loss-card">
      <view class="row-between loss-top">
        <text class="loss-title">{{item.title}}</text>
        <text class="loss-score">{{item.score}}</text>
      </view>
      <text class="loss-desc">{{item.desc}}</text>
    </view>
  </view>

  <view class="card">
    <text class="section-title">训练规划</text>
    <view wx:for="{{stages}}" wx:key="title" class="stage-card">
      <text class="stage-title">{{item.title}}</text>
      <text class="stage-duration">{{item.duration}}</text>
      <text class="stage-goal">{{item.goal}}</text>
    </view>
  </view>

  <view class="card">
    <text class="section-title">学习建议</text>
    <view wx:for="{{suggestions}}" wx:key="index" class="bullet-row">
      <view class="bullet-dot primary-dot"></view>
      <text class="bullet-text">{{item}}</text>
    </view>

    <view class="closing-box">
      <text class="closing-copy">{{closing}}</text>
      <text class="closing-sign">—— {{student.teacher}}</text>
    </view>
  </view>

  <view class="safe-bottom"></view>
</view>

<diagnose-coupon-fab auto-popup="{{true}}"></diagnose-coupon-fab>
