.bind-page {
  min-height: 100vh;
  padding: 32rpx 0 48rpx;
}

.bind-hero,
.bind-form {
  margin-top: 24rpx;
}

.bind-title {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #0f172a;
  line-height: 1.5;
}

.bind-desc {
  display: block;
  margin-top: 18rpx;
  font-size: 28rpx;
  line-height: 1.7;
  color: #475569;
}

.bind-label {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #1e293b;
}

.bind-input {
  width: 100%;
  height: 96rpx;
  margin-top: 20rpx;
  padding: 0 28rpx;
  border-radius: 24rpx;
  border: 1rpx solid rgba(148, 163, 184, 0.4);
  background: #f8fafc;
  font-size: 30rpx;
  color: #0f172a;
}

.bind-submit {
  width: 100%;
  margin-top: 28rpx;
}

.bind-hint {
  display: block;
  margin-top: 18rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #64748b;
}
