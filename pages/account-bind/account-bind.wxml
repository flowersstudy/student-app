<view class="bind-page">
  <view class="login-shell">
    <view class="brand-area">
      <view class="brand-mark">步知</view>
      <text class="brand-name">步知 1v1</text>
      <text class="brand-slogan">做更好的申论教育平台</text>
    </view>

    <view class="login-card">
      <view class="tab-row">
        <view class="tab-pill tab-pill-active">
          <text class="tab-text tab-text-active">{{mode === 'launch' ? '登录' : '绑定'}}</text>
        </view>
      </view>

      <view class="form">
        <view class="field-group">
          <text class="field-label">{{pageCopy.label}}</text>
          <view class="input-wrap">
            <text class="input-prefix">+86</text>
            <input
              class="form-input"
              type="number"
              maxlength="11"
              placeholder="{{pageCopy.placeholder}}"
              placeholder-class="form-placeholder"
              value="{{phone}}"
              bindinput="onPhoneInput"
              confirm-type="done"
            />
          </view>
        </view>
      </view>

      <button class="btn-submit" loading="{{submitting}}" disabled="{{submitting || wechatSubmitting}}" bindtap="submitBind">
        <text>{{pageCopy.submitText}}</text>
      </button>

      <button
        class="btn-wechat"
        open-type="getPhoneNumber"
        bindgetphonenumber="handleGetPhoneNumber"
        loading="{{wechatSubmitting}}"
        disabled="{{submitting || wechatSubmitting}}"
      >
        <text>{{mode === 'launch' ? '使用微信绑定手机号登录' : '使用微信绑定手机号'}}</text>
      </button>
    </view>
  </view>
</view>
