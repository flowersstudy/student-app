.lesson-page {
  min-height: 100vh;
  background: #f5f6fa;
  padding: 24rpx 0;
  padding-bottom: 120rpx;
}

.phase-label {
  font-size: 24rpx;
  color: #999999;
  font-weight: 500;
  display: block;
  margin-bottom: 12rpx;
}

.phase-card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 8rpx;
}

.sub-label {
  font-size: 26rpx;
  color: #666666;
  font-weight: 500;
  display: block;
  margin-bottom: 16rpx;
}

.file-arrow {
  font-size: 36rpx;
  color: #cccccc;
  flex-shrink: 0;
}

.video-placeholder {
  background: #f0f4ff;
  border-radius: 16rpx;
  height: 200rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
}

.video-icon {
  width: 72rpx;
  height: 72rpx;
  filter: drop-shadow(0 10rpx 18rpx rgba(37, 99, 235, 0.14));
}

.video-tip {
  font-size: 24rpx;
  color: #999999;
  margin-top: 8rpx;
}

.btn-enter {
  background: linear-gradient(90deg, #1A6EFF, #4a9eff);
  color: #ffffff;
  border-radius: 56rpx;
  padding: 28rpx 0;
  font-size: 32rpx;
  font-weight: 600;
  text-align: center;
  width: 100%;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(26, 110, 255, 0.35);
}

.btn-enter::after {
  border: none;
}

.ask-btn-row {
  margin-top: 20rpx;
}

.ask-btn {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  background: #f0f4ff;
  border-radius: 16rpx;
  padding: 24rpx;
}

.ask-icon {
  width: 44rpx;
  height: 44rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.task-check-done {
  background: transparent;
  border-color: transparent;
}

.task-check-icon {
  width: 28rpx;
  height: 28rpx;
}

.ask-text {
  font-size: 30rpx;
  color: #1A6EFF;
  font-weight: 500;
}
