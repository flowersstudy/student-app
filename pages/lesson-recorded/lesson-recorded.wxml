<view class="lesson-page">
  <view class="timeline">

    <!-- 课前 -->
    <view class="timeline-item">
      <view class="timeline-left">
        <view class="timeline-dot"></view>
        <view class="timeline-line"></view>
      </view>
      <view class="timeline-content">
        <text class="phase-label">课前</text>
        <view class="phase-card">
          <text class="sub-label">课前资料</text>
          <view wx:for="{{preFiles}}" wx:key="id" class="file-card {{item.url ? '' : 'file-card-disabled'}}" bindtap="openFile" data-list="preFiles" data-id="{{item.id}}">
            <view class="file-icon {{item.url ? '' : 'file-icon-gray'}}">
              <text class="file-icon-text">PDF</text>
            </view>
            <view class="file-info">
              <text class="file-name {{item.url ? '' : 'file-name-gray'}}">{{item.name}}</text>
            </view>
            <text wx:if="{{item.opened}}" class="tag tag-green">已打开</text>
            <text wx:elif="{{item.url}}" class="file-arrow">›</text>
            <text wx:else class="tag tag-gray">暂未上传</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 上课中 -->
    <view class="timeline-item">
      <view class="timeline-left">
        <view class="timeline-dot"></view>
        <view class="timeline-line"></view>
      </view>
      <view class="timeline-content">
        <text class="phase-label">上课中</text>
        <view class="phase-card">
          <view class="video-placeholder">
            <image class="video-icon" src="{{uiIcons.play}}" mode="aspectFit" />
            <text class="video-tip">{{videoTitle}}</text>
          </view>
          <button class="btn-enter" bindtap="enterVideo">进入视频</button>
        </view>
      </view>
    </view>

    <!-- 课程任务 -->
    <view class="timeline-item">
      <view class="timeline-left">
        <view class="timeline-dot"></view>
        <view class="timeline-line"></view>
      </view>
      <view class="timeline-content">
        <text class="phase-label">课程任务</text>
        <view class="phase-card">
          <view class="task-progress-row">
            <text class="task-progress-text">已完成 {{recordedDoneCount}}/{{recordedTasks.length}} 项</text>
          </view>
          <view wx:for="{{recordedTasks}}" wx:key="id" class="task-item" bindtap="toggleRecordedTask" data-id="{{item.id}}">
            <view class="task-check {{item.done ? 'task-check-done' : ''}}">
              <image wx:if="{{item.done}}" class="task-check-icon" src="{{uiIcons.check}}" mode="aspectFit" />
            </view>
            <view class="task-body">
              <text class="task-title {{item.done ? 'task-title-done' : ''}}">{{item.title}}</text>
              <text class="task-desc" wx:if="{{item.desc}}">{{item.desc}}</text>
            </view>
            <text class="task-tag {{item.done ? 'task-tag-done' : 'task-tag-todo'}}">{{item.done ? '已完成' : '待完成'}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 课后 -->
    <view class="timeline-item">
      <view class="timeline-left">
        <view class="timeline-dot timeline-dot-gray"></view>
      </view>
      <view class="timeline-content">
        <text class="phase-label">课后</text>
        <view class="phase-card">
          <text class="sub-label">课后作业</text>
          <view wx:for="{{postFiles}}" wx:key="id" class="file-card {{item.url ? '' : 'file-card-disabled'}}" bindtap="openFile" data-list="postFiles" data-id="{{item.id}}">
            <view class="file-icon {{item.url ? '' : 'file-icon-gray'}}">
              <text class="file-icon-text">PDF</text>
            </view>
            <view class="file-info">
              <text class="file-name {{item.url ? '' : 'file-name-gray'}}">{{item.name}}</text>
            </view>
            <text wx:if="{{item.opened}}" class="tag tag-green">已打开</text>
            <text wx:elif="{{item.url}}" class="file-arrow">›</text>
            <text wx:else class="tag tag-gray">暂未上传</text>
          </view>

          <view class="video-placeholder" style="margin-bottom:16rpx;" bindtap="enterPostVideo">
            <image class="video-icon" src="{{uiIcons.play}}" mode="aspectFit" />
            <text class="video-tip">{{postVideoTitle}}</text>
          </view>

          <view class="ask-btn-row">
            <view class="ask-btn" bindtap="askTeacher">
              <image class="ask-icon" src="{{uiIcons.chat}}" mode="aspectFit" />
              <text class="ask-text">向老师提问</text>
            </view>
          </view>

          <view class="divider" style="margin:20rpx 0;"></view>

          <text class="sub-label">课堂反馈</text>
          <textarea
            class="input-area"
            placeholder="分享本次录播课的收获或问题..."
            value="{{feedback}}"
            bindinput="onFeedbackInput"
            auto-height
          />
        </view>
      </view>
    </view>

  </view>
  <view class="safe-bottom"></view>
</view>
