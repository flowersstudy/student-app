page {
  background: #f5f7fb;
}

.practice-page {
  min-height: 100vh;
  padding: 24rpx 24rpx 0;
  box-sizing: border-box;
}

.hero-card {
  background: linear-gradient(180deg, #eff6ff 0%, #ffffff 100%);
}

.hero-kicker {
  display: inline-flex;
  min-height: 42rpx;
  padding: 0 16rpx;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  background: #dbeafe;
  color: #1d4ed8;
  font-size: 22rpx;
  font-weight: 700;
}

.hero-title {
  display: block;
  margin-top: 18rpx;
  font-size: 38rpx;
  line-height: 1.35;
  font-weight: 700;
  color: #0f172a;
}

.hero-subtitle {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #64748b;
}

.hero-tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 22rpx;
}

.hero-tag {
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(37, 99, 235, 0.08);
  color: #1d4ed8;
  font-size: 22rpx;
  font-weight: 600;
}

.helper-text {
  display: block;
  margin-top: 16rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #64748b;
}

.bullet-row {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  margin-top: 18rpx;
}

.bullet-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  margin-top: 12rpx;
  background: #2563eb;
  flex-shrink: 0;
}

.bullet-text {
  flex: 1;
  font-size: 26rpx;
  line-height: 1.7;
  color: #334155;
}

.bottom-space {
  height: 144rpx;
}

.pay-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 20;
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 20rpx 24rpx calc(20rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.96);
  border-top: 1rpx solid rgba(148, 163, 184, 0.16);
}

.pay-info {
  flex: 1;
}

.pay-label {
  display: block;
  font-size: 22rpx;
  color: #64748b;
}

.pay-price {
  display: block;
  margin-top: 8rpx;
  font-size: 30rpx;
  font-weight: 700;
  color: #0f172a;
}

.pay-btn {
  min-width: 240rpx;
  height: 84rpx;
  line-height: 84rpx;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #2563eb 0%, #3b82f6 100%);
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 700;
  border: none;
}

.pay-btn::after {
  border: none;
}
