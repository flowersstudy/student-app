@import "../square-common.wxss";

.share-page {
  padding-bottom: 60rpx;
  background: #f7f8fa;
}

.share-hero {
  margin-bottom: 2rpx;
  background: #ffffff;
  border-color: #eef1f5;
  box-shadow: 0 10rpx 26rpx rgba(15, 23, 42, 0.04);
}

.share-page .bg-orb-a,
.share-page .bg-orb-b {
  background: radial-gradient(circle, rgba(230, 233, 239, 0.65) 0%, rgba(230, 233, 239, 0) 72%);
}

.share-page .hero-badge,
.share-page .section-mark,
.share-page .feed-tag {
  background: #f2f4f7;
  color: #475467;
}

.share-page .hero-icon-shell {
  background: linear-gradient(180deg, #fafafa 0%, #f3f4f6 100%);
}

.share-page .highlight-card,
.share-page .section-card {
  background: #ffffff;
  border-color: #eef1f5;
  box-shadow: 0 10rpx 26rpx rgba(15, 23, 42, 0.04);
}

.share-page .stat-chip {
  background: #fafbfc;
  border-color: #edf1f5;
}

.share-filter {
  background: #ffffff;
  color: #667085;
  border-color: #e7eaef;
}

.share-filter-active {
  background: #111827;
  color: #ffffff;
  box-shadow: 0 8rpx 18rpx rgba(17, 24, 39, 0.16);
}

.featured-card {
  overflow: visible;
}

.featured-topline {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 16rpx;
  flex-wrap: wrap;
}

.featured-tag {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #f3f4f6;
  color: #4b5563;
  font-size: 20rpx;
  font-weight: 700;
}

.featured-meta {
  color: #667085;
  font-size: 22rpx;
}

.featured-result {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-top: 18rpx;
  padding: 16rpx 18rpx;
  border-radius: 22rpx;
  background: #f8fafc;
}

.result-icon {
  width: 34rpx;
  height: 34rpx;
  flex-shrink: 0;
}

.featured-result-text {
  color: #344054;
  font-size: 24rpx;
  font-weight: 700;
}

.featured-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
  margin-top: 20rpx;
  padding-top: 18rpx;
  border-top: 1rpx solid #eef2f6;
}

.featured-footer-text {
  color: #667085;
  font-size: 21rpx;
}

.featured-arrow,
.post-open-icon {
  width: 28rpx;
  height: 28rpx;
  flex-shrink: 0;
}

.featured-points,
.post-tags,
.detail-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 18rpx;
}

.point-chip,
.mini-tag {
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: #f5f6f7;
  color: #667085;
  font-size: 20rpx;
  line-height: 1.4;
}

.post-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  margin-top: 18rpx;
}

.post-card {
  padding: 22rpx;
  border-radius: 26rpx;
  background: #ffffff;
  border: 1rpx solid #eceff3;
}

.post-card-active {
  border-color: #d0d5dd;
  box-shadow: 0 12rpx 24rpx rgba(15, 23, 42, 0.06);
  background: #ffffff;
}

.post-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 14rpx;
}

.post-author {
  display: flex;
  align-items: center;
  gap: 14rpx;
  min-width: 0;
  flex: 1;
}

.author-avatar {
  width: 68rpx;
  height: 68rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #98a2b3 0%, #667085 100%);
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 700;
  flex-shrink: 0;
}

.author-copy {
  min-width: 0;
  flex: 1;
}

.author-name {
  display: block;
  color: #251f39;
  font-size: 25rpx;
  font-weight: 700;
}

.author-role {
  display: block;
  margin-top: 6rpx;
  color: #667085;
  font-size: 21rpx;
  line-height: 1.5;
}

.post-title,
.detail-title {
  display: block;
  color: #231d35;
  font-size: 32rpx;
  line-height: 1.45;
  font-weight: 700;
}

.post-title {
  margin-top: 18rpx;
}

.post-summary,
.detail-summary {
  display: block;
  margin-top: 12rpx;
  color: #667085;
  font-size: 23rpx;
  line-height: 1.75;
}

.post-footer {
  display: flex;
  flex-wrap: wrap;
  gap: 18rpx;
  margin-top: 18rpx;
}

.post-footer-text {
  color: #667085;
  font-size: 20rpx;
}

.post-open-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 18rpx;
  padding-top: 18rpx;
  border-top: 1rpx solid #eef2f6;
}

.post-open-text {
  color: #344054;
  font-size: 22rpx;
  font-weight: 600;
}
