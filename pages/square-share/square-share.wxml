<view class="square-scene share-page">
  <view class="bg-orb bg-orb-a"></view>
  <view class="bg-orb bg-orb-b"></view>

  <view class="hero-card share-hero">
    <view class="hero-row">
      <view class="hero-copy">
        <text class="hero-badge">经验分享</text>
        <text class="hero-title">把论坛长帖，改成更适合小程序阅读的经验内容</text>
        <text class="hero-desc">这一页先放可参考的假数据结构：有提分案例、方法经验、心态记录和备考节奏，后面你把真实案例替换进去就可以了。</text>
      </view>

      <view class="hero-visual">
        <view class="hero-icon-shell">
          <image class="hero-icon" src="{{uiIcons.spark}}" mode="aspectFit" />
        </view>
      </view>
    </view>

    <view class="hero-stats">
      <view wx:for="{{heroStats}}" wx:key="label" wx:for-item="stat" class="stat-chip">
        <text class="stat-value">{{stat.value}}</text>
        <text class="stat-label">{{stat.label}}</text>
      </view>
    </view>
  </view>

  <scroll-view class="action-scroll" scroll-x enable-flex show-scrollbar="{{false}}">
    <view class="action-row">
      <view
        wx:for="{{categoryChips}}"
        wx:key="key"
        wx:for-item="chip"
        class="action-pill share-filter {{chip.active ? 'share-filter-active' : ''}}"
        data-key="{{chip.key}}"
        bindtap="handleCategoryTap"
      >
        {{chip.label}}
      </view>
    </view>
  </scroll-view>

  <view wx:if="{{featuredPost}}" class="highlight-card featured-card" bindtap="handleFeaturedTap">
    <view class="section-head">
      <view class="section-copy">
        <text class="section-title">本期精读</text>
        <text class="section-subtitle">把一篇值得参考的帖子先拎出来，方便用户快速进入状态</text>
      </view>
      <text class="section-mark">主推</text>
    </view>

    <view class="featured-topline">
      <text class="featured-tag">{{featuredPost.tagText}}</text>
      <text class="featured-meta">{{featuredPost.examLabel}} · {{featuredPost.stage}}</text>
    </view>

    <text class="highlight-title">{{featuredPost.title}}</text>
    <text class="highlight-desc">{{featuredPost.summary}}</text>

    <view class="featured-result">
      <image class="result-icon" src="{{uiIcons.target}}" mode="aspectFit" />
      <text class="featured-result-text">{{featuredPost.resultText}}</text>
    </view>

    <view class="featured-points">
      <view wx:for="{{featuredPost.keyPoints}}" wx:key="*this" class="point-chip">
        {{item}}
      </view>
    </view>

    <view class="featured-footer">
      <text class="featured-footer-text">{{featuredPost.viewsText}} 阅读 · {{featuredPost.likesText}} 点赞 · 点击查看全文</text>
      <image class="featured-arrow" src="{{uiIcons.play}}" mode="aspectFit" />
    </view>
  </view>

  <view class="section-card">
    <view class="section-head">
      <view class="section-copy">
        <text class="section-title">帖子列表</text>
        <text class="section-subtitle">这里更像广场里的信息流，用户先看摘要，再点开精读</text>
      </view>
    </view>

    <view class="post-list">
      <view
        wx:for="{{postCards}}"
        wx:key="id"
        wx:for-item="post"
        class="post-card {{post.active ? 'post-card-active' : ''}}"
        data-id="{{post.id}}"
        bindtap="handlePostTap"
      >
        <view class="post-head">
          <view class="post-author">
            <view class="author-avatar">{{post.avatarText}}</view>
            <view class="author-copy">
              <text class="author-name">{{post.authorName}}</text>
              <text class="author-role">{{post.authorRole}} · {{post.publishDate}}</text>
            </view>
          </view>
          <text class="feed-tag">{{post.tagText}}</text>
        </view>

        <text class="post-title">{{post.title}}</text>
        <text class="post-summary">{{post.summary}}</text>

        <view class="post-tags">
          <text wx:for="{{post.problemTags}}" wx:key="*this" class="mini-tag">{{item}}</text>
        </view>

        <view class="post-footer">
          <text class="post-footer-text">{{post.examLabel}}</text>
          <text class="post-footer-text">{{post.readTime}}</text>
          <text class="post-footer-text">{{post.viewsText}} 阅读</text>
          <text class="post-footer-text">{{post.likesText}} 赞</text>
        </view>
        <view class="post-open-row">
          <text class="post-open-text">点击查看全文</text>
          <image class="post-open-icon" src="{{uiIcons.play}}" mode="aspectFit" />
        </view>
      </view>
    </view>
  </view>
</view>

<diagnose-coupon-fab auto-popup="{{true}}"></diagnose-coupon-fab>
