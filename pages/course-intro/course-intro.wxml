<view class="intro-page">

  <!-- 卡点头部 -->
  <view class="intro-hero">
    <view class="intro-hero-tag">{{course.subject}}</view>
    <text class="intro-hero-name">{{course.name}}</text>
    <text class="intro-hero-tagline">{{course.tagline}}</text>
  </view>

  <!-- 你是否有这些问题 -->
  <view class="card intro-section">
    <text class="intro-section-title">你是否有这些问题？</text>
    <view wx:for="{{course.symptoms}}" wx:key="index" class="symptom-item">
      <view class="symptom-dot"></view>
      <text class="symptom-text">{{item}}</text>
    </view>
  </view>

  <!-- 课程解决什么 -->
  <view class="card intro-section">
    <text class="intro-section-title">这门课帮你解决</text>
    <view wx:for="{{course.solutions}}" wx:key="index" class="solution-item">
      <view class="solution-icon">✓</view>
      <text class="solution-text">{{item}}</text>
    </view>
  </view>

  <!-- 课程包含 -->
  <view class="card intro-section">
    <text class="intro-section-title">课程包含</text>
    <view wx:for="{{course.includes}}" wx:key="index" class="include-item">
      <text class="include-icon">{{item.icon}}</text>
      <view class="include-info">
        <text class="include-name">{{item.name}}</text>
        <text class="include-desc">{{item.desc}}</text>
      </view>
    </view>
  </view>

  <!-- 授课老师 -->
  <view class="card intro-section">
    <text class="intro-section-title">授课老师</text>
    <view wx:for="{{teachers}}" wx:key="id" class="teacher-card">
      <view class="teacher-avatar">
        <text class="teacher-avatar-text">{{item.name[0]}}</text>
      </view>
      <view class="teacher-info">
        <view class="teacher-name-row">
          <text class="teacher-name">{{item.name}}</text>
          <text class="teacher-subject-tag">{{item.subject}}</text>
        </view>
        <text class="teacher-exp">{{item.exp}}</text>
        <text class="teacher-desc">{{item.desc}}</text>
      </view>
    </view>
  </view>

  <view style="height:160rpx;"></view>
</view>

<!-- 底部购买栏 -->
<view class="buy-bar">
  <view class="buy-price-area">
    <text class="buy-price">¥{{course.price}}</text>
    <text class="buy-price-unit">/ 节</text>
  </view>
  <button class="btn-buy" bindtap="goPurchase">立即购买</button>
</view>
