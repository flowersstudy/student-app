.intro-page {
  min-height: 100vh;
  background: #f5f6fa;
  padding-bottom: 160rpx;
}

.intro-hero {
  background: linear-gradient(150deg, #1248cc, #1A6EFF 60%, #4a9eff);
  padding: 48rpx 40rpx 56rpx;
  display: flex;
  flex-direction: column;
}

.intro-hero-foundation {
  background: linear-gradient(150deg, #1248cc 0%, #1A6EFF 60%, #4a9eff 100%);
}

.intro-hero-special {
  background: linear-gradient(150deg, #c97a00 0%, #f4b400 58%, #ffd76a 100%);
}

.intro-hero-tag-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-wrap: wrap;
}

.intro-hero-tag {
  align-self: flex-start;
  background: rgba(255,255,255,0.25);
  color: #fff;
  font-size: 22rpx;
  font-weight: 600;
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
  margin-bottom: 20rpx;
  letter-spacing: 2rpx;
}

.intro-hero-tag-foundation {
  background: rgba(255,255,255,0.22);
}

.intro-hero-tag-special {
  background: rgba(255,255,255,0.26);
}

.intro-hero-level-tag {
  letter-spacing: 0;
}

.intro-hero-level-tag-foundation {
  background: rgba(219, 234, 254, 0.26);
}

.intro-hero-level-tag-special {
  background: rgba(255, 248, 220, 0.3);
}

.intro-hero-name {
  font-size: 52rpx;
  font-weight: 700;
  color: #fff;
  display: block;
  margin-bottom: 16rpx;
  letter-spacing: 1rpx;
}

.intro-hero-tagline {
  font-size: 28rpx;
  color: rgba(255,255,255,0.85);
  display: block;
  line-height: 1.6;
}

.intro-section {
  margin-top: 16rpx;
}

.intro-section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1a1a1a;
  display: block;
  margin-bottom: 24rpx;
}

.intro-subsection-title {
  display: block;
  font-size: 24rpx;
  line-height: 1.2;
  color: #1d2433;
  font-weight: 700;
}

.intro-subsection-title-gap {
  margin-top: 24rpx;
}

/* 症状列表 */
.symptom-item {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  margin-bottom: 20rpx;
}

.symptom-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #ff4d4f;
  margin-top: 10rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.symptom-text {
  font-size: 28rpx;
  color: #444;
  line-height: 1.6;
  flex: 1;
}

.loss-chip-list,
.ability-chip-list {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 16rpx;
}

.loss-chip,
.ability-chip {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: #f8fafc;
  border: 1rpx solid #e7edf4;
}

.loss-chip {
  background: #fff5f5;
  border-color: #ffd9d9;
}

.ability-chip {
  background: #f8fbff;
  border-color: #dfeaff;
}

.loss-chip-text,
.ability-chip-text {
  font-size: 22rpx;
  line-height: 1.4;
  color: #4a5568;
  font-weight: 700;
}

.loss-chip-text {
  color: #d14d41;
}

.lesson-simple-item,
.order-simple-item {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
}

.lesson-simple-item + .lesson-simple-item,
.order-simple-item + .order-simple-item {
  margin-top: 18rpx;
}

.lesson-simple-dot {
  width: 12rpx;
  height: 12rpx;
  margin-top: 14rpx;
  border-radius: 50%;
  background: #1a6eff;
  flex-shrink: 0;
}

.lesson-simple-text {
  flex: 1;
  min-width: 0;
  font-size: 26rpx;
  line-height: 1.6;
  color: #4a5568;
}

.learning-section-desc {
  display: block;
  margin-bottom: 18rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #8b97aa;
}

.learning-block + .learning-block {
  margin-top: 24rpx;
}

.learning-block-title {
  display: block;
  font-size: 26rpx;
  line-height: 1.2;
  color: #1d2433;
  font-weight: 700;
}

.learning-block-desc {
  display: block;
  margin-top: 10rpx;
  margin-bottom: 16rpx;
  font-size: 23rpx;
  line-height: 1.6;
  color: #8b97aa;
}

/* 解决方案列表 */
.solution-item {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  margin-bottom: 20rpx;
}

.solution-icon {
  width: 40rpx;
  height: 40rpx;
  margin-right: 16rpx;
  margin-top: 4rpx;
  flex-shrink: 0;
}

.solution-text {
  font-size: 28rpx;
  color: #444;
  line-height: 1.6;
  flex: 1;
}

.intro-section-title-tight {
  margin-bottom: 0;
}

.version-section-head {
  display: flex;
  align-items: center;
}

.version-section-desc {
  display: block;
  margin-top: 14rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #6f7d93;
}

.version-intro-card {
  margin-top: 18rpx;
  padding: 20rpx 22rpx;
  border-radius: 20rpx;
  background: #f8fbff;
  border: 2rpx solid #e4edf9;
}

.version-intro-card-disabled {
  background: #fafbfc;
  border-color: #e8edf3;
}

.version-intro-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.version-intro-main {
  flex: 1;
  min-width: 0;
}

.version-intro-title-row {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 12rpx;
}

.version-intro-title {
  font-size: 30rpx;
  line-height: 1.2;
  color: #1d2433;
  font-weight: 700;
}

.version-intro-status {
  padding: 6rpx 14rpx;
  background: #eceff3;
  border-radius: 999rpx;
}

.version-intro-status-text {
  font-size: 20rpx;
  line-height: 1.2;
  color: #97a0ad;
  font-weight: 700;
}

.version-intro-cycle {
  display: block;
  margin-top: 10rpx;
  font-size: 23rpx;
  line-height: 1.4;
  color: #4a6286;
  font-weight: 600;
}

.version-intro-hint {
  display: block;
  margin-top: 12rpx;
  font-size: 22rpx;
  line-height: 1.5;
  color: #8b97aa;
}

.version-intro-unavailable {
  display: block;
  margin-top: 12rpx;
  font-size: 22rpx;
  line-height: 1.5;
  color: #98a1ae;
}

/* 底部购买栏 */
.buy-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 -2rpx 16rpx rgba(0,0,0,0.08);
}

.btn-buy {
  background: #1A6EFF;
  color: #fff;
  border-radius: 50rpx;
  padding: 24rpx 64rpx;
  font-size: 30rpx;
  font-weight: 700;
  border: none;
}

.btn-buy-foundation {
  background: linear-gradient(90deg, #1A6EFF 0%, #4a9eff 100%);
}

.btn-buy-special {
  background: linear-gradient(90deg, #e49b00 0%, #f4b400 100%);
  box-shadow: 0 14rpx 28rpx rgba(244, 180, 0, 0.22);
}

.btn-buy::after {
  border: none;
}
