.intro-page {
  min-height: 100vh;
  background: #f5f6fa;
  padding-bottom: 160rpx;
}

.intro-hero {
  background: linear-gradient(150deg, #1248cc, #1A6EFF 60%, #4a9eff);
  padding: 48rpx 40rpx 56rpx;
  display: flex;
  flex-direction: column;
}

.intro-hero-tag {
  align-self: flex-start;
  background: rgba(255,255,255,0.25);
  color: #fff;
  font-size: 22rpx;
  font-weight: 600;
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
  margin-bottom: 20rpx;
  letter-spacing: 2rpx;
}

.intro-hero-name {
  font-size: 52rpx;
  font-weight: 700;
  color: #fff;
  display: block;
  margin-bottom: 16rpx;
  letter-spacing: 1rpx;
}

.intro-hero-tagline {
  font-size: 28rpx;
  color: rgba(255,255,255,0.85);
  display: block;
  line-height: 1.6;
}

.intro-section {
  margin-top: 16rpx;
}

.intro-section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1a1a1a;
  display: block;
  margin-bottom: 24rpx;
}

/* 症状列表 */
.symptom-item {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  margin-bottom: 20rpx;
}

.symptom-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #ff4d4f;
  margin-top: 10rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.symptom-text {
  font-size: 28rpx;
  color: #444;
  line-height: 1.6;
  flex: 1;
}

/* 解决方案列表 */
.solution-item {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  margin-bottom: 20rpx;
}

.solution-icon {
  width: 40rpx;
  height: 40rpx;
  margin-right: 16rpx;
  margin-top: 4rpx;
  flex-shrink: 0;
}

.solution-text {
  font-size: 28rpx;
  color: #444;
  line-height: 1.6;
  flex: 1;
}

/* 课程包含 */
.include-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f6fa;
}

.include-item:last-child {
  border-bottom: none;
}

.include-icon {
  width: 44rpx;
  height: 44rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
  filter: drop-shadow(0 10rpx 14rpx rgba(37, 99, 235, 0.08));
}

.include-info {
  flex: 1;
}

.include-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 4rpx;
}

.include-desc {
  font-size: 24rpx;
  color: #999;
}

/* 授课老师 */
.teacher-card {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f5f6fa;
}

.teacher-card:last-child {
  border-bottom: none;
}

.teacher-avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #1A6EFF, #4a9eff);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-right: 24rpx;
}

.teacher-avatar-text {
  color: #fff;
  font-size: 36rpx;
  font-weight: 700;
}

.teacher-info {
  flex: 1;
}

.teacher-name-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  margin-bottom: 8rpx;
}

.teacher-name {
  font-size: 32rpx;
  font-weight: 700;
  color: #333;
  margin-right: 12rpx;
}

.teacher-subject-tag {
  font-size: 20rpx;
  color: #1A6EFF;
  background: #e8f0ff;
  padding: 4rpx 14rpx;
  border-radius: 8rpx;
}

.teacher-exp {
  font-size: 22rpx;
  color: #999;
  display: block;
  margin-bottom: 8rpx;
}

.teacher-desc {
  font-size: 26rpx;
  color: #555;
  line-height: 1.6;
}

/* 底部购买栏 */
.buy-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 -2rpx 16rpx rgba(0,0,0,0.08);
}

.buy-price-area {
  display: flex;
  flex-direction: row;
  align-items: baseline;
}

.buy-price {
  font-size: 52rpx;
  font-weight: 700;
  color: #ff4d4f;
}

.buy-price-unit {
  font-size: 24rpx;
  color: #999;
  margin-left: 4rpx;
}

.btn-buy {
  background: #1A6EFF;
  color: #fff;
  border-radius: 50rpx;
  padding: 24rpx 64rpx;
  font-size: 30rpx;
  font-weight: 700;
  border: none;
}

.btn-buy::after {
  border: none;
}
