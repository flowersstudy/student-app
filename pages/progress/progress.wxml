<view class="progress-page">
  <!-- 顶部老师信息 -->
  <view class="card teacher-card">

    <!-- 已分配老师 -->
    <view wx:if="{{teacher.assigned}}" class="teacher-row" bindtap="goTeacher">
      <view class="teacher-avatar">
        <text class="teacher-avatar-text">{{teacher.avatar}}</text>
      </view>
      <view class="teacher-info">
        <view class="teacher-name-row">
          <text class="teacher-name">{{teacher.name}}</text>
          <text class="teacher-title-tag">{{teacher.title}}</text>
        </view>
        <text class="teacher-years">从教 {{teacher.years}} 年 · 点击查看详情</text>
      </view>
      <text class="teacher-arrow">›</text>
    </view>

    <!-- 未分配老师 -->
    <view wx:else class="teacher-row teacher-pending-row">
      <view class="teacher-avatar-pending">
        <text class="teacher-pending-icon">?</text>
      </view>
      <view class="teacher-info">
        <text class="teacher-pending-title">等待老师分配</text>
        <text class="teacher-pending-desc">老师确认后将自动更新</text>
      </view>
      <text class="tag tag-gray">待分配</text>
    </view>

    <view class="teacher-divider"></view>

    <!-- 进度条 -->
    <view class="progress-row">
      <view class="row-between" style="margin-bottom:12rpx;">
        <text class="progress-label">整体完成度</text>
        <text class="progress-percent">{{overallProgress}}%</text>
      </view>
      <view class="progress-bar-bg">
        <view class="progress-bar-fill" style="width:{{overallProgress}}%"></view>
      </view>
    </view>
  </view>

  <!-- 任务时间线 -->
  <view class="section-title" style="padding:0 24rpx;margin:16rpx 0 8rpx;">课程任务</view>

  <view class="timeline">
    <view wx:for="{{tasks}}" wx:key="id" class="timeline-item">
      <view class="timeline-left">
        <view class="timeline-dot {{item.status === '待开始' ? 'timeline-dot-gray' : ''}}"></view>
        <view class="timeline-line" wx:if="{{index < tasks.length - 1}}"></view>
      </view>
      <view class="timeline-content">
        <view class="task-card">
          <view class="task-header">
            <text class="task-day">{{item.day}}</text>
            <text class="tag {{item.status === '已完成' ? 'tag-green' : item.status === '进行中' ? 'tag-blue' : 'tag-gray'}}">{{item.status}}</text>
          </view>
          <view class="row-between" style="margin-top:12rpx;">
            <text class="task-label">{{item.label}}</text>
            <button class="btn-task" bindtap="goTask" data-url="{{item.url}}">{{item.btnText}}</button>
          </view>
          <!-- 收起/展开控制 -->
          <view wx:if="{{item.subTasks}}" class="subtask-toggle" bindtap="toggleExpand" data-taskid="{{item.id}}">
            <view class="subtask-toggle-line"></view>
            <text class="subtask-toggle-arrow {{item.expanded ? 'subtask-arrow-up' : ''}}">▾</text>
            <view class="subtask-toggle-line"></view>
          </view>
          <!-- 二级题目列表 -->
          <view wx:if="{{item.expanded}}" class="subtask-list">
            <view
              wx:for="{{item.subTasks}}"
              wx:for-item="sub"
              wx:key="id"
              class="subtask-item"
              bindtap="goSubTask"
              data-url="{{sub.url}}"
            >
              <view class="subtask-index">{{sub.id}}</view>
              <text class="subtask-title">{{sub.title}}</text>
              <text class="tag {{sub.status === '已完成' ? 'tag-green' : sub.status === '进行中' ? 'tag-blue' : 'tag-gray'}}">{{sub.status}}</text>
              <text class="subtask-arrow">›</text>
            </view>
          </view>
        </view>
      </view>
    </view>
  </view>

  <view class="safe-bottom"></view>
</view>
