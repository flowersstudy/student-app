<view class="progress-page">
  <view class="card progress-hero-card">
    <view class="progress-hero-top">
      <view class="progress-hero-main">
        <text class="progress-hero-kicker">卡点学习路径</text>
        <text class="progress-hero-title">{{pointName}}</text>
      </view>
      <view class="progress-version-badge">
        <text class="progress-version-badge-text">{{currentVersionMeta.shortLabel}}</text>
      </view>
    </view>
    <text class="progress-hero-desc">{{progressHint}}</text>
    <view class="progress-facts">
      <view class="progress-fact-item">
        <text class="progress-fact-value">{{progressPercent}}%</text>
        <text class="progress-fact-label">当前进度</text>
      </view>
      <view class="progress-fact-item">
        <text class="progress-fact-value">{{totalTaskCount}}</text>
        <text class="progress-fact-label">学习任务</text>
      </view>
      <view class="progress-fact-item">
        <text class="progress-fact-value">{{completedTaskCount}}</text>
        <text class="progress-fact-label">已完成</text>
      </view>
    </view>
  </view>

  <view wx:for="{{stageGroups}}" wx:key="key" wx:for-item="group" class="card stage-card">
    <view class="stage-card-head">
      <view class="stage-card-main">
        <text class="stage-card-title">{{group.label}}</text>
        <text class="stage-card-subtitle">{{group.subtitle}}</text>
      </view>
      <view class="stage-status-badge stage-status-badge-{{group.status === '已完成' ? 'done' : group.status === '学习中' ? 'active' : 'pending'}}">
        <text class="stage-status-badge-text">{{group.status}}</text>
      </view>
    </view>

    <view class="stage-task-list">
      <view wx:for="{{group.tasks}}" wx:key="id" wx:for-item="task" class="stage-task-item">
        <view class="stage-task-left">
          <view class="stage-task-index stage-task-index-{{task.status === '已完成' ? 'done' : task.status === '学习中' ? 'active' : 'pending'}}">
            <text class="stage-task-index-text">{{task.index}}</text>
          </view>
          <view wx:if="{{index < group.tasks.length - 1}}" class="stage-task-line"></view>
        </view>
        <view class="stage-task-card">
          <view class="stage-task-top">
            <text class="stage-task-title">{{task.title}}</text>
            <text class="stage-task-status stage-task-status-{{task.status === '已完成' ? 'done' : task.status === '学习中' ? 'active' : 'pending'}}">{{task.status}}</text>
          </view>
          <text wx:if="{{task.note}}" class="stage-task-note">{{task.note}}</text>
          <view class="stage-task-bottom">
            <button class="btn-task" bindtap="goTask" data-url="{{task.url}}" data-step-name="{{task.title}}">{{task.actionText}}</button>
          </view>
        </view>
      </view>
    </view>
  </view>

  <view class="safe-bottom"></view>
</view>

<diagnose-coupon-fab auto-popup="{{true}}"></diagnose-coupon-fab>
