.progress-page {
  min-height: 100vh;
  background: #f5f6fa;
  padding-bottom: 120rpx;
}

.progress-hero-card {
  margin-top: 16rpx;
  background: linear-gradient(150deg, #1248cc 0%, #1a6eff 62%, #4a9eff 100%);
  color: #ffffff;
}

.progress-hero-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.progress-hero-main {
  flex: 1;
  min-width: 0;
}

.progress-hero-kicker {
  display: block;
  font-size: 22rpx;
  line-height: 1.2;
  color: rgba(255, 255, 255, 0.72);
}

.progress-hero-title {
  display: block;
  margin-top: 12rpx;
  font-size: 42rpx;
  line-height: 1.2;
  font-weight: 700;
  color: #ffffff;
}

.progress-version-badge {
  flex-shrink: 0;
  padding: 10rpx 18rpx;
  background: rgba(255, 255, 255, 0.18);
  border: 1rpx solid rgba(255, 255, 255, 0.16);
  border-radius: 999rpx;
}

.progress-version-badge-text {
  font-size: 22rpx;
  line-height: 1.2;
  color: #ffffff;
  font-weight: 600;
}

.progress-hero-desc {
  display: block;
  margin-top: 18rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: rgba(255, 255, 255, 0.88);
}

.progress-facts {
  margin-top: 24rpx;
  display: flex;
  gap: 16rpx;
}

.progress-fact-item {
  flex: 1;
  min-width: 0;
  padding: 18rpx 12rpx;
  background: rgba(255, 255, 255, 0.12);
  border-radius: 20rpx;
  text-align: center;
}

.progress-fact-value {
  display: block;
  font-size: 34rpx;
  line-height: 1.1;
  color: #ffffff;
  font-weight: 700;
}

.progress-fact-label {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.2;
  color: rgba(255, 255, 255, 0.72);
}

.stage-card {
  margin-top: 16rpx;
}

.stage-card-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.stage-card-main {
  flex: 1;
  min-width: 0;
}

.stage-card-title {
  display: block;
  font-size: 30rpx;
  line-height: 1.2;
  color: #1d2433;
  font-weight: 700;
}

.stage-card-subtitle {
  display: block;
  margin-top: 10rpx;
  font-size: 22rpx;
  line-height: 1.4;
  color: #8b97aa;
}

.stage-status-badge {
  flex-shrink: 0;
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
}

.stage-status-badge-done {
  background: #ecfdf3;
}

.stage-status-badge-active {
  background: #edf4ff;
}

.stage-status-badge-pending {
  background: #f2f4f7;
}

.stage-status-badge-text {
  font-size: 20rpx;
  line-height: 1.2;
  font-weight: 700;
}

.stage-status-badge-done .stage-status-badge-text {
  color: #12b76a;
}

.stage-status-badge-active .stage-status-badge-text {
  color: #1a6eff;
}

.stage-status-badge-pending .stage-status-badge-text {
  color: #98a2b3;
}

.stage-task-list {
  margin-top: 24rpx;
}

.stage-task-item {
  display: flex;
  align-items: stretch;
  gap: 20rpx;
}

.stage-task-item + .stage-task-item {
  margin-top: 18rpx;
}

.stage-task-left {
  width: 52rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  flex-shrink: 0;
}

.stage-task-index {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.stage-task-index-done {
  background: linear-gradient(180deg, #eafaf2 0%, #d5f5e3 100%);
}

.stage-task-index-active {
  background: linear-gradient(180deg, #eef4ff 0%, #dce9ff 100%);
}

.stage-task-index-pending {
  background: #f2f4f7;
}

.stage-task-index-text {
  font-size: 22rpx;
  line-height: 1;
  font-weight: 700;
}

.stage-task-index-done .stage-task-index-text {
  color: #12b76a;
}

.stage-task-index-active .stage-task-index-text {
  color: #1a6eff;
}

.stage-task-index-pending .stage-task-index-text {
  color: #98a2b3;
}

.stage-task-line {
  margin-top: 10rpx;
  width: 4rpx;
  flex: 1;
  border-radius: 999rpx;
  background: #dbe3ef;
}

.stage-task-card {
  flex: 1;
  min-width: 0;
  padding: 22rpx 24rpx;
  background: #f8fafc;
  border: 1rpx solid #e7edf4;
  border-radius: 22rpx;
  box-sizing: border-box;
}

.stage-task-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.stage-task-title {
  flex: 1;
  min-width: 0;
  font-size: 26rpx;
  line-height: 1.5;
  color: #1d2433;
  font-weight: 600;
}

.stage-task-status {
  flex-shrink: 0;
  font-size: 22rpx;
  line-height: 1.2;
  font-weight: 700;
}

.stage-task-status-done {
  color: #12b76a;
}

.stage-task-status-active {
  color: #1a6eff;
}

.stage-task-status-pending {
  color: #98a2b3;
}

.stage-task-note {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.5;
  color: #7b8aa0;
}

.stage-task-bottom {
  margin-top: 18rpx;
  display: flex;
  align-items: center;
  justify-content: flex-end;
}

.btn-task {
  background: #1A6EFF;
  color: #ffffff;
  font-size: 24rpx;
  padding: 12rpx 28rpx;
  border-radius: 36rpx;
  border: none;
  flex-shrink: 0;
  line-height: 1.5;
}

.btn-task::after {
  border: none;
}
