<view class="chat-page">
  <view class="intro-block">
    <text class="intro-title">{{title}}</text>
    <text class="intro-desc">{{desc}}</text>
  </view>

  <view class="section">
    <text class="section-title">{{feedbackTitle}}</text>
    <text class="section-hint">{{feedbackHint}}</text>
    <textarea
      class="feedback-input"
      maxlength="-1"
      placeholder="{{placeholder}}"
      placeholder-class="feedback-placeholder"
      value="{{feedbackText}}"
      cursor-spacing="24"
      show-confirm-bar="{{false}}"
      auto-height
      bindinput="handleInput"
    />
  </view>

  <view class="section">
    <text class="section-title">上传图片</text>
    <text class="section-hint">比如页面问题、排版问题，或你想特别说明的地方。</text>

    <view class="upload-entry" bindtap="chooseImage">
      <view class="upload-entry-icon">
        <text class="upload-entry-plus">+</text>
      </view>
      <text class="upload-entry-text">添加图片</text>
    </view>

    <view wx:if="{{images.length > 0}}" class="upload-list">
      <view wx:for="{{images}}" wx:key="id" class="image-card">
        <image
          class="image-preview"
          src="{{item.path}}"
          mode="aspectFill"
          bindtap="previewImage"
          data-url="{{item.path}}"
        />
        <view class="image-remove" catchtap="removeImage" data-id="{{item.id}}">
          <text class="image-remove-text">×</text>
        </view>
      </view>
    </view>
  </view>

  <button class="submit-button" bindtap="handleSubmit" loading="{{submitting}}" disabled="{{submitting}}">{{submitText}}</button>
</view>
