<view class="chat-page">

  <!-- 未购课空状态 -->
  <block wx:if="{{!isEnrolled}}">
    <view class="empty-state">
      <view class="empty-icon">💬</view>
      <text class="empty-title">暂无师生对话</text>
      <text class="empty-desc">购课后，你将加入专属学习群，与带教老师、学管实时沟通</text>
      <button class="btn-primary empty-btn" bindtap="goEnroll">去选课</button>
    </view>
  </block>

  <!-- 已购课内容 -->
  <block wx:else>

  <!-- 右上角菜单 -->
  <view class="nav-more" bindtap="toggleMemberPanel">
    <text class="nav-more-icon">⋯</text>
  </view>

  <!-- 消息列表 -->
  <scroll-view scroll-y class="msg-list" scroll-with-animation>
    <view wx:for="{{messages}}" wx:key="id" class="msg-item {{item.type === 'student' ? 'msg-right' : 'msg-left'}}">

      <image
        wx:if="{{item.avatarUrl}}"
        class="msg-avatar"
        src="{{item.avatarUrl}}"
        mode="aspectFill"
      />
      <view wx:else class="msg-avatar avatar-fallback {{item.type === 'student' ? 'avatar-self' : 'avatar-other'}}">
        <text class="msg-avatar-text">{{item.avatar}}</text>
      </view>

      <view class="msg-body">
        <view class="msg-meta {{item.type === 'student' ? 'meta-right' : ''}}">
          <text class="msg-name">{{item.name}}</text>
          <text class="msg-time">{{item.time}}</text>
        </view>
        <view class="msg-bubble {{item.type === 'student' ? 'bubble-green' : 'bubble-white'}}">
          <text class="msg-content">{{item.content}}</text>
        </view>
      </view>

    </view>
    <view style="height:160rpx;"></view>
  </scroll-view>

  <!-- 底部整体容器（输入栏+面板） -->
  <view class="input-area-wrap">

    <!-- 主输入栏 -->
    <view class="input-bar">
      <!-- 语音/键盘切换 -->
      <view class="input-action" bindtap="toggleVoice">
        <text class="input-action-icon">{{voiceMode ? '⌨️' : '🎤'}}</text>
      </view>

      <!-- 文字输入 / 按住说话 -->
      <view wx:if="{{voiceMode}}" class="voice-btn" bindtouchstart="startRecord" bindtouchend="stopRecord">
        <text class="voice-btn-text">按住说话</text>
      </view>
      <input
        wx:else
        class="chat-input"
        value="{{inputText}}"
        placeholder="输入消息..."
        placeholder-class="input-placeholder"
        bindinput="onInputChange"
        confirm-type="send"
        bindconfirm="sendMessage"
        bindfocus="onInputFocus"
      />

      <!-- 表情 -->
      <view class="input-action" bindtap="toggleEmoji">
        <text class="input-action-icon">{{showEmoji ? '⌨️' : '😊'}}</text>
      </view>

      <!-- 更多 或 发送 -->
      <view wx:if="{{inputText}}" class="send-btn" bindtap="sendMessage">
        <text class="send-text">发送</text>
      </view>
      <view wx:else class="input-action" bindtap="toggleMore">
        <text class="input-action-icon">➕</text>
      </view>
    </view>

    <!-- 表情包面板 -->
    <view wx:if="{{showEmoji}}" class="emoji-panel">
      <view
        wx:for="{{emojiList}}"
        wx:key="index"
        class="emoji-item"
        bindtap="sendEmoji"
        data-emoji="{{item}}"
      >
        <text class="emoji-text">{{item}}</text>
      </view>
    </view>

    <!-- 更多面板 -->
    <view wx:if="{{showMore}}" class="more-panel">
      <view class="more-item" bindtap="sendImage">
        <view class="more-icon-box more-icon-blue"><text class="more-icon">🖼️</text></view>
        <text class="more-label">图片</text>
      </view>
      <view class="more-item" bindtap="sendFile">
        <view class="more-icon-box more-icon-purple"><text class="more-icon">📄</text></view>
        <text class="more-label">文件</text>
      </view>
      <view class="more-item" bindtap="sendCamera">
        <view class="more-icon-box more-icon-green"><text class="more-icon">📷</text></view>
        <text class="more-label">拍照</text>
      </view>
      <view class="more-item" bindtap="goLeave">
        <view class="more-icon-box more-icon-orange"><text class="more-icon">🙋</text></view>
        <text class="more-label">申请请假</text>
      </view>
      <view class="more-item" bindtap="goMailbox">
        <view class="more-icon-box more-icon-red"><text class="more-icon">📮</text></view>
        <text class="more-label">校长信箱</text>
      </view>
    </view>

  </view>

  <!-- 成员弹窗遮罩 -->
  <view class="panel-mask" wx:if="{{showMemberPanel}}" bindtap="closeMemberPanel"></view>

  <!-- 成员列表弹窗 -->
  <view class="member-panel {{showMemberPanel ? 'panel-show' : ''}}">
    <text class="panel-title">群成员</text>
    <view wx:for="{{members}}" wx:key="name" class="member-item">
      <view class="member-avatar">
        <text class="member-avatar-text">{{item.avatar}}</text>
      </view>
      <view class="member-info">
        <text class="member-name">{{item.name}}</text>
        <text class="member-role">{{item.role}}</text>
      </view>
    </view>
    <view class="divider"></view>
    <view class="clear-btn" bindtap="clearChat">
      <text class="clear-btn-text">清空聊天记录</text>
    </view>
  </view>

  </block>

</view>
