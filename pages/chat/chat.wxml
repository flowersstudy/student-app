<view class="chat-page">
  <view class="nav-more" bindtap="toggleMemberPanel">
    <image class="nav-more-icon" src="{{inputIcons.menu}}" mode="aspectFit" />
  </view>

  <scroll-view scroll-y class="msg-list" scroll-with-animation scroll-into-view="{{scrollIntoView}}">
    <view
      wx:for="{{messages}}"
      wx:key="id"
      id="msg-{{item.clientId || item.id}}"
      class="msg-item {{item.type === 'student' ? 'msg-right' : 'msg-left'}}"
    >
      <image
        wx:if="{{item.avatarUrl}}"
        class="msg-avatar"
        src="{{item.avatarUrl}}"
        mode="aspectFill"
      />
      <view
        wx:else
        class="msg-avatar avatar-fallback {{item.type === 'student' ? 'avatar-self' : 'avatar-other'}}"
      >
        <text class="msg-avatar-text">{{item.avatar}}</text>
      </view>

      <view class="msg-body">
        <view class="msg-meta {{item.type === 'student' ? 'meta-right' : ''}}">
          <text class="msg-name">{{item.name}}</text>
          <text class="msg-time">{{item.time}}</text>
        </view>
        <view
          class="msg-bubble {{item.type === 'student' ? 'bubble-green' : 'bubble-white'}} {{item.navigateUrl ? 'msg-bubble-clickable' : ''}}"
          bindtap="handleMessageTap"
          data-url="{{item.navigateUrl || ''}}"
        >
          <text wx:if="{{item.content}}" class="msg-content">{{item.content}}</text>

          <view wx:if="{{item.coupon}}" class="coupon-card">
            <view class="coupon-topline">
              <text class="coupon-badge">{{item.coupon.badge}}</text>
              <text class="coupon-save">{{item.coupon.saveText}}</text>
            </view>
            <text class="coupon-title">{{item.coupon.title}}</text>
            <text class="coupon-subtitle">{{item.coupon.subtitle}}</text>
            <view class="coupon-price-row">
              <text class="coupon-price">{{item.coupon.price}}</text>
              <text class="coupon-original-price">{{item.coupon.originalPrice}}</text>
            </view>
            <view class="coupon-tag-row">
              <text wx:for="{{item.coupon.tags}}" wx:key="*this" class="coupon-tag">{{item}}</text>
            </view>
            <text class="coupon-action-text">{{item.coupon.actionText}}</text>
          </view>

          <view wx:if="{{item.imageUrl}}" class="msg-image-shell">
            <image class="msg-image" src="{{item.imageUrl}}" mode="widthFix" />
          </view>
          <text wx:if="{{item.imageCaption}}" class="msg-image-caption">{{item.imageCaption}}</text>
        </view>
        <text
          wx:if="{{item.type === 'student' && item.sendStatus && item.sendStatus !== 'sent'}}"
          class="msg-delivery-status msg-delivery-status-{{item.sendStatus}}"
        >
          {{item.sendStatus === 'sending' ? '发送中...' : item.sendStatus === 'queued' ? '等待连接...' : '发送失败'}}
        </text>
      </view>
    </view>
  </scroll-view>
    <view style="height:160rpx;"></view>

  <view class="input-area-wrap">
    <view class="input-bar">
      <view class="input-action" bindtap="toggleVoice">
        <image
          class="input-action-icon"
          src="{{voiceMode ? inputIcons.keyboard : inputIcons.voice}}"
          mode="aspectFit"
        />
      </view>

      <view
        wx:if="{{voiceMode}}"
        class="voice-btn"
        bindtouchstart="startRecord"
        bindtouchend="stopRecord"
      >
        <text class="voice-btn-text">按住说话</text>
      </view>
      <input
        wx:else
        class="chat-input"
        value="{{inputText}}"
        placeholder="输入消息..."
        placeholder-class="input-placeholder"
        bindinput="onInputChange"
        confirm-type="send"
        bindconfirm="sendMessage"
        bindfocus="onInputFocus"
      />

      <view class="input-action" bindtap="toggleEmoji">
        <image
          class="input-action-icon"
          src="{{showEmoji ? inputIcons.keyboard : inputIcons.emoji}}"
          mode="aspectFit"
        />
      </view>

      <view wx:if="{{inputText}}" class="send-btn" bindtap="sendMessage">
        <text class="send-text">发送</text>
      </view>
      <view wx:else class="input-action" bindtap="toggleMore">
        <image
          class="input-action-icon input-action-icon-plus"
          src="{{inputIcons.plus}}"
          mode="aspectFit"
        />
      </view>
    </view>

    <view wx:if="{{showEmoji}}" class="emoji-panel">
      <view
        wx:for="{{emojiList}}"
        wx:key="index"
        class="emoji-item"
        bindtap="sendEmoji"
        data-emoji="{{item}}"
      >
        <text class="emoji-text">{{item}}</text>
      </view>
    </view>

    <view wx:if="{{showMore}}" class="more-panel">
      <view
        wx:for="{{quickActions}}"
        wx:key="key"
        class="more-item"
        bindtap="handleQuickAction"
        data-key="{{item.key}}"
      >
        <view class="more-icon-stage more-icon-{{item.tone}}">
          <image class="more-icon" src="{{item.icon}}" mode="aspectFit" />
        </view>
        <text class="more-label">{{item.label}}</text>
      </view>
    </view>
  </view>

  <view class="panel-mask" wx:if="{{showMemberPanel}}" bindtap="closeMemberPanel"></view>

  <view class="member-panel {{showMemberPanel ? 'panel-show' : ''}}">
    <text class="panel-title">会话成员</text>
    <view wx:for="{{members}}" wx:key="name" class="member-item">
      <view class="member-avatar">
        <text class="member-avatar-text">{{item.avatar}}</text>
      </view>
      <view class="member-info">
        <text class="member-name">{{item.name}}</text>
        <text class="member-role">{{item.role}}</text>
      </view>
    </view>
    <view class="divider"></view>
    <view class="clear-btn" bindtap="clearChat">
      <text class="clear-btn-text">恢复初始对话</text>
    </view>
  </view>
</view>

<diagnose-coupon-fab auto-popup="{{true}}"></diagnose-coupon-fab>
