.chat-page {
  min-height: 100vh;
  padding: 32rpx 24rpx 56rpx;
  background: #f5f6fa;
  box-sizing: border-box;
}

.intro-block {
  padding: 28rpx;
  background: #ffffff;
  border-radius: 20rpx;
  border: 1rpx solid #e5e7eb;
}

.intro-title {
  display: block;
  font-size: 32rpx;
  line-height: 1.4;
  color: #1f2937;
  font-weight: 700;
}

.intro-desc {
  display: block;
  margin-top: 16rpx;
  font-size: 26rpx;
  line-height: 1.75;
  color: #6b7280;
}

.section {
  margin-top: 20rpx;
  padding: 28rpx;
  background: #ffffff;
  border-radius: 20rpx;
  border: 1rpx solid #e5e7eb;
}

.section-title {
  display: block;
  font-size: 32rpx;
  line-height: 1.4;
  color: #1f2937;
  font-weight: 700;
}

.section-hint {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #6b7280;
}

.feedback-input {
  width: 100%;
  min-height: 300rpx;
  margin-top: 24rpx;
  padding: 0;
  background: transparent;
  box-sizing: border-box;
  font-size: 28rpx;
  line-height: 1.8;
  color: #1f2937;
}

.feedback-placeholder {
  color: #9ca3af;
}

.upload-entry {
  display: flex;
  align-items: center;
  margin-top: 24rpx;
  padding: 22rpx 24rpx;
  border-radius: 16rpx;
  background: #f9fafb;
  border: 1rpx solid #e5e7eb;
}

.upload-entry-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 56rpx;
  height: 56rpx;
  border-radius: 14rpx;
  background: #eef2ff;
}

.upload-entry-plus {
  font-size: 34rpx;
  color: #2563eb;
  line-height: 1;
}

.upload-entry-text {
  margin-left: 18rpx;
  font-size: 28rpx;
  color: #374151;
  font-weight: 500;
}

.upload-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 24rpx;
}

.image-card {
  position: relative;
  width: calc((100% - 32rpx) / 3);
  height: 180rpx;
  border-radius: 16rpx;
  overflow: hidden;
  background: #e5e7eb;
}

.image-preview {
  width: 100%;
  height: 100%;
}

.image-remove {
  position: absolute;
  top: 10rpx;
  right: 10rpx;
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: rgba(17, 24, 39, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
}

.image-remove-text {
  color: #ffffff;
  font-size: 26rpx;
  line-height: 1;
}

.submit-button {
  width: 100%;
  margin-top: 32rpx;
  height: 88rpx;
  line-height: 88rpx;
  background: #2563eb;
  color: #ffffff;
  border-radius: 18rpx;
  font-size: 30rpx;
  font-weight: 600;
  padding: 0;
  text-align: center;
  border: none;
}

.submit-button::after {
  border: none;
}
