.drill-page {
  position: relative;
  min-height: 100vh;
  padding: 20rpx;
  box-sizing: border-box;
  overflow: hidden;
  background: #f5f7fb;
}

.bg-glow {
  display: none;
}

.hero-card,
.route-card {
  position: relative;
  z-index: 1;
  border-radius: 30rpx;
  overflow: hidden;
  background: #ffffff;
  border: 2rpx solid #e8edf5;
}

.hero-card {
  padding: 24rpx 22rpx 20rpx;
  box-shadow: 0 12rpx 28rpx rgba(31, 41, 55, 0.05);
}

.hero-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: 42rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  background: #edf4ff;
  color: #1a6eff;
  font-size: 20rpx;
  font-weight: 700;
}

.hero-title {
  display: block;
  margin-top: 14rpx;
  color: #1f2937;
  font-size: 34rpx;
  line-height: 1.28;
  font-weight: 700;
}

.hero-desc {
  display: block;
  margin-top: 8rpx;
  color: #667789;
  font-size: 22rpx;
  line-height: 1.58;
}

.hero-overview {
  display: flex;
  gap: 10rpx;
  margin-top: 18rpx;
}

.overview-item {
  flex: 1;
  min-width: 0;
  padding: 14rpx 12rpx;
  border-radius: 20rpx;
  background: #f7f9fc;
}

.overview-value {
  display: block;
  color: #1f2937;
  font-size: 24rpx;
  line-height: 1.2;
  font-weight: 700;
}

.overview-label {
  display: block;
  margin-top: 6rpx;
  color: #7b8798;
  font-size: 18rpx;
  line-height: 1.4;
}

.route-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  margin-top: 16rpx;
}

.route-card {
  padding: 20rpx 18rpx 18rpx;
  box-shadow: 0 12rpx 28rpx rgba(31, 41, 55, 0.05);
  transition: transform 160ms ease;
}

.route-card-press {
  transform: scale(0.985);
}

.route-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 12rpx;
}

.route-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: 38rpx;
  padding: 0 14rpx;
  border-radius: 999rpx;
  background: #edf4ff;
  color: #1a6eff;
  font-size: 18rpx;
  font-weight: 700;
}

.route-title {
  display: block;
  margin-top: 12rpx;
  color: #1f2937;
  font-size: 30rpx;
  line-height: 1.28;
  font-weight: 700;
}

.route-icon-shell {
  width: 74rpx;
  height: 74rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 22rpx;
  background: #f4f7fb;
}

.route-icon {
  width: 50rpx;
  height: 50rpx;
}

.route-desc {
  display: block;
  margin-top: 10rpx;
  color: #657587;
  font-size: 21rpx;
  line-height: 1.55;
}

.route-stats {
  display: flex;
  gap: 10rpx;
  margin-top: 16rpx;
}

.route-stat {
  flex: 1;
  min-width: 0;
  padding: 14rpx 14rpx;
  border-radius: 18rpx;
  background: #f7f9fc;
}

.route-stat-label {
  display: block;
  color: #8190a1;
  font-size: 18rpx;
  line-height: 1.3;
}

.route-stat-value {
  display: block;
  margin-top: 6rpx;
  color: #1f2937;
  font-size: 21rpx;
  line-height: 1.4;
  font-weight: 700;
}

.route-tags {
  display: flex;
  gap: 10rpx;
  margin-top: 14rpx;
}

.route-tag {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: #f3f6fb;
  color: #55657c;
  font-size: 18rpx;
  font-weight: 600;
}

.route-cta {
  margin-top: 16rpx;
  height: 72rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #1a6eff;
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 700;
}
