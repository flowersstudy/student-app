.trial-page {
  min-height: 100vh;
  padding: 24rpx 24rpx calc(40rpx + env(safe-area-inset-bottom));
  background: linear-gradient(180deg, #f7f9fc 0%, #eef4ff 100%);
  box-sizing: border-box;
}

.hero-card,
.section-card {
  background: #ffffff;
  border-radius: 32rpx;
  padding: 28rpx 24rpx;
  box-sizing: border-box;
  box-shadow: 0 16rpx 40rpx rgba(15, 23, 42, 0.06);
  margin-bottom: 20rpx;
}

.hero-card {
  background: linear-gradient(135deg, #1a6eff 0%, #4f8dff 100%);
}

.hero-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.18);
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 700;
}

.hero-title {
  display: block;
  margin-top: 18rpx;
  color: #ffffff;
  font-size: 42rpx;
  line-height: 1.35;
  font-weight: 800;
}

.hero-desc,
.hero-deposit {
  display: block;
  margin-top: 14rpx;
  color: rgba(255, 255, 255, 0.88);
  font-size: 24rpx;
  line-height: 1.75;
}

.hero-deposit {
  color: #ffe08a;
  font-weight: 700;
}

.section-head {
  margin-bottom: 20rpx;
}

.section-title {
  display: block;
  color: #0f172a;
  font-size: 32rpx;
  line-height: 1.4;
  font-weight: 800;
}

.section-subtitle {
  display: block;
  margin-top: 8rpx;
  color: #64748b;
  font-size: 22rpx;
  line-height: 1.6;
}

.path-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.path-item {
  display: flex;
  align-items: flex-start;
  gap: 18rpx;
  padding: 22rpx 20rpx;
  border-radius: 24rpx;
  background: #f8fbff;
  border: 1rpx solid rgba(59, 130, 246, 0.12);
}

.path-index {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  background: #1a6eff;
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.path-content {
  flex: 1;
}

.path-title {
  display: block;
  color: #0f172a;
  font-size: 28rpx;
  font-weight: 700;
}

.path-desc {
  display: block;
  margin-top: 8rpx;
  color: #64748b;
  font-size: 22rpx;
  line-height: 1.7;
}

.schedule-week {
  margin-top: 24rpx;
}

.schedule-week:first-child {
  margin-top: 0;
}

.schedule-week-title {
  display: block;
  margin-bottom: 14rpx;
  color: #1d4ed8;
  font-size: 26rpx;
  font-weight: 700;
}

.schedule-item {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  padding: 20rpx 18rpx;
  border-radius: 24rpx;
  margin-bottom: 14rpx;
  background: #f8fafc;
}

.schedule-item-task {
  border-left: 8rpx solid #2563eb;
}

.schedule-item-submit {
  border-left: 8rpx solid #7c3aed;
}

.schedule-item-review {
  border-left: 8rpx solid #ea580c;
}

.schedule-item-live {
  border-left: 8rpx solid #16a34a;
  background: #f3fbf5;
}

.schedule-item-rest {
  border-left: 8rpx solid #cbd5e1;
}

.schedule-date {
  width: 108rpx;
  flex-shrink: 0;
}

.schedule-date-num {
  display: block;
  color: #0f172a;
  font-size: 28rpx;
  font-weight: 800;
}

.schedule-date-week {
  display: block;
  margin-top: 6rpx;
  color: #64748b;
  font-size: 20rpx;
}

.schedule-content {
  flex: 1;
}

.schedule-title {
  display: block;
  color: #1e293b;
  font-size: 24rpx;
  line-height: 1.65;
  font-weight: 600;
}

.schedule-note {
  display: inline-block;
  margin-top: 10rpx;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: #e8f0ff;
  color: #1d4ed8;
  font-size: 20rpx;
  font-weight: 600;
}

.notice-item {
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
  margin-top: 18rpx;
}

.notice-item:first-child {
  margin-top: 0;
}

.notice-index {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: #eff6ff;
  color: #1d4ed8;
  font-size: 20rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.notice-text {
  flex: 1;
  color: #475569;
  font-size: 23rpx;
  line-height: 1.75;
}

.cta-card {
  text-align: center;
  padding-top: 44rpx;
  padding-bottom: 44rpx;
}

.cta-title {
  display: block;
  color: #0f172a;
  font-size: 34rpx;
  font-weight: 800;
}

.cta-desc {
  display: block;
  margin-top: 16rpx;
  color: #64748b;
  font-size: 24rpx;
  line-height: 1.75;
}

.cta-button {
  margin-top: 28rpx;
  height: 88rpx;
  border-radius: 999rpx;
  background: #1a6eff;
  display: flex;
  align-items: center;
  justify-content: center;
}

.cta-button-text {
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 700;
}
