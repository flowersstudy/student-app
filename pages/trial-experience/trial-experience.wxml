<view class="trial-page">
  <view class="hero-card">
    <text class="hero-badge">学习路径</text>
    <text class="hero-title">{{productName}}</text>
    <text class="hero-desc">不再盲目刷题——先找卡点，再开药方。先把你的学习主线跑通，再进入每周日程安排。</text>
    <text class="hero-deposit">{{depositText}}</text>
  </view>

  <view class="section-card">
    <view class="section-head">
      <text class="section-title">学习路径</text>
      <text class="section-subtitle">4 步跑通一轮完整提分闭环</text>
    </view>

    <view class="path-list">
      <view wx:for="{{pathSteps}}" wx:key="id" class="path-item" bindtap="onPathStepTap" data-step-type="{{item.scheduleType}}">
        <view class="path-index">{{index + 1}}</view>
        <view class="path-content">
          <text class="path-title">{{item.title}}</text>
          <text class="path-desc">{{item.desc}}</text>
        </view>
        <text class="path-arrow">›</text>
      </view>
    </view>
  </view>

  <block wx:if="{{isEnrolled}}">
    <view id="schedule-calendar-section" class="section-card">
      <view class="section-head">
        <text class="section-title">学习日历</text>
        <text class="section-subtitle">按日历查看刷题、作业、复盘和直播安排</text>
      </view>

      <view class="cal-card">
        <view class="cal-nav">
          <view class="cal-nav-btn" bindtap="onCalPrev">
            <text class="cal-nav-arrow">‹</text>
          </view>
          <text class="cal-nav-title">{{calendarView === 'week' ? calendarWeekTitle : calendarYear + '年' + calendarMonth + '月'}}</text>
          <view class="cal-view-toggle" bindtap="onCalToggleView">
            <text class="cal-view-toggle-text">{{calendarView === 'month' ? '周' : '月'}}</text>
          </view>
          <view class="cal-nav-btn" bindtap="onCalNext">
            <text class="cal-nav-arrow">›</text>
          </view>
        </view>

        <view class="cal-weekday-row">
          <text class="cal-weekday-label" wx:for="{{['一','二','三','四','五','六','日']}}" wx:key="*this">{{item}}</text>
        </view>

        <view wx:if="{{calendarView === 'month'}}" class="cal-month-body">
          <view wx:for="{{calendarWeeks}}" wx:for-item="week" wx:key="index" class="cal-week-container">
            <view class="cal-week-row">
              <view
                wx:for="{{week.days}}"
                wx:for-item="day"
                wx:key="dateStr"
                class="cal-day-col"
                data-date="{{day.dateStr}}"
                bindtap="onCalDayTap"
              >
                <view class="cal-day-num-wrap">
                  <view class="cal-day-circle {{day.isToday ? 'cal-today-circle' : ''}} {{day.dateStr === calendarSelectedDate && !day.isToday ? 'cal-selected-circle' : ''}}">
                    <text class="cal-day-num {{day.isCurrentMonth ? '' : 'cal-day-other'}} {{day.isToday ? 'cal-day-num-today' : ''}}">{{day.dayNum}}</text>
                  </view>
                </view>
              </view>
            </view>
            <view class="cal-week-row cal-events-row">
              <view
                wx:for="{{week.days}}"
                wx:for-item="day"
                wx:key="dateStr"
                class="cal-day-col"
                data-date="{{day.dateStr}}"
                bindtap="onCalDayTap"
              >
                <view wx:for="{{day.tasks}}" wx:for-item="task" wx:key="index" class="cal-event-block cal-event-{{task.type}}">
                  <text class="cal-event-name">{{task.label}}</text>
                </view>
              </view>
            </view>
          </view>
        </view>

        <view wx:else class="cal-month-body">
          <view class="cal-week-container">
            <view class="cal-week-row">
              <view
                wx:for="{{calendarWeekDays.days}}"
                wx:key="dateStr"
                class="cal-day-col"
                data-date="{{item.dateStr}}"
                bindtap="onCalDayTap"
              >
                <view class="cal-day-num-wrap">
                  <view class="cal-day-circle {{item.isToday ? 'cal-today-circle' : ''}} {{item.dateStr === calendarSelectedDate && !item.isToday ? 'cal-selected-circle' : ''}}">
                    <text class="cal-day-num {{item.isToday ? 'cal-day-num-today' : ''}}">{{item.dayNum}}</text>
                  </view>
                </view>
              </view>
            </view>
            <view class="cal-week-row cal-events-row">
              <view
                wx:for="{{calendarWeekDays.days}}"
                wx:key="dateStr"
                class="cal-day-col"
                data-date="{{item.dateStr}}"
                bindtap="onCalDayTap"
              >
                <view wx:for="{{item.tasks}}" wx:for-item="task" wx:key="index" class="cal-event-block cal-event-{{task.type}}">
                  <text class="cal-event-name">{{task.label}}</text>
                </view>
              </view>
            </view>
          </view>
        </view>

        <view class="selected-day-panel">
          <view class="selected-day-header">
            <text class="selected-day-title">所选日期安排</text>
            <text class="selected-day-date">{{calendarSelectedLabel}}</text>
          </view>

          <view wx:if="{{calendarSelectedTasks.length === 0}}" class="selected-day-empty">
            <text class="selected-day-empty-text">当天暂无安排</text>
          </view>

          <view wx:for="{{calendarSelectedTasks}}" wx:key="index" class="selected-day-item">
            <view class="selected-day-bar cal-event-{{item.type}}"></view>
            <view class="selected-day-info">
              <text class="selected-day-label">{{item.label}}</text>
              <text wx:if="{{item.note}}" class="selected-day-meta">{{item.note}}</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <view class="section-card">
      <view class="section-head">
        <text class="section-title">今日日程</text>
        <text class="section-subtitle">{{todayDateStr}}</text>
      </view>

      <view class="today-card">
        <view wx:if="{{todayTasks.length === 0}}" class="today-empty">
          <text class="today-empty-text">今天暂无日程</text>
        </view>

        <view wx:for="{{todayTasks}}" wx:key="index" class="today-item">
          <view class="today-item-bar cal-event-{{item.type}}"></view>
          <view class="today-item-info">
            <text class="today-item-label">{{item.label}}</text>
            <text wx:if="{{item.note}}" class="today-item-meta">{{item.note}}</text>
          </view>
        </view>
      </view>
    </view>

    <view class="section-card">
      <view class="section-head">
        <text class="section-title">注意事项</text>
      </view>

      <view wx:for="{{noticeList}}" wx:key="index" class="notice-item">
        <text class="notice-index">{{index + 1}}</text>
        <text class="notice-text">{{item}}</text>
      </view>
    </view>
  </block>

  <block wx:else>
    <view class="section-card cta-card">
      <text class="cta-title">你还没有生成专属学习计划</text>
      <text class="cta-desc">购买课程后，这里会自动展示你的月度日程安排、直播时间和每日任务节点。</text>
      <view class="cta-button" bindtap="goToPurchase">
        <text class="cta-button-text">去生成我的学习计划</text>
      </view>
    </view>
  </block>
</view>
