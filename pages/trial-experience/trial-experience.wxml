<view class="trial-page">
  <view class="hero-card">
    <text class="hero-badge">学习路径</text>
    <text class="hero-title">{{productName}}</text>
    <text class="hero-desc">不再盲目刷题——先找卡点，再开药方。先把你的学习主线跑通，再进入每周日程安排。</text>
    <text class="hero-deposit">{{depositText}}</text>
  </view>

  <view class="section-card">
    <view class="section-head">
      <text class="section-title">学习路径</text>
      <text class="section-subtitle">4 步跑通一轮完整提分闭环</text>
    </view>

    <view class="path-list">
      <view wx:for="{{pathSteps}}" wx:key="id" class="path-item">
        <view class="path-index">{{index + 1}}</view>
        <view class="path-content">
          <text class="path-title">{{item.title}}</text>
          <text class="path-desc">{{item.desc}}</text>
        </view>
      </view>
    </view>
  </view>

  <block wx:if="{{isEnrolled}}">
    <view class="section-card">
      <view class="section-head">
        <text class="section-title">日程安排</text>
        <text class="section-subtitle">买课用户可按计划完成任务、作业、复盘和直播</text>
      </view>

      <view wx:for="{{scheduleWeeks}}" wx:key="label" class="schedule-week">
        <text class="schedule-week-title">{{item.label}}</text>

        <view wx:for="{{item.days}}" wx:key="index" wx:for-item="day" class="schedule-item schedule-item-{{day.type}}">
          <view class="schedule-date">
            <text class="schedule-date-num">{{day.date}}</text>
            <text class="schedule-date-week">{{day.weekday}}</text>
          </view>
          <view class="schedule-content">
            <text class="schedule-title">{{day.title}}</text>
            <text wx:if="{{day.note}}" class="schedule-note">{{day.note}}</text>
          </view>
        </view>
      </view>
    </view>

    <view class="section-card">
      <view class="section-head">
        <text class="section-title">注意事项</text>
      </view>

      <view wx:for="{{noticeList}}" wx:key="index" class="notice-item">
        <text class="notice-index">{{index + 1}}</text>
        <text class="notice-text">{{item}}</text>
      </view>
    </view>
  </block>

  <block wx:else>
    <view class="section-card cta-card">
      <text class="cta-title">你还没有生成专属学习计划</text>
      <text class="cta-desc">购买课程后，这里会自动展示你的月度日程安排、直播时间和每日任务节点。</text>
      <view class="cta-button" bindtap="goToPurchase">
        <text class="cta-button-text">去生成我的学习计划</text>
      </view>
    </view>
  </block>
</view>
