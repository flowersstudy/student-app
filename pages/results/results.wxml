<view class="results-page">
  <view class="profile-summary-section">
    <view class="profile-summary-card">
      <view class="profile-avatar-box" bindtap="goAvatarPicker">
        <image
          wx:if="{{profileSummary.avatarUrl}}"
          class="profile-avatar-image"
          src="{{profileSummary.avatarUrl}}"
          mode="aspectFill"
        />
        <view wx:else class="profile-avatar-fallback">
          <text class="profile-avatar-text">{{profileSummary.avatarText}}</text>
        </view>
      </view>

      <view class="profile-summary-main">
        <view class="profile-summary-head">
          <view class="profile-summary-title">
            <text class="profile-summary-name">{{studentName}}</text>
            <text class="profile-summary-tag">{{profileSummary.identityTag}}</text>
          </view>
          <text class="profile-summary-action" bindtap="goAvatarPicker">更换头像</text>
        </view>

        <view class="profile-summary-grid">
          <view class="profile-summary-item">
            <text class="profile-summary-label">目标考试</text>
            <text class="profile-summary-value">{{profileSummary.targetExam}}</text>
          </view>
          <view class="profile-summary-item">
            <text class="profile-summary-label">考试倒计时</text>
            <text class="profile-summary-value profile-summary-value-accent">{{profileSummary.examCountdown}}</text>
          </view>
          <view class="profile-summary-item">
            <text class="profile-summary-label">提分目标</text>
            <text class="profile-summary-value">{{profileSummary.raiseTarget}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <view class="summary-section">
    <view class="summary-board">
      <view class="summary-top-row">
        <view class="summary-main">
          <image class="summary-bg-icon" src="{{uiIcons.calendar}}" mode="aspectFit" />
          <view class="summary-content">
            <view class="summary-label-row">
              <text class="summary-label">累计学习时长</text>
            </view>
            <text class="summary-value">{{totalStudyDisplay}}</text>
          </view>
        </view>

        <view class="summary-points">
          <image class="summary-points-bg-icon" src="{{uiIcons.points}}" mode="aspectFit" />
          <view class="summary-content">
            <view class="summary-label-row">
              <text class="summary-points-label">累计积分</text>
            </view>
            <text class="summary-points-value">{{totalPoints}}</text>
          </view>
        </view>
      </view>

      <view class="summary-bottom-row">
        <view
          class="stat-chip stat-goal {{!hasDiagnoseCourse ? 'stat-chip-clickable' : ''}}"
          bindtap="handleGoalGapTap"
        >
          <text class="stat-chip-label">目标提分</text>
          <view class="stat-chip-main">
            <text class="stat-chip-value">{{stats.scoreGap}}</text>
            <text class="stat-chip-unit">分</text>
          </view>
        </view>
        <view class="stat-chip stat-solved">
          <text class="stat-chip-label">已解决</text>
          <view class="stat-chip-main">
            <text class="stat-chip-value">{{stats.solved}}</text>
            <text class="stat-chip-unit">个</text>
          </view>
        </view>
        <view class="stat-chip stat-pending">
          <text class="stat-chip-label">待突破</text>
          <view class="stat-chip-main">
            <text class="stat-chip-value">{{stats.pending}}</text>
            <text class="stat-chip-unit">个</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <view id="diagnosis-report-section" class="card fold-card fold-card-diagnose">
    <view class="fold-card-head" bindtap="toggleSection" data-key="diagnose">
      <view class="fold-card-head-main">
        <view class="fold-card-title-row">
          <text class="fold-card-title">诊断课</text>
          <text class="fold-card-tag">{{hasDiagnoseCourse ? '已开通' : '未开通'}}</text>
        </view>
      </view>
      <view class="fold-card-head-side">
        <text class="fold-card-meta">{{diagnosisReport.reportDate}}</text>
        <view class="section-toggle-arrow {{sectionExpanded.diagnose ? 'section-toggle-arrow-open' : ''}}"></view>
      </view>
    </view>

    <view wx:if="{{sectionExpanded.diagnose}}" class="fold-card-body fold-card-entry-body">
      <view class="fold-entry-item">
        <text class="fold-entry-title">{{hasDiagnoseCourse ? '我的诊断报告' : '我的专属学习计划'}}</text>
        <button class="fold-entry-btn" bindtap="goDiagnoseReport">
          <text class="fold-entry-btn-text">{{hasDiagnoseCourse ? '查看' : '去生成'}}</text>
        </button>
      </view>
      <view class="fold-entry-item">
        <text class="fold-entry-title">我的学习数据</text>
        <button class="fold-entry-btn" bindtap="goStudyData" data-scene="diagnose">
          <text class="fold-entry-btn-text">查看</text>
        </button>
      </view>
    </view>
  </view>

  <view class="card fold-card fold-card-solved">
    <view class="fold-card-head" bindtap="toggleSection" data-key="solved">
      <view class="fold-card-head-main">
        <view class="fold-card-title-row">
          <text class="fold-card-title">已解决卡点</text>
          <text class="fold-card-tag fold-card-tag-solved">{{solvedPoints.length}} 个</text>
        </view>
      </view>
      <view class="fold-card-head-side">
        <view class="section-toggle-arrow {{sectionExpanded.solved ? 'section-toggle-arrow-open' : ''}}"></view>
      </view>
    </view>

    <view wx:if="{{sectionExpanded.solved}}" class="fold-card-body fold-card-list-body">
      <view wx:for="{{solvedPoints}}" wx:key="id" class="fold-card-list-item fold-card-list-item-solved">
        <view class="row-between">
          <text class="point-block-name">{{item.name}}</text>
          <button class="btn-detail" bindtap="goCardDetail" data-id="{{item.id}}">查看详情</button>
        </view>
        <text class="point-block-summary">{{item.summary}}</text>
        <text class="point-block-date">完成时间：{{item.completedAt}}</text>
      </view>
    </view>
  </view>

  <view class="card fold-card fold-card-pending">
    <view class="fold-card-head" bindtap="toggleSection" data-key="pending">
      <view class="fold-card-head-main">
        <view class="fold-card-title-row">
          <text class="fold-card-title">待突破卡点</text>
          <text class="fold-card-tag fold-card-tag-pending">{{pendingPoints.length}} 个</text>
        </view>
      </view>
      <view class="fold-card-head-side">
        <view class="section-toggle-arrow {{sectionExpanded.pending ? 'section-toggle-arrow-open' : ''}}"></view>
      </view>
    </view>

    <view wx:if="{{sectionExpanded.pending}}" class="fold-card-body fold-card-list-body">
      <view wx:for="{{pendingPoints}}" wx:key="id" class="fold-card-list-item fold-card-list-item-pending">
        <view class="row-between">
          <text class="point-block-name">{{item.name}}</text>
        </view>
        <text class="point-block-summary">{{item.desc}}</text>
      </view>
    </view>
  </view>

  <view id="practice-report-section" class="card fold-card fold-card-practice">
    <view class="fold-card-head" bindtap="toggleSection" data-key="practice">
      <view class="fold-card-head-main">
        <view class="fold-card-title-row">
          <text class="fold-card-title">刷题课</text>
          <text class="fold-card-tag fold-card-tag-practice">{{practiceCourse.cycleLabel}}</text>
        </view>
      </view>
      <view class="fold-card-head-side">
        <view class="section-toggle-arrow {{sectionExpanded.practice ? 'section-toggle-arrow-open' : ''}}"></view>
      </view>
    </view>

    <view wx:if="{{sectionExpanded.practice}}" class="fold-card-body fold-card-entry-body">
      <view class="fold-entry-item">
        <text class="fold-entry-title">{{hasPracticeCourse ? '我的刷题报告' : '我的专属刷题计划'}}</text>
        <button class="fold-entry-btn" bindtap="goPracticeCourse">
          <text class="fold-entry-btn-text">{{hasPracticeCourse ? '查看' : '去生成'}}</text>
        </button>
      </view>
      <view class="fold-entry-item">
        <text class="fold-entry-title">我的学习数据</text>
        <button class="fold-entry-btn" bindtap="goStudyData" data-scene="practice">
          <text class="fold-entry-btn-text">查看</text>
        </button>
      </view>
    </view>
  </view>

  <view class="safe-bottom"></view>
</view>

<diagnose-coupon-fab auto-popup="{{true}}"></diagnose-coupon-fab>
<bottom-nav selected="results"></bottom-nav>
