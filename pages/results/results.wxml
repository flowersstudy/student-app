<view class="results-page">
  <view class="profile-summary-section">
    <view class="profile-summary-card">
      <view class="profile-avatar-box" bindtap="goAvatarPicker">
        <image
          wx:if="{{profileSummary.avatarUrl}}"
          class="profile-avatar-image"
          src="{{profileSummary.avatarUrl}}"
          mode="aspectFill"
        />
        <view wx:else class="profile-avatar-fallback">
          <text class="profile-avatar-text">{{profileSummary.avatarText}}</text>
        </view>
      </view>

      <view class="profile-summary-main">
        <view class="profile-summary-inline">
          <text class="profile-summary-name">{{studentName}}</text>
          <text class="profile-summary-divider">·</text>
          <text class="profile-summary-goal-inline">{{profileSummary.targetExam}}</text>
        </view>
      </view>
    </view>
  </view>

  <view class="review-chart-section">
    <view class="card review-chart-card review-chart-card-progress">
      <view class="review-chart-head">
        <text class="review-chart-title">{{progressChart.title}}</text>
        <text wx:if="{{progressChart.hint}}" class="review-chart-hint">{{progressChart.hint}}</text>
      </view>

      <view class="progress-timeline {{progressChart.isEmpty ? 'progress-timeline-empty' : ''}}">
        <view class="progress-track"></view>
        <view wx:if="{{progressChart.activeLineStyle}}" class="progress-track-active" style="{{progressChart.activeLineStyle}}"></view>
        <view class="progress-track-arrow"></view>

        <view
          wx:for="{{progressChart.nodes}}"
          wx:key="key"
          class="progress-node"
          style="{{item.style}}"
        >
          <text class="progress-node-score {{item.active ? 'progress-node-score-active' : 'progress-node-score-inactive'}}">{{item.valueText}}</text>
          <view class="progress-node-dot-shell {{item.active ? 'progress-node-dot-shell-active' : 'progress-node-dot-shell-inactive'}}">
            <view class="progress-node-dot-core {{item.active ? 'progress-node-dot-core-active' : 'progress-node-dot-core-inactive'}}"></view>
          </view>
          <text class="progress-node-label {{item.active ? 'progress-node-label-active' : 'progress-node-label-inactive'}}">{{item.label}}</text>
        </view>
      </view>
    </view>

    <view class="card review-chart-card">
      <view class="review-chart-head">
        <text class="review-chart-title">{{pointRateChart.title}}</text>
      </view>
      <view class="review-chart-legend">
        <view class="review-chart-legend-item">
          <view class="legend-bar legend-bar-orange"></view>
          <text class="legend-text">{{pointRateChart.legendBar}}</text>
        </view>
        <view class="review-chart-legend-item">
          <view class="legend-line legend-line-dark"></view>
          <text class="legend-text">{{pointRateChart.legendLine}}</text>
        </view>
      </view>

      <view class="mix-chart-wrap {{pointRateChart.isEmpty ? 'mix-chart-shell-empty' : ''}}">
        <view class="mix-chart-shell">
          <view class="mix-chart-axis">
            <text wx:for="{{pointRateChart.yAxis}}" wx:key="value" class="mix-chart-axis-label" style="bottom: {{item.bottom}};">{{item.label}}</text>
          </view>

          <view class="mix-chart-main">
            <view class="mix-chart-plot">
              <view wx:for="{{pointRateChart.yAxis}}" wx:key="value" class="mix-chart-grid-line" style="bottom: {{item.bottom}};"></view>
              <image wx:if="{{pointRateChart.lineSvg}}" class="mix-chart-line-image" src="{{pointRateChart.lineSvg}}" mode="scaleToFill" />
              <view wx:if="{{pointRateChart.linePoints.length > 0}}" class="mix-chart-line-points">
                <view
                  wx:for="{{pointRateChart.linePoints}}"
                  wx:key="key"
                  class="chart-line-point chart-line-point-dark"
                  style="{{item.style}}"
                >
                  <view class="chart-line-point-core"></view>
                </view>
              </view>

              <view class="mix-chart-columns">
                <view wx:for="{{pointRateChart.items}}" wx:key="id" class="mix-chart-column">
                  <text class="mix-chart-bar-value mix-chart-bar-value-{{item.tone}} {{item.isMissing ? 'mix-chart-bar-value-missing' : ''}}">{{item.valueText}}</text>
                  <view class="mix-chart-bar-track">
                    <view class="mix-chart-bar mix-chart-bar-{{item.tone}} {{item.isMissing ? 'mix-chart-bar-missing' : ''}}" style="height: {{item.barHeight}}%;"></view>
                  </view>
                </view>
              </view>
            </view>
          </view>
        </view>

        <view class="mix-chart-label-shell">
          <view class="mix-chart-label-spacer"></view>
          <view class="mix-chart-label-row">
            <view wx:for="{{pointRateChart.items}}" wx:key="id" class="mix-chart-label-column">
              <text class="mix-chart-index-label">{{item.indexLabel}}</text>
            </view>
          </view>
        </view>
      </view>

      <view class="mix-chart-reference-box">
        <view class="mix-chart-reference-head" bindtap="togglePointRateLegend">
          <text class="mix-chart-reference-title">卡点说明</text>
          <text class="mix-chart-reference-toggle">{{pointRateLegendExpanded ? '收起' : '展开'}}</text>
        </view>
        <view wx:if="{{pointRateLegendExpanded}}" class="mix-chart-reference">
          <view wx:for="{{pointRateChart.items}}" wx:key="id" class="mix-chart-reference-item">
            <view class="mix-chart-reference-marker"></view>
            <text class="mix-chart-reference-text">{{item.indexLabel}}. {{item.name}}</text>
          </view>
        </view>
      </view>

      <text wx:if="{{pointRateChart.hint}}" class="review-chart-footnote">{{pointRateChart.hint}}</text>
    </view>

    <view class="card review-chart-card">
      <view class="review-chart-head">
        <text class="review-chart-title">{{studyTimeChart.title}}</text>
      </view>
      <view class="study-time-tabs">
        <view
          wx:for="{{studyTimeTabs}}"
          wx:key="key"
          class="study-time-tab {{item.active ? 'study-time-tab-active' : ''}}"
          bindtap="switchStudyTimeRange"
          data-range="{{item.key}}"
        >
          <text class="study-time-tab-text {{item.active ? 'study-time-tab-text-active' : ''}}">{{item.label}}</text>
        </view>
      </view>
      <view class="review-chart-legend">
        <view class="review-chart-legend-item">
          <view class="legend-bar legend-bar-study"></view>
          <text class="legend-text">{{studyTimeChart.legendBar}}</text>
        </view>
        <view class="review-chart-legend-item">
          <view class="legend-line legend-line-study"></view>
          <text class="legend-text">{{studyTimeChart.legendLine}}</text>
        </view>
      </view>

      <view class="study-chart-shell {{studyTimeChart.isEmpty ? 'study-chart-shell-empty' : ''}}">
        <view class="study-chart-plot">
          <view class="study-chart-baseline"></view>
          <image wx:if="{{studyTimeChart.lineSvg}}" class="study-chart-line-image" src="{{studyTimeChart.lineSvg}}" mode="scaleToFill" />
          <view wx:if="{{studyTimeChart.linePoints.length > 0}}" class="study-chart-line-points">
            <view
              wx:for="{{studyTimeChart.linePoints}}"
              wx:key="key"
              class="chart-line-point chart-line-point-study"
              style="{{item.style}}"
            >
              <view class="chart-line-point-core"></view>
            </view>
          </view>

          <view class="study-chart-columns">
            <view wx:for="{{studyTimeChart.items}}" wx:key="key" class="study-chart-column">
              <text class="study-chart-value {{item.isMissing ? 'study-chart-value-missing' : ''}}">{{item.valueText}}</text>
              <view class="study-chart-bar-track">
                <view class="study-chart-bar {{item.isMissing ? 'study-chart-bar-missing' : ''}}" style="height: {{item.barHeight}}%;"></view>
              </view>
              <text class="study-chart-label">{{item.label}}</text>
            </view>
          </view>
        </view>
      </view>

      <text wx:if="{{studyTimeChart.hint}}" class="review-chart-footnote">{{studyTimeChart.hint}}</text>
    </view>
  </view>

  <view class="card fold-card fold-card-solved">
    <view class="fold-card-head" bindtap="toggleSection" data-key="solved">
      <view class="fold-card-head-main">
        <view class="fold-card-title-row">
          <text class="fold-card-title">已解决卡点</text>
          <text class="fold-card-tag fold-card-tag-solved">{{solvedPoints.length}} 个</text>
        </view>
      </view>
      <view class="fold-card-head-side">
        <view class="section-toggle-arrow {{sectionExpanded.solved ? 'section-toggle-arrow-open' : ''}}"></view>
      </view>
    </view>

    <view wx:if="{{sectionExpanded.solved}}" class="fold-card-body fold-card-list-body">
      <view
        wx:for="{{solvedPoints}}"
        wx:key="id"
        class="fold-card-list-item fold-card-list-item-solved fold-card-list-item-clickable"
        bindtap="goCardDetail"
        data-id="{{item.id}}"
        data-status="solved"
      >
        <view class="row-between">
          <text class="point-block-name">{{item.name}}</text>
          <view class="point-path-entry">
            <text class="point-path-entry-text">去回顾</text>
            <view class="point-path-entry-arrow"></view>
          </view>
        </view>
      </view>
    </view>
  </view>

  <view class="card fold-card fold-card-pending">
    <view class="fold-card-head" bindtap="toggleSection" data-key="pending">
      <view class="fold-card-head-main">
        <view class="fold-card-title-row">
          <text class="fold-card-title">待突破卡点</text>
          <text class="fold-card-tag fold-card-tag-pending">{{pendingPoints.length}} 个</text>
        </view>
      </view>
      <view class="fold-card-head-side">
        <view class="section-toggle-arrow {{sectionExpanded.pending ? 'section-toggle-arrow-open' : ''}}"></view>
      </view>
    </view>

      <view wx:if="{{sectionExpanded.pending}}" class="fold-card-body fold-card-list-body">
      <view
        wx:for="{{pendingPoints}}"
        wx:key="id"
        class="fold-card-list-item fold-card-list-item-pending fold-card-list-item-clickable"
        bindtap="goCardDetail"
        data-id="{{item.id}}"
        data-status="pending"
      >
        <view class="row-between">
          <text class="point-block-name">{{item.name}}</text>
          <view class="point-path-entry">
            <text class="point-path-entry-text">去回顾</text>
            <view class="point-path-entry-arrow"></view>
          </view>
        </view>
      </view>
    </view>
  </view>

  <view class="safe-bottom"></view>
</view>

<diagnose-coupon-fab auto-popup="{{true}}"></diagnose-coupon-fab>
