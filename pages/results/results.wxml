<view class="results-page">
  <block wx:if="{{!isEnrolled}}">
    <view class="empty-state">
      <image class="empty-icon" src="{{uiIcons.chart}}" mode="aspectFit" />
      <text class="empty-title">暂无学习数据</text>
      <text class="empty-desc">购课并开始学习后，你的卡点突破记录、学习时长、老师寄语都会在这里展示。</text>
      <button class="btn-primary empty-btn" bindtap="goEnroll">去选课</button>
    </view>
  </block>

  <block wx:else>
    <view class="summary-section">
      <view class="summary-board">
        <view class="summary-top-row">
          <view class="summary-main">
            <image class="summary-bg-icon" src="{{uiIcons.calendar}}" mode="aspectFit" />
            <view class="summary-content">
              <view class="summary-label-row">
                <text class="summary-label">累计学习时长</text>
              </view>
              <text class="summary-value">{{totalStudyDisplay}}</text>
            </view>
          </view>

          <view class="summary-points">
            <image class="summary-points-bg-icon" src="{{uiIcons.points}}" mode="aspectFit" />
            <view class="summary-content">
              <view class="summary-label-row">
                <text class="summary-points-label">累计积分</text>
              </view>
              <text class="summary-points-value">{{totalPoints}}</text>
            </view>
          </view>

        </view>

        <view class="summary-bottom-row">
          <view class="stat-chip stat-goal">
            <text class="stat-chip-label">提分目标</text>
            <view class="stat-chip-main">
              <text class="stat-chip-value">{{stats.scoreGap}}</text>
              <text class="stat-chip-unit">分</text>
            </view>
          </view>
          <view class="stat-chip stat-solved">
            <text class="stat-chip-label">已突破</text>
            <view class="stat-chip-main">
              <text class="stat-chip-value">{{stats.solved}}</text>
              <text class="stat-chip-unit">个</text>
            </view>
          </view>
          <view class="stat-chip stat-pending">
            <text class="stat-chip-label">待解决</text>
            <view class="stat-chip-main">
              <text class="stat-chip-value">{{stats.pending}}</text>
              <text class="stat-chip-unit">个</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <view class="section-header-bar">
      <view class="section-dot solved-dot"></view>
      <text class="section-title-bar resolved-title">已解决</text>
      <text class="section-count">{{solvedPoints.length}} 个</text>
    </view>

    <view wx:for="{{solvedPoints}}" wx:key="id" class="card point-block">
      <view class="row-between">
        <text class="point-block-name">{{item.name}}</text>
        <button class="btn-detail" bindtap="goCardDetail" data-id="{{item.id}}">学习数据</button>
      </view>
      <text class="point-block-summary">{{item.summary}}</text>
      <text class="point-block-date">完成时间：{{item.completedAt}}</text>
    </view>

    <view class="section-header-bar">
      <view class="section-dot pending-dot"></view>
      <text class="section-title-bar pending-title">待突破</text>
      <text class="section-count">{{pendingPoints.length}} 个</text>
    </view>

    <view wx:for="{{pendingPoints}}" wx:key="id" class="card point-block">
      <view class="row-between">
        <text class="point-block-name">{{item.name}}</text>
      </view>
      <text class="point-block-summary">{{item.desc}}</text>
    </view>

    <view class="section-header-bar report-header-bar">
      <view class="section-dot diagnose-dot"></view>
      <text class="section-title-bar">诊断报告</text>
      <text class="section-count">{{diagnosisReport.reportDate}}</text>
    </view>

    <view class="card report-card diagnose-report-card">
      <view class="report-top">
        <view>
          <text class="report-title">专属诊断报告</text>
          <text class="report-sub">{{studentName}} · {{diagnosisReport.exam}} · {{diagnosisReport.teacher}}</text>
        </view>
        <button class="btn-report-action" bindtap="goDiagnoseReport">查看完整报告</button>
      </view>

      <view class="report-stats">
        <view class="report-stat-item">
          <text class="report-stat-value">{{diagnosisScore}}</text>
          <text class="report-stat-label">诊断分</text>
        </view>
        <view class="report-stat-item">
          <text class="report-stat-value">{{targetScore}}</text>
          <text class="report-stat-label">目标分</text>
        </view>
        <view class="report-stat-item">
          <text class="report-stat-value report-stat-warn">{{stats.scoreGap}}</text>
          <text class="report-stat-label">待提升</text>
        </view>
      </view>

      <text class="report-summary">{{diagnosisReport.summary}}</text>

      <view class="report-tags">
        <view wx:for="{{diagnosisReport.keyFindings}}" wx:key="*this" class="report-tag">{{item}}</view>
      </view>
    </view>

    <view class="section-header-bar report-header-bar">
      <view class="section-dot practice-dot"></view>
      <text class="section-title-bar">刷题报告</text>
      <text class="section-count">近 {{practiceReport.recentDays}} 天</text>
    </view>

    <view class="card report-card practice-report-card">
      <view class="report-top">
        <view>
          <text class="report-title">近期刷题表现</text>
          <text class="report-sub">累计 {{practiceReport.totalQuestions}} 题 · 平均正确率 {{practiceReport.accuracy}}%</text>
        </view>
        <button class="btn-report-action practice-action" bindtap="goPracticeReport">查看卡点明细</button>
      </view>

      <view class="practice-highlight">
        <view class="practice-highlight-good">
          <text class="practice-label">最稳定卡点</text>
          <text class="practice-point">{{practiceReport.strongestPoint}}</text>
        </view>
        <view class="practice-highlight-weak">
          <text class="practice-label">当前重点补强</text>
          <text class="practice-point">{{practiceReport.weakestPoint}}</text>
        </view>
      </view>

      <text class="report-summary">{{practiceReport.weakestAdvice}}</text>

      <view class="practice-records">
        <view wx:for="{{practiceReport.recentRecords}}" wx:key="id" class="practice-record-row">
          <view class="practice-record-main">
            <text class="practice-record-title">{{item.title}}</text>
            <text class="practice-record-date">{{item.date}}</text>
          </view>
          <text class="practice-record-score">{{item.score}} 分</text>
        </view>
      </view>
    </view>

    <view class="safe-bottom"></view>
  </block>
</view>
