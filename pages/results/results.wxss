.results-page {
  min-height: 100vh;
  background:
    radial-gradient(circle at top left, rgba(37, 99, 235, 0.09), transparent 26%),
    linear-gradient(180deg, #f7f9fc 0%, #f3f5f8 100%);
  padding-bottom: calc(120rpx + 56px + env(safe-area-inset-bottom));
}

.profile-summary-section {
  padding: 16rpx 24rpx 0;
}

.review-chart-section {
  padding: 16rpx 24rpx 0;
}

.profile-summary-card {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 16rpx 22rpx;
  border-radius: 24rpx;
  background:
    radial-gradient(circle at top right, rgba(96, 165, 250, 0.18), transparent 34%),
    linear-gradient(135deg, #ffffff 0%, #f7fbff 100%);
  border: 1rpx solid rgba(148, 163, 184, 0.16);
  box-shadow: 0 16rpx 40rpx rgba(15, 23, 42, 0.06);
}

.profile-avatar-box {
  width: 76rpx;
  height: 76rpx;
  border-radius: 50%;
  overflow: hidden;
  flex-shrink: 0;
  box-shadow: 0 12rpx 24rpx rgba(37, 99, 235, 0.12);
}

.profile-avatar-box:active {
  transform: scale(0.97);
}

.profile-avatar-image,
.profile-avatar-fallback {
  width: 100%;
  height: 100%;
}

.profile-avatar-fallback {
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #2563eb 0%, #60a5fa 100%);
}

.profile-avatar-text {
  font-size: 30rpx;
  font-weight: 700;
  color: #ffffff;
}

.profile-summary-main {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: center;
}

.profile-summary-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
}

.profile-summary-title {
  display: flex;
  align-items: center;
  gap: 14rpx;
  min-width: 0;
}

.profile-summary-name {
  font-size: 32rpx;
  font-weight: 700;
  color: #0f172a;
  line-height: 1.2;
}

.profile-summary-tag {
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(37, 99, 235, 0.1);
  color: #2563eb;
  font-size: 20rpx;
  font-weight: 700;
  line-height: 1.4;
}

.profile-summary-action {
  flex-shrink: 0;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #eef4ff;
  color: #2563eb;
  font-size: 22rpx;
  font-weight: 700;
  line-height: 1.4;
}

.profile-summary-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 18rpx;
}

.profile-summary-item {
  min-width: 0;
  padding: 16rpx 14rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.86);
  border: 1rpx solid rgba(148, 163, 184, 0.12);
}

.profile-summary-label {
  display: block;
  font-size: 20rpx;
  color: #64748b;
  line-height: 1.4;
}

.profile-summary-value {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  font-weight: 700;
  color: #0f172a;
  line-height: 1.45;
  word-break: break-all;
}

.profile-summary-value-accent {
  color: #2563eb;
}

.profile-summary-inline {
  display: flex;
  align-items: center;
  min-width: 0;
  gap: 10rpx;
}

.profile-summary-divider {
  flex-shrink: 0;
  font-size: 24rpx;
  color: #94a3b8;
  line-height: 1;
}

.profile-summary-goal-inline {
  min-width: 0;
  flex: 1;
  font-size: 24rpx;
  font-weight: 600;
  color: #475569;
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.review-chart-card {
  margin: 0 0 18rpx;
  padding: 28rpx 24rpx 30rpx;
  overflow: hidden;
}

.review-chart-card-progress {
  padding-top: 22rpx;
  padding-bottom: 14rpx;
}

.review-chart-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.review-chart-title {
  font-size: 30rpx;
  font-weight: 800;
  color: #0f172a;
  line-height: 1.35;
}

.review-chart-hint {
  font-size: 22rpx;
  color: #94a3b8;
  line-height: 1.5;
  text-align: right;
}

.review-chart-legend {
  display: flex;
  align-items: center;
  gap: 28rpx;
  margin-top: 18rpx;
}

.review-chart-legend-item {
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
}

.legend-bar {
  width: 30rpx;
  height: 16rpx;
  border-radius: 6rpx;
}

.legend-bar-orange {
  background: linear-gradient(180deg, #ff9838 0%, #ff7a18 100%);
}

.legend-bar-blue {
  background: linear-gradient(180deg, #6fa1ff 0%, #2563eb 100%);
}

.legend-bar-study {
  background: #f9f6e5;
}

.legend-line {
  width: 34rpx;
  height: 0;
  border-top-width: 4rpx;
  border-top-style: solid;
  position: relative;
}

.legend-line::after {
  content: '';
  position: absolute;
  right: -2rpx;
  top: -7rpx;
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: currentColor;
}

.legend-line-dark {
  border-top-color: #4b5563;
  color: #4b5563;
}

.legend-line-green {
  border-top-color: #22c55e;
  color: #22c55e;
}

.legend-line-study {
  border-top-color: #ffeaee;
  color: #ffeaee;
}

.legend-text {
  font-size: 22rpx;
  color: #64748b;
  line-height: 1.4;
  font-weight: 600;
}

.review-chart-footnote {
  display: block;
  margin-top: 18rpx;
  font-size: 22rpx;
  color: #94a3b8;
  line-height: 1.6;
}

.progress-timeline {
  position: relative;
  padding: 0;
  height: 142rpx;
}

.progress-timeline-empty .progress-track,
.progress-timeline-empty .progress-track-arrow {
  border-color: #d1d5db;
  color: #d1d5db;
}

.progress-track {
  position: absolute;
  left: 0;
  right: 0;
  top: 54rpx;
  height: 2rpx;
  background: #ff8a1f;
}

.progress-track-active {
  position: absolute;
  top: 54rpx;
  height: 2rpx;
  background: #ff7a18;
}

.progress-track-arrow {
  position: absolute;
  right: 0;
  top: 47rpx;
  width: 12rpx;
  height: 12rpx;
  border-top: 2rpx solid #ff8a1f;
  border-right: 2rpx solid #ff8a1f;
  transform: rotate(45deg);
}

.progress-node {
  position: absolute;
  top: 0;
  width: 220rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  transform: translateX(-50%);
}

.progress-node-score {
  font-size: 22rpx;
  font-weight: 500;
  line-height: 1.1;
}

.progress-node-score-active {
  color: #0f172a;
}

.progress-node-score-inactive {
  color: #cbd5e1;
}

.progress-node-dot-shell {
  width: 20rpx;
  height: 20rpx;
  margin-top: 18rpx;
  display: block;
}

.progress-node-dot-shell-active {
  background: transparent;
  border: 0;
}

.progress-node-dot-shell-inactive {
  background: transparent;
  border: 0;
}

.progress-node-dot-core {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  box-sizing: border-box;
  display: block;
}

.progress-node-dot-core-active {
  background: #ff8a1f;
  border: 2rpx solid #ff8a1f;
  box-shadow: none;
}

.progress-node-dot-core-inactive {
  background: #d7dee8;
  border: 2rpx solid #d7dee8;
  box-shadow: none;
}

.progress-node-label {
  width: 100%;
  font-size: 20rpx;
  font-weight: 500;
  line-height: 1.2;
  text-align: center;
  white-space: nowrap;
  letter-spacing: 0;
  margin-top: 10rpx;
}

.progress-node-label-active {
  color: #1f2937;
}

.progress-node-label-inactive {
  color: #94a3b8;
}

.mix-chart-wrap {
  margin-top: 18rpx;
}

.mix-chart-shell {
  display: flex;
  gap: 16rpx;
  align-items: flex-start;
}

.mix-chart-shell-empty {
  opacity: 0.72;
}

.mix-chart-axis {
  position: relative;
  width: 62rpx;
  height: 300rpx;
  flex-shrink: 0;
}

.mix-chart-axis-label {
  position: absolute;
  left: 0;
  transform: translateY(50%);
  font-size: 20rpx;
  color: #94a3b8;
  line-height: 1;
}

.mix-chart-main {
  flex: 1;
  min-width: 0;
}

.mix-chart-plot {
  position: relative;
  height: 300rpx;
  padding: 0 4rpx;
}

.mix-chart-grid-line {
  position: absolute;
  left: 0;
  right: 0;
  height: 1rpx;
  background: rgba(148, 163, 184, 0.18);
  transform: translateY(50%);
}

.mix-chart-line-image {
  position: absolute;
  left: 0;
  right: 0;
  top: 24rpx;
  bottom: 0;
  width: 100%;
  height: calc(100% - 24rpx);
  z-index: 2;
  pointer-events: none;
}

.mix-chart-line-points,
.study-chart-line-points {
  position: absolute;
  left: 0;
  right: 0;
  pointer-events: none;
  z-index: 4;
}

.mix-chart-line-points {
  top: 24rpx;
  bottom: 0;
}

.study-chart-line-points {
  top: 24rpx;
  bottom: 58rpx;
}

.chart-line-point {
  position: absolute;
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  transform: translate(-50%, 50%);
  display: flex;
  align-items: center;
  justify-content: center;
  background: transparent;
  box-shadow: none;
}

.chart-line-point-core {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
}

.chart-line-point-dark {
  border: 0;
}

.chart-line-point-dark .chart-line-point-core {
  background: #475569;
}

.chart-line-point-green {
  border: 0;
}

.chart-line-point-green .chart-line-point-core {
  background: #22c55e;
}

.chart-line-point-study {
  border: 0;
}

.chart-line-point-study .chart-line-point-core {
  background: #ffeaee;
}

.study-chart-line-image {
  position: absolute;
  left: 0;
  right: 0;
  top: 24rpx;
  bottom: 58rpx;
  width: 100%;
  height: calc(100% - 82rpx);
  z-index: 2;
  pointer-events: none;
}

.mix-chart-columns {
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 0;
  z-index: 1;
}

.mix-chart-column {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-end;
}

.mix-chart-bar-value {
  font-size: 20rpx;
  color: #ff7a18;
  line-height: 1.2;
  font-weight: 700;
  margin-bottom: 10rpx;
}

.mix-chart-bar-value-red {
  color: #fe4a4c;
}

.mix-chart-bar-value-orange {
  color: #ff7a18;
}

.mix-chart-bar-value-blue {
  color: #1fb0f5;
}

.mix-chart-bar-value-yellow {
  color: #ff9601;
}

.mix-chart-bar-value-missing {
  color: #cbd5e1;
}

.mix-chart-bar-track {
  width: 100%;
  height: 250rpx;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.mix-chart-bar {
  width: 42rpx;
  min-height: 18rpx;
  border-radius: 14rpx 14rpx 0 0;
}

.mix-chart-bar-orange {
  background: linear-gradient(180deg, #ff9838 0%, #ff7a18 100%);
}

.mix-chart-bar-red {
  background: linear-gradient(180deg, #ff8b8c 0%, #fe4a4c 100%);
}

.mix-chart-bar-blue {
  background: linear-gradient(180deg, #6fd6ff 0%, #1fb0f5 100%);
}

.mix-chart-bar-yellow {
  background: linear-gradient(180deg, #ffbf63 0%, #ff9601 100%);
}

.mix-chart-bar-missing {
  background: linear-gradient(180deg, #e5e7eb 0%, #cbd5e1 100%);
}

.mix-chart-label-row {
  display: flex;
  flex: 1;
  justify-content: space-between;
  gap: 10rpx;
  padding: 0 4rpx;
  box-sizing: border-box;
}

.mix-chart-label-shell {
  margin-top: 18rpx;
  display: flex;
  gap: 16rpx;
  align-items: flex-start;
}

.mix-chart-label-spacer {
  width: 62rpx;
  flex-shrink: 0;
}

.mix-chart-label-column {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.mix-chart-label-group {
  margin-top: 16rpx;
  min-height: 62rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.mix-chart-index-label {
  color: #64748b;
  font-size: 22rpx;
  font-weight: 600;
  line-height: 1.4;
  text-align: center;
}

.mix-chart-reference-box {
  margin-top: 18rpx;
  border-radius: 20rpx;
  background: #f8fbff;
  border: 1rpx solid rgba(37, 99, 235, 0.08);
}

.mix-chart-reference-head {
  padding: 16rpx 18rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.mix-chart-reference-title {
  font-size: 22rpx;
  font-weight: 700;
  color: #334155;
  line-height: 1.4;
}

.mix-chart-reference-toggle {
  font-size: 22rpx;
  font-weight: 600;
  color: #2563eb;
  line-height: 1.4;
}

.mix-chart-reference {
  padding: 0 18rpx 16rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx 18rpx;
}

.mix-chart-reference-item {
  flex-shrink: 0;
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
}

.mix-chart-reference-marker {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  flex-shrink: 0;
  background: #cbd5e1;
}

.mix-chart-reference-text {
  color: #475569;
  font-size: 22rpx;
  font-weight: 600;
  line-height: 1.4;
  white-space: nowrap;
}

.study-chart-shell {
  margin-top: 18rpx;
}

.study-time-tabs {
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
  margin-top: 16rpx;
  padding: 8rpx;
  border-radius: 999rpx;
  background: #f1f5f9;
}

.study-time-tab {
  min-width: 96rpx;
  padding: 12rpx 24rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.18s ease;
}

.study-time-tab-active {
  background: #ffffff;
  box-shadow: 0 8rpx 20rpx rgba(37, 99, 235, 0.12);
}

.study-time-tab-text {
  font-size: 22rpx;
  color: #64748b;
  font-weight: 600;
  line-height: 1;
}

.study-time-tab-text-active {
  color: #2563eb;
}

.study-chart-shell-empty {
  opacity: 0.72;
}

.study-chart-plot {
  position: relative;
  height: 350rpx;
}

.study-chart-baseline {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 58rpx;
  height: 2rpx;
  background: rgba(148, 163, 184, 0.18);
}

.study-chart-columns {
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 0;
  z-index: 1;
}

.study-chart-column {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.study-chart-value {
  font-size: 20rpx;
  color: #2563eb;
  line-height: 1.2;
  font-weight: 700;
  margin-bottom: 12rpx;
}

.study-chart-value-missing {
  color: #cbd5e1;
}

.study-chart-bar-track {
  width: 100%;
  height: 246rpx;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.study-chart-bar {
  width: 56rpx;
  min-height: 18rpx;
  border-radius: 16rpx 16rpx 0 0;
  background: #f9f6e5;
  box-shadow: inset 0 0 0 2rpx rgba(255, 255, 255, 0.24);
}

.study-chart-bar-missing {
  background: linear-gradient(180deg, #e5e7eb 0%, #cbd5e1 100%);
}

.study-chart-label {
  margin-top: 16rpx;
  font-size: 24rpx;
  color: #475569;
  line-height: 1.4;
  text-align: center;
}

.pending-title {
  color: #c2410c;
  font-weight: 700;
}

.resolved-title {
  color: #15803d;
  font-weight: 700;
}

.summary-section {
  padding: 18rpx 24rpx 0;
}

.summary-board {
  padding: 18rpx;
  border-radius: 28rpx;
  background: #ffffff;
  border: 1rpx solid rgba(148, 163, 184, 0.16);
  box-shadow: 0 16rpx 40rpx rgba(15, 23, 42, 0.06);
}

.summary-top-row {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
}

.summary-main,
.summary-points {
  min-width: 0;
  padding: 20rpx 16rpx;
  position: relative;
  overflow: hidden;
  border-radius: 24rpx;
  border: 1rpx solid rgba(148, 163, 184, 0.1);
  box-sizing: border-box;
  box-shadow: none;
}

.summary-main {
  background: linear-gradient(180deg, #fbfdff 0%, #f7fbff 100%);
}

.summary-label-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.summary-content {
  position: relative;
  z-index: 2;
}

.summary-bg-icon,
.summary-points-bg-icon {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 148rpx;
  height: 148rpx;
  transform: translate(-50%, -50%);
  z-index: 1;
}

.summary-bg-icon {
  opacity: 0.08;
}

.summary-points-bg-icon {
  opacity: 0.1;
}

.summary-label {
  font-size: 18rpx;
  color: #475569;
  font-weight: 600;
}

.summary-value {
  display: block;
  margin-top: 18rpx;
  font-size: 36rpx;
  font-weight: 700;
  color: #1d4ed8;
  line-height: 1.05;
  letter-spacing: -1rpx;
}

.summary-points {
  background: linear-gradient(180deg, #fffdf8 0%, #fff9ee 100%);
  border-color: rgba(245, 158, 11, 0.14);
  display: flex;
  flex-direction: column;
}

.summary-points-icon {
  width: 28rpx;
  height: 28rpx;
  flex-shrink: 0;
  filter: drop-shadow(0 6rpx 10rpx rgba(245, 158, 11, 0.12));
}

.summary-points-value {
  display: block;
  margin-top: 18rpx;
  font-size: 36rpx;
  font-weight: 700;
  color: #0f172a;
  line-height: 1;
}

.summary-points-label {
  font-size: 18rpx;
  font-weight: 600;
  color: #78716c;
}

.summary-bottom-row {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 12rpx;
}

.stat-chip {
  min-width: 0;
  padding: 18rpx 14rpx 16rpx;
  border-radius: 20rpx;
  border: 1rpx solid rgba(148, 163, 184, 0.1);
  box-sizing: border-box;
  box-shadow: none;
}

.stat-chip-clickable {
  position: relative;
}

.stat-chip-clickable:active {
  transform: scale(0.98);
}

.stat-goal {
  background: linear-gradient(180deg, #f7fbff 0%, #eef5ff 100%);
  border-color: rgba(96, 165, 250, 0.16);
}

.stat-solved {
  background: linear-gradient(180deg, #f6fffb 0%, #ecfdf5 100%);
  border-color: rgba(34, 197, 94, 0.16);
}

.stat-pending {
  background: linear-gradient(180deg, #fffaf5 0%, #fff4e8 100%);
  border-color: rgba(249, 115, 22, 0.16);
}

.stat-chip-label {
  display: block;
  font-size: 24rpx;
  color: #475569;
  font-weight: 700;
  text-align: center;
}

.stat-chip-main {
  display: flex;
  align-items: flex-end;
  justify-content: center;
  gap: 6rpx;
  margin-top: 12rpx;
}

.stat-chip-value {
  font-size: 46rpx;
  font-weight: 700;
  line-height: 1;
}

.stat-goal .stat-chip-value {
  color: #2563eb;
}

.stat-solved .stat-chip-value {
  color: #15803d;
}

.stat-pending .stat-chip-value {
  color: #c2410c;
}

.stat-chip-unit {
  font-size: 22rpx;
  color: #94a3b8;
  margin-bottom: 3rpx;
}

.section-header-bar {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 18rpx 24rpx 10rpx;
}

.section-header-toggle {
  justify-content: space-between;
}

.section-header-main,
.section-header-side {
  display: flex;
  align-items: center;
}

.section-header-main {
  flex: 1;
  min-width: 0;
}

.section-header-side {
  flex-shrink: 0;
  gap: 12rpx;
}

.section-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  margin-right: 12rpx;
}

.solved-dot {
  background: #15803d;
}

.pending-dot {
  background: #c2410c;
}

.diagnose-dot {
  background: #2563eb;
}

.practice-dot {
  background: #64748b;
}

.section-title-bar {
  font-size: 28rpx;
  font-weight: 700;
  color: #0f172a;
  flex: 1;
}

.section-count {
  font-size: 23rpx;
  color: #94a3b8;
}

.section-toggle-arrow {
  width: 12rpx;
  height: 12rpx;
  border-top: 2rpx solid #c7c7cc;
  border-right: 2rpx solid #c7c7cc;
  box-sizing: border-box;
  transform: rotate(45deg);
  transition: transform 0.18s ease, border-color 0.18s ease;
  flex-shrink: 0;
  margin-right: 2rpx;
  opacity: 0.95;
}

.section-toggle-arrow-open {
  transform: rotate(135deg);
}

.fold-card {
  padding: 0;
  overflow: hidden;
}

.fold-card-diagnose {
  background: linear-gradient(180deg, #f7fbff 0%, #ffffff 100%);
  border-color: rgba(37, 99, 235, 0.14);
}

.fold-card-solved {
  background: #ffffff;
  border-color: rgba(34, 197, 94, 0.16);
}

.fold-card-pending {
  background: #ffffff;
  border-color: rgba(249, 115, 22, 0.16);
}

.fold-card-practice {
  background: linear-gradient(180deg, #f8fbff 0%, #ffffff 100%);
  border-color: rgba(37, 99, 235, 0.12);
}

.fold-card-head {
  min-height: 88rpx;
  padding: 20rpx 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.fold-card-head-main {
  flex: 1;
  min-width: 0;
}

.fold-card-head-side {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-shrink: 0;
}

.fold-card-title-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-wrap: wrap;
}

.fold-card-title {
  font-size: 29rpx;
  font-weight: 800;
  color: #1f2329;
  line-height: 1.25;
}

.fold-card-tag {
  height: 42rpx;
  padding: 0 16rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  background: #eaf2ff;
  color: #2563eb;
  font-size: 20rpx;
  font-weight: 700;
  line-height: 1.4;
}

.fold-card-tag-solved {
  background: #eefbf3;
  color: #15803d;
}

.fold-card-tag-pending {
  background: #fff1e8;
  color: #c2410c;
}

.fold-card-tag-practice {
  background: #eef4ff;
  color: #2563eb;
}

.fold-card-sub {
  display: block;
  margin-top: 10rpx;
  font-size: 23rpx;
  color: #64748b;
  line-height: 1.5;
}

.fold-card-meta {
  font-size: 21rpx;
  color: #94a3b8;
}

.fold-card-body {
  padding: 0 30rpx 30rpx;
  border-top: 1rpx solid rgba(37, 99, 235, 0.08);
}

.fold-card-entry-body {
  padding-top: 0;
  padding-bottom: 0;
}

.fold-card-list-body {
  padding-top: 8rpx;
}

.fold-card-list-item {
  padding: 24rpx 0;
}

.fold-card-list-item-clickable:active {
  opacity: 0.82;
}

.fold-card-list-item + .fold-card-list-item {
  border-top: 1rpx solid rgba(148, 163, 184, 0.14);
}

.fold-card-list-item-solved {
  border-color: rgba(34, 197, 94, 0.14);
}

.fold-card-list-item-pending {
  border-color: rgba(249, 115, 22, 0.14);
}

.fold-card-action-row {
  padding-top: 20rpx;
  display: flex;
  justify-content: flex-end;
}

.fold-card-row-top {
  align-items: flex-start;
}

.fold-card-section-title {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: #0f172a;
  line-height: 1.4;
}

.fold-card-section-desc {
  display: block;
  margin-top: 14rpx;
  font-size: 24rpx;
  color: #475569;
  line-height: 1.7;
}

.fold-card-metrics {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12rpx;
}

.fold-card-metric {
  min-width: 0;
  padding: 18rpx 10rpx 16rpx;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.88);
  border: 1rpx solid rgba(148, 163, 184, 0.12);
  text-align: center;
}

.fold-card-metric-value {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #2563eb;
  line-height: 1.15;
}

.fold-card-metric-value-warn {
  color: #c2410c;
}

.fold-card-metric-label {
  display: block;
  margin-top: 8rpx;
  font-size: 20rpx;
  color: #94a3b8;
  line-height: 1.45;
}

.fold-card-chip-list {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 14rpx;
}

.fold-card-chip {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: #edf4ff;
  color: #2563eb;
  font-size: 20rpx;
  font-weight: 600;
  line-height: 1.4;
}

.fold-card-chip-practice {
  background: #f1f5f9;
  color: #475569;
}

.fold-entry-item {
  min-height: 0;
  padding: 24rpx 4rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  box-sizing: border-box;
}

.fold-entry-item + .fold-entry-item {
  border-top: 1rpx solid rgba(148, 163, 184, 0.14);
}

.fold-entry-title {
  flex: 1;
  min-width: 0;
  font-size: 27rpx;
  font-weight: 600;
  color: #1f2329;
  line-height: 38rpx;
}

.fold-entry-btn {
  min-width: 108rpx;
  height: 52rpx;
  margin: 0;
  padding: 0 22rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  border: none;
  background: #3d8bfd;
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 600;
  line-height: 52rpx;
  flex-shrink: 0;
}

.fold-entry-btn::after {
  border: none;
}

.fold-entry-btn-text {
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 600;
  line-height: 1;
}

.fold-entry-btn:active {
  opacity: 0.88;
}

.point-block {
  padding: 30rpx;
}

.point-block-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #0f172a;
}

.btn-detail {
  background: #eaf2ff;
  color: #2563eb;
  font-size: 23rpx;
  padding: 10rpx 24rpx;
  border-radius: 999rpx;
  border: none;
  line-height: 1.5;
  font-weight: 700;
}

.btn-detail::after {
  border: none;
}

.point-path-entry {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  flex-shrink: 0;
  min-height: 48rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  background: rgba(37, 99, 235, 0.1);
  border: 1rpx solid rgba(37, 99, 235, 0.14);
}

.point-path-entry-text {
  font-size: 22rpx;
  font-weight: 700;
  color: #2563eb;
  line-height: 1.4;
}

.point-path-entry-arrow {
  width: 9rpx;
  height: 9rpx;
  border-top: 2rpx solid #2563eb;
  border-right: 2rpx solid #2563eb;
  transform: rotate(45deg);
  flex-shrink: 0;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 64rpx;
}

.empty-icon {
  width: 104rpx;
  height: 104rpx;
  margin-bottom: 32rpx;
  filter: drop-shadow(0 16rpx 22rpx rgba(37, 99, 235, 0.1));
}

.empty-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #0f172a;
  margin-bottom: 20rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #64748b;
  line-height: 1.7;
  text-align: center;
  margin-bottom: 48rpx;
}

.empty-btn {
  width: 320rpx;
}

.row-between {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  gap: 20rpx;
}

.report-header-bar {
  margin-top: 8rpx;
}

.report-card {
  margin: 0 24rpx 20rpx;
  padding: 30rpx;
  border-radius: 28rpx;
  background: #ffffff;
  border: 1rpx solid rgba(148, 163, 184, 0.16);
  box-shadow: 0 16rpx 36rpx rgba(15, 23, 42, 0.05);
}

.diagnose-report-card {
  background: linear-gradient(180deg, #f7fbff 0%, #ffffff 100%);
}

.practice-report-card {
  padding: 0;
  overflow: hidden;
  background: #ffffff;
  border-color: rgba(37, 99, 235, 0.12);
}

.practice-card-hero {
  padding: 30rpx 30rpx 24rpx;
  background:
    radial-gradient(circle at top right, rgba(96, 165, 250, 0.2), transparent 38%),
    linear-gradient(135deg, #f7fbff 0%, #eef5ff 100%);
  border-bottom: 1rpx solid rgba(37, 99, 235, 0.08);
}

.practice-card-badge-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.practice-card-title-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.practice-card-badge,
.practice-card-status {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 42rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  font-size: 21rpx;
  font-weight: 700;
  line-height: 1.4;
}

.practice-card-badge {
  background: #2563eb;
  color: #ffffff;
}

.practice-card-status {
  background: rgba(255, 255, 255, 0.78);
  color: #2563eb;
  border: 1rpx solid rgba(37, 99, 235, 0.12);
}

.practice-card-report-action {
  margin: 0;
  flex-shrink: 0;
}

.practice-card-title {
  display: block;
  flex: 1;
  min-width: 0;
  font-size: 32rpx;
  font-weight: 700;
  color: #0f172a;
  line-height: 1.35;
}

.practice-card-sub {
  display: block;
  margin-top: 8rpx;
  font-size: 23rpx;
  color: #475569;
  line-height: 1.5;
}

.practice-card-stats {
  display: flex;
  flex-direction: row;
  gap: 14rpx;
  padding: 24rpx 24rpx 0;
}

.practice-card-stat {
  flex: 1;
  min-width: 0;
  padding: 18rpx 8rpx 16rpx;
  border-radius: 20rpx;
  background: #ffffff;
  border: 1rpx solid rgba(148, 163, 184, 0.14);
  text-align: center;
}

.practice-card-stat-value {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #2563eb;
  line-height: 1.15;
}

.practice-card-stat-compact {
  font-size: 26rpx;
}

.practice-card-stat-accent {
  color: #c2410c;
}

.practice-card-stat-label {
  display: block;
  margin-top: 8rpx;
  font-size: 21rpx;
  color: #94a3b8;
}

.practice-card-summary {
  display: block;
  padding: 22rpx 28rpx 0;
  font-size: 25rpx;
  color: #475569;
  line-height: 1.72;
}

.practice-card-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  padding: 22rpx 28rpx 30rpx;
}

.practice-card-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  flex: 1;
  min-width: 0;
}

.practice-card-tags-alone {
  padding: 22rpx 28rpx 30rpx;
}

.practice-card-tag {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: #f1f5f9;
  color: #475569;
  font-size: 20rpx;
  font-weight: 600;
  line-height: 1.4;
}

.practice-card-action {
  margin: 0;
  padding: 12rpx 24rpx;
  border-radius: 999rpx;
  border: none;
  background: #2563eb;
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 700;
  line-height: 1.4;
  flex-shrink: 0;
}

.practice-card-action::after {
  border: none;
}

.report-top {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: flex-start;
  gap: 20rpx;
}

.report-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #0f172a;
}

.report-sub {
  display: block;
  margin-top: 8rpx;
  font-size: 23rpx;
  color: #64748b;
  line-height: 1.5;
}

.btn-report-action {
  margin: 0;
  padding: 12rpx 24rpx;
  border-radius: 999rpx;
  border: none;
  background: #eaf2ff;
  color: #2563eb;
  font-size: 22rpx;
  line-height: 1.4;
  font-weight: 700;
}

.btn-report-action::after {
  border: none;
}

.practice-action {
  background: #eef2ff;
  color: #475569;
}

.report-stats {
  display: flex;
  flex-direction: row;
  gap: 16rpx;
  margin-top: 24rpx;
}

.report-stat-item {
  flex: 1;
  padding: 22rpx 0 18rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.92);
  border: 1rpx solid rgba(148, 163, 184, 0.12);
  text-align: center;
}

.report-stat-value {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #2563eb;
}

.report-stat-warn {
  color: #c2410c;
}

.report-stat-label {
  display: block;
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #94a3b8;
}

.report-summary {
  display: block;
  margin-top: 22rpx;
  font-size: 25rpx;
  color: #475569;
  line-height: 1.72;
}

.report-tags {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 20rpx;
}

.report-tag {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: #edf4ff;
  color: #2563eb;
  font-size: 22rpx;
  font-weight: 600;
}

.safe-bottom {
  height: 24rpx;
}
