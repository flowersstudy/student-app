<view class="consult-page">
  <view class="card consult-hero-card">
    <view class="consult-badge">
      <text class="consult-badge-text">{{courseLabel}}</text>
    </view>
    <text class="consult-title">{{title}}</text>
    <text class="consult-subtitle">{{subtitle}}</text>
  </view>

  <view class="card consult-help-card">
    <text class="section-title">学管老师可以帮你确认</text>
    <view wx:for="{{helpList}}" wx:key="*this" class="consult-help-item">
      <view class="consult-help-dot"></view>
      <text class="consult-help-text">{{item}}</text>
    </view>
  </view>

  <view class="card consult-qr-card">
    <text class="section-title">{{qrTitle}}</text>
    <text class="consult-qr-desc">{{qrNote}}</text>
    <image class="consult-qr-image" src="{{qrImage}}" mode="aspectFit" bindtap="previewQr"></image>
  </view>

  <view class="bottom-space"></view>
</view>

<view class="consult-bar">
  <button class="consult-btn consult-btn-secondary" bindtap="previewQr">查看二维码</button>
</view>
