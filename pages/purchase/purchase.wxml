<view class="purchase-page">
  <block wx:if="{{diagnoseMode}}">
    <view class="card diagnose-hero-card">
      <view class="diagnose-topline">
        <view class="diagnose-kicker">
          <text class="diagnose-kicker-text">{{diagnosePurchase.badge}}</text>
        </view>
        <view class="diagnose-countdown {{!diagnosePurchase.couponActive ? 'diagnose-countdown-expired' : ''}}">
          <text class="diagnose-countdown-label">{{diagnosePurchase.countdownLabel}}</text>
          <text class="diagnose-countdown-value">{{diagnosePurchase.couponRemainingText}}</text>
        </view>
      </view>

      <text class="diagnose-title">{{diagnosePurchase.heroTitle}}</text>
      <text class="diagnose-subtitle">{{diagnosePurchase.heroSubtitle}}</text>

      <view class="diagnose-hero-points">
        <view wx:for="{{diagnosePurchase.heroPoints}}" wx:key="*this" class="diagnose-hero-point">
          <view class="diagnose-hero-point-dot"></view>
          <text class="diagnose-hero-point-text">{{item}}</text>
        </view>
      </view>

      <view class="diagnose-price-card">
        <view class="diagnose-price-main">
          <text class="diagnose-price-label">当前到手价</text>
          <view class="diagnose-price-row">
            <text class="diagnose-price-value">{{diagnosePurchase.currentPrice}}</text>
            <text class="diagnose-price-original">{{diagnosePurchase.originalPrice}}</text>
          </view>
        </view>
        <view class="diagnose-save-badge {{!diagnosePurchase.couponActive ? 'diagnose-save-badge-muted' : ''}}">
          <text class="diagnose-save-badge-text">{{diagnosePurchase.saveText}}</text>
        </view>
      </view>

      <view class="diagnose-preview-entry" bindtap="goDiagnosePreview">
        <view class="diagnose-preview-entry-main">
          <text class="diagnose-preview-entry-title">先看找病因样例</text>
          <text class="diagnose-preview-entry-desc">先看老师怎么拆病因、定优先级，再决定是否购买。</text>
        </view>
        <view class="diagnose-preview-entry-side">
          <text class="diagnose-preview-entry-side-label">去看看</text>
          <text class="diagnose-preview-entry-arrow">→</text>
        </view>
      </view>
    </view>

    <view class="card diagnose-sample-card">
      <text class="section-title">{{diagnosePurchase.sampleCauseTitle}}</text>
      <view class="diagnose-sample-list">
        <view wx:for="{{diagnosePurchase.sampleCauses}}" wx:key="name" class="diagnose-sample-item diagnose-sample-item-{{item.tier}}">
          <view class="diagnose-sample-head">
            <text class="diagnose-sample-tier diagnose-sample-tier-{{item.tier}}">{{item.tierText}}</text>
            <text class="diagnose-sample-name">{{item.name}}</text>
          </view>
          <text class="diagnose-sample-desc">{{item.desc}}</text>
        </view>
      </view>
    </view>

    <view class="card diagnose-benefit-card">
      <text class="section-title">{{diagnosePurchase.benefitTitle}}</text>
      <view class="diagnose-benefit-list">
        <view wx:for="{{diagnosePurchase.benefitList}}" wx:key="*this" class="diagnose-benefit-item">
          <view class="diagnose-benefit-dot"></view>
          <text class="diagnose-benefit-text">{{item}}</text>
        </view>
      </view>
    </view>

    <view class="card diagnose-evidence-card">
      <text class="section-title">{{diagnosePurchase.evidenceTitle}}</text>
      <view class="diagnose-evidence-list">
        <view wx:for="{{diagnosePurchase.evidenceRows}}" wx:key="label" class="diagnose-evidence-row">
          <text class="diagnose-evidence-label">{{item.label}}</text>
          <text class="diagnose-evidence-value">{{item.value}}</text>
        </view>
      </view>
    </view>

    <view class="card diagnose-journey-card">
      <text class="section-title">购买后怎么进行</text>
      <view class="diagnose-journey-list">
        <view wx:for="{{diagnosePurchase.clarifyRows}}" wx:key="label" class="diagnose-journey-item">
          <text class="diagnose-journey-label">{{item.label}}</text>
          <text class="diagnose-journey-text">{{item.value}}</text>
        </view>
      </view>
    </view>

    <view class="card diagnose-fact-card">
      <text class="section-title">{{diagnosePurchase.factTitle}}</text>
      <view class="diagnose-fact-grid">
        <view wx:for="{{diagnosePurchase.factList}}" wx:key="label" class="diagnose-fact-item">
          <text class="diagnose-fact-value">{{item.value}}</text>
          <text class="diagnose-fact-label">{{item.label}}</text>
          <text class="diagnose-fact-desc">{{item.desc}}</text>
        </view>
      </view>
    </view>

    <view class="card diagnose-process-card">
      <text class="section-title">{{diagnosePurchase.processTitle}}</text>
      <view class="diagnose-process-list">
        <view wx:for="{{diagnosePurchase.processList}}" wx:key="title" class="diagnose-process-item">
          <view class="diagnose-process-index">
            <text class="diagnose-process-index-text">{{index + 1}}</text>
          </view>
          <view class="diagnose-process-main">
            <text class="diagnose-process-title">{{item.title}}</text>
            <text class="diagnose-process-desc">{{item.desc}}</text>
          </view>
        </view>
      </view>
    </view>

    <view class="card diagnose-audience-card">
      <text class="section-title">{{diagnosePurchase.audienceTitle}}</text>
      <view class="diagnose-audience-list">
        <view wx:for="{{diagnosePurchase.audienceList}}" wx:key="*this" class="diagnose-audience-item">
          <view class="diagnose-audience-mark">•</view>
          <text class="diagnose-audience-text">{{item}}</text>
        </view>
      </view>
    </view>
  </block>

  <block wx:else>
    <view class="card purchase-header-card purchase-header-card-{{pointLevelClass}}">
      <view class="purchase-header-top">
        <view class="purchase-header-main">
          <view wx:if="{{hasPointContext}}" class="purchase-header-level-tag purchase-header-level-tag-{{pointLevelClass}}">
            <text class="purchase-header-level-tag-text purchase-header-level-tag-text-{{pointLevelClass}}">{{pointLevel}}</text>
          </view>
          <text class="purchase-header-title">{{hasPointContext ? pointName : '卡点学习路径版本'}}</text>
          <text class="purchase-header-desc">
            {{hasPointContext ? '根据你的备考周期和理解能力，选择更适合当前卡点的版本。' : systemOverview.judgeText}}
          </text>
        </view>
      </view>
      <view class="purchase-header-tags">
        <view class="purchase-header-tag purchase-header-tag-{{pointLevelClass}}">
          <text class="purchase-header-tag-text purchase-header-tag-text-{{pointLevelClass}}">{{systemOverview.versionCount}}个版本</text>
        </view>
        <view class="purchase-header-tag purchase-header-tag-{{pointLevelClass}}">
          <text class="purchase-header-tag-text purchase-header-tag-text-{{pointLevelClass}}">{{systemOverview.pathCount}}条路径</text>
        </view>
      </view>
    </view>

    <view class="card version-panel">
      <text class="section-title">选择版本</text>
      <view class="version-tabs">
        <view
          wx:for="{{versionTabs}}"
          wx:key="key"
          class="version-tab {{item.selected ? 'version-tab-active' : ''}} {{!item.available ? 'version-tab-disabled' : ''}}"
          bindtap="handleVersionChange"
          data-key="{{item.key}}"
        >
          <text class="version-tab-text {{item.selected ? 'version-tab-text-active' : ''}}">{{item.label}}</text>
          <text wx:if="{{!item.available}}" class="version-tab-status">未开放</text>
        </view>
      </view>

      <view class="version-summary-card">
        <view class="version-summary-top">
          <text class="version-summary-title">{{currentVersionMeta.label}}</text>
          <text class="version-summary-price">{{currentVersionMeta.priceText}}</text>
        </view>
        <text class="version-summary-cycle">{{currentVersionMeta.cycleText}}</text>
        <text class="version-summary-desc">{{currentVersionMeta.description}}</text>

        <view class="version-summary-block">
          <text class="version-summary-block-title">版本包含</text>
          <view wx:for="{{currentVersionMeta.serviceItems}}" wx:key="index" class="version-bullet-item">
            <view class="version-bullet-dot"></view>
            <text class="version-bullet-text">{{item}}</text>
          </view>
        </view>

        <view wx:if="{{currentVersionMeta.followUps.length > 0}}" class="version-summary-block">
          <text class="version-summary-block-title">后续推进</text>
          <view wx:for="{{currentVersionMeta.followUps}}" wx:key="index" class="version-bullet-item">
            <view class="version-bullet-dot version-bullet-dot-light"></view>
            <text class="version-bullet-text">{{item}}</text>
          </view>
        </view>
      </view>
    </view>

    <view wx:if="{{stageTabs.length > 0}}" class="card stage-panel">
      <text class="section-title">循序渐进阶段</text>
      <view class="stage-tabs">
        <view
          wx:for="{{stageTabs}}"
          wx:key="key"
          class="stage-tab {{item.selected ? 'stage-tab-active' : ''}}"
          bindtap="handleStageChange"
          data-key="{{item.key}}"
        >
          <text class="stage-tab-text {{item.selected ? 'stage-tab-text-active' : ''}}">{{item.label}}</text>
        </view>
      </view>
    </view>

    <view class="card path-list-card">
      <view class="path-list-header">
        <view>
          <text class="path-list-title">{{currentVersionMeta.label}}{{currentStageLabel ? ' · ' + currentStageLabel : ''}}</text>
          <text class="path-list-subtitle">当前卡点对应的购买路径预览</text>
        </view>
        <view class="path-status-badge">
          <text class="path-status-badge-text">路径预览</text>
        </view>
      </view>
      <text class="path-status-hint">{{previewHint}}</text>

      <view class="path-steps">
        <view wx:for="{{pathSteps}}" wx:key="index" class="path-step-item">
          <view class="path-step-left">
            <view class="path-step-index">
              <text class="path-step-index-text">{{item.index}}</text>
            </view>
            <view wx:if="{{index < pathSteps.length - 1}}" class="path-step-line"></view>
          </view>
          <view class="path-step-card">
            <text class="path-step-title">{{item.title}}</text>
            <text wx:if="{{item.note}}" class="path-step-note">{{item.note}}</text>
          </view>
        </view>
      </view>
    </view>

    <view wx:if="{{hasPointContext && otherPoints.length > 0}}" class="card other-points-card">
      <view class="other-points-head">
        <view>
          <view class="other-points-kicker">
            <text class="other-points-kicker-text">推荐了解</text>
          </view>
          <text class="section-title">你可能还需要解决这些卡点</text>
        </view>
        <text class="other-points-desc">结合学习情况，也可以一起看看</text>
      </view>
      <view class="other-points-grid">
        <view
          wx:for="{{otherPoints}}"
          wx:key="pointId"
          class="other-point-item other-point-item-{{item.levelClass}}"
          bindtap="handleOtherPointTap"
          data-point-id="{{item.pointId}}"
        >
          <view class="other-point-top">
            <text class="other-point-name">{{item.pointName}}</text>
            <view class="other-point-tag other-point-tag-{{item.levelClass}}">
              <text class="other-point-tag-text other-point-tag-text-{{item.levelClass}}">{{item.level}}</text>
            </view>
          </view>
          <text class="other-point-link">查看购买方案</text>
        </view>
      </view>
    </view>
  </block>

  <view class="bottom-space"></view>
</view>

<view class="pay-bar">
  <view class="pay-info">
    <text class="pay-label">{{diagnoseMode ? '当前价格' : '当前选择'}}</text>
    <view class="pay-price-row">
      <text class="pay-price">{{diagnoseMode ? diagnosePurchase.currentPrice : currentVersionMeta.priceText}}</text>
      <text wx:if="{{diagnoseMode}}" class="pay-original-price">{{diagnosePurchase.originalPrice}}</text>
    </view>
  </view>
  <button class="pay-btn" bindtap="confirmPurchase">
    {{diagnoseMode ? '立即购买诊断课' : '选择该版本'}}
  </button>
</view>

<diagnose-coupon-fab auto-popup="{{true}}"></diagnose-coupon-fab>
