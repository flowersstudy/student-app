<view class="purchase-page">
  <view class="hero-card">
    <text class="hero-badge">课程详情</text>
    <text class="hero-title">{{productName}}</text>
    <text class="hero-desc">{{coreSummary}}</text>
    <text class="hero-price">{{priceDesc}}</text>
  </view>

  <view class="section-card">
    <text class="section-title">卖点</text>
    <view wx:for="{{sellingPoints}}" wx:key="title" class="point-card point-card-{{item.tone}}">
      <text class="point-title">{{item.title}}</text>
      <text class="point-desc">{{item.desc}}</text>
    </view>
  </view>

  <view class="section-card">
    <text class="section-title">学习流程</text>
    <view class="process-list">
      <view wx:for="{{processSteps}}" wx:key="index" class="process-item">
        <view class="process-index">{{index + 1}}</view>
        <text class="process-text">{{item}}</text>
      </view>
    </view>
  </view>

  <view class="section-card">
    <text class="section-title">产品权益</text>
    <view wx:for="{{rights}}" wx:key="index" class="rights-item">
      <text class="rights-dot"></text>
      <text class="rights-text">{{item}}</text>
    </view>
  </view>

  <view class="section-card deposit-card">
    <text class="section-title">押金</text>
    <text class="deposit-price">99 元 / 月</text>
    <text class="deposit-desc">跟完 4 次直播即返押金 99 元。</text>
  </view>

  <view class="section-card">
    <text class="section-title">月度直播课表（4 月）</text>
    <view wx:for="{{scheduleWeeks}}" wx:key="label" class="schedule-week">
      <text class="schedule-week-title">{{item.label}}</text>
      <view wx:for="{{item.days}}" wx:key="index" wx:for-item="day" class="schedule-item">
        <view class="schedule-date">
          <text class="schedule-date-num">{{day.date}}</text>
          <text class="schedule-date-week">{{day.weekday}}</text>
        </view>
        <view class="schedule-content">
          <view class="schedule-head">
            <text class="schedule-tag">{{day.tag}}</text>
          </view>
          <text class="schedule-title">{{day.title}}</text>
          <text wx:if="{{day.note}}" class="schedule-note">{{day.note}}</text>
        </view>
      </view>
    </view>
  </view>

  <view class="section-card">
    <text class="section-title">注意事项</text>
    <view wx:for="{{noticeList}}" wx:key="index" class="notice-item">
      <text class="notice-index">{{index + 1}}</text>
      <text class="notice-text">{{item}}</text>
    </view>
  </view>

  <view class="bottom-space"></view>
</view>

<view class="pay-bar">
  <view class="pay-info">
    <text class="pay-label">押金</text>
    <text class="pay-price">¥{{price}}</text>
  </view>
  <button class="pay-btn" bindtap="goPayment">支付 99 元并生成计划</button>
</view>
