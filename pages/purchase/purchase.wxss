.purchase-page {
  min-height: 100vh;
  background: #f4f7fb;
  padding: 24rpx 24rpx 0;
  box-sizing: border-box;
}

.hero-card,
.section-card {
  background: #ffffff;
  border-radius: 32rpx;
  padding: 28rpx 24rpx;
  box-sizing: border-box;
  box-shadow: 0 16rpx 40rpx rgba(15, 23, 42, 0.06);
  margin-bottom: 20rpx;
}

.hero-card {
  background: linear-gradient(135deg, #111827 0%, #1e3a8a 100%);
}

.hero-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.16);
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 700;
}

.hero-title {
  display: block;
  margin-top: 18rpx;
  color: #ffffff;
  font-size: 42rpx;
  line-height: 1.35;
  font-weight: 800;
}

.hero-desc {
  display: block;
  margin-top: 14rpx;
  color: rgba(255, 255, 255, 0.86);
  font-size: 24rpx;
  line-height: 1.75;
}

.hero-price {
  display: block;
  margin-top: 16rpx;
  color: #facc15;
  font-size: 26rpx;
  font-weight: 700;
}

.section-title {
  display: block;
  color: #0f172a;
  font-size: 32rpx;
  font-weight: 800;
  margin-bottom: 20rpx;
}

.point-card {
  border-radius: 24rpx;
  padding: 22rpx 20rpx;
  margin-bottom: 16rpx;
}

.point-card:last-child {
  margin-bottom: 0;
}

.point-card-primary {
  background: linear-gradient(135deg, #eff6ff, #dbeafe);
}

.point-card-blue {
  background: #f8fbff;
}

.point-card-orange {
  background: #fff7ed;
}

.point-card-green {
  background: #f0fdf4;
}

.point-title {
  display: block;
  color: #0f172a;
  font-size: 28rpx;
  line-height: 1.5;
  font-weight: 700;
}

.point-desc {
  display: block;
  margin-top: 10rpx;
  color: #475569;
  font-size: 23rpx;
  line-height: 1.75;
}

.process-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.process-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx;
  border-radius: 22rpx;
  background: #f8fafc;
}

.process-index {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #1a6eff;
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.process-text {
  flex: 1;
  color: #1e293b;
  font-size: 25rpx;
  font-weight: 600;
}

.rights-item {
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
  margin-bottom: 16rpx;
}

.rights-item:last-child {
  margin-bottom: 0;
}

.rights-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: #1a6eff;
  margin-top: 10rpx;
  flex-shrink: 0;
}

.rights-text {
  flex: 1;
  color: #475569;
  font-size: 24rpx;
  line-height: 1.75;
}

.deposit-card {
  background: linear-gradient(135deg, #fffdf3, #fff7d6);
}

.deposit-price {
  display: block;
  color: #d97706;
  font-size: 44rpx;
  font-weight: 800;
}

.deposit-desc {
  display: block;
  margin-top: 10rpx;
  color: #92400e;
  font-size: 24rpx;
  line-height: 1.7;
}

.schedule-week {
  margin-top: 24rpx;
}

.schedule-week:first-child {
  margin-top: 0;
}

.schedule-week-title {
  display: block;
  margin-bottom: 14rpx;
  color: #1d4ed8;
  font-size: 26rpx;
  font-weight: 700;
}

.schedule-item {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  padding: 20rpx 18rpx;
  border-radius: 22rpx;
  background: #f8fafc;
  margin-bottom: 14rpx;
}

.schedule-date {
  width: 88rpx;
  flex-shrink: 0;
}

.schedule-date-num {
  display: block;
  color: #0f172a;
  font-size: 28rpx;
  font-weight: 800;
}

.schedule-date-week {
  display: block;
  margin-top: 6rpx;
  color: #64748b;
  font-size: 20rpx;
}

.schedule-content {
  flex: 1;
}

.schedule-head {
  margin-bottom: 10rpx;
}

.schedule-tag {
  display: inline-flex;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: #e8f0ff;
  color: #1d4ed8;
  font-size: 20rpx;
  font-weight: 700;
}

.schedule-title {
  display: block;
  color: #1e293b;
  font-size: 24rpx;
  line-height: 1.7;
  font-weight: 600;
}

.schedule-note {
  display: block;
  margin-top: 8rpx;
  color: #64748b;
  font-size: 21rpx;
  line-height: 1.6;
}

.notice-item {
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
  margin-bottom: 16rpx;
}

.notice-item:last-child {
  margin-bottom: 0;
}

.notice-index {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: #eff6ff;
  color: #1d4ed8;
  font-size: 20rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.notice-text {
  flex: 1;
  color: #475569;
  font-size: 23rpx;
  line-height: 1.75;
}

.bottom-space {
  height: 180rpx;
}

.pay-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #ffffff;
  box-shadow: 0 -8rpx 24rpx rgba(15, 23, 42, 0.08);
  padding: 20rpx 24rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.pay-info {
  flex-shrink: 0;
}

.pay-label {
  display: block;
  color: #64748b;
  font-size: 20rpx;
}

.pay-price {
  display: block;
  margin-top: 4rpx;
  color: #ef4444;
  font-size: 42rpx;
  font-weight: 800;
}

.pay-btn {
  flex: 1;
  height: 84rpx;
  border-radius: 999rpx;
  background: #1a6eff;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 700;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.pay-btn::after {
  border: none;
}
