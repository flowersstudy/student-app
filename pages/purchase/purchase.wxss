.purchase-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #f7f8fb 0%, #f3f5f8 100%);
  padding-bottom: 160rpx;
}

.purchase-header-card,
.version-panel,
.stage-panel,
.path-list-card,
.other-points-card,
.diagnose-benefit-card,
.diagnose-journey-card,
.diagnose-process-card,
.diagnose-audience-card,
.diagnose-guarantee-card {
  margin-top: 16rpx;
}

.diagnose-hero-card {
  margin-top: 16rpx;
  padding: 34rpx 30rpx 30rpx;
  background: #ffffff;
  border: 1rpx solid #eef2f7;
}

.diagnose-topline {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.diagnose-kicker {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #fff1df 0%, #fde7bf 100%);
}

.diagnose-kicker-text {
  font-size: 22rpx;
  line-height: 1.2;
  color: #b45309;
  font-weight: 700;
}

.diagnose-countdown {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.88);
  border: 1rpx solid #fed7aa;
}

.diagnose-countdown-expired {
  border-color: #e5e7eb;
  background: #f8fafc;
}

.diagnose-countdown-label {
  font-size: 20rpx;
  color: #9a3412;
  font-weight: 600;
}

.diagnose-countdown-value {
  font-size: 24rpx;
  color: #ea580c;
  font-weight: 800;
  letter-spacing: 1rpx;
}

.diagnose-title {
  display: block;
  margin-top: 18rpx;
  font-size: 40rpx;
  line-height: 1.28;
  color: #1f2937;
  font-weight: 800;
}

.diagnose-subtitle {
  display: block;
  margin-top: 14rpx;
  font-size: 25rpx;
  line-height: 1.7;
  color: #64748b;
}

.diagnose-hero-points {
  margin-top: 20rpx;
  padding: 20rpx 22rpx;
  border-radius: 20rpx;
  background: #f8fafc;
  border: 1rpx solid #eef2f7;
}

.diagnose-hero-point {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
}

.diagnose-hero-point + .diagnose-hero-point {
  margin-top: 14rpx;
}

.diagnose-hero-point-dot {
  width: 10rpx;
  height: 10rpx;
  margin-top: 12rpx;
  border-radius: 50%;
  background: #f97316;
  flex-shrink: 0;
}

.diagnose-hero-point-text {
  flex: 1;
  min-width: 0;
  font-size: 23rpx;
  line-height: 1.65;
  color: #475569;
}

.diagnose-preview-entry {
  margin-top: 22rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  padding: 24rpx 22rpx;
  border-radius: 20rpx;
  background: #ffffff;
  border: 1rpx solid #eef2f7;
  box-shadow: none;
}

.diagnose-preview-entry-main {
  flex: 1;
  min-width: 0;
}

.diagnose-preview-entry-title {
  display: block;
  font-size: 28rpx;
  line-height: 1.3;
  color: #9a3412;
  font-weight: 700;
}

.diagnose-preview-entry-desc {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: #7c5a46;
}

.diagnose-preview-entry-side {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding-left: 12rpx;
}

.diagnose-preview-entry-side-label {
  font-size: 22rpx;
  color: #ea580c;
  font-weight: 700;
}

.diagnose-preview-entry-arrow {
  font-size: 28rpx;
  color: #ea580c;
  font-weight: 700;
}

.diagnose-price-card {
  margin-top: 24rpx;
  padding: 24rpx;
  border-radius: 24rpx;
  background: #fff7ed;
  border: 1rpx solid #fed7aa;
}

.diagnose-price-main {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.diagnose-price-label {
  font-size: 22rpx;
  color: #9a3412;
  font-weight: 700;
}

.diagnose-price-row {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
}

.diagnose-price-value {
  font-size: 56rpx;
  line-height: 1;
  color: #ea580c;
  font-weight: 800;
}

.diagnose-price-original {
  font-size: 24rpx;
  color: #94a3b8;
  text-decoration: line-through;
}

.diagnose-save-badge {
  display: inline-flex;
  margin-top: 16rpx;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(234, 88, 12, 0.1);
}

.diagnose-save-badge-muted {
  background: #f3f4f6;
}

.diagnose-save-badge-text {
  font-size: 22rpx;
  color: #c2410c;
  font-weight: 700;
}

.diagnose-sample-list,
.diagnose-evidence-list,
.diagnose-journey-list {
  margin-top: 20rpx;
}

.diagnose-sample-item {
  padding: 22rpx 22rpx 20rpx;
  border-radius: 22rpx;
  border: 1rpx solid #e7edf4;
  background: #f8fafc;
}

.diagnose-sample-item + .diagnose-sample-item {
  margin-top: 16rpx;
}

.diagnose-sample-item-high {
  background: linear-gradient(180deg, #fff5f5 0%, #fffdfd 100%);
  border-color: #ffd7db;
}

.diagnose-sample-item-mid {
  background: linear-gradient(180deg, #fffaf1 0%, #fffefd 100%);
  border-color: #fde7b2;
}

.diagnose-sample-item-follow {
  background: linear-gradient(180deg, #f7fbff 0%, #ffffff 100%);
  border-color: #d9e7ff;
}

.diagnose-sample-head {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-wrap: wrap;
}

.diagnose-sample-tier {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 40rpx;
  padding: 0 14rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 700;
}

.diagnose-sample-tier-high {
  background: #ffe6e9;
  color: #e5484d;
}

.diagnose-sample-tier-mid {
  background: #fff1c4;
  color: #b7791f;
}

.diagnose-sample-tier-follow {
  background: #e8f1ff;
  color: #2563eb;
}

.diagnose-sample-name {
  font-size: 26rpx;
  line-height: 1.35;
  color: #1d2433;
  font-weight: 700;
}

.diagnose-sample-desc {
  display: block;
  margin-top: 12rpx;
  font-size: 23rpx;
  line-height: 1.7;
  color: #5b677a;
}

.diagnose-evidence-row {
  padding: 18rpx 0;
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
  border-bottom: 1rpx solid #eef2f7;
}

.diagnose-evidence-row:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.diagnose-evidence-label {
  width: 124rpx;
  flex-shrink: 0;
  font-size: 22rpx;
  line-height: 1.6;
  color: #c2410c;
  font-weight: 700;
}

.diagnose-evidence-value {
  flex: 1;
  min-width: 0;
  font-size: 23rpx;
  line-height: 1.7;
  color: #50607a;
}

.diagnose-journey-item + .diagnose-journey-item {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #eef2f7;
}

.diagnose-journey-label {
  display: block;
  font-size: 22rpx;
  line-height: 1.2;
  color: #c2410c;
  font-weight: 700;
}

.diagnose-journey-text {
  display: block;
  margin-top: 10rpx;
  font-size: 23rpx;
  line-height: 1.7;
  color: #50607a;
}

.diagnose-fact-grid {
  margin-top: 20rpx;
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 16rpx;
}

.diagnose-fact-item {
  min-height: 178rpx;
  padding: 22rpx 18rpx;
  border-radius: 22rpx;
  background: #f8fafc;
  border: 1rpx solid #e7edf4;
}

.diagnose-fact-value {
  display: block;
  font-size: 40rpx;
  line-height: 1;
  color: #ea580c;
  font-weight: 800;
}

.diagnose-fact-label {
  display: block;
  margin-top: 10rpx;
  font-size: 22rpx;
  line-height: 1.2;
  color: #1f2937;
  font-weight: 700;
}

.diagnose-fact-desc {
  display: block;
  margin-top: 10rpx;
  font-size: 20rpx;
  line-height: 1.6;
  color: #6b7280;
}

.section-title {
  display: block;
  font-size: 30rpx;
  line-height: 1.2;
  color: #1d2433;
  font-weight: 700;
}

.diagnose-benefit-list,
.diagnose-audience-list,
.diagnose-process-list {
  margin-top: 20rpx;
}

.diagnose-benefit-item,
.diagnose-audience-item,
.diagnose-process-item,
.version-bullet-item {
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
}

.diagnose-benefit-item + .diagnose-benefit-item,
.diagnose-audience-item + .diagnose-audience-item,
.diagnose-process-item + .diagnose-process-item,
.version-bullet-item + .version-bullet-item {
  margin-top: 16rpx;
}

.diagnose-benefit-dot,
.version-bullet-dot {
  width: 12rpx;
  height: 12rpx;
  margin-top: 10rpx;
  border-radius: 50%;
  background: linear-gradient(180deg, #fb923c 0%, #ea580c 100%);
  flex-shrink: 0;
}

.version-bullet-dot-light {
  background: #8bb4ff;
}

.diagnose-benefit-text,
.diagnose-audience-text,
.version-bullet-text {
  flex: 1;
  min-width: 0;
  font-size: 24rpx;
  line-height: 1.7;
  color: #50607a;
}

.diagnose-process-index {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: linear-gradient(180deg, #fff3e6 0%, #ffe3bf 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.diagnose-process-index-text {
  font-size: 22rpx;
  color: #c2410c;
  font-weight: 800;
}

.diagnose-process-main {
  flex: 1;
  min-width: 0;
}

.diagnose-process-title {
  display: block;
  font-size: 26rpx;
  line-height: 1.5;
  color: #1d2433;
  font-weight: 700;
}

.diagnose-process-desc {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: #7b8aa0;
}

.diagnose-audience-mark {
  width: 24rpx;
  line-height: 1.6;
  color: #ea580c;
  font-size: 28rpx;
  font-weight: 700;
  flex-shrink: 0;
}

.diagnose-guarantee-grid {
  margin-top: 20rpx;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}

.diagnose-guarantee-item {
  min-height: 112rpx;
  padding: 22rpx 20rpx;
  border-radius: 22rpx;
  background: #f8fafc;
  border: 1rpx solid #e7edf4;
  display: flex;
  align-items: center;
}

.diagnose-guarantee-text {
  font-size: 24rpx;
  line-height: 1.6;
  color: #334155;
  font-weight: 600;
}

.purchase-header-card {
  background: linear-gradient(180deg, #eff6ff 0%, #ffffff 100%);
  border: 1rpx solid rgba(59, 130, 246, 0.12);
}

.purchase-header-card-foundation {
  background:
    radial-gradient(circle at top right, rgba(59, 130, 246, 0.14), transparent 34%),
    linear-gradient(180deg, #eef5ff 0%, #ffffff 100%);
  border-color: rgba(59, 130, 246, 0.16);
}

.purchase-header-card-special {
  background:
    radial-gradient(circle at top right, rgba(250, 204, 21, 0.18), transparent 36%),
    linear-gradient(180deg, #fff8dc 0%, #ffffff 100%);
  border-color: rgba(245, 158, 11, 0.16);
}

.purchase-header-top {
  display: flex;
}

.purchase-header-main {
  flex: 1;
  min-width: 0;
}

.purchase-header-level-tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  margin-bottom: 16rpx;
}

.purchase-header-level-tag-foundation {
  background: rgba(37, 99, 235, 0.12);
}

.purchase-header-level-tag-special {
  background: rgba(245, 158, 11, 0.14);
}

.purchase-header-level-tag-text {
  font-size: 20rpx;
  line-height: 1.2;
  font-weight: 700;
}

.purchase-header-level-tag-text-foundation {
  color: #1d4ed8;
}

.purchase-header-level-tag-text-special {
  color: #b45309;
}

.purchase-header-title {
  display: block;
  font-size: 34rpx;
  line-height: 1.2;
  font-weight: 700;
  color: #1d2433;
}

.purchase-header-desc {
  display: block;
  margin-top: 14rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #7b8aa0;
}

.purchase-header-tags {
  margin-top: 18rpx;
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
}

.purchase-header-tag {
  padding: 8rpx 18rpx;
  background: #f4f7fb;
  border: 1rpx solid #e6edf7;
  border-radius: 999rpx;
}

.purchase-header-tag-foundation {
  background: rgba(255, 255, 255, 0.76);
  border-color: rgba(59, 130, 246, 0.16);
}

.purchase-header-tag-special {
  background: rgba(255, 251, 235, 0.92);
  border-color: rgba(245, 158, 11, 0.16);
}

.purchase-header-tag-text {
  font-size: 22rpx;
  line-height: 1.2;
  color: #68809f;
  font-weight: 700;
}

.purchase-header-tag-text-foundation {
  color: #1d4ed8;
}

.purchase-header-tag-text-special {
  color: #b45309;
}

.version-tabs {
  margin-top: 20rpx;
  display: flex;
  gap: 16rpx;
}

.version-tab {
  flex: 1;
  min-width: 0;
  min-height: 94rpx;
  padding: 18rpx 14rpx;
  border-radius: 22rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  border: 2rpx solid #e6ebf2;
  background: #f8fafc;
}

.version-tab-active {
  border-color: #bcd2ff;
  background: linear-gradient(180deg, #eef5ff 0%, #f8fbff 100%);
  box-shadow: 0 10rpx 20rpx rgba(26, 110, 255, 0.08);
}

.version-tab-disabled {
  opacity: 0.52;
}

.version-tab-text {
  font-size: 24rpx;
  line-height: 1.2;
  color: #68778f;
  font-weight: 600;
}

.version-tab-text-active {
  color: #1a6eff;
}

.version-tab-status {
  font-size: 20rpx;
  line-height: 1.2;
  color: #9aa5b5;
}

.version-summary-card {
  margin-top: 22rpx;
  padding: 24rpx;
  background: #f8fbff;
  border: 2rpx solid #e4edf9;
  border-radius: 24rpx;
}

.version-summary-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.version-summary-title {
  flex: 1;
  min-width: 0;
  font-size: 32rpx;
  line-height: 1.2;
  color: #1d2433;
  font-weight: 700;
}

.version-summary-price {
  flex-shrink: 0;
  font-size: 26rpx;
  line-height: 1.2;
  color: #1a6eff;
  font-weight: 700;
}

.version-summary-cycle {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.4;
  color: #4a6286;
  font-weight: 600;
}

.version-summary-desc {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #6f7d93;
}

.version-summary-block {
  margin-top: 22rpx;
}

.version-summary-block-title {
  display: block;
  margin-bottom: 14rpx;
  font-size: 24rpx;
  line-height: 1.2;
  color: #1d2433;
  font-weight: 700;
}

.stage-tabs {
  margin-top: 18rpx;
  display: flex;
  gap: 14rpx;
}

.stage-tab {
  flex: 1;
  min-width: 0;
  height: 78rpx;
  border-radius: 20rpx;
  background: #f4f7fb;
  display: flex;
  align-items: center;
  justify-content: center;
}

.stage-tab-active {
  background: linear-gradient(180deg, #eef4ff 0%, #f8fbff 100%);
  border: 2rpx solid #cfe0ff;
}

.stage-tab-text {
  font-size: 24rpx;
  line-height: 1.2;
  color: #7d8aa0;
  font-weight: 600;
}

.stage-tab-text-active {
  color: #1a6eff;
}

.path-list-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.path-list-title {
  display: block;
  font-size: 30rpx;
  line-height: 1.2;
  color: #1d2433;
  font-weight: 700;
}

.path-list-subtitle {
  display: block;
  margin-top: 10rpx;
  font-size: 22rpx;
  line-height: 1.4;
  color: #8b97aa;
}

.path-status-badge {
  flex-shrink: 0;
  padding: 10rpx 16rpx;
  background: #edf4ff;
  border-radius: 999rpx;
}

.path-status-badge-text {
  font-size: 20rpx;
  line-height: 1.2;
  color: #1a6eff;
  font-weight: 700;
}

.path-status-hint {
  display: block;
  margin-top: 18rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: #7b8aa0;
}

.path-steps {
  margin-top: 24rpx;
}

.path-step-item {
  display: flex;
  align-items: stretch;
  gap: 20rpx;
}

.path-step-item + .path-step-item {
  margin-top: 18rpx;
}

.path-step-left {
  width: 52rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  flex-shrink: 0;
}

.path-step-index {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: linear-gradient(180deg, #eef4ff 0%, #dce9ff 100%);
  display: flex;
  align-items: center;
  justify-content: center;
}

.path-step-index-text {
  font-size: 22rpx;
  line-height: 1;
  color: #1a6eff;
  font-weight: 700;
}

.path-step-line {
  margin-top: 10rpx;
  width: 4rpx;
  flex: 1;
  border-radius: 999rpx;
  background: #dbe3ef;
}

.path-step-card {
  flex: 1;
  min-width: 0;
  padding: 22rpx 24rpx;
  background: #f8fafc;
  border: 1rpx solid #e7edf4;
  border-radius: 22rpx;
}

.path-step-title {
  display: block;
  font-size: 26rpx;
  line-height: 1.5;
  color: #1d2433;
  font-weight: 600;
}

.path-step-note {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.5;
  color: #7b8aa0;
}

.other-points-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.other-points-kicker {
  display: inline-flex;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #edf4ff;
}

.other-points-kicker-text {
  font-size: 20rpx;
  line-height: 1.2;
  color: #1a6eff;
  font-weight: 700;
}

.other-points-desc {
  flex-shrink: 0;
  font-size: 22rpx;
  line-height: 1.4;
  color: #8b97aa;
  text-align: right;
  padding-top: 8rpx;
}

.other-points-grid {
  margin-top: 20rpx;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}

.other-point-item {
  padding: 22rpx 20rpx;
  border-radius: 22rpx;
  border: 1rpx solid #e7edf4;
  background: #f8fafc;
  box-shadow: 0 8rpx 20rpx rgba(29, 45, 74, 0.05);
}

.other-point-item-foundation {
  background: linear-gradient(180deg, #f4f9ff 0%, #ffffff 100%);
  border-color: #dbeafe;
}

.other-point-item-special {
  background: linear-gradient(180deg, #fffbf2 0%, #fffefd 100%);
  border-color: #fde7b2;
}

.other-point-top {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 12rpx;
}

.other-point-name {
  font-size: 28rpx;
  line-height: 1.4;
  color: #1d2433;
  font-weight: 700;
}

.other-point-tag {
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
}

.other-point-tag-foundation {
  background: #e0ecff;
}

.other-point-tag-special {
  background: #fff3cd;
}

.other-point-tag-text {
  font-size: 20rpx;
  line-height: 1.2;
  font-weight: 700;
}

.other-point-tag-text-foundation {
  color: #1d4ed8;
}

.other-point-tag-text-special {
  color: #b7791f;
}

.other-point-link {
  display: block;
  margin-top: 18rpx;
  font-size: 22rpx;
  line-height: 1.2;
  color: #1a6eff;
  font-weight: 700;
}

.bottom-space {
  height: 200rpx;
}

.pay-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(255, 255, 255, 0.98);
  box-shadow: 0 -8rpx 24rpx rgba(15, 23, 42, 0.08);
  padding: 20rpx 24rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.pay-info {
  flex-shrink: 0;
}

.pay-label {
  display: block;
  color: #64748b;
  font-size: 20rpx;
}

.pay-price-row {
  display: flex;
  align-items: baseline;
  gap: 10rpx;
  margin-top: 4rpx;
}

.pay-price {
  color: #ea580c;
  font-size: 32rpx;
  font-weight: 800;
}

.pay-original-price {
  font-size: 22rpx;
  color: #94a3b8;
  text-decoration: line-through;
}

.pay-btn {
  flex: 1;
  height: 84rpx;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #f97316 0%, #fb923c 100%);
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 700;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 14rpx 28rpx rgba(249, 115, 22, 0.24);
}

.pay-btn::after {
  border: none;
}
