.purchase-page {
  min-height: 100vh;
  background: #f5f6fa;
  padding-bottom: 120rpx;
}

.purchase-header-card {
  margin-top: 16rpx;
  background: #ffffff;
}

.purchase-header-top {
  display: flex;
}

.purchase-header-main {
  flex: 1;
  min-width: 0;
}

.purchase-header-title {
  display: block;
  font-size: 34rpx;
  line-height: 1.2;
  font-weight: 700;
  color: #1d2433;
}

.purchase-header-desc {
  display: block;
  margin-top: 14rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #7b8aa0;
}

.purchase-header-tags {
  margin-top: 18rpx;
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
}

.purchase-header-tag {
  padding: 8rpx 18rpx;
  background: #f4f7fb;
  border: 1rpx solid #e6edf7;
  border-radius: 999rpx;
}

.purchase-header-tag-text {
  font-size: 22rpx;
  line-height: 1.2;
  color: #68809f;
  font-weight: 700;
}

.version-panel,
.stage-panel,
.path-list-card,
.other-points-card {
  margin-top: 16rpx;
}

.section-title {
  display: block;
  font-size: 30rpx;
  line-height: 1.2;
  color: #1d2433;
  font-weight: 700;
}

.version-tabs {
  margin-top: 20rpx;
  display: flex;
  gap: 16rpx;
}

.version-tab {
  flex: 1;
  min-width: 0;
  min-height: 94rpx;
  padding: 18rpx 14rpx;
  border-radius: 22rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  border: 2rpx solid #e6ebf2;
  background: #f8fafc;
}

.version-tab-active {
  border-color: #bcd2ff;
  background: linear-gradient(180deg, #eef5ff 0%, #f8fbff 100%);
  box-shadow: 0 10rpx 20rpx rgba(26, 110, 255, 0.08);
}

.version-tab-disabled {
  opacity: 0.52;
}

.version-tab-text {
  font-size: 24rpx;
  line-height: 1.2;
  color: #68778f;
  font-weight: 600;
}

.version-tab-text-active {
  color: #1a6eff;
}

.version-tab-status {
  font-size: 20rpx;
  line-height: 1.2;
  color: #9aa5b5;
}

.version-summary-card {
  margin-top: 22rpx;
  padding: 24rpx;
  background: #f8fbff;
  border: 2rpx solid #e4edf9;
  border-radius: 24rpx;
}

.version-summary-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.version-summary-title {
  flex: 1;
  min-width: 0;
  font-size: 32rpx;
  line-height: 1.2;
  color: #1d2433;
  font-weight: 700;
}

.version-summary-price {
  flex-shrink: 0;
  font-size: 26rpx;
  line-height: 1.2;
  color: #1a6eff;
  font-weight: 700;
}

.version-summary-cycle {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.4;
  color: #4a6286;
  font-weight: 600;
}

.version-summary-desc {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #6f7d93;
}

.version-summary-block {
  margin-top: 22rpx;
}

.version-summary-block-title {
  display: block;
  margin-bottom: 14rpx;
  font-size: 24rpx;
  line-height: 1.2;
  color: #1d2433;
  font-weight: 700;
}

.version-bullet-item {
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
}

.version-bullet-item + .version-bullet-item {
  margin-top: 14rpx;
}

.version-bullet-dot {
  width: 12rpx;
  height: 12rpx;
  margin-top: 10rpx;
  border-radius: 50%;
  background: #1a6eff;
  flex-shrink: 0;
}

.version-bullet-dot-light {
  background: #8bb4ff;
}

.version-bullet-text {
  flex: 1;
  min-width: 0;
  font-size: 24rpx;
  line-height: 1.6;
  color: #50607a;
}

.stage-tabs {
  margin-top: 18rpx;
  display: flex;
  gap: 14rpx;
}

.stage-tab {
  flex: 1;
  min-width: 0;
  height: 78rpx;
  border-radius: 20rpx;
  background: #f4f7fb;
  display: flex;
  align-items: center;
  justify-content: center;
}

.stage-tab-active {
  background: linear-gradient(180deg, #eef4ff 0%, #f8fbff 100%);
  border: 2rpx solid #cfe0ff;
  box-sizing: border-box;
}

.stage-tab-text {
  font-size: 24rpx;
  line-height: 1.2;
  color: #7d8aa0;
  font-weight: 600;
}

.stage-tab-text-active {
  color: #1a6eff;
}

.path-list-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.path-list-title {
  display: block;
  font-size: 30rpx;
  line-height: 1.2;
  color: #1d2433;
  font-weight: 700;
}

.path-list-subtitle {
  display: block;
  margin-top: 10rpx;
  font-size: 22rpx;
  line-height: 1.4;
  color: #8b97aa;
}

.path-status-badge {
  flex-shrink: 0;
  padding: 10rpx 16rpx;
  background: #edf4ff;
  border-radius: 999rpx;
}

.path-status-badge-text {
  font-size: 20rpx;
  line-height: 1.2;
  color: #1a6eff;
  font-weight: 700;
}

.path-status-hint {
  display: block;
  margin-top: 18rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: #7b8aa0;
}

.path-steps {
  margin-top: 24rpx;
}

.path-step-item {
  display: flex;
  align-items: stretch;
  gap: 20rpx;
}

.path-step-item + .path-step-item {
  margin-top: 18rpx;
}

.path-step-left {
  width: 52rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  flex-shrink: 0;
}

.path-step-index {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: linear-gradient(180deg, #eef4ff 0%, #dce9ff 100%);
  display: flex;
  align-items: center;
  justify-content: center;
}

.path-step-index-text {
  font-size: 22rpx;
  line-height: 1;
  color: #1a6eff;
  font-weight: 700;
}

.path-step-line {
  margin-top: 10rpx;
  width: 4rpx;
  flex: 1;
  border-radius: 999rpx;
  background: #dbe3ef;
}

.path-step-card {
  flex: 1;
  min-width: 0;
  padding: 22rpx 24rpx;
  background: #f8fafc;
  border: 1rpx solid #e7edf4;
  border-radius: 22rpx;
  box-sizing: border-box;
}

.path-step-title {
  display: block;
  font-size: 26rpx;
  line-height: 1.5;
  color: #1d2433;
  font-weight: 600;
}

.path-step-note {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.5;
  color: #7b8aa0;
}

.other-points-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.other-points-kicker {
  display: inline-flex;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #edf4ff;
}

.other-points-kicker-text {
  font-size: 20rpx;
  line-height: 1.2;
  color: #1a6eff;
  font-weight: 700;
}

.other-points-desc {
  flex-shrink: 0;
  font-size: 22rpx;
  line-height: 1.4;
  color: #8b97aa;
  text-align: right;
  padding-top: 8rpx;
}

.other-points-grid {
  margin-top: 20rpx;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}

.other-point-item {
  padding: 22rpx 20rpx;
  border-radius: 22rpx;
  border: 1rpx solid #e7edf4;
  background: #f8fafc;
  box-sizing: border-box;
  box-shadow: 0 8rpx 20rpx rgba(29, 45, 74, 0.05);
}

.other-point-item-foundation {
  background: linear-gradient(180deg, #fff7f7 0%, #fffdfd 100%);
  border-color: #ffdfe1;
}

.other-point-item-special {
  background: linear-gradient(180deg, #fffbf2 0%, #fffefd 100%);
  border-color: #fde7b2;
}

.other-point-item-targeted {
  background: linear-gradient(180deg, #f7fbff 0%, #ffffff 100%);
  border-color: #dbe8ff;
}

.other-point-top {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 12rpx;
}

.other-point-name {
  font-size: 28rpx;
  line-height: 1.4;
  color: #1d2433;
  font-weight: 700;
}

.other-point-tag {
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
}

.other-point-tag-foundation {
  background: #ffe8e9;
}

.other-point-tag-special {
  background: #fff3cd;
}

.other-point-tag-targeted {
  background: #e8f1ff;
}

.other-point-tag-text {
  font-size: 20rpx;
  line-height: 1.2;
  font-weight: 700;
}

.other-point-tag-text-foundation {
  color: #e5484d;
}

.other-point-tag-text-special {
  color: #b7791f;
}

.other-point-tag-text-targeted {
  color: #1a6eff;
}

.other-point-link {
  display: block;
  margin-top: 18rpx;
  font-size: 22rpx;
  line-height: 1.2;
  color: #1a6eff;
  font-weight: 700;
}

.bottom-space {
  height: 180rpx;
}

.pay-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #ffffff;
  box-shadow: 0 -8rpx 24rpx rgba(15, 23, 42, 0.08);
  padding: 20rpx 24rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.pay-info {
  flex-shrink: 0;
}

.pay-label {
  display: block;
  color: #64748b;
  font-size: 20rpx;
}

.pay-price {
  display: block;
  margin-top: 4rpx;
  color: #1a6eff;
  font-size: 30rpx;
  font-weight: 800;
}

.pay-btn {
  flex: 1;
  height: 84rpx;
  border-radius: 999rpx;
  background: #1a6eff;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 700;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.pay-btn::after {
  border: none;
}
