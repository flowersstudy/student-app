.path-page {
  height: 100vh;
  background: #ffffff;
  overflow: hidden;
}

.path-back-top {
  position: fixed;
  left: 18rpx;
  top: calc(18rpx + env(safe-area-inset-top));
  z-index: 70;
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.path-back-top-arrow {
  color: #475569;
  font-size: 46rpx;
  line-height: 1;
}

.path-stage {
  position: relative;
  height: 100vh;
  padding-top: 0;
  box-sizing: border-box;
}

.tier-band {
  position: absolute;
  left: 0;
  width: 100%;
}

.tier-band-red {
  top: 0;
  height: 20%;
  background: rgba(255, 107, 107, 0.04);
}

.tier-band-yellow {
  top: 20%;
  height: 54%;
  background: rgba(255, 217, 61, 0.04);
}

.tier-band-blue {
  top: 74%;
  height: 26%;
  background: rgba(78, 205, 196, 0.04);
}

.note-card {
  position: absolute;
  width: 198rpx;
  background: #ffffff;
  border-radius: 12rpx;
  padding: 12rpx;
  box-sizing: border-box;
  box-shadow: 0 6rpx 18rpx rgba(15, 23, 42, 0.05);
  z-index: 8;
}

.note-card-red {
  top: 36rpx;
  left: 32rpx;
  border: 2rpx solid #ff6b6b;
}

.note-card-yellow {
  top: 42%;
  right: 32rpx;
  border: 2rpx solid #ffd93d;
}

.note-card-blue {
  left: 32rpx;
  bottom: 70rpx;
  border: 2rpx solid #4ecdc4;
}

.note-text {
  display: block;
  color: #555555;
  font-size: 20rpx;
  line-height: 1.6;
}

.path-line-wrap {
  position: absolute;
  inset: 0;
  z-index: 2;
}

.path-svg {
  width: 100%;
  height: 100%;
}

.path-node {
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
  z-index: 10;
}

.path-node-row {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  transform: scale(1);
  transition: transform 0.18s ease;
}

.path-node-active .path-node-row,
.path-node:active .path-node-row {
  transform: scale(1.05);
}

.path-node-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.path-node-dot-red {
  background: #ff6b6b;
}

.path-node-dot-yellow {
  background: #ffd93d;
}

.path-node-dot-blue {
  background: #4ecdc4;
}

.path-node-name {
  color: #2c3e50;
  font-size: 24rpx;
  line-height: 1.35;
  font-weight: 500;
}

.hover-card {
  position: absolute;
  width: 252rpx;
  background: #ffffff;
  border-radius: 12rpx;
  padding: 14rpx 14rpx 12rpx;
  box-sizing: border-box;
  box-shadow: 0 10rpx 24rpx rgba(15, 23, 42, 0.07);
  z-index: 18;
}

.hover-card-red {
  border: 2rpx solid rgba(255, 107, 107, 0.42);
}

.hover-card-yellow {
  border: 2rpx solid rgba(255, 217, 61, 0.62);
}

.hover-card-blue {
  border: 2rpx solid rgba(78, 205, 196, 0.45);
}

.hover-card-title {
  display: block;
  color: #2c3e50;
  font-size: 22rpx;
  font-weight: 600;
  line-height: 1.4;
}

.hover-card-summary {
  display: block;
  margin-top: 8rpx;
  color: #5b6673;
  font-size: 19rpx;
  line-height: 1.6;
}

.hover-card-points {
  margin-top: 10rpx;
}

.hover-card-row {
  display: flex;
  align-items: flex-start;
  margin-bottom: 4rpx;
}

.hover-card-dot {
  margin-right: 8rpx;
  color: #8aa0b5;
  font-size: 18rpx;
  line-height: 1.6;
}

.hover-card-point {
  flex: 1;
  color: #5b6673;
  font-size: 18rpx;
  line-height: 1.6;
}

.hover-card-footer {
  margin-top: 8rpx;
}

.hover-card-link {
  color: #2f6bff;
  font-size: 18rpx;
  line-height: 1.5;
}
