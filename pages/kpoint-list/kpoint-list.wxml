<view class="path-page" bindtap="closeNode">
  <view class="path-stage">
    <view class="tier-band tier-band-red"></view>
    <view class="tier-band tier-band-yellow"></view>
    <view class="tier-band tier-band-blue"></view>

    <view class="note-card note-card-red">
      <text class="note-text">底层信息处理问题，不先纠偏，后续题型方法学了也会跑偏</text>
    </view>

    <view class="note-card note-card-yellow">
      <text class="note-text">题型结构方法问题，会持续拖累对应题型，不解决会反复失分</text>
    </view>

    <view class="note-card note-card-blue">
      <text class="note-text">考情靶向问题，放在冲刺阶段突破最合适</text>
    </view>

    <view class="path-line-wrap">
      <image class="path-svg" src="{{pathSvg}}" mode="scaleToFill" />
    </view>

    <view
      wx:for="{{nodes}}"
      wx:key="id"
      class="path-node {{activeNode && activeNode.id === item.id ? 'path-node-active' : ''}}"
      style="top: {{item.top}}; left: {{item.left}};"
      catchtap="openNode"
      data-id="{{item.id}}"
    >
      <view class="path-node-row">
        <view class="path-node-dot path-node-dot-{{item.tier}}"></view>
        <text class="path-node-name">{{item.name}}</text>
      </view>
    </view>

    <view
      wx:if="{{activeNode}}"
      class="hover-card hover-card-{{activeNode.tier}}"
      style="top: {{activeNode.cardTop}}; left: {{activeNode.cardLeft}};"
      catchtap="noop"
    >
      <text class="hover-card-title">{{activeNode.name}}</text>
      <text class="hover-card-summary">{{activeNode.summary}}</text>
      <view class="hover-card-points">
        <view wx:for="{{activeNode.focusPoints}}" wx:key="index" class="hover-card-row">
          <text class="hover-card-dot">•</text>
          <text class="hover-card-point">{{item}}</text>
        </view>
      </view>
      <view class="hover-card-footer">
        <text class="hover-card-link" bindtap="goCourseDetail" data-course-id="{{activeNode.courseId}}">查看对应课程</text>
      </view>
    </view>
  </view>
</view>
