<view class="register-page">

  <!-- 第一区：8个卡点 -->
  <view class="section-label">全部卡点课程</view>
  <view class="course-grid">
    <view
      wx:for="{{courses}}"
      wx:key="id"
      class="course-card {{item.selected ? 'course-card-selected' : ''}}"
      bindtap="toggleCourse"
      data-id="{{item.id}}"
    >
      <view class="course-card-top">
        <view class="course-num">{{item.id}}</view>
        <view class="check-icon" wx:if="{{item.selected}}">✓</view>
      </view>
      <text class="course-card-name">{{item.name}}</text>
      <text class="course-card-price">¥{{item.price}}</text>
    </view>
  </view>

  <!-- 底部购买栏 -->
  <view class="buy-bar">
    <view class="buy-bar-info">
      <text class="buy-selected">已选 {{selectedCount}} 个</text>
      <text class="buy-price">¥{{totalPrice}}</text>
    </view>
    <button class="btn-buy" bindtap="goPayment">去购买</button>
  </view>

  <!-- 第二区：诊断推荐 -->
  <view class="section-label" style="margin-top:24rpx;">不知道选哪个？</view>
  <view class="diagnose-card">
    <view class="diagnose-left">
      <view class="diagnose-icon">诊</view>
      <view class="diagnose-info">
        <text class="diagnose-title">免费诊断测评</text>
        <text class="diagnose-desc">3分钟答题，精准匹配你的薄弱卡点</text>
      </view>
    </view>
    <button class="btn-diagnose">立即测评</button>
  </view>

  <!-- 第三区：档案示例 -->
  <view class="section-label" style="margin-top:24rpx;">学员档案示例</view>
  <view class="profile-example" wx:for="{{examples}}" wx:key="id">
    <view class="example-header">
      <view class="example-avatar">{{item.name[0]}}</view>
      <view class="example-base">
        <view class="example-name-row">
          <text class="example-name">{{item.name}}</text>
          <text class="tag tag-blue" style="margin-left:12rpx;">{{item.exam}}</text>
        </view>
        <text class="example-meta">{{item.grade}} · {{item.major}}</text>
      </view>
      <view class="example-score">+{{item.score}}分</view>
    </view>
    <view class="example-divider"></view>
    <view class="example-points">
      <text class="example-points-label">突破卡点：</text>
      <text class="tag tag-green" wx:for="{{item.points}}" wx:key="*this" style="margin-right:8rpx;">{{item}}</text>
    </view>
    <text class="example-comment">"{{item.comment}}"</text>
  </view>

  <view style="height:120rpx;"></view>

</view>
