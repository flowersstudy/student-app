.register-page {
  background: #f5f6fa;
  min-height: 100vh;
}

.section-label {
  font-size: 30rpx;
  font-weight: 700;
  color: #1a1a1a;
  padding: 36rpx 32rpx 16rpx;
}

/* 卡点宫格 */
.course-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 0 24rpx;
}

.course-card {
  width: 22%;
  margin: 0 1.5% 16rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx 12rpx;
  display: flex;
  flex-direction: column;
  border: 2rpx solid transparent;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.05);
}

.course-card-selected {
  border-color: #1A6EFF;
  background: #f0f5ff;
}

.course-card-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.course-num {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: #f0f0f0;
  font-size: 22rpx;
  font-weight: 700;
  color: #999;
  display: flex;
  align-items: center;
  justify-content: center;
}

.course-card-selected .course-num {
  background: #1A6EFF;
  color: #fff;
}

.check-icon {
  width: 28rpx;
  height: 28rpx;
}

.course-card-name {
  font-size: 24rpx;
  font-weight: 600;
  color: #1a1a1a;
  line-height: 1.4;
  margin-bottom: 8rpx;
}

.course-card-price {
  font-size: 22rpx;
  color: #999;
}

.course-card-selected .course-card-name {
  color: #1A6EFF;
}

/* 购买栏 */
.buy-bar {
  margin: 24rpx 32rpx 0;
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx 28rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 4rpx 16rpx rgba(26,110,255,0.1);
}

.buy-bar-info {
  display: flex;
  align-items: baseline;
  gap: 16rpx;
}

.buy-selected {
  font-size: 26rpx;
  color: #666;
}

.buy-price {
  font-size: 36rpx;
  font-weight: 700;
  color: #1A6EFF;
}

.btn-buy {
  background: #1A6EFF;
  color: #fff;
  border-radius: 50rpx;
  padding: 18rpx 40rpx;
  font-size: 28rpx;
  font-weight: 600;
  border: none;
}
.btn-buy::after { border: none; }

/* 诊断推荐 */
.diagnose-card {
  margin: 0 32rpx;
  background: linear-gradient(135deg, #1A6EFF, #4a9eff);
  border-radius: 20rpx;
  padding: 28rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.diagnose-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.diagnose-icon {
  width: 72rpx;
  height: 72rpx;
  flex-shrink: 0;
  filter: drop-shadow(0 10rpx 16rpx rgba(255, 255, 255, 0.12));
}

.diagnose-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #fff;
  display: block;
  margin-bottom: 6rpx;
}

.diagnose-desc {
  font-size: 22rpx;
  color: rgba(255,255,255,0.85);
  display: block;
}

.btn-diagnose {
  background: #fff;
  color: #1A6EFF;
  border-radius: 50rpx;
  padding: 16rpx 28rpx;
  font-size: 26rpx;
  font-weight: 600;
  border: none;
  flex-shrink: 0;
}
.btn-diagnose::after { border: none; }

/* 档案示例 */
.profile-example {
  margin: 0 32rpx 20rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}

.example-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.example-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: #1A6EFF;
  color: #fff;
  font-size: 32rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.example-base {
  flex: 1;
}

.example-name-row {
  display: flex;
  align-items: center;
  margin-bottom: 6rpx;
}

.example-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #1a1a1a;
}

.example-meta {
  font-size: 22rpx;
  color: #999;
}

.example-score {
  font-size: 40rpx;
  font-weight: 700;
  color: #52c41a;
  flex-shrink: 0;
}

.example-divider {
  height: 1rpx;
  background: #f5f5f5;
  margin: 20rpx 0;
}

.example-points {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-bottom: 16rpx;
}

.example-points-label {
  font-size: 24rpx;
  color: #666;
}

.example-comment {
  font-size: 26rpx;
  color: #555;
  line-height: 1.7;
  font-style: italic;
}
