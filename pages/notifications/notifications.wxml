<view class="notif-page">

  <view wx:if="{{notifications.length === 0}}" class="notif-empty">
    <image class="notif-empty-icon" src="{{uiIcons.bell}}" mode="aspectFit" />
    <text class="notif-empty-text">暂无新通知</text>
  </view>

  <view wx:else>
    <!-- 置顶提醒（上课 / 考试）-->
    <view wx:if="{{notifications[0].pinned}}" class="notif-section-label">重要提醒</view>
    <view
      wx:for="{{notifications}}"
      wx:key="index"
      wx:if="{{item.pinned}}"
      class="notif-item notif-item-pinned"
      bindtap="onItemTap"
      data-url="{{item.url}}"
      data-pinned="{{item.pinned}}"
    >
      <view class="notif-item-bar notif-bar-{{item.type}}"></view>
      <view class="notif-item-icon-wrap notif-bg-{{item.type}}">
        <image class="notif-item-icon" src="{{item.type === 'class' ? uiIcons.class : uiIcons.exam}}" mode="aspectFit" />
      </view>
      <view class="notif-item-body">
        <text class="notif-item-label">{{item.label}}</text>
        <text class="notif-item-desc">{{item.desc}}</text>
      </view>
      <view class="notif-item-arrow"><text class="notif-arrow-text">›</text></view>
    </view>

    <!-- 普通提醒 -->
    <view class="notif-section-label">其他提醒</view>
    <view
      wx:for="{{notifications}}"
      wx:key="index"
      wx:if="{{!item.pinned}}"
      class="notif-item"
      bindtap="onItemTap"
      data-url="{{item.url}}"
      data-pinned="{{item.pinned}}"
    >
      <view class="notif-item-bar notif-bar-{{item.type}}"></view>
      <view class="notif-item-icon-wrap notif-bg-{{item.type}}">
        <image class="notif-item-icon" src="{{item.type === 'hw' ? uiIcons.homework : item.type === 'drill' ? uiIcons.drill : uiIcons.video}}" mode="aspectFit" />
      </view>
      <view class="notif-item-body">
        <text class="notif-item-label">{{item.label}}</text>
        <text class="notif-item-desc">{{item.desc}}</text>
      </view>
      <view class="notif-item-arrow"><text class="notif-arrow-text">›</text></view>
    </view>
  </view>

</view>
