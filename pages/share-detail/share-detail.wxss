.share-detail-page {
  min-height: 100vh;
  padding: 24rpx 20rpx 48rpx;
  box-sizing: border-box;
  background: #f7f8fa;
}

.detail-hero,
.detail-section {
  border-radius: 28rpx;
  background: #ffffff;
  border: 1rpx solid #eef1f5;
  box-shadow: 0 10rpx 26rpx rgba(15, 23, 42, 0.04);
}

.detail-hero {
  padding: 28rpx 24rpx;
}

.detail-topline {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 12rpx;
}

.detail-tag,
.info-tag {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #f3f4f6;
  color: #475467;
  font-size: 20rpx;
  line-height: 1.4;
}

.detail-top-meta {
  color: #667085;
  font-size: 22rpx;
}

.detail-title {
  display: block;
  margin-top: 18rpx;
  color: #101828;
  font-size: 40rpx;
  line-height: 1.4;
  font-weight: 700;
}

.detail-summary {
  display: block;
  margin-top: 14rpx;
  color: #667085;
  font-size: 25rpx;
  line-height: 1.8;
}

.detail-author-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-top: 24rpx;
  padding: 20rpx;
  border-radius: 24rpx;
  background: #fafbfc;
}

.detail-author-main {
  display: flex;
  align-items: center;
  gap: 14rpx;
  flex: 1;
  min-width: 0;
}

.detail-avatar {
  width: 76rpx;
  height: 76rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #98a2b3 0%, #667085 100%);
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 700;
  flex-shrink: 0;
}

.detail-author-copy {
  min-width: 0;
}

.detail-author-name {
  display: block;
  color: #101828;
  font-size: 26rpx;
  font-weight: 700;
}

.detail-author-role,
.detail-publish,
.detail-read-time {
  display: block;
  color: #667085;
  font-size: 22rpx;
  line-height: 1.6;
}

.detail-author-side {
  text-align: right;
  flex-shrink: 0;
}

.detail-meta-row {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 20rpx;
}

.detail-meta-chip {
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
  padding: 14rpx 18rpx;
  border-radius: 999rpx;
  background: #f8fafc;
}

.detail-meta-icon,
.result-icon {
  width: 28rpx;
  height: 28rpx;
  flex-shrink: 0;
}

.detail-meta-text {
  color: #344054;
  font-size: 22rpx;
}

.detail-section {
  margin-top: 18rpx;
  padding: 24rpx 22rpx;
}

.section-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.section-copy {
  min-width: 0;
}

.section-title {
  display: block;
  color: #1f2a37;
  font-size: 28rpx;
  line-height: 1.4;
  font-weight: 700;
}

.section-subtitle {
  display: block;
  margin-top: 6rpx;
  color: #7b8798;
  font-size: 22rpx;
  line-height: 1.58;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 18rpx;
}

.takeaway-card {
  background: #ffffff;
}

.takeaway-item {
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
  margin-top: 18rpx;
}

.takeaway-index {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #111827;
  color: #ffffff;
  font-size: 20rpx;
  font-weight: 700;
  flex-shrink: 0;
}

.takeaway-text {
  color: #475467;
  font-size: 24rpx;
  line-height: 1.72;
}

.result-card {
  background: #ffffff;
}

.result-top {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 6rpx 0;
}

.result-copy {
  display: flex;
  flex-direction: column;
}

.result-label {
  color: #667085;
  font-size: 21rpx;
}

.result-text {
  margin-top: 6rpx;
  color: #101828;
  font-size: 28rpx;
  font-weight: 700;
}

.article-card {
  background: #ffffff;
}

.article-title {
  display: block;
  color: #101828;
  font-size: 30rpx;
  font-weight: 700;
}

.article-text {
  display: block;
  margin-top: 14rpx;
  color: #475467;
  font-size: 24rpx;
  line-height: 1.88;
}
