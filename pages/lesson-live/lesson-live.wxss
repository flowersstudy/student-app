.container {
  padding: 32rpx;
  min-height: 100vh;
  background: #f5f6fa;
}

.center {
  display: flex;
  justify-content: center;
  align-items: center;
  padding-top: 120rpx;
}

.tip {
  font-size: 28rpx;
  color: #999;
}

.tip.error {
  color: #e74c3c;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 40rpx;
  margin-top: 24rpx;
}

.title {
  font-size: 36rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 24rpx;
}

.meta {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.actions {
  margin-top: 48rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.btn-primary {
  background: #1a6eff;
  color: #fff;
  border-radius: 12rpx;
  font-size: 32rpx;
  height: 88rpx;
  line-height: 88rpx;
  border: none;
}

.btn-secondary {
  background: #f0f4ff;
  color: #1a6eff;
  border-radius: 12rpx;
  font-size: 32rpx;
  height: 88rpx;
  line-height: 88rpx;
  border: none;
}
