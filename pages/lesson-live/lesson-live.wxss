.lesson-page {
  min-height: 100vh;
  background: #f5f6fa;
  padding: 24rpx 0;
  padding-bottom: 120rpx;
}

.phase-label {
  font-size: 24rpx;
  color: #999999;
  font-weight: 500;
  display: block;
  margin-bottom: 12rpx;
}

.phase-card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 8rpx;
}

.lesson-info-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  margin-bottom: 12rpx;
}

.info-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.info-text {
  font-size: 28rpx;
  color: #333333;
}

.btn-outline {
  background: #ffffff;
  color: #1A6EFF;
  border: 2rpx solid #1A6EFF;
  border-radius: 36rpx;
  font-size: 26rpx;
  padding: 12rpx 28rpx;
  line-height: 1.5;
}

.btn-outline::after {
  border: none;
}

.sub-label {
  font-size: 26rpx;
  color: #666666;
  font-weight: 500;
  display: block;
  margin-bottom: 16rpx;
}

.topic-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.topic-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 16rpx 20rpx;
  background: #f5f6fa;
  border-radius: 12rpx;
  border: 2rpx solid transparent;
}

.topic-selected {
  background: #e8f0ff;
  border-color: #1A6EFF;
}

.topic-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  border: 2rpx solid #cccccc;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.topic-dot-selected {
  background: #1A6EFF;
  border-color: #1A6EFF;
}

.topic-name {
  font-size: 28rpx;
  color: #333333;
}

.btn-enter {
  background: linear-gradient(90deg, #1A6EFF, #4a9eff);
  color: #ffffff;
  border-radius: 56rpx;
  padding: 28rpx 0;
  font-size: 32rpx;
  font-weight: 600;
  text-align: center;
  width: 100%;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(26, 110, 255, 0.35);
}

.btn-enter::after {
  border: none;
}
