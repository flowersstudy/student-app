.review-page {
  min-height: 100vh;
  background: #f5f6fa;
  padding-bottom: 40rpx;
}

/* ===== 触发原因卡 ===== */
.trigger-card {
  display: flex;
  flex-direction: row;
  align-items: center;
  margin: 24rpx 24rpx 0;
  border-radius: 20rpx;
  padding: 28rpx 28rpx;
  gap: 20rpx;
}

.trigger-interrupted {
  background: linear-gradient(135deg, #fff7e6, #fff1cc);
  border-left: 6rpx solid #fa8c16;
}

.trigger-cycle_end {
  background: linear-gradient(135deg, #f0f7ff, #dbeeff);
  border-left: 6rpx solid #1A6EFF;
}

.trigger-all_complete {
  background: linear-gradient(135deg, #f6ffed, #d9f7be);
  border-left: 6rpx solid #52c41a;
}

.trigger-icon-wrap {
  flex-shrink: 0;
}

.trigger-icon {
  font-size: 56rpx;
}

.trigger-info {
  flex: 1;
}

.trigger-label {
  font-size: 30rpx;
  font-weight: 700;
  color: #1a1a1a;
  display: block;
  margin-bottom: 6rpx;
}

.trigger-desc {
  font-size: 24rpx;
  color: #666;
  line-height: 1.5;
  display: block;
}

/* ===== 进度条 ===== */
.progress-section {
  margin: 20rpx 24rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx 28rpx;
}

.progress-header-row {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.progress-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #333;
}

.progress-count {
  font-size: 24rpx;
  color: #1A6EFF;
  font-weight: 600;
}

.progress-bar-bg {
  height: 12rpx;
  background: #f0f0f0;
  border-radius: 6rpx;
  overflow: hidden;
}

.progress-bar-fill {
  height: 100%;
  background: linear-gradient(90deg, #1A6EFF, #4a9eff);
  border-radius: 6rpx;
  transition: width 0.3s ease;
}

/* ===== 复习列表 ===== */
.review-list {
  margin: 0 24rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.review-group {
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
}

.group-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 24rpx;
}

.group-left {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 16rpx;
}

.group-index {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: #1A6EFF;
  color: #fff;
  font-size: 24rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.group-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #1a1a1a;
}

.group-right {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 12rpx;
}

.group-checked-num {
  font-size: 24rpx;
  color: #999;
}

.group-arrow {
  font-size: 36rpx;
  color: #ccc;
  transition: transform 0.2s;
  display: inline-block;
  transform: rotate(90deg);
}

.group-arrow-up {
  transform: rotate(-90deg);
}

.kp-list {
  padding: 0 24rpx 16rpx;
  border-top: 1rpx solid #f5f6fa;
}

.kp-item {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  padding: 20rpx 8rpx;
  border-bottom: 1rpx solid #f8f8f8;
  gap: 16rpx;
}

.kp-item:last-child {
  border-bottom: none;
}

.kp-item-checked {
  opacity: 0.6;
}

.kp-checkbox {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  border: 3rpx solid #d0d0d0;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-top: 2rpx;
  transition: all 0.2s;
}

.kp-checkbox-checked {
  background: #1A6EFF;
  border-color: #1A6EFF;
}

.kp-check-icon {
  color: #fff;
  font-size: 22rpx;
  font-weight: 700;
}

.kp-title {
  font-size: 26rpx;
  color: #333;
  line-height: 1.6;
  flex: 1;
}

.kp-title-checked {
  text-decoration: line-through;
  color: #aaa;
}

/* ===== 完成按钮 ===== */
.finish-wrap {
  margin: 24rpx 24rpx 0;
}

.btn-finish {
  width: 100%;
  border-radius: 50rpx;
  padding: 28rpx 0;
  font-size: 28rpx;
  font-weight: 700;
  border: none;
  text-align: center;
}

.btn-finish-active {
  background: linear-gradient(90deg, #1A6EFF, #4a9eff);
  color: #fff;
}

.btn-finish-disabled {
  background: #e8e8e8;
  color: #bbb;
}

.btn-finish-active::after { border: none; }
.btn-finish-disabled::after { border: none; }

/* ===== 老师反馈区 ===== */
.feedback-section {
  margin: 24rpx 24rpx 0;
}

.feedback-header {
  margin-bottom: 20rpx;
}

.feedback-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1a1a1a;
  display: block;
  margin-bottom: 6rpx;
}

.feedback-sub {
  font-size: 22rpx;
  color: #999;
  display: block;
}

.chat-bubble-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.chat-row {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  gap: 16rpx;
}

.chat-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #1A6EFF, #4a9eff);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.chat-avatar-text {
  color: #fff;
  font-size: 28rpx;
  font-weight: 700;
}

/* 语音气泡 */
.bubble {
  flex: 1;
  background: #fff;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.06);
}

.bubble-voice {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 24rpx 24rpx;
  gap: 20rpx;
}

.voice-wave {
  display: flex;
  flex-direction: row;
  align-items: flex-end;
  gap: 5rpx;
  flex-shrink: 0;
}

.wave-bar {
  width: 6rpx;
  background: #1A6EFF;
  border-radius: 3rpx;
}
.wb1 { height: 20rpx; opacity: 0.4; }
.wb2 { height: 32rpx; opacity: 0.6; }
.wb3 { height: 44rpx; opacity: 0.9; }
.wb4 { height: 30rpx; opacity: 0.6; }
.wb5 { height: 18rpx; opacity: 0.4; }

.voice-info {
  flex: 1;
}

.voice-duration {
  font-size: 28rpx;
  font-weight: 700;
  color: #1A6EFF;
  display: block;
  margin-bottom: 4rpx;
}

.voice-label {
  font-size: 22rpx;
  color: #999;
  display: block;
}

/* 视频气泡 */
.bubble-video {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 20rpx 24rpx;
  gap: 20rpx;
}

.video-thumb {
  width: 96rpx;
  height: 72rpx;
  background: linear-gradient(135deg, #1248cc, #1A6EFF);
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.video-play-icon {
  color: #fff;
  font-size: 28rpx;
}

.video-info {
  flex: 1;
}

.video-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #1a1a1a;
  display: block;
  margin-bottom: 6rpx;
}

.video-meta {
  font-size: 22rpx;
  color: #999;
}

/* 完成返回按钮 */
.btn-done {
  display: block;
  margin-top: 28rpx;
  width: 100%;
  background: #52c41a;
  color: #fff;
  border: none;
  border-radius: 50rpx;
  padding: 28rpx 0;
  font-size: 30rpx;
  font-weight: 700;
  text-align: center;
}
.btn-done::after { border: none; }
