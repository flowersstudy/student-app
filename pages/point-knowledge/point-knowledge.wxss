.knowledge-page {
  position: relative;
  min-height: 100vh;
  overflow: hidden;
  background: linear-gradient(180deg, var(--knowledge-page-top, #f4f8ff) 0%, var(--knowledge-page-bottom, #f8f5ff) 100%);
  padding: 48rpx 24rpx 64rpx;
  box-sizing: border-box;
}

.knowledge-decor {
  position: absolute;
  border-radius: 50%;
  background: var(--knowledge-accent, #1A6EFF);
  opacity: 0.08;
  pointer-events: none;
}

.knowledge-decor-left {
  width: 260rpx;
  height: 260rpx;
  left: -96rpx;
  top: -70rpx;
}

.knowledge-decor-right {
  width: 180rpx;
  height: 180rpx;
  right: -64rpx;
  top: 280rpx;
  opacity: 0.06;
}

.knowledge-card {
  position: relative;
  z-index: 1;
  overflow: hidden;
  background: #ffffff;
  border-radius: 32rpx;
  padding: 34rpx 24rpx 28rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.72);
  box-shadow: 0 18rpx 42rpx rgba(29, 45, 74, 0.1);
}

.knowledge-card-accent {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 12rpx;
  background: linear-gradient(90deg, var(--knowledge-accent, #1A6EFF), var(--knowledge-accent-deep, #0D8EC9));
}

.knowledge-card-head {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-bottom: 24rpx;
}

.knowledge-card-marker {
  width: 10rpx;
  height: 34rpx;
  border-radius: 999rpx;
  background: var(--knowledge-accent, #1A6EFF);
  box-shadow: 0 8rpx 16rpx rgba(29, 45, 74, 0.12);
}

.knowledge-section-title {
  flex: 1;
  min-width: 0;
  font-size: 30rpx;
  line-height: 1.4;
  color: #1d2433;
  font-weight: 800;
}

.knowledge-item {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
}

.knowledge-item + .knowledge-item {
  margin-top: 18rpx;
}

.knowledge-index {
  width: 46rpx;
  height: 46rpx;
  border-radius: 50%;
  background: linear-gradient(180deg, var(--knowledge-accent, #1A6EFF) 0%, var(--knowledge-accent-deep, #0D8EC9) 100%);
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-top: 16rpx;
  box-shadow: 0 8rpx 16rpx rgba(29, 45, 74, 0.12);
}

.knowledge-item-body {
  flex: 1;
  min-width: 0;
  padding: 20rpx 22rpx;
  border-radius: 22rpx;
  background: var(--knowledge-soft, #f4f8ff);
  border: 2rpx solid var(--knowledge-soft-border, #d9e8ff);
}

.knowledge-text {
  display: block;
  font-size: 27rpx;
  line-height: 1.75;
  color: #334155;
}
