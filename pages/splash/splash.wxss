page {
  background: #f7f9fc;
}

.splash {
  position: relative;
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  box-sizing: border-box;
  background: linear-gradient(180deg, #fbfcfe 0%, #f5f7fb 100%);
  overflow: hidden;
}

.bg-glow {
  position: absolute;
  border-radius: 50%;
  filter: blur(8rpx);
  pointer-events: none;
}

.bg-glow-top {
  width: 360rpx;
  height: 360rpx;
  top: -100rpx;
  right: -80rpx;
  background: rgba(47, 107, 255, 0.08);
}

.bg-glow-bottom {
  width: 300rpx;
  height: 300rpx;
  left: -80rpx;
  bottom: -60rpx;
  background: rgba(78, 205, 196, 0.07);
}

.welcome-card {
  position: relative;
  z-index: 2;
  width: 100%;
  max-width: 560rpx;
  background: rgba(255, 255, 255, 0.96);
  border: 1rpx solid rgba(15, 23, 42, 0.06);
  border-radius: 28rpx;
  padding: 78rpx 44rpx;
  box-sizing: border-box;
  box-shadow: 0 20rpx 60rpx rgba(15, 23, 42, 0.08);
  display: flex;
  flex-direction: column;
  align-items: center;
}

.brand-title {
  font-size: 54rpx;
  line-height: 1.2;
  font-weight: 700;
  color: #1f2937;
  letter-spacing: 2rpx;
}

.brand-subtitle {
  margin-top: 18rpx;
  font-size: 26rpx;
  line-height: 1.8;
  color: #6b7280;
  text-align: center;
}
