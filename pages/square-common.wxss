.square-scene {
  position: relative;
  min-height: 100vh;
  padding: 24rpx 20rpx 30rpx;
  box-sizing: border-box;
  overflow: hidden;
}

.bg-orb {
  position: absolute;
  border-radius: 50%;
  pointer-events: none;
  filter: blur(6rpx);
  opacity: 0.7;
}

.bg-orb-a {
  top: -90rpx;
  right: -40rpx;
  width: 260rpx;
  height: 260rpx;
}

.bg-orb-b {
  top: 320rpx;
  left: -80rpx;
  width: 220rpx;
  height: 220rpx;
}

.hero-card,
.highlight-card,
.section-card {
  position: relative;
  z-index: 1;
  border-radius: 32rpx;
  overflow: hidden;
}

.hero-card {
  padding: 30rpx 24rpx 24rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.65);
  box-shadow: 0 18rpx 40rpx rgba(25, 43, 74, 0.08);
  backdrop-filter: blur(10rpx);
}

.hero-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.hero-copy {
  flex: 1;
  min-width: 0;
}

.hero-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: 48rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 700;
}

.hero-title {
  display: block;
  margin-top: 18rpx;
  color: #1f2a37;
  font-size: 40rpx;
  line-height: 1.28;
  font-weight: 700;
}

.hero-desc {
  display: block;
  margin-top: 12rpx;
  color: #607089;
  font-size: 24rpx;
  line-height: 1.7;
}

.hero-visual {
  flex-shrink: 0;
}

.hero-icon-shell {
  width: 112rpx;
  height: 112rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 32rpx;
  box-shadow: inset 0 8rpx 18rpx rgba(255, 255, 255, 0.38);
}

.hero-icon {
  width: 74rpx;
  height: 74rpx;
}

.hero-stats {
  display: flex;
  gap: 14rpx;
  margin-top: 24rpx;
}

.stat-chip {
  flex: 1;
  min-width: 0;
  padding: 18rpx 14rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.74);
  border: 1rpx solid rgba(255, 255, 255, 0.8);
}

.stat-value {
  display: block;
  color: #1f2a37;
  font-size: 28rpx;
  line-height: 1.2;
  font-weight: 700;
}

.stat-label {
  display: block;
  margin-top: 8rpx;
  color: #718198;
  font-size: 20rpx;
  line-height: 1.5;
}

.action-scroll {
  position: relative;
  z-index: 1;
  margin-top: 18rpx;
  white-space: nowrap;
}

.action-row {
  display: inline-flex;
  gap: 14rpx;
  padding-right: 20rpx;
}

.action-pill {
  flex-shrink: 0;
  padding: 16rpx 24rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.82);
  border: 1rpx solid rgba(255, 255, 255, 0.9);
  color: #334155;
  font-size: 24rpx;
  font-weight: 600;
  transition: transform 160ms ease, box-shadow 160ms ease;
}

.action-pill-press {
  transform: scale(0.97);
}

.highlight-card,
.section-card {
  margin-top: 18rpx;
  padding: 24rpx 22rpx;
  background: rgba(255, 255, 255, 0.9);
  border: 2rpx solid rgba(255, 255, 255, 0.72);
  box-shadow: 0 14rpx 32rpx rgba(25, 43, 74, 0.06);
}

.section-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.section-copy {
  min-width: 0;
}

.section-title {
  display: block;
  color: #1f2a37;
  font-size: 28rpx;
  line-height: 1.4;
  font-weight: 700;
}

.section-subtitle {
  display: block;
  margin-top: 6rpx;
  color: #7b8798;
  font-size: 22rpx;
  line-height: 1.58;
}

.section-mark {
  flex-shrink: 0;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 700;
}

.highlight-title {
  display: block;
  margin-top: 16rpx;
  color: #1f2a37;
  font-size: 34rpx;
  line-height: 1.35;
  font-weight: 700;
}

.highlight-desc {
  display: block;
  margin-top: 12rpx;
  color: #667789;
  font-size: 24rpx;
  line-height: 1.72;
}

.feed-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  margin-top: 18rpx;
}

.feed-item {
  display: flex;
  gap: 16rpx;
  padding: 18rpx 18rpx;
  border-radius: 24rpx;
  background: #f8fbff;
  border: 1rpx solid #e9eef5;
  transition: transform 160ms ease, box-shadow 160ms ease;
}

.feed-item-press {
  transform: scale(0.985);
}

.feed-icon-wrap {
  flex-shrink: 0;
  width: 68rpx;
  height: 68rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 20rpx;
  background: #ffffff;
  box-shadow: inset 0 2rpx 8rpx rgba(255, 255, 255, 0.8);
}

.feed-icon {
  width: 42rpx;
  height: 42rpx;
}

.feed-main {
  flex: 1;
  min-width: 0;
}

.feed-topline {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.feed-title {
  flex: 1;
  min-width: 0;
  color: #1f2a37;
  font-size: 26rpx;
  line-height: 1.45;
  font-weight: 700;
}

.feed-tag {
  flex-shrink: 0;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  font-size: 18rpx;
  line-height: 1.2;
  font-weight: 700;
}

.feed-desc {
  display: block;
  margin-top: 8rpx;
  color: #667789;
  font-size: 23rpx;
  line-height: 1.68;
}

.feed-meta {
  display: block;
  margin-top: 10rpx;
  color: #8a97a8;
  font-size: 20rpx;
  line-height: 1.5;
}

.theme-sky {
  background: linear-gradient(180deg, #f3f9ff 0%, #ecf5ff 100%);
}

.theme-sky .bg-orb-a,
.theme-sky .bg-orb-b {
  background: radial-gradient(circle, rgba(169, 214, 255, 0.42) 0%, rgba(169, 214, 255, 0) 72%);
}

