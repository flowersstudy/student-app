.drill-page {
  min-height: 100vh;
  background: #f5f6fa;
  padding-bottom: 120rpx;
}

.flow-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  margin-bottom: 24rpx;
}

.flow-badge {
  background: #1A6EFF;
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 600;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  margin-right: 16rpx;
}

.flow-badge-green {
  background: #52c41a;
}

.flow-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
}

.timer-display {
  background: linear-gradient(135deg, #1A6EFF, #4a9eff);
  border-radius: 20rpx;
  padding: 40rpx;
  text-align: center;
  margin-bottom: 24rpx;
  transition: background 0.4s;
}

.timer-display-low {
  background: linear-gradient(135deg, #d4380d, #fa541c);
}

.timer-display-up {
  background: linear-gradient(135deg, #434343, #666);
}

.timer-badge {
  display: inline-block;
  background: rgba(255,255,255,0.22);
  color: #fff;
  font-size: 20rpx;
  font-weight: 700;
  letter-spacing: 3rpx;
  padding: 4rpx 18rpx;
  border-radius: 20rpx;
  margin-bottom: 16rpx;
}

.timer-text {
  font-size: 72rpx;
  font-weight: 700;
  color: #ffffff;
  font-family: 'Courier New', monospace;
  display: block;
  letter-spacing: 4rpx;
}

.timer-status-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  margin-top: 12rpx;
  gap: 10rpx;
}

.timer-dot-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
}

.timer-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: #a0f080;
  animation: dot-blink 1s infinite;
}

@keyframes dot-blink {
  0%, 100% { opacity: 1; }
  50%       { opacity: 0.2; }
}

.timer-label {
  font-size: 24rpx;
  color: rgba(255,255,255,0.85);
  display: block;
}

.btn-flow-disabled {
  background: #aaa;
}

.btn-row {
  display: flex;
  flex-direction: row;
  gap: 20rpx;
}

.btn-flow {
  flex: 1;
  background: #1A6EFF;
  color: #ffffff;
  border-radius: 48rpx;
  padding: 22rpx 0;
  font-size: 28rpx;
  font-weight: 600;
  text-align: center;
  border: none;
}

.btn-flow::after {
  border: none;
}

.btn-flow-outline {
  background: #ffffff;
  color: #1A6EFF;
  border: 2rpx solid #1A6EFF;
}

/* 视频解析主入口 */
.video-banner {
  background: linear-gradient(135deg, #1a1a2e, #16213e);
  border-radius: 20rpx;
  padding: 28rpx 24rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  margin-bottom: 24rpx;
}

.video-play-icon {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-right: 20rpx;
}

.video-play-icon-image {
  width: 80rpx;
  height: 80rpx;
  filter: drop-shadow(0 10rpx 18rpx rgba(37, 99, 235, 0.2));
}

.video-info {
  flex: 1;
}

.video-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #ffffff;
  display: block;
  margin-bottom: 8rpx;
}

.video-sub {
  font-size: 22rpx;
  color: rgba(255,255,255,0.6);
  display: block;
}

.video-arrow {
  font-size: 40rpx;
  color: rgba(255,255,255,0.4);
  margin-left: 12rpx;
}

/* 次要操作三按钮 */
.sub-actions {
  background: #f5f6fa;
  border-radius: 16rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
}

.sub-action-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 0;
}

.sub-action-divider {
  width: 1rpx;
  height: 60rpx;
  background: #e0e0e0;
}

.sub-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 700;
  margin-bottom: 10rpx;
}

.sub-icon-green { background: #f0fff4; color: #52c41a; }
.sub-icon-orange { background: #fff7e6; color: #fa8c16; }
.sub-icon-red { background: #fff0f0; color: #ff4d4f; }

.sub-label {
  font-size: 24rpx;
  color: #666;
}

.file-arrow {
  font-size: 36rpx;
  color: #cccccc;
  flex-shrink: 0;
}

.file-icon-green {
  background: #52c41a;
}

.question-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
  flex: 1;
  margin-right: 16rpx;
}

.btn-done {
  width: 100%;
  margin-top: 20rpx;
  background: #f5f6fa;
  color: #999999;
  border-radius: 48rpx;
  padding: 20rpx 0;
  font-size: 28rpx;
  font-weight: 500;
  text-align: center;
  border: none;
}

.btn-done::after {
  border: none;
}

.btn-done-active {
  background: #f0fff4;
  color: #52c41a;
}

.modal-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.45);
  z-index: 999;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-box {
  background: #fff;
  border-radius: 24rpx;
  padding: 44rpx 40rpx 32rpx;
  width: 580rpx;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1a1a1a;
  display: block;
  margin-bottom: 36rpx;
  text-align: center;
}

.modal-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
  margin-bottom: 8rpx;
}

.modal-label {
  font-size: 28rpx;
  color: #555;
}

.modal-input {
  font-size: 30rpx;
  font-weight: 700;
  color: #1A6EFF;
  text-align: right;
  width: 120rpx;
}

.modal-unit {
  font-size: 26rpx;
  color: #888;
  margin-left: 8rpx;
}

.modal-btns {
  display: flex;
  flex-direction: row;
  gap: 20rpx;
  margin-top: 36rpx;
}

.modal-btn {
  flex: 1;
  border-radius: 48rpx;
  padding: 22rpx 0;
  text-align: center;
  font-size: 28rpx;
  font-weight: 600;
}

.modal-btn-cancel {
  background: #f5f6fa;
  color: #888;
}

.modal-btn-confirm {
  background: #1A6EFF;
  color: #fff;
}
