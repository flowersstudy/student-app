<view class="drill-page">

  <!-- 顶部进度 + 计时器 -->
  <view class="card">
    <view class="row-between" style="margin-bottom:24rpx;">
      <text class="section-title" style="margin-bottom:0;">刷题练习</text>
      <text class="task-progress-text">{{drillDoneCount}}/{{drillQuestions.length}} 已完成</text>
    </view>

    <!-- 倒计时显示 -->
    <view class="timer-display {{timeLow ? 'timer-display-low' : ''}} {{timeUp ? 'timer-display-up' : ''}}">
      <text class="timer-badge">倒计时</text>
      <text class="timer-text">{{timerDisplay}}</text>
      <view class="timer-status-row">
        <view wx:if="{{timerRunning}}" class="timer-dot-wrap">
          <view class="timer-dot"></view>
        </view>
        <text class="timer-label">
          {{timeUp ? '时间已到，请提交作答' : timeLow ? '剩余时间不足5分钟' : timerRunning ? '计时中' : '点击开始'}}
        </text>
      </view>
    </view>

    <!-- 按钮行 -->
    <view class="btn-row">
      <button
        class="btn-flow {{timeUp ? 'btn-flow-disabled' : ''}}"
        bindtap="toggleTimer"
        disabled="{{timeUp}}"
      >{{timerRunning ? '暂停' : timeUp ? '已结束' : '开始计时'}}</button>
      <button class="btn-flow btn-flow-outline" bindtap="resetTimer">重置</button>
      <button class="btn-flow btn-flow-outline" bindtap="openTimerEdit">编辑时长</button>
    </view>
  </view>

  <!-- 编辑时长 Modal -->
  <view wx:if="{{showTimerEdit}}" class="modal-mask">
    <view class="modal-box">
      <text class="modal-title">设置刷题时长</text>
      <view class="modal-row">
        <text class="modal-label">时长（分钟）</text>
        <view style="display:flex;align-items:center;">
          <input
            class="modal-input"
            type="number"
            value="{{editMinutes}}"
            bindinput="onEditMinutesInput"
            placeholder="90"
          />
          <text class="modal-unit">分钟</text>
        </view>
      </view>
      <view class="modal-btns">
        <view class="modal-btn modal-btn-cancel" bindtap="cancelTimerEdit"><text>取消</text></view>
        <view class="modal-btn modal-btn-confirm" bindtap="confirmTimerEdit"><text>确定</text></view>
      </view>
    </view>
  </view>

  <!-- 第一题 -->
  <view class="card">
    <view class="row-between" style="margin-bottom:24rpx;">
      <text class="question-title">第一题：追寻长期价值</text>
      <text class="tag {{drillQuestions[0].done ? 'tag-green' : 'tag-gray'}}">
        {{drillQuestions[0].done ? '已完成' : '待完成'}}
      </text>
    </view>
    <view class="file-card {{drillQuestions[0].preFiles[0].url ? '' : 'file-card-disabled'}}" bindtap="openFile" data-qid="{{1}}" data-filetype="pre" data-fileid="{{1}}">
      <view class="file-icon {{drillQuestions[0].preFiles[0].url ? '' : 'file-icon-gray'}}"><text class="file-icon-text">PDF</text></view>
      <view class="file-info"><text class="file-name {{drillQuestions[0].preFiles[0].url ? '' : 'file-name-gray'}}">第一题追寻长期价值讲义.pdf</text></view>
      <text wx:if="{{drillQuestions[0].preFiles[0].opened}}" class="tag tag-green">已打开</text>
      <text wx:elif="{{drillQuestions[0].preFiles[0].url}}" class="file-arrow">›</text>
      <text wx:else class="tag tag-gray">暂未上传</text>
    </view>
    <view class="file-card {{drillQuestions[0].postFiles[0].url ? '' : 'file-card-disabled'}}" bindtap="openFile" data-qid="{{1}}" data-filetype="post" data-fileid="{{2}}">
      <view class="file-icon file-icon-green {{drillQuestions[0].postFiles[0].url ? '' : 'file-icon-gray'}}"><text class="file-icon-text">PDF</text></view>
      <view class="file-info"><text class="file-name {{drillQuestions[0].postFiles[0].url ? '' : 'file-name-gray'}}">第一题追寻长期价值解析.pdf</text></view>
      <text wx:if="{{drillQuestions[0].postFiles[0].opened}}" class="tag tag-green">已打开</text>
      <text wx:elif="{{drillQuestions[0].postFiles[0].url}}" class="file-arrow">›</text>
      <text wx:else class="tag tag-gray">暂未上传</text>
    </view>
    <view class="video-banner" style="margin-top:16rpx;" bindtap="watchAnalysis" data-videoid="{{drillQuestions[0].videoId}}">
      <view class="video-play-icon">
        <image class="video-play-icon-image" src="{{uiIcons.play}}" mode="aspectFit" />
      </view>
      <view class="video-info">
        <text class="video-title">视频解析</text>
        <text class="video-sub">第一题：追寻长期价值</text>
      </view>
      <text class="video-arrow">›</text>
    </view>
    <button class="btn-done {{drillQuestions[0].done ? 'btn-done-active' : ''}}" bindtap="toggleDrillTask" data-id="1">
      {{drillQuestions[0].done ? '已完成 ✓' : '标记完成'}}
    </button>
  </view>

  <!-- 第二题 -->
  <view class="card">
    <view class="row-between" style="margin-bottom:24rpx;">
      <text class="question-title">第二题：流动与新生</text>
      <text class="tag {{drillQuestions[1].done ? 'tag-green' : 'tag-gray'}}">
        {{drillQuestions[1].done ? '已完成' : '待完成'}}
      </text>
    </view>
    <view class="file-card {{drillQuestions[1].preFiles[0].url ? '' : 'file-card-disabled'}}" bindtap="openFile" data-qid="{{2}}" data-filetype="pre" data-fileid="{{3}}">
      <view class="file-icon {{drillQuestions[1].preFiles[0].url ? '' : 'file-icon-gray'}}"><text class="file-icon-text">PDF</text></view>
      <view class="file-info"><text class="file-name {{drillQuestions[1].preFiles[0].url ? '' : 'file-name-gray'}}">第二题流动与新生讲义.pdf</text></view>
      <text wx:if="{{drillQuestions[1].preFiles[0].opened}}" class="tag tag-green">已打开</text>
      <text wx:elif="{{drillQuestions[1].preFiles[0].url}}" class="file-arrow">›</text>
      <text wx:else class="tag tag-gray">暂未上传</text>
    </view>
    <view class="file-card {{drillQuestions[1].postFiles[0].url ? '' : 'file-card-disabled'}}" bindtap="openFile" data-qid="{{2}}" data-filetype="post" data-fileid="{{4}}">
      <view class="file-icon file-icon-green {{drillQuestions[1].postFiles[0].url ? '' : 'file-icon-gray'}}"><text class="file-icon-text">PDF</text></view>
      <view class="file-info"><text class="file-name {{drillQuestions[1].postFiles[0].url ? '' : 'file-name-gray'}}">第二题流动与新生解析.pdf</text></view>
      <text wx:if="{{drillQuestions[1].postFiles[0].opened}}" class="tag tag-green">已打开</text>
      <text wx:elif="{{drillQuestions[1].postFiles[0].url}}" class="file-arrow">›</text>
      <text wx:else class="tag tag-gray">暂未上传</text>
    </view>
    <view class="video-banner" style="margin-top:16rpx;" bindtap="watchAnalysis" data-videoid="{{drillQuestions[1].videoId}}">
      <view class="video-play-icon">
        <image class="video-play-icon-image" src="{{uiIcons.play}}" mode="aspectFit" />
      </view>
      <view class="video-info">
        <text class="video-title">视频解析</text>
        <text class="video-sub">第二题：流动与新生</text>
      </view>
      <text class="video-arrow">›</text>
    </view>
    <button class="btn-done {{drillQuestions[1].done ? 'btn-done-active' : ''}}" bindtap="toggleDrillTask" data-id="2">
      {{drillQuestions[1].done ? '已完成 ✓' : '标记完成'}}
    </button>
  </view>

  <!-- 第三题 -->
  <view class="card">
    <view class="row-between" style="margin-bottom:24rpx;">
      <text class="question-title">第三题：思维播种</text>
      <text class="tag {{drillQuestions[2].done ? 'tag-green' : 'tag-gray'}}">
        {{drillQuestions[2].done ? '已完成' : '待完成'}}
      </text>
    </view>
    <view class="file-card {{drillQuestions[2].preFiles[0].url ? '' : 'file-card-disabled'}}" bindtap="openFile" data-qid="{{3}}" data-filetype="pre" data-fileid="{{5}}">
      <view class="file-icon {{drillQuestions[2].preFiles[0].url ? '' : 'file-icon-gray'}}"><text class="file-icon-text">PDF</text></view>
      <view class="file-info"><text class="file-name {{drillQuestions[2].preFiles[0].url ? '' : 'file-name-gray'}}">第三题思维播种讲义.pdf</text></view>
      <text wx:if="{{drillQuestions[2].preFiles[0].opened}}" class="tag tag-green">已打开</text>
      <text wx:elif="{{drillQuestions[2].preFiles[0].url}}" class="file-arrow">›</text>
      <text wx:else class="tag tag-gray">暂未上传</text>
    </view>
    <view class="file-card {{drillQuestions[2].postFiles[0].url ? '' : 'file-card-disabled'}}" bindtap="openFile" data-qid="{{3}}" data-filetype="post" data-fileid="{{6}}">
      <view class="file-icon file-icon-green {{drillQuestions[2].postFiles[0].url ? '' : 'file-icon-gray'}}"><text class="file-icon-text">PDF</text></view>
      <view class="file-info"><text class="file-name {{drillQuestions[2].postFiles[0].url ? '' : 'file-name-gray'}}">第三题思维播种解析.pdf</text></view>
      <text wx:if="{{drillQuestions[2].postFiles[0].opened}}" class="tag tag-green">已打开</text>
      <text wx:elif="{{drillQuestions[2].postFiles[0].url}}" class="file-arrow">›</text>
      <text wx:else class="tag tag-gray">暂未上传</text>
    </view>
    <view class="video-banner" style="margin-top:16rpx;" bindtap="watchAnalysis" data-videoid="{{drillQuestions[2].videoId}}">
      <view class="video-play-icon">
        <image class="video-play-icon-image" src="{{uiIcons.play}}" mode="aspectFit" />
      </view>
      <view class="video-info">
        <text class="video-title">视频解析</text>
        <text class="video-sub">第三题：思维播种</text>
      </view>
      <text class="video-arrow">›</text>
    </view>
    <button class="btn-done {{drillQuestions[2].done ? 'btn-done-active' : ''}}" bindtap="toggleDrillTask" data-id="3">
      {{drillQuestions[2].done ? '已完成 ✓' : '标记完成'}}
    </button>
  </view>

  <!-- 笔记 -->
  <view class="card">
    <text class="section-title">学习笔记</text>
    <textarea
      class="input-area"
      placeholder="记录本次刷题的心得、错误点..."
      value="{{notes}}"
      bindinput="onNotesInput"
      auto-height
      style="min-height:160rpx;"
    />
  </view>

  <view class="safe-bottom"></view>
</view>
