<view class="teacher-page" wx:if="{{teacher}}">

  <!-- 头像 + 基本信息 -->
  <view class="profile-hero">
    <view class="profile-avatar">
      <text class="profile-avatar-text">{{teacher.avatar}}</text>
    </view>
    <text class="profile-name">{{teacher.name}}</text>
    <text class="profile-title">{{teacher.title}}</text>
    <view class="profile-tags">
      <text wx:for="{{teacher.specialty}}" wx:key="*this" class="profile-tag">{{item}}</text>
    </view>
  </view>

  <!-- 数据亮点 -->
  <view class="card highlights-card">
    <view wx:for="{{teacher.highlights}}" wx:key="label" class="highlight-item">
      <text class="highlight-value">{{item.value}}</text>
      <text class="highlight-label">{{item.label}}</text>
    </view>
  </view>

  <!-- 个人简介 -->
  <view class="card">
    <text class="section-title">教师简介</text>
    <text class="bio-text">{{teacher.bio}}</text>
  </view>

  <!-- 操作按钮 -->
  <view class="action-bar">
    <button class="btn-chat" bindtap="goChat">发消息</button>
  </view>

</view>
