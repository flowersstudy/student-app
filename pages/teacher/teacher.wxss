.teacher-page {
  min-height: 100vh;
  background: #f5f6fa;
  padding-bottom: 140rpx;
}

/* ===== 顶部大头像区 ===== */
.profile-hero {
  background: linear-gradient(160deg, #1248cc, #1A6EFF 55%, #4a9eff);
  padding: 60rpx 32rpx 48rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.profile-avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.25);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
  border: 4rpx solid rgba(255,255,255,0.5);
}

.profile-avatar-text {
  font-size: 60rpx;
  font-weight: 700;
  color: #fff;
}

.profile-name {
  font-size: 44rpx;
  font-weight: 700;
  color: #fff;
  display: block;
  margin-bottom: 10rpx;
}

.profile-title {
  font-size: 26rpx;
  color: rgba(255,255,255,0.8);
  display: block;
  margin-bottom: 24rpx;
}

.profile-tags {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 12rpx;
  justify-content: center;
}

.profile-tag {
  background: rgba(255,255,255,0.2);
  color: #fff;
  font-size: 22rpx;
  font-weight: 600;
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
}

/* ===== 数据亮点 ===== */
.highlights-card {
  display: flex;
  flex-direction: row;
  margin-top: -1rpx;
  border-radius: 0 0 16rpx 16rpx;
}

.highlight-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 28rpx 0;
  border-right: 1rpx solid #f0f0f0;
}

.highlight-item:last-child {
  border-right: none;
}

.highlight-value {
  font-size: 38rpx;
  font-weight: 700;
  color: #1A6EFF;
  margin-bottom: 6rpx;
}

.highlight-label {
  font-size: 22rpx;
  color: #999;
}

/* ===== 简介 ===== */
.bio-text {
  font-size: 27rpx;
  color: #555;
  line-height: 1.9;
  display: block;
  margin-top: 16rpx;
}

/* ===== 底部按钮 ===== */
.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  border-top: 1rpx solid #f0f0f0;
  padding: 20rpx 32rpx calc(20rpx + env(safe-area-inset-bottom));
}

.btn-chat {
  width: 100%;
  background: #1A6EFF;
  color: #fff;
  border-radius: 50rpx;
  padding: 26rpx 0;
  font-size: 30rpx;
  font-weight: 700;
  border: none;
  text-align: center;
}

.btn-chat::after { border: none; }
