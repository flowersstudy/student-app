.study-square-page {
  position: relative;
  height: 100vh;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  box-sizing: border-box;
  padding: 8rpx 20rpx calc(8rpx + 56px + env(safe-area-inset-bottom));
  gap: 12rpx;
  background:
    radial-gradient(circle at 50% -10%, rgba(255, 255, 255, 0.92), transparent 24%),
    linear-gradient(180deg, #ffffff 0%, #f8fafc 20%, #f4f7fb 52%, #f2f5fa 100%);
}

.study-square-page::before,
.study-square-page::after {
  content: '';
  position: absolute;
  inset: 0;
  z-index: 0;
  pointer-events: none;
}

.study-square-page::before {
  background:
    radial-gradient(ellipse at 20% 14%, rgba(255, 255, 255, 0.3), transparent 20%),
    radial-gradient(ellipse at 82% 76%, rgba(148, 163, 184, 0.03), transparent 24%);
  opacity: 0.76;
}

.study-square-page::after {
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.04) 0%, rgba(255, 255, 255, 0) 26%, rgba(148, 163, 184, 0.03) 100%);
  opacity: 0.72;
}

.map-shell {
  position: relative;
  flex: 1;
  min-height: 0;
  z-index: 1;
  height: auto;
  margin-top: 0;
  border-radius: 44rpx;
  background:
    radial-gradient(circle at 50% -8%, rgba(255, 255, 255, 0.62), transparent 34%),
    linear-gradient(180deg, #ddf4ff 0%, #c8ebfb 46%, #b7e1f4 100%);
  border: 1rpx solid rgba(191, 228, 249, 0.82);
  box-shadow: 0 18rpx 40rpx rgba(14, 116, 144, 0.08);
  overflow: hidden;
}

.map-scene {
  position: relative;
  width: 100%;
  height: 1180rpx;
  transform: translateY(-44rpx) scale(1.04);
  transform-origin: top center;
}

.sea-horizon {
  position: absolute;
  left: -12rpx;
  right: -12rpx;
  top: 82rpx;
  height: 2rpx;
  background: linear-gradient(90deg, rgba(255,255,255,0) 0%, rgba(255,255,255,0.48) 16%, rgba(255,255,255,0.76) 50%, rgba(255,255,255,0.48) 84%, rgba(255,255,255,0) 100%);
  pointer-events: none;
}

.map-shell::before,
.map-shell::after,
.foam,
.station-aura {
  position: absolute;
  pointer-events: none;
}

.map-shell::before,
.map-shell::after,
.foam {
  z-index: 0;
}

.map-shell::before {
  content: '';
  inset: 0;
  border-radius: inherit;
  background:
    radial-gradient(ellipse at 18% 18%, rgba(255, 255, 255, 0.22), transparent 18%),
    radial-gradient(ellipse at 82% 24%, rgba(255, 255, 255, 0.16), transparent 16%),
    radial-gradient(ellipse at 50% 88%, rgba(157, 215, 245, 0.14), transparent 26%);
}

.map-shell::after {
  content: '';
  inset: 0;
  border-radius: inherit;
  background:
    linear-gradient(180deg, rgba(255,255,255,0.12), transparent 22%, transparent 78%, rgba(255,255,255,0.04));
}

.foam {
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.22);
  animation: foamFloat 9s ease-in-out infinite;
}

.foam-1 { top: 236rpx; left: 118rpx; width: 10rpx; height: 10rpx; }
.foam-2 { top: 352rpx; right: 122rpx; width: 10rpx; height: 10rpx; animation-delay: -2s; }
.foam-3 { top: 790rpx; left: 176rpx; width: 10rpx; height: 10rpx; animation-delay: -4s; }
.foam-4 { bottom: 210rpx; right: 150rpx; width: 10rpx; height: 10rpx; animation-delay: -6s; }

.station {
  position: absolute;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  transition: transform 220ms ease;
}

.station-primary {
  z-index: 2;
}

.station-press {
  transform: scale(0.97);
}

.station-aura {
  top: 18rpx;
  left: 50%;
  width: 324rpx;
  height: 244rpx;
  transform: translateX(-50%);
  border-radius: 50%;
  background: radial-gradient(circle at 50% 50%, rgba(250, 204, 21, 0.22) 0%, rgba(250, 204, 21, 0.08) 44%, rgba(250, 204, 21, 0) 72%);
  animation: auraPulse 3.8s ease-in-out infinite;
}

.island {
  position: relative;
  filter: drop-shadow(0 16rpx 24rpx rgba(40, 94, 76, 0.12));
}

.island-shore,
.island-land,
.island-contour,
.island-lagoon,
.island-grass,
.island-bush,
.station-icon-halo,
.station-icon-gloss {
  position: absolute;
  pointer-events: none;
}

.island-primary {
  width: 316rpx;
  height: 248rpx;
}

.island-normal {
  width: 224rpx;
  height: 172rpx;
}

.island-shape-activity { transform: rotate(-12deg); animation: islandFloatActivity 5.8s ease-in-out infinite; }
.island-shape-team { transform: rotate(10deg); animation: islandFloatTeam 6.4s ease-in-out infinite; }
.island-shape-drill { transform: rotate(-4deg); animation: islandFloatDrill 4.8s ease-in-out infinite; }
.island-shape-comment { transform: rotate(8deg); animation: islandFloatComment 5.6s ease-in-out infinite; }
.island-shape-case { transform: rotate(-10deg); animation: islandFloatCase 6.6s ease-in-out infinite; }
.island-shape-points { transform: rotate(14deg); animation: islandFloatPoints 5.4s ease-in-out infinite; }
.island-shape-share { transform: rotate(-14deg); animation: islandFloatShare 6s ease-in-out infinite; }

.island-shore-primary,
.island-shore-normal {
  inset: 0;
  background:
    radial-gradient(circle at 28% 18%, rgba(255,255,255,0.42), transparent 18%),
    linear-gradient(180deg, #fff8df 0%, #f4dfad 66%, #d8d9c8 82%, #bfd8e6 100%);
  box-shadow:
    inset 0 8rpx 16rpx rgba(255,255,255,0.16),
    0 12rpx 20rpx rgba(15, 23, 42, 0.08);
  -webkit-clip-path: polygon(14% 10%, 28% 3%, 54% 0%, 78% 4%, 93% 18%, 96% 42%, 92% 66%, 82% 80%, 58% 88%, 28% 86%, 10% 72%, 4% 48%, 6% 24%);
  clip-path: polygon(14% 10%, 28% 3%, 54% 0%, 78% 4%, 93% 18%, 96% 42%, 92% 66%, 82% 80%, 58% 88%, 28% 86%, 10% 72%, 4% 48%, 6% 24%);
}

.island-shore-activity {
  -webkit-clip-path: polygon(12% 12%, 30% 2%, 56% 0%, 80% 4%, 94% 20%, 96% 42%, 92% 66%, 82% 82%, 56% 88%, 26% 84%, 10% 70%, 4% 48%, 6% 28%);
  clip-path: polygon(12% 12%, 30% 2%, 56% 0%, 80% 4%, 94% 20%, 96% 42%, 92% 66%, 82% 82%, 56% 88%, 26% 84%, 10% 70%, 4% 48%, 6% 28%);
}

.island-shore-team {
  -webkit-clip-path: polygon(18% 8%, 40% 2%, 68% 2%, 90% 10%, 96% 28%, 92% 50%, 84% 76%, 64% 88%, 34% 88%, 12% 78%, 4% 56%, 8% 28%);
  clip-path: polygon(18% 8%, 40% 2%, 68% 2%, 90% 10%, 96% 28%, 92% 50%, 84% 76%, 64% 88%, 34% 88%, 12% 78%, 4% 56%, 8% 28%);
}

.island-shore-drill {
  -webkit-clip-path: polygon(16% 10%, 34% 2%, 58% 0%, 82% 6%, 96% 22%, 96% 44%, 92% 68%, 80% 84%, 54% 90%, 26% 86%, 8% 70%, 4% 46%, 8% 22%);
  clip-path: polygon(16% 10%, 34% 2%, 58% 0%, 82% 6%, 96% 22%, 96% 44%, 92% 68%, 80% 84%, 54% 90%, 26% 86%, 8% 70%, 4% 46%, 8% 22%);
}

.island-shore-comment {
  -webkit-clip-path: polygon(18% 6%, 38% 2%, 62% 2%, 86% 8%, 96% 24%, 92% 48%, 86% 74%, 66% 86%, 38% 88%, 14% 80%, 4% 58%, 6% 30%);
  clip-path: polygon(18% 6%, 38% 2%, 62% 2%, 86% 8%, 96% 24%, 92% 48%, 86% 74%, 66% 86%, 38% 88%, 14% 80%, 4% 58%, 6% 30%);
}

.island-shore-case {
  -webkit-clip-path: polygon(14% 10%, 30% 2%, 56% 0%, 80% 6%, 94% 22%, 94% 46%, 88% 70%, 76% 84%, 52% 90%, 24% 86%, 8% 68%, 4% 42%, 8% 22%);
  clip-path: polygon(14% 10%, 30% 2%, 56% 0%, 80% 6%, 94% 22%, 94% 46%, 88% 70%, 76% 84%, 52% 90%, 24% 86%, 8% 68%, 4% 42%, 8% 22%);
}

.island-shore-points {
  -webkit-clip-path: polygon(18% 8%, 36% 2%, 62% 0%, 84% 8%, 94% 24%, 92% 48%, 86% 72%, 72% 84%, 46% 88%, 20% 82%, 6% 64%, 4% 40%, 10% 20%);
  clip-path: polygon(18% 8%, 36% 2%, 62% 0%, 84% 8%, 94% 24%, 92% 48%, 86% 72%, 72% 84%, 46% 88%, 20% 82%, 6% 64%, 4% 40%, 10% 20%);
}

.island-shore-share {
  -webkit-clip-path: polygon(20% 8%, 42% 2%, 68% 0%, 88% 8%, 96% 24%, 92% 50%, 82% 74%, 62% 86%, 34% 88%, 12% 78%, 4% 56%, 8% 26%);
  clip-path: polygon(20% 8%, 42% 2%, 68% 0%, 88% 8%, 96% 24%, 92% 50%, 82% 74%, 62% 86%, 34% 88%, 12% 78%, 4% 56%, 8% 26%);
}

.island-land-primary,
.island-land-normal {
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow:
    inset 0 10rpx 18rpx rgba(255,255,255,0.14),
    inset 0 -12rpx 20rpx rgba(22, 84, 94, 0.18);
  -webkit-clip-path: polygon(14% 10%, 28% 3%, 54% 0%, 78% 4%, 93% 18%, 96% 42%, 92% 66%, 82% 80%, 58% 88%, 28% 86%, 10% 72%, 4% 48%, 6% 24%);
  clip-path: polygon(14% 10%, 28% 3%, 54% 0%, 78% 4%, 93% 18%, 96% 42%, 92% 66%, 82% 80%, 58% 88%, 28% 86%, 10% 72%, 4% 48%, 6% 24%);
}

.island-land-primary {
  inset: 16rpx 14rpx 18%;
}

.island-land-normal {
  inset: 12rpx 10rpx 18%;
}

.island-land-activity,
.island-land-team,
.island-land-drill,
.island-land-comment,
.island-land-case,
.island-land-points,
.island-land-share {
  -webkit-clip-path: polygon(14% 10%, 28% 3%, 54% 0%, 78% 4%, 93% 18%, 96% 42%, 92% 66%, 82% 80%, 58% 88%, 28% 86%, 10% 72%, 4% 48%, 6% 24%);
  clip-path: polygon(14% 10%, 28% 3%, 54% 0%, 78% 4%, 93% 18%, 96% 42%, 92% 66%, 82% 80%, 58% 88%, 28% 86%, 10% 72%, 4% 48%, 6% 24%);
}

.island-contour {
  inset: 14rpx 14rpx 18%;
  border: 2rpx solid rgba(255, 255, 255, 0.18);
  opacity: 1;
  -webkit-clip-path: polygon(14% 10%, 28% 3%, 54% 0%, 78% 4%, 93% 18%, 96% 42%, 92% 66%, 82% 80%, 58% 88%, 28% 86%, 10% 72%, 4% 48%, 6% 24%);
  clip-path: polygon(14% 10%, 28% 3%, 54% 0%, 78% 4%, 93% 18%, 96% 42%, 92% 66%, 82% 80%, 58% 88%, 28% 86%, 10% 72%, 4% 48%, 6% 24%);
  box-shadow: inset 0 -10rpx 16rpx rgba(51, 115, 138, 0.12);
}

.island-contour-primary { inset: 22rpx 20rpx 20%; }
.island-contour-normal { inset: 16rpx 14rpx 20%; }
.island-contour-activity,
.island-contour-team,
.island-contour-drill,
.island-contour-comment,
.island-contour-case,
.island-contour-points,
.island-contour-share {
  transform: none;
}

.island-lagoon,
.island-grass,
.island-bush {
  display: none;
}

.island-sky .island-land,
.island-blue .island-land,
.island-gold .island-land,
.island-green .island-land,
.island-teal .island-land,
.island-amber .island-land,
.island-purple .island-land {
  background:
    radial-gradient(circle at 28% 18%, rgba(255,255,255,0.22), transparent 16%),
    linear-gradient(180deg, rgba(255,255,255,0) 0%, rgba(255,255,255,0) 68%, rgba(104, 164, 177, 0.14) 78%, rgba(115, 187, 216, 0.24) 100%),
    linear-gradient(180deg,
      #cfeab3 0%,
      #a9d785 42%,
      #79bf8a 64%,
      #6ea690 76%,
      #6da9b5 86%,
      #83c6e8 100%);
}

.island-land-primary::after,
.island-land-normal::after {
  content: '';
  position: absolute;
  left: 10%;
  right: 10%;
  bottom: 18%;
  height: 18%;
  border-radius: 999rpx;
  background: linear-gradient(180deg, rgba(255,255,255,0) 0%, rgba(191, 232, 255, 0.08) 30%, rgba(157, 216, 244, 0.24) 100%);
  filter: blur(2rpx);
  pointer-events: none;
}

.island-land-primary::before,
.island-land-normal::before {
  content: '';
  position: absolute;
  left: 12%;
  right: 12%;
  bottom: 17%;
  height: 3rpx;
  background: linear-gradient(90deg, rgba(255,255,255,0) 0%, rgba(255,255,255,0.54) 18%, rgba(255,255,255,0.72) 50%, rgba(255,255,255,0.54) 82%, rgba(255,255,255,0) 100%);
  opacity: 0.7;
  pointer-events: none;
}

.station-icon-seat {
  position: relative;
  z-index: 3;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: radial-gradient(circle at 35% 30%, rgba(255,255,255,0.78) 0%, rgba(255,255,255,0.3) 54%, rgba(255,255,255,0.18) 100%);
  border: 2rpx solid rgba(255, 255, 255, 0.42);
  box-shadow: 0 10rpx 20rpx rgba(15, 23, 42, 0.07), inset 0 4rpx 10rpx rgba(255, 255, 255, 0.34);
  animation: iconSeatBreath 4s ease-in-out infinite;
}

.station-icon-seat-primary { width: 128rpx; height: 128rpx; }
.station-icon-seat-normal { width: 90rpx; height: 90rpx; }

.station-icon-halo {
  inset: 10rpx;
  border-radius: 50%;
  background: radial-gradient(circle at 50% 50%, rgba(255,255,255,0.26) 0%, rgba(255,255,255,0.08) 52%, rgba(255,255,255,0) 72%);
}

.station-icon-halo-primary { inset: 12rpx; }

.station-icon-gloss {
  top: 10rpx;
  left: 16rpx;
  width: 34%;
  height: 18%;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.42);
  transform: rotate(-24deg);
}

.station-icon-gloss-primary { top: 14rpx; }

.station-icon {
  position: relative;
  z-index: 3;
  filter: drop-shadow(0 6rpx 10rpx rgba(15, 23, 42, 0.08));
}

.station-icon-primary { width: 108rpx; height: 108rpx; }
.station-icon-normal { width: 72rpx; height: 72rpx; }
.station-icon-activity { width: 78rpx; height: 78rpx; }

.station-badge {
  position: absolute;
  top: 22rpx;
  right: 20rpx;
  z-index: 4;
  padding: 6rpx 12rpx;
  border-radius: 999rpx;
  font-size: 18rpx;
  font-weight: 600;
  background: rgba(255, 255, 255, 0.86);
  color: #2f855a;
  box-shadow: 0 8rpx 14rpx rgba(15, 23, 42, 0.08);
}

.island-title-shell {
  position: absolute;
  left: 50%;
  bottom: 10%;
  z-index: 4;
  transform: translateX(-50%);
  white-space: nowrap;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(255,255,255,0.82);
  box-shadow: 0 8rpx 16rpx rgba(15, 23, 42, 0.08);
}

.island-title-shell-primary {
  bottom: 12%;
}

.station-title {
  display: block;
  text-align: center;
  color: #16324f;
  font-weight: 700;
}

.station-title-primary {
  font-size: 32rpx;
  color: #16324f;
}

.station-title-normal {
  font-size: 24rpx;
}

.station-activity { top: 164rpx; left: 66rpx; }
.station-team { top: 178rpx; right: 64rpx; }
.station-drill { top: 392rpx; left: 50%; transform: translateX(-50%); }
.station-comment { top: 708rpx; left: 54rpx; }
.station-case { top: 720rpx; right: 56rpx; }
.station-points { top: 1004rpx; left: 86rpx; }
.station-share { top: 1018rpx; right: 88rpx; }

.map-inline-guide {
  position: relative;
  flex-shrink: 0;
  z-index: 1;
  margin: 0;
  padding: 18rpx 24rpx;
  border-radius: 28rpx;
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.96) 0%, rgba(247, 250, 253, 0.94) 100%);
  border: 1rpx solid rgba(226, 232, 240, 0.9);
  box-shadow: 0 12rpx 24rpx rgba(29, 45, 74, 0.05);
}

.map-inline-guide-text {
  display: block;
  text-align: center;
  font-size: 22rpx;
  line-height: 1.55;
  color: #64748b;
  font-weight: 500;
  text-shadow: none;
}

@keyframes foamFloat {
  0%, 100% { transform: translate3d(0, 0, 0); opacity: 0.4; }
  50% { transform: translate3d(10rpx, -8rpx, 0); opacity: 0.68; }
}

@keyframes islandFloatActivity {
  0%, 100% { transform: translateY(0) rotate(-12deg); }
  50% { transform: translateY(-8rpx) rotate(-9deg); }
}

@keyframes islandFloatTeam {
  0%, 100% { transform: translateY(0) rotate(10deg); }
  50% { transform: translateY(-8rpx) rotate(7deg); }
}

@keyframes islandFloatDrill {
  0%, 100% { transform: translateY(0) rotate(-4deg); }
  50% { transform: translateY(-10rpx) rotate(-2deg); }
}

@keyframes islandFloatComment {
  0%, 100% { transform: translateY(0) rotate(8deg); }
  50% { transform: translateY(-8rpx) rotate(5deg); }
}

@keyframes islandFloatCase {
  0%, 100% { transform: translateY(0) rotate(-10deg); }
  50% { transform: translateY(-8rpx) rotate(-7deg); }
}

@keyframes islandFloatPoints {
  0%, 100% { transform: translateY(0) rotate(14deg); }
  50% { transform: translateY(-8rpx) rotate(11deg); }
}

@keyframes islandFloatShare {
  0%, 100% { transform: translateY(0) rotate(-14deg); }
  50% { transform: translateY(-8rpx) rotate(-11deg); }
}

@keyframes auraPulse {
  0%, 100% { transform: translateX(-50%) scale(1); opacity: 0.72; }
  50% { transform: translateX(-50%) scale(1.04); opacity: 1; }
}

@keyframes iconSeatBreath {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.03); }
}
