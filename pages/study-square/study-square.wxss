.study-square-page {
  position: relative;
  min-height: 100vh;
  overflow: hidden;
  padding: 24rpx 24rpx 140rpx;
  background:
    radial-gradient(circle at 18% 12%, rgba(186, 230, 253, 0.52), transparent 24%),
    radial-gradient(circle at 82% 18%, rgba(191, 219, 254, 0.46), transparent 22%),
    linear-gradient(180deg, #eaf9ff 0%, #dff4ff 42%, #d8efff 100%);
}

.sea-glow,
.sea-bubble,
.wave-track,
.pearl,
.route-guide {
  position: absolute;
  pointer-events: none;
}

.sea-glow {
  border-radius: 50%;
}

.glow-left {
  top: 180rpx;
  left: -120rpx;
  width: 300rpx;
  height: 300rpx;
  background: rgba(125, 211, 252, 0.18);
}

.glow-right {
  right: -110rpx;
  bottom: 220rpx;
  width: 320rpx;
  height: 320rpx;
  background: rgba(147, 197, 253, 0.2);
}

.sea-bubble {
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.72);
  border: 1rpx solid rgba(191, 219, 254, 0.9);
}

.bubble-a {
  top: 210rpx;
  right: 70rpx;
  width: 18rpx;
  height: 18rpx;
}

.bubble-b {
  top: 760rpx;
  left: 46rpx;
  width: 20rpx;
  height: 20rpx;
}

.bubble-c {
  right: 88rpx;
  bottom: 260rpx;
  width: 14rpx;
  height: 14rpx;
}

.ocean-stage {
  position: relative;
  z-index: 1;
}

.ocean-stage {
  height: 1160rpx;
  margin-top: 8rpx;
  border-radius: 36rpx;
  overflow: hidden;
  background:
    radial-gradient(circle at 18% 12%, rgba(255, 255, 255, 0.75), transparent 14%),
    radial-gradient(circle at 82% 18%, rgba(255, 255, 255, 0.58), transparent 16%),
    linear-gradient(180deg, #cef0ff 0%, #bfe8fb 46%, #b2e1f8 100%);
  border: 1rpx solid rgba(186, 230, 253, 0.9);
  box-shadow: 0 20rpx 50rpx rgba(14, 116, 144, 0.08);
}

.ocean-stage::after {
  content: '';
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 180rpx;
  background:
    radial-gradient(circle at 16% 18%, rgba(255, 255, 255, 0.25), transparent 18%),
    radial-gradient(circle at 82% 28%, rgba(255, 255, 255, 0.2), transparent 16%);
}

.wave-track {
  width: 240rpx;
  height: 170rpx;
  border-radius: 999rpx;
  border: 16rpx solid rgba(244, 252, 255, 0.9);
  background: transparent;
  box-shadow:
    0 0 0 3rpx rgba(186, 230, 253, 0.72),
    0 12rpx 24rpx rgba(14, 165, 233, 0.08);
}

