.study-square-page {
  position: relative;
  min-height: 100vh;
  overflow: hidden;
  padding: 28rpx 24rpx 140rpx;
  background: linear-gradient(180deg, #f8fbff 0%, #eef7ff 52%, #ebf6ff 100%);
}

.foam,
.islet {
  position: absolute;
  pointer-events: none;
}

.map-shell {
  position: relative;
  z-index: 1;
  height: 1180rpx;
  margin-top: 8rpx;
  border-radius: 44rpx;
  background:
    radial-gradient(circle at 50% -8%, rgba(255, 255, 255, 0.62), transparent 34%),
    linear-gradient(180deg, #ddf4ff 0%, #d2eeff 42%, #c5e6f8 100%);
  border: 1rpx solid rgba(191, 228, 249, 0.82);
  box-shadow: 0 18rpx 40rpx rgba(14, 116, 144, 0.07);
  overflow: visible;
}

.map-shell::before {
  content: '';
  position: absolute;
  inset: 0;
  border-radius: inherit;
  background:
    radial-gradient(ellipse at 18% 18%, rgba(255, 255, 255, 0.22), transparent 18%),
    radial-gradient(ellipse at 82% 24%, rgba(255, 255, 255, 0.16), transparent 16%),
    radial-gradient(ellipse at 50% 88%, rgba(157, 215, 245, 0.14), transparent 26%);
  pointer-events: none;
}

.map-shell::after {
  content: '';
  position: absolute;
  inset: 0;
  background:
    linear-gradient(180deg, rgba(255,255,255,0.12), transparent 22%, transparent 78%, rgba(255,255,255,0.04));
  pointer-events: none;
}

.foam {
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.22);
  animation: foamFloat 9s ease-in-out infinite;
}

.foam-1 {
  top: 236rpx;
  left: 118rpx;
  width: 10rpx;
  height: 10rpx;
}

.foam-2 {
  top: 352rpx;
  right: 122rpx;
  width: 10rpx;
  height: 10rpx;
  animation-delay: -2s;
}

.foam-3 {
  top: 790rpx;
  left: 176rpx;
  width: 10rpx;
  height: 10rpx;
  animation-delay: -4s;
}

.foam-4 {
  bottom: 210rpx;
  right: 150rpx;
  width: 10rpx;
  height: 10rpx;
  animation-delay: -6s;
}

.station {
  position: absolute;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  transition: transform 220ms ease, filter 220ms ease;
}

.station-primary {
  z-index: 2;
}

.station-press {
  transform: scale(0.96);
}

.station-aura {
  position: absolute;
  top: 18rpx;
  left: 50%;
  width: 304rpx;
  height: 228rpx;
  transform: translateX(-50%);
  border-radius: 50%;
  background: radial-gradient(circle at 50% 50%, rgba(250, 204, 21, 0.22) 0%, rgba(250, 204, 21, 0.08) 44%, rgba(250, 204, 21, 0) 72%);
  animation: auraPulse 3.8s ease-in-out infinite;
}

.island {
  position: relative;
}

.island-shore,
.island-land {
  position: absolute;
  inset: 0;
}

.island-shape-activity {
  transform: rotate(-12deg);
  animation: islandFloatActivity 5.8s ease-in-out infinite;
}

.island-shape-team {
  transform: rotate(10deg);
  animation: islandFloatTeam 6.4s ease-in-out infinite;
}

.island-shape-drill {
  transform: rotate(-4deg);
  animation: islandFloatDrill 4.8s ease-in-out infinite;
}

.island-shape-sync {
  transform: rotate(12deg);
  animation: islandFloatSync 6.2s ease-in-out infinite;
}

.island-shape-comment {
  transform: rotate(8deg);
  animation: islandFloatComment 5.6s ease-in-out infinite;
}

.island-shape-case {
  transform: rotate(-10deg);
  animation: islandFloatCase 6.6s ease-in-out infinite;
}

.island-shape-points {
  transform: rotate(14deg);
  animation: islandFloatPoints 5.4s ease-in-out infinite;
}

.island-shape-share {
  transform: rotate(-14deg);
  animation: islandFloatShare 6s ease-in-out infinite;
}

.island-primary {
  width: 292rpx;
  height: 228rpx;
}

.island-normal {
  width: 182rpx;
  height: 140rpx;
}

.island-small {
  width: 156rpx;
  height: 118rpx;
}

.island-shore-primary {
  border-radius: 52% 48% 46% 54% / 48% 54% 46% 52%;
  background:
    radial-gradient(circle at 26% 24%, rgba(255,255,255,0.55), transparent 18%),
    linear-gradient(180deg, #fffaf0 0%, #ffefc9 100%);
  transform: rotate(-6deg);
  box-shadow: 0 18rpx 28rpx rgba(245, 158, 11, 0.1);
}

.island-land-primary {
  inset: 16rpx;
  border-radius: 54% 46% 48% 52% / 46% 56% 44% 54%;
  display: flex;
  align-items: center;
  justify-content: center;
  transform: rotate(-4deg);
  box-shadow: inset 0 10rpx 16rpx rgba(255, 255, 255, 0.18);
}

.island-shore-drill {
  border-radius: 58% 42% 52% 48% / 46% 58% 42% 54%;
}

.island-land-drill {
  border-radius: 60% 40% 54% 46% / 44% 58% 42% 56%;
}

.island-shore-normal {
  border-radius: 54% 46% 50% 50% / 46% 56% 44% 54%;
  background:
    radial-gradient(circle at 24% 22%, rgba(255,255,255,0.5), transparent 18%),
    linear-gradient(180deg, #fffaf0 0%, #ffefcb 100%);
  transform: rotate(-8deg);
  box-shadow: 0 14rpx 24rpx rgba(245, 158, 11, 0.08);
}

.island-land-normal {
  inset: 12rpx;
  border-radius: 52% 48% 54% 46% / 48% 58% 42% 52%;
  display: flex;
  align-items: center;
  justify-content: center;
  transform: rotate(-6deg);
  box-shadow: inset 0 8rpx 14rpx rgba(255, 255, 255, 0.14);
}

.island-shore-activity {
  border-radius: 62% 38% 54% 46% / 46% 60% 40% 54%;
}

.island-land-activity {
  border-radius: 60% 40% 58% 42% / 44% 60% 40% 56%;
}

.island-shore-team {
  border-radius: 46% 54% 42% 58% / 52% 44% 56% 48%;
}

.island-land-team {
  border-radius: 44% 56% 40% 60% / 54% 42% 58% 46%;
}

.island-shore-sync {
  border-radius: 56% 44% 60% 40% / 42% 54% 46% 58%;
}

.island-land-sync {
  border-radius: 54% 46% 62% 38% / 40% 56% 44% 60%;
}

.island-shore-comment {
  border-radius: 42% 58% 56% 44% / 58% 42% 54% 46%;
}

.island-land-comment {
  border-radius: 40% 60% 58% 42% / 60% 40% 56% 44%;
}

.island-shore-case {
  border-radius: 58% 42% 44% 56% / 54% 46% 58% 42%;
}

.island-land-case {
  border-radius: 56% 44% 42% 58% / 56% 44% 60% 40%;
}

.island-shore-small {
  border-radius: 56% 44% 52% 48% / 48% 56% 44% 52%;
  background:
    radial-gradient(circle at 24% 22%, rgba(255,255,255,0.46), transparent 18%),
    linear-gradient(180deg, #fffaf2 0%, #fff1d6 100%);
  transform: rotate(8deg);
  box-shadow: 0 12rpx 22rpx rgba(245, 158, 11, 0.08);
}

.island-land-small {
  inset: 10rpx;
  border-radius: 50% 50% 56% 44% / 44% 58% 42% 56%;
  display: flex;
  align-items: center;
  justify-content: center;
  transform: rotate(6deg);
  box-shadow: inset 0 8rpx 12rpx rgba(255, 255, 255, 0.14);
}

.island-shore-points {
  border-radius: 60% 40% 48% 52% / 50% 58% 42% 50%;
}

.island-land-points {
  border-radius: 58% 42% 46% 54% / 48% 60% 40% 52%;
}

.island-shore-share {
  border-radius: 44% 56% 60% 40% / 56% 42% 58% 44%;
}

.island-land-share {
  border-radius: 42% 58% 62% 38% / 58% 40% 60% 42%;
}

.station-icon {
  position: relative;
  z-index: 3;
  filter: drop-shadow(0 6rpx 10rpx rgba(15, 23, 42, 0.08));
}

.station-icon-seat {
  position: relative;
  z-index: 3;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: radial-gradient(circle at 35% 30%, rgba(255,255,255,0.78) 0%, rgba(255,255,255,0.3) 54%, rgba(255,255,255,0.18) 100%);
  border: 2rpx solid rgba(255, 255, 255, 0.42);
  box-shadow: 0 10rpx 20rpx rgba(15, 23, 42, 0.07), inset 0 4rpx 10rpx rgba(255, 255, 255, 0.34);
  animation: iconSeatBreath 4s ease-in-out infinite;
}

