.station-body {
  position: relative;
  width: 180rpx;
  min-height: 168rpx;
  padding: 18rpx 16rpx 20rpx;
  border-radius: 32rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.78);
  box-shadow: 0 18rpx 30rpx rgba(8, 47, 73, 0.08);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.tone-pink {
  background: linear-gradient(180deg, rgba(254, 226, 226, 0.96) 0%, rgba(252, 231, 243, 0.94) 100%);
}

.tone-blue {
  background: linear-gradient(180deg, rgba(239, 246, 255, 0.96) 0%, rgba(224, 242, 254, 0.94) 100%);
}

.tone-cyan {
  background: linear-gradient(180deg, rgba(236, 254, 255, 0.96) 0%, rgba(207, 250, 254, 0.94) 100%);
}

.tone-teal {
  background: linear-gradient(180deg, rgba(240, 253, 250, 0.96) 0%, rgba(204, 251, 241, 0.94) 100%);
}

.tone-gold {
  background: linear-gradient(180deg, rgba(255, 251, 235, 0.96) 0%, rgba(254, 243, 199, 0.94) 100%);
}

.tone-purple {
  background: linear-gradient(180deg, rgba(245, 243, 255, 0.96) 0%, rgba(237, 233, 254, 0.94) 100%);
}

.station-badge {
  position: absolute;
  top: -10rpx;
  right: 10rpx;
  padding: 6rpx 12rpx;
  border-radius: 999rpx;
  background: #fda4af;
  color: #ffffff;
  font-size: 18rpx;
  font-weight: 700;
  line-height: 1;
}

.station-icon {
  width: 82rpx;
  height: 82rpx;
}

.station-title {
  margin-top: 14rpx;
  font-size: 30rpx;
  font-weight: 700;
  color: #082f49;
  line-height: 1.2;
}
