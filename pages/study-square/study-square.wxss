.map-footer {
  position: relative;
  z-index: 1;
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 44rpx;
  padding: 0 8rpx;
}

.map-tip {
  padding: 12rpx 20rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.84);
  color: #55687f;
  font-size: 22rpx;
  font-weight: 600;
  border: 1rpx solid rgba(219, 234, 254, 0.95);
  box-shadow: 0 8rpx 18rpx rgba(15, 23, 42, 0.04);
}

@keyframes foamFloat {
  0%, 100% { transform: translate3d(0, 0, 0); opacity: 0.4; }
  50% { transform: translate3d(10rpx, -8rpx, 0); opacity: 0.68; }
}

@keyframes islandFloatActivity {
  0%, 100% { transform: translateY(0) rotate(-12deg); }
  50% { transform: translateY(-8rpx) rotate(-9deg); }
}

@keyframes islandFloatTeam {
  0%, 100% { transform: translateY(0) rotate(10deg); }
  50% { transform: translateY(-8rpx) rotate(7deg); }
}

@keyframes islandFloatDrill {
  0%, 100% { transform: translateY(0) rotate(-4deg); }
  50% { transform: translateY(-10rpx) rotate(-2deg); }
}

@keyframes islandFloatSync {
  0%, 100% { transform: translateY(0) rotate(12deg); }
  50% { transform: translateY(-8rpx) rotate(9deg); }
}

@keyframes islandFloatComment {
  0%, 100% { transform: translateY(0) rotate(8deg); }
  50% { transform: translateY(-8rpx) rotate(5deg); }
}

@keyframes islandFloatCase {
  0%, 100% { transform: translateY(0) rotate(-10deg); }
  50% { transform: translateY(-8rpx) rotate(-7deg); }
}

@keyframes islandFloatPoints {
  0%, 100% { transform: translateY(0) rotate(14deg); }
  50% { transform: translateY(-8rpx) rotate(11deg); }
}

@keyframes islandFloatShare {
  0%, 100% { transform: translateY(0) rotate(-14deg); }
  50% { transform: translateY(-8rpx) rotate(-11deg); }
}

@keyframes auraPulse {
  0%, 100% { transform: translateX(-50%) scale(1); opacity: 0.72; }
  50% { transform: translateX(-50%) scale(1.04); opacity: 1; }
}

@keyframes iconSeatBreath {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.03); }
}
