<view class="square-page">
  <view class="hero-card">
    <view class="hero-decor hero-decor-one"></view>
    <view class="hero-decor hero-decor-two"></view>
    <view class="hero-main">
      <view class="hero-badge">学习广场</view>
      <text class="hero-title">把广场收敛成正在发生的几件事</text>
      <text class="hero-desc">活动、组队、同步、评论、案例和积分兑换放在同一个地方，方便快速浏览和参与。</text>
    </view>
    <view class="hero-stats">
      <view wx:for="{{heroStats}}" wx:key="id" class="hero-stat">
        <text class="hero-stat-value">{{item.value}}</text>
        <text class="hero-stat-label">{{item.label}}</text>
      </view>
    </view>
  </view>

  <view class="section">
    <view class="section-head">
      <view class="section-head-main">
        <text class="section-kicker">Campus</text>
        <text class="section-title">活动发布</text>
      </view>
      <text class="section-sub">优先展示近期可参与内容</text>
    </view>
    <view wx:for="{{activities}}" wx:key="id" class="feature-card">
      <view class="feature-accent"></view>
      <view class="row-between row-start">
        <text class="tag">{{item.tag}}</text>
        <text class="muted">{{item.time}}</text>
      </view>
      <text class="card-title">{{item.title}}</text>
      <text class="card-desc">{{item.desc}}</text>
      <view class="row-between card-bottom">
        <text class="card-meta">{{item.extra}}</text>
        <view class="action-btn" bindtap="handleAction" data-label="{{item.cta}}">
          <text class="action-btn-text">{{item.cta}}</text>
        </view>
      </view>
    </view>
  </view>

  <view class="section">
    <view class="section-head">
      <view class="section-head-main">
        <text class="section-kicker">Team</text>
        <text class="section-title">组队学习</text>
      </view>
      <text class="section-sub">一起学更容易坚持</text>
    </view>
    <view class="team-grid">
      <view wx:for="{{teams}}" wx:key="id" class="team-card">
        <view class="team-mark"></view>
        <text class="card-title">{{item.name}}</text>
        <text class="card-desc">{{item.desc}}</text>
        <view class="row-between card-bottom">
          <text class="meta-chip">{{item.meta}}</text>
          <text class="action-text" bindtap="handleAction" data-label="{{item.cta}}">{{item.cta}}</text>
        </view>
      </view>
    </view>
  </view>

  <view class="section">
    <view class="section-head">
      <view class="section-head-main">
        <text class="section-kicker">Update</text>
        <text class="section-title">信息同步</text>
      </view>
      <text class="section-sub">课程和提醒统一查看</text>
    </view>
    <view class="panel-card">
      <view class="panel-topline"></view>
      <view wx:for="{{syncItems}}" wx:key="*this" class="sync-row">
        <view class="sync-dot"></view>
        <text class="sync-text">{{item}}</text>
      </view>
    </view>
  </view>

  <view class="section">
    <view class="section-head">
      <view class="section-head-main">
        <text class="section-kicker">Voices</text>
        <text class="section-title">用户评论</text>
      </view>
      <text class="section-sub">保留真实学习反馈</text>
    </view>
    <view wx:for="{{comments}}" wx:key="id" class="comment-card">
      <view class="comment-avatar">{{item.avatar}}</view>
      <view class="comment-main">
        <view class="comment-top">
          <text class="card-title">{{item.user}}</text>
          <text class="comment-quote">“”</text>
        </view>
        <text class="card-desc">{{item.text}}</text>
      </view>
    </view>
  </view>

  <view class="section">
    <view class="section-head">
      <view class="section-head-main">
        <text class="section-kicker">Cases</text>
        <text class="section-title">学生案例</text>
      </view>
      <text class="section-sub">看看别人是怎么提分的</text>
    </view>
    <view wx:for="{{cases}}" wx:key="id" class="case-card">
      <view class="row-between row-start">
        <view>
          <text class="card-title">{{item.name}}</text>
          <text class="card-desc">{{item.summary}}</text>
        </view>
        <view class="case-result-badge">
          <text class="case-result">{{item.result}}</text>
        </view>
      </view>
    </view>
  </view>

  <view class="section">
    <view class="section-head">
      <view class="section-head-main">
        <text class="section-kicker">Points</text>
        <text class="section-title">积分兑换</text>
      </view>
      <text class="section-sub">当前可兑换内容</text>
    </view>
    <view class="compact-stack">
      <view wx:for="{{pointGoods}}" wx:key="id" class="compact-card">
        <view class="row-between row-start">
          <view>
            <text class="card-title">{{item.name}}</text>
            <text class="compact-desc">{{item.desc}}</text>
          </view>
          <text class="points-text">{{item.points}} 积分</text>
        </view>
        <view class="card-action-row">
          <view class="ghost-btn" bindtap="handleAction" data-label="{{item.cta}}">
            <text class="ghost-btn-text">{{item.cta}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <view class="safe-bottom"></view>
</view>
