<view class="study-square-page">
  <view class="sea-glow glow-left"></view>
  <view class="sea-glow glow-right"></view>
  <view class="sea-bubble bubble-a"></view>
  <view class="sea-bubble bubble-b"></view>
  <view class="sea-bubble bubble-c"></view>

  <view class="ocean-stage">
    <view class="wave-track track-1"></view>
    <view class="wave-track track-2"></view>
    <view class="wave-track track-3"></view>
    <view class="wave-track track-4"></view>
    <view class="wave-track track-5"></view>
    <view class="wave-track track-6"></view>

    <view class="pearl pearl-1"></view>
    <view class="pearl pearl-2"></view>
    <view class="pearl pearl-3"></view>
    <view class="pearl pearl-4"></view>
    <view class="pearl pearl-5"></view>
    <view class="pearl pearl-6"></view>

    <image
      wx:for="{{routeGuides}}"
      wx:key="id"
      class="route-guide guide-{{item.position}}"
      src="{{item.icon}}"
      mode="aspectFit"
    />

    <view
      wx:for="{{stations}}"
      wx:key="key"
      class="station station-{{item.position}}"
      bindtap="handleStationTap"
      data-key="{{item.key}}"
    >
      <view class="station-body tone-{{item.tone}}">
        <text wx:if="{{item.badge}}" class="station-badge">{{item.badge}}</text>
        <image class="station-icon" src="{{item.icon}}" mode="aspectFit" />
        <text class="station-title">{{item.title}}</text>
      </view>
    </view>
  </view>
</view>
