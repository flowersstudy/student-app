.exam-page {
  min-height: 100vh;
  background: #f5f6fa;
  padding-bottom: 120rpx;
}

.exam-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  margin-bottom: 16rpx;
}

.exam-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #333333;
  line-height: 1.5;
  display: block;
}

.file-icon-green {
  background: #52c41a;
}

.file-arrow {
  font-size: 36rpx;
  color: #cccccc;
  flex-shrink: 0;
}

.timer-display {
  background: linear-gradient(135deg, #1A6EFF, #4a9eff);
  border-radius: 20rpx;
  padding: 40rpx;
  text-align: center;
  margin-bottom: 24rpx;
  transition: background 0.4s;
}

/* 最后5分钟 → 橙色警告 */
.timer-display-low {
  background: linear-gradient(135deg, #d4380d, #fa541c);
}

/* 时间到 → 深灰 */
.timer-display-up {
  background: linear-gradient(135deg, #434343, #666);
}

.timer-badge {
  display: inline-block;
  background: rgba(255,255,255,0.22);
  color: #fff;
  font-size: 20rpx;
  font-weight: 700;
  letter-spacing: 3rpx;
  padding: 4rpx 18rpx;
  border-radius: 20rpx;
  margin-bottom: 16rpx;
}

.timer-text {
  font-size: 80rpx;
  font-weight: 700;
  color: #ffffff;
  font-family: 'Courier New', monospace;
  display: block;
  letter-spacing: 6rpx;
}

.timer-status-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  margin-top: 12rpx;
  gap: 10rpx;
}

/* 跳动绿点（计时中）*/
.timer-dot-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
}

.timer-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: #a0f080;
  animation: dot-blink 1s infinite;
}

@keyframes dot-blink {
  0%, 100% { opacity: 1; }
  50%       { opacity: 0.2; }
}

.timer-label {
  font-size: 24rpx;
  color: rgba(255,255,255,0.85);
  display: block;
}

.btn-row {
  display: flex;
  flex-direction: row;
  gap: 20rpx;
  margin-bottom: 16rpx;
}

.btn-flow-disabled {
  background: #aaa;
}

.btn-upload {
  width: 100%;
  background: #ffffff;
  color: #1A6EFF;
  border: 2rpx solid #1A6EFF;
  border-radius: 48rpx;
  padding: 22rpx 0;
  font-size: 28rpx;
  font-weight: 600;
  text-align: center;
}

.btn-upload::after { border: none; }

.btn-flow {
  flex: 1;
  height: 64rpx;
  background: #1A6EFF;
  color: #ffffff;
  border-radius: 32rpx;
  padding: 0;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  box-sizing: border-box;
  overflow: hidden;
}

.btn-flow-text {
  display: block;
  width: 100%;
  height: 64rpx;
  font-size: 26rpx;
  font-weight: 600;
  line-height: 64rpx;
  text-align: center;
}

.btn-flow-outline {
  background: #ffffff;
  color: #1A6EFF;
  border: 2rpx solid #1A6EFF;
}

.video-banner {
  background: linear-gradient(135deg, #1a1a2e, #16213e);
  border-radius: 20rpx;
  padding: 28rpx 24rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
}

.video-play-icon {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-right: 20rpx;
}

.video-play-icon-image {
  width: 80rpx;
  height: 80rpx;
  filter: drop-shadow(0 10rpx 18rpx rgba(37, 99, 235, 0.2));
}

.video-info { flex: 1; }

.video-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #ffffff;
  display: block;
  margin-bottom: 8rpx;
}

.video-sub {
  font-size: 22rpx;
  color: rgba(255,255,255,0.6);
  display: block;
}

.video-arrow {
  font-size: 40rpx;
  color: rgba(255,255,255,0.4);
  margin-left: 12rpx;
}

.ask-btn-row {
  display: flex;
  flex-direction: row;
}

.ask-btn {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 10rpx;
  padding: 16rpx 24rpx;
  background: #f0f5ff;
  border-radius: 12rpx;
}

.ask-icon {
  width: 38rpx;
  height: 38rpx;
  flex-shrink: 0;
}

.ask-text {
  font-size: 26rpx;
  color: #1A6EFF;
}

