<view class="exam-page">

  <!-- 鑰冮淇℃伅 -->
  <view class="card">
    <view class="exam-header">
      <text class="tag tag-orange">{{examInfo.type}}</text>
      <text class="tag tag-gray" style="margin-left:12rpx;">闄愭椂 {{examInfo.timeLimit}}</text>
    </view>
    <text class="exam-title">{{examInfo.title}}</text>
  </view>

  <!-- 棰樼洰璁蹭箟 -->
  <view class="card">
    <text class="section-title">棰樼洰 & 璁蹭箟</text>
    <view wx:for="{{files}}" wx:key="id" class="file-card {{item.url ? '' : 'file-card-disabled'}}" bindtap="openFile" data-id="{{item.id}}">
      <view class="file-icon {{item.type === '瑙ｆ瀽' ? 'file-icon-green' : ''}} {{item.url ? '' : 'file-icon-gray'}}">
        <text class="file-icon-text">PDF</text>
      </view>
      <view class="file-info">
        <text class="file-name {{item.url ? '' : 'file-name-gray'}}">{{item.name}}</text>
        <text class="file-size">{{item.type}}</text>
      </view>
      <text wx:if="{{item.opened}}" class="tag tag-green">宸叉墦寮€</text>
      <text wx:elif="{{item.url}}" class="file-arrow">鈥?</text>
      <text wx:else class="tag tag-gray">鏆傛湭涓婁紶</text>
    </view>
  </view>

  <!-- 浣滅瓟鍖?-->
  <view class="card">
    <text class="section-title">浣滅瓟</text>

    <!-- 鍊掕鏃舵樉绀哄尯 -->
    <picker mode="multiSelector" range="{{timerPickerRange}}" value="{{timerPickerValue}}" bindchange="onTimerPickerConfirm">
      <view class="timer-display {{timeLow ? 'timer-display-low' : ''}} {{timeUp ? 'timer-display-up' : ''}}">
        <text class="timer-badge">鍊掕鏃?</text>
        <text class="timer-text">{{timerDisplay}}</text>
        <view class="timer-status-row">
          <view wx:if="{{timerRunning}}" class="timer-dot-wrap">
            <view class="timer-dot"></view>
          </view>
          <text class="timer-label">
            {{timeUp ? '时间已到，请提交答案' : timeLow ? '剩余时间不足5分钟' : timerRunning ? '计时中' : ''}}
          </text>
        </view>
      </view>
    </picker>

    <!-- 鎸夐挳琛?-->
    <view class="btn-row">
      <view class="btn-flow {{timeUp ? 'btn-flow-disabled' : ''}}" bindtap="toggleTimer">
        <view class="btn-flow-text">{{timerRunning ? '暂停' : timeUp ? '已结束' : '开始计时'}}</view>
      </view>
      <view class="btn-flow btn-flow-outline" bindtap="resetTimer">
        <view class="btn-flow-text">閲嶇疆</view>
      </view>
    </view>
    <button class="btn-upload" bindtap="uploadAnswer">涓婁紶绛旀</button>
  </view>

  <!-- 瑙嗛瑙ｆ瀽 -->
  <view class="card">
    <text class="section-title">瑙ｆ瀽瑙嗛</text>
    <view class="video-banner" bindtap="watchAnalysis">
      <view class="video-play-icon">
        <image class="video-play-icon-image" src="{{uiIcons.play}}" mode="aspectFit" />
      </view>
      <view class="video-info">
        <text class="video-title">瑙傜湅鑰冮瑙ｆ瀽瑙嗛</text>
        <text class="video-sub">{{examInfo.title}}</text>
      </view>
      <text class="video-arrow">鈥?</text>
    </view>
  </view>

  <!-- 绗旇 -->
  <view class="card">
    <text class="section-title">澶囪€冪瑪璁?</text>
    <textarea
      class="input-area"
      placeholder="璁板綍鏈鑰冭瘯鐨勬€濊矾銆侀棶棰樻垨澶嶇洏..."
      value="{{notes}}"
      bindinput="onNotesInput"
      auto-height
      style="min-height:160rpx;"
    />
    <view class="ask-btn-row" style="margin-top:16rpx;">
      <view class="ask-btn" bindtap="askTeacher">
        <image class="ask-icon" src="{{uiIcons.chat}}" mode="aspectFit" />
        <text class="ask-text">鍚戣€佸笀鎻愰棶</text>
      </view>
    </view>
  </view>

  <view class="safe-bottom"></view>
</view>

<diagnose-coupon-fab auto-popup="{{true}}"></diagnose-coupon-fab>




