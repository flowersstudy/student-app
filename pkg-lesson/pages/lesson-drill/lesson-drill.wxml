<view class="drill-page">

  <!-- 顶部进度 + 计时器 -->
  <view class="card">
    <view class="row-between" style="margin-bottom:24rpx;">
      <text class="section-title" style="margin-bottom:0;">刷题练习</text>
      <text class="task-progress-text">{{drillDoneCount}}/{{drillQuestions.length}} 已完成</text>
    </view>

    <!-- 倒计时显示 -->
    <picker mode="multiSelector" range="{{timerPickerRange}}" value="{{timerPickerValue}}" bindchange="onTimerPickerConfirm">
      <view class="timer-display {{timeLow ? 'timer-display-low' : ''}} {{timeUp ? 'timer-display-up' : ''}}">
        <text class="timer-badge">倒计时</text>
        <text class="timer-text">{{timerDisplay}}</text>
        <view class="timer-status-row">
          <view wx:if="{{timerRunning}}" class="timer-dot-wrap">
            <view class="timer-dot"></view>
          </view>
          <text class="timer-label">
            {{timeUp ? '时间已到，请提交作答' : timeLow ? '剩余时间不足5分钟' : timerRunning ? '计时中' : ''}}
          </text>
        </view>
      </view>
    </picker>

    <!-- 按钮行 -->
    <view class="btn-row">
      <view class="btn-flow {{timeUp ? 'btn-flow-disabled' : ''}}" bindtap="toggleTimer">
        <view class="btn-flow-text">{{timerRunning ? '暂停' : timeUp ? '已结束' : '开始计时'}}</view>
      </view>
      <view class="btn-flow btn-flow-outline" bindtap="resetTimer">
        <view class="btn-flow-text">重置</view>
      </view>
    </view>
  </view>

  <view class="card" wx:for="{{drillQuestions}}" wx:key="id" wx:for-item="question">
    <view class="row-between" style="margin-bottom:24rpx;">
      <text class="question-title">{{question.title}}</text>
      <text class="tag {{question.done ? 'tag-green' : 'tag-gray'}}">
        {{question.done ? '已完成' : '待完成'}}
      </text>
    </view>

    <view class="file-card {{question.preFiles[0].url ? '' : 'file-card-disabled'}}" bindtap="openFile" data-qid="{{question.id}}" data-filetype="pre" data-fileid="{{question.preFiles[0].id}}">
      <view class="file-icon {{question.preFiles[0].url ? '' : 'file-icon-gray'}}">
        <text class="file-icon-text">PDF</text>
      </view>
      <view class="file-info">
        <text class="file-name {{question.preFiles[0].url ? '' : 'file-name-gray'}}">{{question.preFiles[0].name}}</text>
      </view>
      <text wx:if="{{question.preFiles[0].opened}}" class="tag tag-green">已打开</text>
      <text wx:elif="{{question.preFiles[0].url}}" class="file-arrow">›</text>
      <text wx:else class="tag tag-gray">暂未上传</text>
    </view>

    <view class="file-card {{question.postFiles[0].url ? '' : 'file-card-disabled'}}" bindtap="openFile" data-qid="{{question.id}}" data-filetype="post" data-fileid="{{question.postFiles[0].id}}">
      <view class="file-icon file-icon-green {{question.postFiles[0].url ? '' : 'file-icon-gray'}}">
        <text class="file-icon-text">PDF</text>
      </view>
      <view class="file-info">
        <text class="file-name {{question.postFiles[0].url ? '' : 'file-name-gray'}}">{{question.postFiles[0].name}}</text>
      </view>
      <text wx:if="{{question.postFiles[0].opened}}" class="tag tag-green">已打开</text>
      <text wx:elif="{{question.postFiles[0].url}}" class="file-arrow">›</text>
      <text wx:else class="tag tag-gray">暂未上传</text>
    </view>

    <view class="video-banner" style="margin-top:16rpx;" bindtap="watchAnalysis" data-videoid="{{question.videoId}}">
      <view class="video-play-icon">
        <image class="video-play-icon-image" src="{{uiIcons.play}}" mode="aspectFit" />
      </view>
      <view class="video-info">
        <text class="video-title">视频解析</text>
        <text class="video-sub">{{question.title}}</text>
      </view>
      <text class="video-arrow">›</text>
    </view>
    <button class="btn-done {{question.done ? 'btn-done-active' : ''}}" bindtap="toggleDrillTask" data-id="{{question.id}}">
      {{question.done ? '已完成 ✓' : '标记完成'}}
    </button>
  </view>

  <!-- 笔记 -->
  <view class="card">
    <text class="section-title">学习笔记</text>
    <textarea
      class="input-area"
      placeholder="记录本次刷题的心得、错误点..."
      value="{{notes}}"
      bindinput="onNotesInput"
      auto-height
      style="min-height:160rpx;"
    />
  </view>

  <view class="safe-bottom"></view>
</view>

<diagnose-coupon-fab auto-popup="{{true}}"></diagnose-coupon-fab>
