<view class="drill-page">

  <!-- 椤堕儴杩涘害 + 璁℃椂鍣?-->
  <view class="card">
    <view class="row-between" style="margin-bottom:24rpx;">
      <text class="section-title" style="margin-bottom:0;">鍒烽缁冧範</text>
      <text class="task-progress-text">{{drillDoneCount}}/{{drillQuestions.length}} 宸插畬鎴?</text>
    </view>

    <!-- 鍊掕鏃舵樉绀?-->
    <picker mode="multiSelector" range="{{timerPickerRange}}" value="{{timerPickerValue}}" bindchange="onTimerPickerConfirm">
      <view class="timer-display {{timeLow ? 'timer-display-low' : ''}} {{timeUp ? 'timer-display-up' : ''}}">
        <text class="timer-badge">鍊掕鏃?</text>
        <text class="timer-text">{{timerDisplay}}</text>
        <view class="timer-status-row">
          <view wx:if="{{timerRunning}}" class="timer-dot-wrap">
            <view class="timer-dot"></view>
          </view>
          <text class="timer-label">
            {{timeUp ? '时间已到，请提交作答' : timeLow ? '剩余时间不足5分钟' : timerRunning ? '计时中' : ''}}
          </text>
        </view>
      </view>
    </picker>

    <!-- 鎸夐挳琛?-->
    <view class="btn-row">
      <view class="btn-flow {{timeUp ? 'btn-flow-disabled' : ''}}" bindtap="toggleTimer">
        <view class="btn-flow-text">{{timerRunning ? '暂停' : timeUp ? '已结束' : '开始计时'}}</view>
      </view>
      <view class="btn-flow btn-flow-outline" bindtap="resetTimer">
        <view class="btn-flow-text">閲嶇疆</view>
      </view>
    </view>
  </view>

  <!-- 绗竴棰?-->
  <view class="card">
    <view class="row-between" style="margin-bottom:24rpx;">
      <text class="question-title">绗竴棰橈細杩藉闀挎湡浠峰€?</text>
      <text class="tag {{drillQuestions[0].done ? 'tag-green' : 'tag-gray'}}">
        {{drillQuestions[0].done ? '已完成' : '待完成'}}
      </text>
    </view>
    <view class="file-card {{drillQuestions[0].preFiles[0].url ? '' : 'file-card-disabled'}}" bindtap="openFile" data-qid="{{1}}" data-filetype="pre" data-fileid="{{1}}">
      <view class="file-icon {{drillQuestions[0].preFiles[0].url ? '' : 'file-icon-gray'}}"><text class="file-icon-text">PDF</text></view>
      <view class="file-info"><text class="file-name {{drillQuestions[0].preFiles[0].url ? '' : 'file-name-gray'}}">绗竴棰樿拷瀵婚暱鏈熶环鍊艰涔?pdf</text></view>
      <text wx:if="{{drillQuestions[0].preFiles[0].opened}}" class="tag tag-green">宸叉墦寮€</text>
      <text wx:elif="{{drillQuestions[0].preFiles[0].url}}" class="file-arrow">鈥?</text>
      <text wx:else class="tag tag-gray">鏆傛湭涓婁紶</text>
    </view>
    <view class="file-card {{drillQuestions[0].postFiles[0].url ? '' : 'file-card-disabled'}}" bindtap="openFile" data-qid="{{1}}" data-filetype="post" data-fileid="{{2}}">
      <view class="file-icon file-icon-green {{drillQuestions[0].postFiles[0].url ? '' : 'file-icon-gray'}}"><text class="file-icon-text">PDF</text></view>
      <view class="file-info"><text class="file-name {{drillQuestions[0].postFiles[0].url ? '' : 'file-name-gray'}}">绗竴棰樿拷瀵婚暱鏈熶环鍊艰В鏋?pdf</text></view>
      <text wx:if="{{drillQuestions[0].postFiles[0].opened}}" class="tag tag-green">宸叉墦寮€</text>
      <text wx:elif="{{drillQuestions[0].postFiles[0].url}}" class="file-arrow">鈥?</text>
      <text wx:else class="tag tag-gray">鏆傛湭涓婁紶</text>
    </view>
    <view class="video-banner" style="margin-top:16rpx;" bindtap="watchAnalysis" data-videoid="{{drillQuestions[0].videoId}}">
      <view class="video-play-icon">
        <image class="video-play-icon-image" src="{{uiIcons.play}}" mode="aspectFit" />
      </view>
      <view class="video-info">
        <text class="video-title">瑙嗛瑙ｆ瀽</text>
        <text class="video-sub">绗竴棰橈細杩藉闀挎湡浠峰€?</text>
      </view>
      <text class="video-arrow">鈥?</text>
    </view>
    <button class="btn-done {{drillQuestions[0].done ? 'btn-done-active' : ''}}" bindtap="toggleDrillTask" data-id="1">
      {{drillQuestions[0].done ? '已完成 ✓' : '标记完成'}}
    </button>
  </view>

  <!-- 绗簩棰?-->
  <view class="card">
    <view class="row-between" style="margin-bottom:24rpx;">
      <text class="question-title">绗簩棰橈細娴佸姩涓庢柊鐢?</text>
      <text class="tag {{drillQuestions[1].done ? 'tag-green' : 'tag-gray'}}">
        {{drillQuestions[1].done ? '已完成' : '待完成'}}
      </text>
    </view>
    <view class="file-card {{drillQuestions[1].preFiles[0].url ? '' : 'file-card-disabled'}}" bindtap="openFile" data-qid="{{2}}" data-filetype="pre" data-fileid="{{3}}">
      <view class="file-icon {{drillQuestions[1].preFiles[0].url ? '' : 'file-icon-gray'}}"><text class="file-icon-text">PDF</text></view>
      <view class="file-info"><text class="file-name {{drillQuestions[1].preFiles[0].url ? '' : 'file-name-gray'}}">绗簩棰樻祦鍔ㄤ笌鏂扮敓璁蹭箟.pdf</text></view>
      <text wx:if="{{drillQuestions[1].preFiles[0].opened}}" class="tag tag-green">宸叉墦寮€</text>
      <text wx:elif="{{drillQuestions[1].preFiles[0].url}}" class="file-arrow">鈥?</text>
      <text wx:else class="tag tag-gray">鏆傛湭涓婁紶</text>
    </view>
    <view class="file-card {{drillQuestions[1].postFiles[0].url ? '' : 'file-card-disabled'}}" bindtap="openFile" data-qid="{{2}}" data-filetype="post" data-fileid="{{4}}">
      <view class="file-icon file-icon-green {{drillQuestions[1].postFiles[0].url ? '' : 'file-icon-gray'}}"><text class="file-icon-text">PDF</text></view>
      <view class="file-info"><text class="file-name {{drillQuestions[1].postFiles[0].url ? '' : 'file-name-gray'}}">绗簩棰樻祦鍔ㄤ笌鏂扮敓瑙ｆ瀽.pdf</text></view>
      <text wx:if="{{drillQuestions[1].postFiles[0].opened}}" class="tag tag-green">宸叉墦寮€</text>
      <text wx:elif="{{drillQuestions[1].postFiles[0].url}}" class="file-arrow">鈥?</text>
      <text wx:else class="tag tag-gray">鏆傛湭涓婁紶</text>
    </view>
    <view class="video-banner" style="margin-top:16rpx;" bindtap="watchAnalysis" data-videoid="{{drillQuestions[1].videoId}}">
      <view class="video-play-icon">
        <image class="video-play-icon-image" src="{{uiIcons.play}}" mode="aspectFit" />
      </view>
      <view class="video-info">
        <text class="video-title">瑙嗛瑙ｆ瀽</text>
        <text class="video-sub">绗簩棰橈細娴佸姩涓庢柊鐢?</text>
      </view>
      <text class="video-arrow">鈥?</text>
    </view>
    <button class="btn-done {{drillQuestions[1].done ? 'btn-done-active' : ''}}" bindtap="toggleDrillTask" data-id="2">
      {{drillQuestions[1].done ? '已完成 ✓' : '标记完成'}}
    </button>
  </view>

  <!-- 绗笁棰?-->
  <view class="card">
    <view class="row-between" style="margin-bottom:24rpx;">
      <text class="question-title">绗笁棰橈細鎬濈淮鎾</text>
      <text class="tag {{drillQuestions[2].done ? 'tag-green' : 'tag-gray'}}">
        {{drillQuestions[2].done ? '已完成' : '待完成'}}
      </text>
    </view>
    <view class="file-card {{drillQuestions[2].preFiles[0].url ? '' : 'file-card-disabled'}}" bindtap="openFile" data-qid="{{3}}" data-filetype="pre" data-fileid="{{5}}">
      <view class="file-icon {{drillQuestions[2].preFiles[0].url ? '' : 'file-icon-gray'}}"><text class="file-icon-text">PDF</text></view>
      <view class="file-info"><text class="file-name {{drillQuestions[2].preFiles[0].url ? '' : 'file-name-gray'}}">绗笁棰樻€濈淮鎾璁蹭箟.pdf</text></view>
      <text wx:if="{{drillQuestions[2].preFiles[0].opened}}" class="tag tag-green">宸叉墦寮€</text>
      <text wx:elif="{{drillQuestions[2].preFiles[0].url}}" class="file-arrow">鈥?</text>
      <text wx:else class="tag tag-gray">鏆傛湭涓婁紶</text>
    </view>
    <view class="file-card {{drillQuestions[2].postFiles[0].url ? '' : 'file-card-disabled'}}" bindtap="openFile" data-qid="{{3}}" data-filetype="post" data-fileid="{{6}}">
      <view class="file-icon file-icon-green {{drillQuestions[2].postFiles[0].url ? '' : 'file-icon-gray'}}"><text class="file-icon-text">PDF</text></view>
      <view class="file-info"><text class="file-name {{drillQuestions[2].postFiles[0].url ? '' : 'file-name-gray'}}">绗笁棰樻€濈淮鎾瑙ｆ瀽.pdf</text></view>
      <text wx:if="{{drillQuestions[2].postFiles[0].opened}}" class="tag tag-green">宸叉墦寮€</text>
      <text wx:elif="{{drillQuestions[2].postFiles[0].url}}" class="file-arrow">鈥?</text>
      <text wx:else class="tag tag-gray">鏆傛湭涓婁紶</text>
    </view>
    <view class="video-banner" style="margin-top:16rpx;" bindtap="watchAnalysis" data-videoid="{{drillQuestions[2].videoId}}">
      <view class="video-play-icon">
        <image class="video-play-icon-image" src="{{uiIcons.play}}" mode="aspectFit" />
      </view>
      <view class="video-info">
        <text class="video-title">瑙嗛瑙ｆ瀽</text>
        <text class="video-sub">绗笁棰橈細鎬濈淮鎾</text>
      </view>
      <text class="video-arrow">鈥?</text>
    </view>
    <button class="btn-done {{drillQuestions[2].done ? 'btn-done-active' : ''}}" bindtap="toggleDrillTask" data-id="3">
      {{drillQuestions[2].done ? '已完成 ✓' : '标记完成'}}
    </button>
  </view>

  <!-- 绗旇 -->
  <view class="card">
    <text class="section-title">瀛︿範绗旇</text>
    <textarea
      class="input-area"
      placeholder="璁板綍鏈鍒烽鐨勫績寰椼€侀敊璇偣..."
      value="{{notes}}"
      bindinput="onNotesInput"
      auto-height
      style="min-height:160rpx;"
    />
  </view>

  <view class="safe-bottom"></view>
</view>

<diagnose-coupon-fab auto-popup="{{true}}"></diagnose-coupon-fab>




