<view class="path-page">
  <view class="theory-group-card" wx:for="{{theoryGroups}}" wx:key="title" wx:for-item="group">
    <view class="theory-group-head">
      <text class="theory-group-title">{{group.title}}</text>
    </view>

    <view class="path-list">
      <view wx:for="{{group.items}}" wx:key="id" wx:for-item="item" class="path-item">
        <view class="path-left">
          <view class="path-dot path-dot-{{item.status}}"></view>
          <view wx:if="{{index < group.items.length - 1}}" class="path-line"></view>
        </view>
        <view class="path-main">
          <view class="path-row">
            <text class="path-title">{{item.title}}</text>
            <view class="path-actions" wx:if="{{item.actionText || item.secondaryActionText}}">
              <view
                wx:if="{{item.actionText}}"
                class="path-action {{item.status === 'pending' ? 'path-action-disabled' : ''}}"
                bindtap="onActionTap"
                data-task-id="{{item.id}}"
                data-status="{{item.status}}"
                data-action-type="{{item.actionType}}"
                data-title="{{item.title}}"
              >
                <text class="path-action-text">{{item.actionText}}</text>
                <view class="path-action-arrow"></view>
              </view>
              <view
                wx:if="{{item.secondaryActionText}}"
                class="path-action path-action-secondary {{item.status === 'pending' ? 'path-action-disabled' : ''}}"
                bindtap="onSecondaryActionTap"
                data-task-id="{{item.id}}"
                data-status="{{item.status}}"
                data-action-type="{{item.secondaryActionType}}"
              >
                <text class="path-action-text">{{item.secondaryActionText}}</text>
                <view class="path-action-arrow"></view>
              </view>
            </view>
          </view>
          <text wx:if="{{item.desc}}" class="path-desc">{{item.desc}}</text>
        </view>
      </view>
    </view>
  </view>

  <view wx:if="{{ratingPopupVisible}}" class="rating-mask">
    <view class="rating-popup">
      <text class="rating-popup-title">{{ratingTaskTitle}}</text>
      <text class="rating-popup-subtitle">学习完成后可选评价，给这节内容打个分吧</text>
      <view class="rating-stars">
        <view
          wx:for="{{[1,2,3,4,5]}}"
          wx:key="*this"
          class="rating-star {{item <= ratingScore ? 'rating-star-active' : ''}}"
          bindtap="onRatingStarTap"
          data-score="{{item}}"
        >★</view>
      </view>
      <view class="rating-actions">
        <view class="rating-action" bindtap="closeRatingPopup">稍后再评</view>
        <view class="rating-action rating-action-primary" bindtap="submitRating">提交评价</view>
      </view>
    </view>
  </view>

  <view class="safe-bottom"></view>
</view>
