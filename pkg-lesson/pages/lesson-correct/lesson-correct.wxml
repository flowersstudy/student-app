<view class="lesson-page">
  <view class="timeline">

    <!-- 课前 -->
    <view class="timeline-item">
      <view class="timeline-left">
        <view class="timeline-dot"></view>
        <view class="timeline-line"></view>
      </view>
      <view class="timeline-content">
        <text class="phase-label">课前</text>
        <view class="phase-card">
          <view class="lesson-info-row">
            <image class="info-icon" src="{{uiIcons.calendar}}" mode="aspectFit" />
            <text class="info-text">{{lessonInfo.date}} {{lessonInfo.time}}</text>
          </view>
          <view class="lesson-info-row">
            <image class="info-icon" src="{{uiIcons.user}}" mode="aspectFit" />
            <text class="info-text">{{lessonInfo.teacher}} · {{lessonInfo.subject}}</text>
          </view>
          <view class="row-between" style="margin-top:20rpx;">
            <text class="tag tag-orange">{{lessonInfo.status}}</text>
            <button class="btn-outline" bindtap="viewReport">查看报告</button>
          </view>

          <view class="divider" style="margin:20rpx 0;"></view>

          <!-- 上传作业区域 -->
          <text class="sub-label">上传作业</text>
          <view class="upload-area">
            <view class="upload-box" bindtap="choosePhoto">
              <image class="upload-icon" src="{{uiIcons.camera}}" mode="aspectFit" />
              <text class="upload-text">拍照上传</text>
            </view>
            <view class="upload-box" bindtap="chooseFile">
              <image class="upload-icon" src="{{uiIcons.file}}" mode="aspectFit" />
              <text class="upload-text">文件上传</text>
            </view>
          </view>
          <text class="upload-tip">支持 PDF、Word、图片格式</text>

          <view class="divider" style="margin:20rpx 0;"></view>

          <text class="sub-label">本次纠偏内容</text>
          <view class="topic-list">
            <view
              wx:for="{{topicOptions}}"
              wx:key="id"
              class="topic-item {{item.selected ? 'topic-selected' : ''}}"
              bindtap="selectTopic"
              data-id="{{item.id}}"
            >
              <view class="topic-dot {{item.selected ? 'topic-dot-selected' : ''}}"></view>
              <text class="topic-name">{{item.name}}</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- 上课中 -->
    <view class="timeline-item">
      <view class="timeline-left">
        <view class="timeline-dot"></view>
        <view class="timeline-line"></view>
      </view>
      <view class="timeline-content">
        <text class="phase-label">上课中</text>
        <view class="phase-card">
          <button class="btn-enter" bindtap="enterCourse">进入课程</button>
        </view>
      </view>
    </view>

    <!-- 课后 -->
    <view class="timeline-item">
      <view class="timeline-left">
        <view class="timeline-dot timeline-dot-gray"></view>
      </view>
      <view class="timeline-content">
        <text class="phase-label">课后</text>
        <view class="phase-card">
          <text class="sub-label">课堂笔记</text>
          <textarea
            class="input-area"
            placeholder="记录纠偏要点..."
            value="{{notes}}"
            bindinput="onNotesInput"
            auto-height
          />

          <button class="btn-outline" style="margin-top:20rpx;width:100%;" bindtap="viewPlayback">
            观看课堂回放
          </button>

          <view class="divider" style="margin:20rpx 0;"></view>

          <text class="sub-label">课堂反馈</text>
          <textarea
            class="input-area"
            placeholder="分享纠偏学习的收获..."
            value="{{feedback}}"
            bindinput="onFeedbackInput"
            auto-height
          />
        </view>
      </view>
    </view>

  </view>
  <view class="safe-bottom"></view>
</view>

<diagnose-coupon-fab auto-popup="{{true}}"></diagnose-coupon-fab>
